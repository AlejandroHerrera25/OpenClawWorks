{"type":"message","id":"3ecfc9fc","parentId":"ef3e24f9","timestamp":"2026-03-10T02:01:13.389Z","message":{"role":"toolResult","toolCallId":"call_00_CW7cUhFByfL46VTD2CQGKFbQ","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nIntegration module for Tavily Web Search with OpenClaw ecosystem.\nProvides integration with watchdog, error-learning-loop, and janitor.\n\"\"\"\n\nimport os\nimport sys\nimport json\nimport time\nimport subprocess\nfrom pathlib import Path\nfrom datetime import datetime\nfrom typing import Dict, List, Optional, Any\n\n\ndef expand_env_vars(value):\n    \"\"\"Expand environment variables in a string.\"\"\"\n    if isinstance(value, str) and value.startswith(\"${\") and value.endswith(\"}\"):\n        env_var = value[2:-1]\n        return os.environ.get(env_var, value)\n    return value\n\ndef deep_expand_env_vars(obj):\n    \"\"\"Recursively expand environment variables in a nested structure.\"\"\"\n    if isinstance(obj, dict):\n        return {k: deep_expand_env_vars(v) for k, v in obj.items()}\n    elif isinstance(obj, list):\n        return [deep_expand_env_vars(item) for item in obj]\n    elif isinstance(obj, str):\n        return expand_env_vars(obj)\n    else:\n        return obj\n\ndef load_config() -> Dict:\n    \"\"\"Load Tavily configuration from config file and expand environment variables.\"\"\"\n    config_path = Path(__file__).parent.parent / \"config\" / \"tavily_config.json\"\n    \n    try:\n        with open(config_path) as f:\n            config = json.load(f)\n        \n        # Expand environment variables in the entire config\n        config = deep_expand_env_vars(config)\n        \n        # Special handling for API keys - check if they're still placeholders\n        if config.get(\"api_key\", \"\").startswith(\"${\"):\n            print(f\"[CONFIG] WARNING: API key not expanded: {config['api_key']}\")\n            print(f\"[CONFIG] Available env vars: TAVILY_API_KEY={os.environ.get('TAVILY_API_KEY', 'NOT SET')[:10]}...\")\n        \n        return config\n    except Exception as e:\n        print(f\"[CONFIG] Error loading config: {e}\")\n        # Return default config\n        return {\n            \"api_key\": os.environ.get(\"TAVILY_API_KEY\", \"\"),\n            \"defaults\": {\n                \"max_results\": 5,\n                \"search_depth\": \"basic\",\n                \"timeout\": 30,\n                \"cache_ttl_minutes\": 15\n            }\n        }\n\n\ndef register_with_watchdog(session_id: str, run_id: str, task_desc: str, \n                          expected_time: int, model: str = \"tavily-search\",\n                          runtime_type: str = \"search\") -> bool:\n    \"\"\"\n    Register a search operation with the agent watchdog.\n    \n    Args:\n        session_id: Unique session identifier\n        run_id: Unique run identifier\n        task_desc: Description of the task\n        expected_time: Expected runtime in seconds\n        model: Model name (default: \"tavily-search\")\n        runtime_type: Type of runtime (default: \"search\")\n    \n    Returns:\n        True if registration successful, False otherwise\n    \"\"\"\n    try:\n        # Check if watchdog skill exists\n        watchdog_script = Path.home() / \".openclaw\" / \"workspace\" / \"skills\" / \"agent-watchdog\"\n        \n        if not watchdog_script.exists():\n            print(f\"[WATCHDOG] Watchdog skill not found at {watchdog_script}\")\n            return False\n        \n        # Try to use watchdog orchestrator script\n        orchestrator_path = watchdog_script / \"scripts\" / \"watchdog_orchestrator.py\"\n        \n        if orchestrator_path.exists():\n            cmd = [\n                \"python3\", str(orchestrator_path),\n                \"--register\",\n                \"--session-id\", session_id,\n                \"--run-id\", run_id,\n                \"--task\", task_desc,\n\n[352 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1773108073382}}
