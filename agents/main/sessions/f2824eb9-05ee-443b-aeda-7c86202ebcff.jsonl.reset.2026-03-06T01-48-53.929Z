nimal (Pattern‑Key, tags, rule, promoted).\n- Uses fixed domain sections: `tools`, `requirements`, `planning`, `multi‑"}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-reasoner","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"aborted","timestamp":1772732245527,"errorMessage":"Request was aborted"}}
