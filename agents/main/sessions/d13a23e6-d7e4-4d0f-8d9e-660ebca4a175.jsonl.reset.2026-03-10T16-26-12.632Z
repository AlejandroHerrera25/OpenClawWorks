{"type":"message","id":"bf4bfca1","parentId":"7e1a952d","timestamp":"2026-03-09T18:46:36.248Z","message":{"role":"assistant","content":[{"type":"text","text":"Ahora voy a crear un validador determinístico de Definition of Done:"},{"type":"toolCall","id":"call_00_eyYLrTUYL6hp1gDpiQ7Ljcoa","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/dod_validator.py","content":"#!/usr/bin/env python3\n\"\"\"\nDeterministic Definition of Done Validator.\nValidates specialist outputs against required fields, sections, evidence, and handoff completeness.\n\"\"\"\n\nimport os\nimport sys\nimport yaml\nimport re\nimport logging\nfrom pathlib import Path\nfrom typing import Dict, List, Tuple, Set, Optional\nfrom enum import Enum\n\n# Configure logging\nlogging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')\nlogger = logging.getLogger(__name__)\n\nclass ValidationSeverity(Enum):\n    \"\"\"Validation severity levels.\"\"\"\n    BLOCKING = \"BLOCKING\"      # Must be fixed before approval\n    WARNING = \"WARNING\"        # Should be fixed but not blocking\n    INFO = \"INFO\"              # Optional improvement\n\nclass DoDValidator:\n    \"\"\"Deterministic validator for Definition of Done.\"\"\"\n    \n    def __init__(self):\n        self.dod_definitions = None\n        self.role_definitions = None\n        self._load_definitions()\n    \n    def _load_definitions(self):\n        \"\"\"Load DoD and role definitions from YAML.\"\"\"\n        # Load DoD definitions\n        dod_path = Path(__file__).parent.parent / 'references' / 'dod_definitions.yaml'\n        if dod_path.exists():\n            with open(dod_path, 'r', encoding='utf-8') as f:\n                self.dod_definitions = yaml.safe_load(f)\n        else:\n            logger.warning('DoD definitions not found, using built-in defaults')\n            self.dod_definitions = self._get_default_dod_definitions()\n        \n        # Load role definitions\n        role_path = Path(__file__).parent.parent / 'references' / 'role_model.yaml'\n        if role_path.exists():\n            with open(role_path, 'r', encoding='utf-8') as f:\n                self.role_definitions = yaml.safe_load(f)\n        else:\n            logger.warning('Role definitions not found')\n            self.role_definitions = {}\n    \n    def _get_default_dod_definitions(self) -> Dict:\n        \"\"\"Get default DoD definitions for common roles.\"\"\"\n        return {\n            'version': '1.0',\n            'format': 'yaml',\n            'description': 'Default Definition of Done definitions',\n            \n            'validation_rules': {\n                'required_fields': {\n                    'all_roles': [\n                        'purpose_stated',\n                        'assumptions_documented',\n                        'evidence_provided',\n                        'decisions_documented',\n                        'next_actions_defined'\n                    ],\n                    'functional_consultant': [\n                        'process_interpretation',\n                        'scope_dependencies',\n                        'official_evidence',\n                        'open_decisions'\n                    ],\n                    'integration_developer': [\n                        'integration_pattern',\n                        'authentication_assumptions',\n                        'retry_error_strategy',\n                        'limits_failure_modes',\n                        'impacted_objects_events'\n                    ],\n                    'custom_ui_developer': [\n                        'ui_interaction_model',\n                        'component_structure',\n                        'event_flow',\n                        'navigation_implications',\n                        'accessibility_considerations'\n                    ],\n                    'code_auditor': [\n                        'findings_listed',\n                        'code_evidence_snippets',\n                        'severity_levels',\n                        'architectural_impact',\n                        'remediation_suggestions',\n                        'confidence_level'\n                    ],\n                    'architect': [\n                        'final_decision',\n                        'rationale',\n                        'alternatives_considered',\n                        'unresolved_risks',\n                        'next_steps'\n                    ]\n                },\n                \n                'required_sections': {\n                    'all_roles': [\n                        'executive_summary',\n                        'detailed_analysis',\n                        'assumptions',\n                        'evidence',\n                        'recommendations'\n                    ],\n                    'design_documents': [\n                        'introduction',\n                        'scope',\n                        'business_process_algorithms',\n                        'system_interactions',\n                        'object_model',\n                        'automations',\n                        'security'\n                    ],\n                    'audit_reports': [\n                        'executive_summary',\n                        'technical_assessment',\n                        'findings',\n                        'risk_assessment',\n                        'recommendations',\n                        'evidence'\n                    ]\n                },\n                \n                'evidence_requirements': {\n                    'minimum_evidence_count': 3,\n                    'evidence_types': [\n                        'official_documentation',\n                        'code_snippets',\n                        'diagrams',\n                        'test_results',\n                        'performance_metrics',\n                        'security_assessments'\n                    ],\n                    'evidence_quality': [\n                        'source_cited',\n                        'relevance_explained',\n                        'timestamp_provided',\n                        'authority_established'\n                    ]\n                },\n                \n                'handoff_completeness': {\n                    'required_elements': [\n                        'clear_next_owner',\n                        'outstanding_issues_listed',\n                        'dependencies_identified',\n                        'acceptance_criteria_met',\n                        'quality_gates_passed'\n                    ],\n                    'quality_checks': [\n                        'no_ambiguous_terms',\n                        'all_acronyms_defined',\n                        'consistent_terminology',\n                        'actionable_recommendations'\n                    ]\n                }\n            },\n            \n            'validation_thresholds': {\n                'blocking_threshold': 0.8,  # Must have 80% of required fields\n                'warning_threshold': 0.9,   # Should have 90% of required fields\n                'minimum_evidence_score': 0.7,\n                'minimum_handoff_score': 0.8\n            }\n        }\n    \n    def validate(self, role_name: str, artifacts: Dict, artifact_type: str = None) -> Dict:\n        \"\"\"\n        Validate artifacts against Definition of Done for specific role.\n        \n        Args:\n            role_name: Name of the specialist role\n            artifacts: Dictionary of artifacts to validate\n            artifact_type: Type of artifact (design, audit, requirements, etc.)\n            \n        Returns:\n            Dictionary with validation results\n        \"\"\"\n        results = {\n            'role': role_name,\n            'artifact_type': artifact_type,\n            'overall_score': 0.0,\n            'is_compliant': False,\n            'validation_details': {},\n            'issues': [],\n            'recommendations': []\n        }\n        \n        # Normalize role name\n        normalized_role = self._normalize_role_name(role_name)\n        \n        # Get validation rules for this role\n        role_rules = self._get_role_rules(normalized_role)\n        \n        # Perform validations\n        field_validation = self._validate_required_fields(normalized_role, artifacts, role_rules)\n        section_validation = self._validate_required_sections(artifact_type, artifacts, role_rules)\n        evidence_validation = self._validate_evidence(artifacts, role_rules)\n        handoff_validation = self._validate_handoff_completeness(artifacts, role_rules)\n        \n        # Combine results\n        results['validation_details'] = {\n            'required_fields': field_validation,\n            'required_sections': section_validation,\n            'evidence': evidence_validation,\n            'handoff_completeness': handoff_validation\n        }\n        \n        # Calculate overall score\n        scores = [\n            field_validation.get('score', 0),\n            section_validation.get('score', 0),\n            evidence_validation.get('score', 0),\n            handoff_validation.get('score', 0)\n        ]\n        results['overall_score'] = sum(scores) / len(scores) if scores else 0\n        \n        # Check compliance\n        thresholds = self.dod_definitions['validation_thresholds']\n        results['is_compliant'] = results['overall_score'] >= thresholds['blocking_threshold']\n        \n        # Generate issues and recommendations\n        results['issues'] = self._generate_issues(results['validation_details'], thresholds)\n        results['recommendations'] = self._generate_recommendations(results['validation_details'])\n        \n        return results\n    \n    def _normalize_role_name(self, role_name: str) -> str:\n        \"\"\"Normalize role name to match definition keys.\"\"\"\n        role_lower = role_name.lower()\n        \n        # Map common role names to normalized keys\n        role_mapping = {\n            'salesforce administrator': 'salesforce_administrator',\n            'administrator': 'salesforce_administrator',\n            'admin': 'salesforce_administrator',\n            \n            'salesforce functional consultant': 'functional_consultant_standard',\n            'functional consultant': 'functional_consultant_standard',\n            'business analyst': 'functional_consultant_standard',\n            \n            'salesforce integration developer': 'integration_developer',\n            'integration developer': 'integration_developer',\n            'integration specialist': 'integration_developer',\n            \n            'salesforce custom ui developer': 'custom_ui_developer',\n            'ui developer': 'custom_ui_developer',\n            'lwc developer': 'custom_ui_developer',\n            \n            'salesforce code auditor': 'code_auditor',\n            'code auditor': 'code_auditor',\n            'technical reviewer': 'code_auditor',\n            \n            'salesforce architect': 'architect',\n            'architect': 'architect',\n            'solution architect': 'architect'\n        }\n        \n        for key, value in role_mapping.items():\n            if key in role_lower:\n                return value\n        \n        # Default: convert to snake_case\n        return role_lower.replace(' ', '_').replace('-', '_')\n    \n    def _get_role_rules(self, normalized_role: str) -> Dict:\n        \"\"\"Get validation rules for a specific role.\"\"\"\n        rules = self.dod_definitions['validation_rules']\n        role_rules = {}\n        \n        # Add rules for all roles\n        for rule_type, rule_values in rules.items():\n            if 'all_roles' in rule_values:\n                role_rules[rule_type] = rule_values.get('all_roles', [])\n            \n            # Add role-specific rules\n            if normalized_role in rule_values:\n                if rule_type not in role_rules:\n                    role_rules[rule_type] = []\n                role_rules[rule_type].extend(rule_values[normalized_role])\n        \n        return role_rules\n    \n    def _validate_required_fields(self, role: str, artifacts: Dict, role_rules: Dict) -> Dict:\n        \"\"\"Validate required fields are present.\"\"\"\n        required_fields = role_rules.get('required_fields', [])\n        \n        if not required_fields:\n            return {'score': 1.0, 'found': [], 'missing': [], 'details': 'No field requirements defined'}\n        \n        # Combine all artifact text for searching\n        artifact_text = self._combine_artifact_text(artifacts)\n        artifact_text_lower = artifact_text.lower()\n        \n        found_fields = []\n        missing_fields = []\n        \n        for field in required_fields:\n            # Convert field name to search patterns\n            search_patterns = self._field_to_search_patterns(field)\n            \n            # Check if any pattern matches\n            field_found = any(pattern in artifact_text_lower for pattern in search_patterns)\n            \n            if field_found:\n                found_fields.append(field)\n            else:\n                missing_fields.append(field)\n        \n        score = len(found_fields) / len(required_fields) if required_fields else 1.0\n        \n        return {\n            'score': score,\n            'found': found_fields,\n            'missing': missing_fields,\n            'total_required': len(required_fields),\n            'details': f'Found {len(found_fields)} of {len(required_fields)} required fields'\n        }\n    \n    def _validate_required_sections(self, artifact_type: str, artifacts: Dict, role_rules: Dict) -> Dict:\n        \"\"\"Validate required sections are present.\"\"\"\n        # Get section requirements based on artifact type\n        section_rules = self.dod_definitions['validation_rules']['required_sections']\n        required_sections = []\n        \n        # Add sections for all roles\n        if 'all_roles' in section_rules:\n            required_sections.extend(section_rules['all_roles'])\n        \n        # Add type-specific sections\n        if artifact_type and artifact_type in section_rules:\n            required_sections.extend(section_rules[artifact_type])\n        \n        if not required_sections:\n            return {'score': 1.0, 'found': [], 'missing': [], 'details': 'No section requirements defined'}\n        \n        # Check for section headers in artifacts\n        found_sections = []\n        missing_sections = []\n        \n        for artifact_name, artifact_content in artifacts.items():\n            if isinstance(artifact_content, str):\n                content_lower = artifact_content.lower()\n                \n                for section in required_sections:\n                    # Convert section name to header patterns\n                    header_patterns = self._section_to_header_patterns(section)\n                    \n                    # Check if any header pattern exists\n                    section_found = any(\n                        any(pattern in line.lower() for line in artifact_content.split('\\n'))\n                        for pattern in header_patterns\n                    )\n                    \n                    if section_found and section not in found_sections:\n                        found_sections.append(section)\n        \n        # Determine missing sections\n        missing_sections = [s for s in required_sections if s not in found_sections]\n        \n        score = len(found_sections) / len(required_sections) if required_sections else 1.0\n        \n        return {\n            'score': score,\n            'found': found_sections,\n            'missing': missing_sections,\n            'total_required': len(required_sections),\n            'details': f'Found {len(found_sections)} of {len(required_sections)} required sections'\n        }\n    \n    def _validate_evidence(self, artifacts: Dict, role_rules: Dict) -> Dict:\n        \"\"\"Validate evidence requirements.\"\"\"\n        evidence_rules = self.dod_definitions['validation_rules']['evidence_requirements']\n        \n        # Combine all artifact text\n        artifact_text = self._combine_artifact_text(artifacts)\n        \n        # Count evidence markers\n        evidence_markers = [\n            'evidence:', 'reference:', 'source:', 'documentation:',\n            'test result', 'performance metric', 'security assessment',\n            'code snippet', 'diagram', 'screenshot'\n        ]\n        \n        found_evidence = []\n        for marker in evidence_markers:\n            if marker.lower() in artifact_text.lower():\n                found_evidence.append(marker)\n        \n        # Check evidence quality indicators\n        quality_indicators = evidence_rules.get('evidence_quality', [])\n        quality_score = 0\n        \n        for indicator in quality_indicators:\n            indicator_patterns = self._evidence_quality_to_patterns(indicator)\n            if any(pattern in artifact_text.lower() for pattern in indicator_patterns):\n                quality_score += 1\n        \n        quality_score = quality_score / len(quality_indicators) if quality_indicators else 1.0\n        \n        # Calculate overall evidence score\n        min_count = evidence_rules.get('minimum_evidence_count', 3)\n        count_score = min(len(found_evidence) / min_count, 1.0)\n        \n        overall_score = (count_score + quality_score) / 2\n        \n        return {\n            'score': overall_score,\n            'evidence_count': len(found_evidence),\n            'minimum_required': min_count,\n            'quality_score': quality_score,\n            'found_markers': found_evidence,\n            'details': f'Found {len(found_evidence)} evidence markers (min {min_count}), quality score: {quality_score:.2f}'\n        }\n    \n    def _validate_handoff_completeness(self, artifacts: Dict, role_rules: Dict) -> Dict:\n        \"\"\"Validate handoff completeness.\"\"\"\n        handoff_rules = self.dod_definitions['validation_rules']['handoff_completeness']\n        \n        # Combine all artifact text\n        artifact_text = self._combine_artifact_text(artifacts)\n        artifact_lower = artifact_text.lower()\n        \n        # Check required elements\n        required_elements = handoff_rules.get('required_elements', [])\n        found_elements = []\n        \n        for element in required_elements:\n            element_patterns = self._handoff_element_to_patterns(element)\n            if any(pattern in artifact_lower for pattern in element_patterns):\n                found_elements.append(element)\n        \n        elements_score = len(found_elements) / len(required_elements) if required_elements else 1.0\n        \n        # Check quality indicators\n        quality_checks = handoff_rules.get('quality_checks', [])\n        quality_score = 0\n        \n        # Simple quality checks\n        if 'no_ambiguous_terms' in quality_checks:\n            ambiguous_terms = ['maybe', 'possibly', 'might', 'could', 'perhaps', 'sometimes']\n            if not any(term in artifact_lower for term in ambiguous_terms):\n                quality_score += 1\n        \n        if 'all_acronyms_defined' in quality_checks:\n            # Simple check for acronym definitions\n            if 'acronym' in artifact_lower or 'abbreviation' in artifact_lower:\n                quality_score += 1\n        \n        if 'consistent_terminology' in quality_checks:\n            # Check for consistent use of key terms\n            key_terms = ['salesforce', 'cloud', 'integration', 'security']\n            term_variations = {}\n            for term in key_terms:\n                variations = [term, term.capitalize(), term.upper()]\n                term_variations[term] = any(var in artifact_text for var in variations)\n            \n            if all(term_variations.values()):\n                quality_score += 1\n        \n        if 'actionable_recommendations' in quality_checks:\n            action_verbs = ['implement', 'create', 'update', 'modify', 'add', 'remove', 'test', 'validate']\n            if any(verb in artifact_lower for verb in action_verbs):\n                quality_score += 1\n        \n        quality_score = quality_score / len(quality_checks) if quality_checks else 1.0\n        \n        # Overall handoff score\n        overall_score = (elements_score + quality_score) / 2\n        \n        return {\n            'score': overall_score,\n            'elements_score': elements_score,\n            'quality_score': quality_score,\n            'found_elements': found_elements,\n            'missing_elements': [e for e in required_elements if e not in found_elements],\n            'details': f'Handoff elements: {elements_score:.2f}, Quality: {quality_score:.2f}'\n        }\n    \n    def _combine_artifact_text(self, artifacts:"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":41749,"output":4096,"cacheRead":57600,"cacheWrite":0,"totalTokens":103445,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"length","timestamp":1773081853134}}
