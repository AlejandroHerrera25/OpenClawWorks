{"type":"message","id":"356f5bc1","parentId":"51360866","timestamp":"2026-03-09T23:21:25.666Z","message":{"role":"toolResult","toolCallId":"call_00_Fh1TYcetQDBjJY8uOi1tUwu6","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"Auto-curate MEMORY.md based on recent daily notes.\"\"\"\nimport argparse, glob, json, os, re, sys, subprocess, datetime, tempfile, textwrap\nfrom pathlib import Path\n\nWORKSPACE = os.path.expanduser(\"~/.openclaw/workspace\")\nMEMORY_PATH = os.path.join(WORKSPACE, \"MEMORY.md\")\nMEMORY_DIR = os.path.join(WORKSPACE, \"memory\")\nPROJECTS_PATH = os.path.join(MEMORY_DIR, \"projects.md\")\nFLUSH_SCRIPT = os.path.join(os.path.dirname(__file__), \"memory_flush.py\")\n\ndef read_file(path):\n    \"\"\"Read file content.\"\"\"\n    if not os.path.exists(path):\n        return \"\"\n    with open(path, 'r') as f:\n        return f.read()\n\ndef write_file(path, content):\n    \"\"\"Write content to file.\"\"\"\n    with open(path, 'w') as f:\n        f.write(content)\n\ndef get_recent_daily_notes(count=7):\n    \"\"\"Get the most recent daily note files.\"\"\"\n    # Get all markdown files in memory directory\n    all_files = glob.glob(os.path.join(MEMORY_DIR, \"*.md\"))\n    \n    # Filter out non-daily files (projects.md, janitor_log.md, etc.)\n    daily_files = []\n    for f in all_files:\n        fname = os.path.basename(f)\n        # Skip known non-daily files\n        if fname in [\"projects.md\", \"janitor_log.md\"]:\n            continue\n        # Skip files with special suffixes\n        if \"-gemini-config.md\" in fname or \"-request-timed-out-\" in fname:\n            continue\n        daily_files.append(f)\n    \n    # Sort by modification time (newest first)\n    daily_files.sort(key=os.path.getmtime, reverse=True)\n    \n    # Return the most recent ones\n    return daily_files[:count]\n\ndef extract_sections_from_memory(memory_content):\n    \"\"\"Extract sections from MEMORY.md.\"\"\"\n    sections = {}\n    lines = memory_content.split('\\n')\n\n[300 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1773098485656}}
