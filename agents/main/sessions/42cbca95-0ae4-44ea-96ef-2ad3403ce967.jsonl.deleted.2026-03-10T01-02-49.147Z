{"type":"message","id":"2a03e56f","parentId":"86185a2b","timestamp":"2026-03-10T00:03:19.381Z","message":{"role":"toolResult","toolCallId":"call_00_e3yeLNwLY72aWdcihbzuGHvc","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nDetect overly long/complex prompts and decompose into mini‑tasks.\n\"\"\"\n\nimport re\nimport math\nfrom typing import List, Dict, Any, Tuple, Optional\n\ndef estimate_tokens(text: str) -> int:\n    \"\"\"Rough token estimation (4 chars ≈ 1 token).\"\"\"\n    return len(text) // 4\n\ndef detect_complexity(prompt: str) -> Tuple[bool, List[str], Dict[str, Any]]:\n    \"\"\"\n    Detect if prompt is complex based on heuristics.\n    Returns (should_decompose, reasons, complexity_metrics).\n    \"\"\"\n    reasons = []\n    metrics = {\n        'token_estimate': 0,\n        'task_count_estimate': 0,\n        'artifact_count_estimate': 0,\n        'dependency_complexity': 0,\n        'cross_skill_complexity': 0,\n        'complexity_score': 0,\n        'requires_supervisor': False\n    }\n    \n    # Token count - B1: Primary trigger\n    tokens = estimate_tokens(prompt)\n    metrics['token_estimate'] = tokens\n    if tokens > 4000:  # default MAX_PROMPT_TOKENS\n        reasons.append(f\"Token count {tokens} > 4000 (long-prompt threshold)\")\n    \n    # Task count estimate (based on structure)\n    # Count numbered/bulleted items, sections, parts\n    numbered_items = len(re.findall(r'\\n\\s*\\d+\\.\\s+', prompt))\n    bullet_items = len(re.findall(r'\\n\\s*[-*•]\\s+', prompt))\n    sections = len(re.findall(r'\\n\\s*(?:Part|Step|Section|Chapter)\\s+\\w+\\s*:', prompt, re.IGNORECASE))\n    task_count = max(numbered_items, bullet_items, sections, 1)\n    metrics['task_count_estimate'] = task_count\n    \n    # B1: Multi-objective detection (>1 objective or >5 reasoning steps)\n    objective_keywords = ['also', 'additionally', 'furthermore', 'moreover', 'besides', 'and also', 'second', 'third', 'finally']\n    multi_objective = sum(1 for kw in objective_keywords if kw in prompt.lower()) > 0\n    if multi_objective:\n        reasons.append(\"Multi-objective detected\")\n    \n    # B1: Expected steps > 5\n    step_keywords = ['step', 'first', 'then', 'next', 'finally', 'part', 'section', 'chapter', 'task']\n    step_count = sum(1 for word in step_keywords if word in prompt.lower())\n    if step_count > 5:\n        reasons.append(f\"Step-like keywords {step_count} > 5 (requires decomposition)\")\n    \n    # B1: Multi-file outputs\n    file_extensions = ['.py', '.md', '.txt', '.json', '.csv', '.html', '.ipynb', '.yml', '.yaml', '.js', '.ts', '.java', '.cpp']\n    artifact_count = sum(1 for ext in file_extensions if ext in prompt)\n    metrics['artifact_count_estimate'] = artifact_count\n    if artifact_count > 0:\n        reasons.append(f\"Contains {artifact_count} file extensions (multi‑file outputs)\")\n    \n    # B1: Multiple skills required\n    skill_keywords = ['skill', 'salesforce', 'weather', 'search', 'tavily', 'janitor', 'watchdog', 'memory', 'vector']\n    cross_skill_complexity = sum(1 for kw in skill_keywords if kw in prompt.lower())\n    metrics['cross_skill_complexity'] = cross_skill_complexity\n    if cross_skill_complexity > 0:\n        reasons.append(f\"Mentions multiple skills ({cross_skill_complexity} mentions)\")\n    \n    # Multi‑agent operations\n    agent_keywords = ['sub‑agent', 'subagent', 'validator', 'spawn', 'delegate', 'parallel', 'multiple agents', 'team of agents']\n    agent_mentions = sum(1 for kw in agent_keywords if kw in prompt.lower())\n    if agent_mentions > 0:\n        reasons.append(f\"Mentions multi‑agent operations\")\n    \n    # Long tool execution sequences\n    tool_keywords = ['run', 'execute', 'call', 'tool', 'command', 'script', 'bash', 'python', 'shell', 'git', 'docker']\n    tool_count = sum(1 for word in tool_keywords if word in prompt.lower())\n    if tool_count > 3:\n        reasons.append(f\"Tool‑like keywords {tool_count} > 3\")\n    \n    # Dependency complexity (based on ordering words)\n    dependency_keywords = ['after', 'before', 'then', 'next', 'following', 'based on', 'using output from', 'depend', 'requires', 'needs']\n    dependency_complexity = sum(1 for kw in dependency_keywords if kw in prompt.lower())\n    metrics['dependency_complexity'] = dependency_complexity\n    if dependency_complexity > 2:\n        reasons.append(f\"Dependency complexity {dependency_complexity} > 2\")\n    \n    # Calculate composite complexity score\n    # Weighted sum of normalized metrics\n    complexity_score = 0\n    complexity_score += min(tokens / 4000, 1.0) * 0.3  # token weight\n    complexity_score += min(task_count / 10, 1.0) * 0.25  # task count weight\n    complexity_score += min(artifact_count / 5, 1.0) * 0.2  # artifact weight\n    complexity_score += min(dependency_complexity / 5, 1.0) * 0.15  # dependency weight\n    complexity_score += min(cross_skill_complexity / 3, 1.0) * 0.1  # cross-skill weight\n    \n    metrics['complexity_score'] = complexity_score\n    \n    # B1: Enhanced activation criteria\n\n[240 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1773100999376}}
{"type":"message","id":"619235a8","parentId":"2a03e56f","timestamp":"2026-03-10T00:03:24.902Z","message":{"role":"assistant","content":[{"type":"text","text":"Let me see more of the decompose.py file to understand the task generation logic:"},{"type":"toolCall","id":"call_00_ALqOWegrHzR6S1stP9obGcNl","name":"read","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/long-prompt-orchestrator/scripts/decompose.py","offset":100,"limit":200}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":1395,"output":117,"cacheRead":27200,"cacheWrite":0,"totalTokens":28712,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773100999380}}
{"type":"message","id":"b9c8ec13","parentId":"619235a8","timestamp":"2026-03-10T00:03:24.911Z","message":{"role":"toolResult","toolCallId":"call_00_ALqOWegrHzR6S1stP9obGcNl","toolName":"read","content":[{"type":"text","text":"    # B1: Enhanced activation criteria\n    # Trigger if ANY of these conditions are met:\n    # 1. Token count > threshold\n    # 2. Multi-objective or >5 steps\n    # 3. Requires multi-file outputs\n    # 4. Requires multiple skills\n    should_decompose = False\n    \n    # Primary triggers (any one is enough)\n    if tokens > 4000:\n        should_decompose = True\n        metrics['requires_supervisor'] = True\n    if step_count > 5:\n        should_decompose = True\n        metrics['requires_supervisor'] = True\n    if artifact_count > 0:\n        should_decompose = True\n    if cross_skill_complexity > 0:\n        should_decompose = True\n        metrics['requires_supervisor'] = True\n    \n    # Secondary triggers (need at least 2)\n    secondary_triggers = []\n    if multi_objective:\n        secondary_triggers.append(\"multi_objective\")\n    if tool_count > 3:\n        secondary_triggers.append(\"tool_heavy\")\n    if dependency_complexity > 2:\n        secondary_triggers.append(\"complex_dependencies\")\n    if agent_mentions > 0:\n        secondary_triggers.append(\"multi_agent\")\n    \n    if len(secondary_triggers) >= 2:\n        should_decompose = True\n        metrics['requires_supervisor'] = True\n    \n    # Fallback: complexity score threshold\n    if complexity_score > 0.4 and not should_decompose:\n        should_decompose = True\n    \n    # Special case: explicit decomposition benefit\n    decomposition_benefit_keywords = ['decompose', 'break down', 'split into', 'divide into', 'multiple steps', 'orchestrate', 'supervisor']\n    if any(kw in prompt.lower() for kw in decomposition_benefit_keywords):\n        reasons.append(\"Explicit decomposition benefit mentioned\")\n        should_decompose = True\n        metrics['requires_supervisor'] = True\n    \n    return should_decompose, reasons, metrics\n\ndef decompose_prompt(prompt: str, max_mini_tasks: int = 20) -> List[Dict[str, Any]]:\n    \"\"\"\n    Enhanced rule‑based decomposition with better task analysis.\n    Splits by numbered lists, bullet points, or 'Part X' patterns.\n    \"\"\"\n    # Look for numbered lists (1., 2., etc.)\n    numbered = re.findall(r'\\n\\s*\\d+\\.\\s+(.+?)(?=\\n\\s*\\d+\\.|\\n\\s*$)', prompt, re.DOTALL)\n    # Look for bullet points (‑, *, •)\n    bullet = re.findall(r'\\n\\s*[-*•]\\s+(.+?)(?=\\n\\s*[-*•]|\\n\\s*$)', prompt, re.DOTALL)\n    # Look for 'Part X:' or 'Step X:'\n    parts = re.findall(r'\\n\\s*(?:Part|Step|Section|Chapter)\\s+\\w+\\s*:\\s*(.+?)(?=\\n\\s*(?:Part|Step|Section|Chapter)|\\n\\s*$)', prompt, re.IGNORECASE | re.DOTALL)\n    \n    segments = []\n    if numbered:\n        segments = numbered\n    elif bullet:\n        segments = bullet\n    elif parts:\n        segments = parts\n    else:\n        # Fallback: split by major sentences ending with colon or containing key verbs\n        # Look for sentences that start with action verbs\n        action_verbs = ['create', 'write', 'build', 'implement', 'design', 'analyze', 'develop', 'generate', 'produce', 'make']\n        sentences = re.findall(r'([A-Z][^.!?]*[.!?])', prompt)\n        action_sentences = [s for s in sentences if any(verb in s.lower().split()[0] for verb in action_verbs)]\n        if len(action_sentences) > 1:\n            segments = action_sentences\n        else:\n            # Last resort: treat as single task\n            return []\n    \n    # Limit to max_mini_tasks\n    if len(segments) > max_mini_tasks:\n        segments = segments[:max_mini_tasks]\n    \n    tasks = []\n    for i, seg in enumerate(segments, start=1):\n        task_id = f\"task_{i:02d}\"\n        \n        # Analyze segment for dependencies\n        dependencies = []\n        # Check for explicit dependency references\n        dep_patterns = [\n            r'after\\s+(?:task|step|part)\\s*(\\d+)',\n            r'based\\s+on\\s+(?:task|step|part)\\s*(\\d+)',\n            r'using\\s+(?:the\\s+)?output\\s+from\\s+(?:task|step|part)\\s*(\\d+)',\n            r'following\\s+(?:task|step|part)\\s*(\\d+)'\n        ]\n        for pattern in dep_patterns:\n            matches = re.findall(pattern, seg, re.IGNORECASE)\n            for match in matches:\n                dep_id = f\"task_{int(match):02d}\"\n                if dep_id not in dependencies:\n                    dependencies.append(dep_id)\n        \n        # If no explicit dependencies, use linear chain for ordered lists\n        if not dependencies and (numbered or parts):\n            dependencies = [f\"task_{j:02d}\" for j in range(1, i)] if i > 1 else []\n        \n        # Analyze complexity of segment\n        seg_tokens = estimate_tokens(seg)\n        complexity_score = 0\n        \n        # B3: Enhanced complexity scoring for sub-agent dispatch\n        if seg_tokens > 500:\n            complexity_score += 2  # Longer segments need sub-agents\n        elif seg_tokens > 300:\n            complexity_score += 1\n        \n        # Code-related tasks\n        if any(ext in seg for ext in ['.py', '.md', '.json', '.txt', '.csv', '.js', '.ts', '.java', '.cpp']):\n            complexity_score += 2  # File creation needs sub-agent\n        elif any(kw in seg.lower() for kw in ['code', 'script', 'function', 'class', 'module', 'program', 'application']):\n            complexity_score += 1\n        \n        # Analysis/processing tasks\n        if any(kw in seg.lower() for kw in ['analyze', 'calculate', 'process', 'transform', 'compute', 'evaluate', 'assess']):\n            complexity_score += 1\n        \n        # Multi-step tasks within segment\n        if any(kw in seg.lower() for kw in ['first', 'then', 'next', 'after', 'before']):\n            complexity_score += 1\n        \n        # External tool usage\n        if any(kw in seg.lower() for kw in ['run', 'execute', 'command', 'bash', 'shell', 'git', 'docker', 'api', 'call']):\n            complexity_score += 1\n        \n        # B3: Determine if subagent is required\n        # Sub-agent required if:\n        # 1. High complexity score (≥3)\n        # 2. Medium complexity (2) AND segment tokens > 400\n        # 3. Explicit multi-agent keywords\n        subagent_required = False\n        if complexity_score >= 3:\n            subagent_required = True\n        elif complexity_score == 2 and seg_tokens > 400:\n            subagent_required = True\n        elif any(kw in seg.lower() for kw in ['subagent', 'sub-agent', 'delegate', 'spawn', 'parallel']):\n            subagent_required = True\n        \n        # Guess outputs based on content\n        outputs = []\n        if '.py' in seg:\n            outputs.append(f\"{task_id}.py\")\n        if '.md' in seg:\n            outputs.append(f\"{task_id}.md\")\n        if '.json' in seg:\n            outputs.append(f\"{task_id}.json\")\n        if '.txt' in seg:\n            outputs.append(f\"{task_id}.txt\")\n        if 'file' in seg.lower() and not outputs:\n            outputs.append(f\"{task_id}_output.txt\")\n        \n        # Estimate runtime based on complexity\n        estimated_runtime = 60 + (complexity_score * 30)  # base 60s + 30s per complexity point\n        \n        tasks.append({\n            'id': task_id,\n            'objective': seg.strip(),\n            'inputs': [],\n            'outputs': outputs,\n            'dependencies': dependencies,\n            'acceptance_criteria': [\n                \"Complete the described objective.\",\n                \"Output matches expected format.\"\n            ],\n            'max_token_budget': 1000,  # default\n            'complexity_score': complexity_score,\n            'estimated_tokens': seg_tokens,\n            'estimated_runtime': estimated_runtime,\n            'subagent_required': subagent_required\n        })\n    \n    return tasks\n\ndef detect_and_decompose(prompt: str, max_prompt_tokens: int = 4000, max_mini_tasks: int = 20) -> Tuple[List[Dict[str, Any]], Dict[str, Any]]:\n    \"\"\"\n    Main entry point: detect if decomposition needed, and decompose.\n    Returns (list of mini‑tasks, complexity_metrics) or (empty list, metrics) if no decomposition.\n    \"\"\"\n    should_decompose, reasons, metrics = detect_complexity(prompt)\n    if not should_decompose:\n        return [], metrics\n    \n    print(f\"=== Long-Prompt Orchestrator Activation ===\")\n    print(f\"Decomposition needed: {', '.join(reasons)}\")\n    print(f\"Complexity metrics:\")\n    print(f\"  - Token estimate: {metrics['token_estimate']}\")\n    print(f\"  - Task count estimate: {metrics['task_count_estimate']}\")\n    print(f\"  - Artifact count: {metrics['artifact_count_estimate']}\")\n    print(f\"  - Complexity score: {metrics['complexity_score']:.2f}\")\n\n[41 more lines in file. Use offset=300 to continue.]"}],"isError":false,"timestamp":1773101004908}}
{"type":"message","id":"4012c466","parentId":"b9c8ec13","timestamp":"2026-03-10T00:03:31.260Z","message":{"role":"assistant","content":[{"type":"text","text":"Now I understand the issue. The current plan format generates tasks with abstract objectives like \"Write introduction section\" but doesn't provide executable instructions. Let me check the PLAN_FORMAT_SPECIFICATION.md to see the current format:"},{"type":"toolCall","id":"call_00_kjofWoLv01B7NFGuvhgeMyJA","name":"read","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/long-prompt-orchestrator/PLAN_FORMAT_SPECIFICATION.md","offset":1,"limit":100}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":2256,"output":149,"cacheRead":28672,"cacheWrite":0,"totalTokens":31077,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101004910}}
{"type":"message","id":"e86fc97a","parentId":"4012c466","timestamp":"2026-03-10T00:03:31.276Z","message":{"role":"toolResult","toolCallId":"call_00_kjofWoLv01B7NFGuvhgeMyJA","toolName":"read","content":[{"type":"text","text":"# Plan Format Specification\n\n## Overview\n\nThis document specifies the JSON format for execution plans generated by the `long-prompt-orchestrator` skill. Plans are structured documents that main agents use to coordinate complex task execution.\n\n## Schema Version\n\n**Current Version**: 1.0.0  \n**Last Updated**: 2026-03-09  \n**Compatibility**: Backward compatible within major version\n\n## Complete Schema\n\n### Root Object\n\n```json\n{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"title\": \"Execution Plan\",\n  \"type\": \"object\",\n  \"required\": [\n    \"plan_id\",\n    \"original_prompt\",\n    \"created_at\",\n    \"tasks\",\n    \"dependency_graph\",\n    \"validation_protocol\"\n  ],\n  \"properties\": {\n    \"plan_id\": {\n      \"type\": \"string\",\n      \"pattern\": \"^plan_\\\\d+_[a-f0-9]{8}$\",\n      \"description\": \"Unique identifier for the plan\"\n    },\n    \"original_prompt\": {\n      \"type\": \"string\",\n      \"description\": \"Original prompt that triggered plan generation\"\n    },\n    \"created_at\": {\n      \"type\": \"string\",\n      \"format\": \"date-time\",\n      \"description\": \"ISO 8601 timestamp of plan creation\"\n    },\n    \"estimated_total_tokens\": {\n      \"type\": \"integer\",\n      \"minimum\": 0,\n      \"description\": \"Estimated total tokens required for execution\"\n    },\n    \"estimated_total_runtime_seconds\": {\n      \"type\": \"integer\",\n      \"minimum\": 0,\n      \"description\": \"Estimated total runtime in seconds\"\n    },\n    \"global_token_budget\": {\n      \"type\": \"integer\",\n      \"minimum\": 0,\n      \"default\": 16000,\n      \"description\": \"Global token budget for entire plan execution\"\n    },\n    \"tasks\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"$ref\": \"#/definitions/Task\"\n      },\n      \"minItems\": 1,\n      \"maxItems\": 50,\n      \"description\": \"List of tasks to execute\"\n    },\n    \"dependency_graph\": {\n      \"$ref\": \"#/definitions/DependencyGraph\"\n    },\n    \"resource_allocation\": {\n      \"$ref\": \"#/definitions/ResourceAllocation\"\n    },\n    \"validation_protocol\": {\n      \"$ref\": \"#/definitions/ValidationProtocol\"\n    },\n    \"synthesis_strategy\": {\n      \"type\": \"string\",\n      \"enum\": [\"concatenate\", \"summarize\", \"structured_merge\", \"custom\"],\n      \"default\": \"concatenate\",\n      \"description\": \"Strategy for synthesizing final result\"\n    },\n    \"metadata\": {\n      \"type\": \"object\",\n      \"additionalProperties\": true,\n      \"description\": \"Additional metadata about the plan\"\n    }\n  }\n}\n```\n\n## Definitions\n\n### Task Object\n\n```json\n{\n  \"definitions\": {\n\n[492 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1773101011270}}
