_TIMEOUT if session.runtime_type == 'acp' else STALL_TIMEOUT\n    if session.state == \"running\" and inactivity > timeout:\n        return True\n    return False\n\ndef monitor(session):\n    while True:\n        if detect_stall(session):\n            return \"stall_detected\"\n        time.sleep(MONITOR_INTERVAL)"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-reasoner","usage":{"input":35238,"output":590,"cacheRead":37760,"cacheWrite":0,"totalTokens":73588,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772739946090}}
