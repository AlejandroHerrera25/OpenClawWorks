{"type":"message","id":"d824648c","parentId":"8c29f1a5","timestamp":"2026-03-10T00:04:57.781Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_00_DEhGPBxJEvJlpG0SyadVQP01","name":"write","arguments":{"path":"~/.openclaw/workspace/fixtures/real_salesforce_samples/AccountService.cls","content":"/**\n * AccountService - Example with GOOD patterns for testing\n * Demonstrates proper Salesforce development practices\n */\npublic with sharing class AccountService {\n    \n    // GOOD: Bulkified SOQL\n    public static void updateAccountContacts(List<Id> accountIds) {\n        // GOOD: Query outside loop\n        Map<Id, Account> accountMap = new Map<Id, Account>([\n            SELECT Id, Name \n            FROM Account \n            WHERE Id IN :accountIds\n        ]);\n        \n        // GOOD: Query all contacts at once\n        List<Contact> contacts = [\n            SELECT Id, FirstName, LastName, AccountId \n            FROM Contact \n            WHERE AccountId IN :accountIds\n        ];\n        \n        List<Contact> contactsToUpdate = new List<Contact>();\n        \n        for(Contact con : contacts) {\n            Account acc = accountMap.get(con.AccountId);\n            if(acc != null) {\n                con.Description = 'Updated by AccountService for ' + acc.Name;\n                contactsToUpdate.add(con);\n            }\n        }\n        \n        // GOOD: Single DML outside loop\n        if(!contactsToUpdate.isEmpty()) {\n            update contactsToUpdate;\n        }\n    }\n    \n    // GOOD: Proper FLS check\n    public static Account createAccount(String name, String industry) {\n        // GOOD: Check field accessibility\n        if(!Schema.sObjectType.Account.fields.Name.isCreateable() ||\n           !Schema.sObjectType.Account.fields.Industry.isCreateable() ||\n           !Schema.sObjectType.Account.fields.AnnualRevenue.isCreateable()) {\n            throw new SecurityException('Insufficient permissions to create Account');\n        }\n        \n        Account acc = new Account();\n        acc.Name = name;\n        acc.Industry = industry;\n        acc.AnnualRevenue = 1000000;\n        \n        // GOOD: Try-catch with specific handling\n        try {\n            insert acc;\n            return acc;\n        } catch(DmlException e) {\n            // GOOD: Specific error handling\n            System.debug('DML Error creating account: ' + e.getMessage());\n            throw new AccountServiceException('Failed to create account: ' + e.getMessage());\n        }\n    }\n    \n    // GOOD: Single responsibility - business logic only\n    public static Decimal calculateTotalRevenue(List<Id> accountIds) {\n        // GOOD: Aggregate query\n        AggregateResult[] results = [\n            SELECT SUM(AnnualRevenue) total \n            FROM Account \n            WHERE Id IN :accountIds\n            GROUP BY Id\n        ];\n        \n        Decimal total = 0;\n        for(AggregateResult ar : results) {\n            total += (Decimal)ar.get('total');\n        }\n        \n        return total;\n    }\n    \n    // GOOD: Proper error handling with custom exception\n    public class AccountServiceException extends Exception {}\n    \n    // GOOD: Governor limit awareness\n    public static void processLargeDataset(List<Id> accountIds) {\n        Integer batchSize = 100;\n        Integer processed = 0;\n        \n        for(Integer i = 0; i < accountIds.size(); i += batchSize) {\n            Integer endIndex = Math.min(i + batchSize, accountIds.size());\n            List<Id> batch = accountIds.subList(i, endIndex);\n            \n            // Process batch\n            updateAccountContacts(batch);\n            processed += batch.size();\n            \n            // GOOD: Governor limit check\n            if(Limits.getDmlStatements() >= Limits.getLimitDmlStatements() - 10) {\n                System.debug('Approaching DML limit: ' + Limits.getDmlStatements());\n                break;\n            }\n        }\n        \n        System.debug('Processed ' + processed + ' accounts');\n    }\n}"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":108,"output":851,"cacheRead":18368,"cacheWrite":0,"totalTokens":19327,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101072059}}
