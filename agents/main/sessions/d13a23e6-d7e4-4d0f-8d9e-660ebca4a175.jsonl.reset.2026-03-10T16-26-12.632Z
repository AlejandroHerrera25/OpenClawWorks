{"type":"message","id":"13d02c94","parentId":"a3efe155","timestamp":"2026-03-10T01:57:31.792Z","message":{"role":"assistant","content":[{"type":"text","text":"### **Paso 2: Agregar endpoints API al dashboard**"},{"type":"toolCall","id":"call_00_hI6HHVtpABXtOQluzxQ4CJRx","name":"edit","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/agent-watchdog/scripts/watchdog_dashboard.py","oldText":"# HTML Template\nHTML_TEMPLATE = \"\"\"","newText":"# Routes\n@app.route('/')\ndef index():\n    \"\"\"Main dashboard page\"\"\"\n    return render_template_string(HTML_TEMPLATE)\n\n@app.route('/api/stats')\ndef api_stats():\n    \"\"\"API endpoint for session statistics\"\"\"\n    stats = get_session_stats()\n    return jsonify({\n        \"stats\": stats,\n        \"timestamp\": datetime.now(timezone.utc).isoformat()\n    })\n\n@app.route('/api/alerts')\ndef api_alerts():\n    \"\"\"API endpoint for recent alerts\"\"\"\n    alerts = get_recent_alerts(10)\n    return jsonify({\n        \"alerts\": alerts,\n        \"count\": len(alerts),\n        \"timestamp\": datetime.now(timezone.utc).isoformat()\n    })\n\n@app.route('/api/logs')\ndef api_logs():\n    \"\"\"API endpoint for log tail\"\"\"\n    log_text = get_log_tail(50)\n    return log_text\n\n@app.route('/api/health')\ndef api_health():\n    \"\"\"Health check endpoint\"\"\"\n    return jsonify({\n        \"status\": \"healthy\",\n        \"service\": \"openclaw_watchdog_dashboard\",\n        \"timestamp\": datetime.now(timezone.utc).isoformat(),\n        \"watchdog_running\": os.path.exists(WATCHDOG_DIR / \"service.pid\")\n    })\n\n# HTML Template\nHTML_TEMPLATE = \"\"\""}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":64,"output":401,"cacheRead":73792,"cacheWrite":0,"totalTokens":74257,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773107835218}}
