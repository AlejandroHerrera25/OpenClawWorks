{"type":"message","id":"dc260076","parentId":"93fdb975","timestamp":"2026-03-10T00:09:07.225Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create an integration script that connects the monitoring and recovery systems:"},{"type":"toolCall","id":"call_00_lqmtuPg17bGu3A3DMrnmyOLz","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/agent-watchdog/scripts/watchdog_integration.py","content":"#!/usr/bin/env python3\n\"\"\"\nIntegration system for agent-watchdog.\nConnects real monitoring with real recovery and integrates with OpenClaw ecosystem.\n\"\"\"\n\nimport os\nimport json\nimport time\nimport threading\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\n# Workspace paths\nWORKSPACE = Path.home() / '.openclaw' / 'workspace'\nWATCHDOG_DIR = WORKSPACE / '.watchdog'\nINTEGRATION_LOG = WATCHDOG_DIR / 'integration.log'\n\n# Import real monitoring and recovery systems\nsys.path.insert(0, str(Path(__file__).parent))\ntry:\n    from watchdog_monitor_real import RealSessionMonitor\n    from watchdog_recovery_real import RealRecoverySystem\n    REAL_SYSTEMS_AVAILABLE = True\nexcept ImportError as e:\n    print(f\"Warning: Real systems not available: {e}\")\n    REAL_SYSTEMS_AVAILABLE = False\n\nclass WatchdogIntegration:\n    \"\"\"Integration system for agent-watchdog.\"\"\"\n    \n    def __init__(self):\n        self.monitor = None\n        self.recovery = None\n        self.running = False\n        self.integration_thread = None\n        \n        if REAL_SYSTEMS_AVAILABLE:\n            self.monitor = RealSessionMonitor()\n            self.recovery = RealRecoverySystem()\n    \n    def log_integration(self, message, level=\"INFO\"):\n        \"\"\"Log integration activity.\"\"\"\n        timestamp = datetime.utcnow().isoformat()\n        log_entry = f\"[{timestamp}] [{level}] {message}\\n\"\n        \n        # Write to integration log\n        try:\n            with open(INTEGRATION_LOG, 'a') as f:\n                f.write(log_entry)\n        except Exception as e:\n            print(f\"Failed to write to integration log: {e}\")\n        \n        # Also print to console\n        print(log_entry.strip())\n    \n    def check_openclaw_ecosystem(self):\n        \"\"\"Check OpenClaw ecosystem components.\"\"\"\n        ecosystem_status = {\n            \"gateway_running\": False,\n            \"sessions_available\": False,\n            \"error_learning_loop_available\": False,\n            \"workspace_janitor_available\": False,\n            \"vector_memory_available\": False\n        }\n        \n        # Check if gateway is running\n        try:\n            result = subprocess.run(['ps', 'aux'], capture_output=True, text=True)\n            if 'openclaw-gateway' in result.stdout:\n                ecosystem_status[\"gateway_running\"] = True\n        except Exception as e:\n            self.log_integration(f\"Error checking gateway: {e}\", level=\"ERROR\")\n        \n        # Check if sessions file exists\n        sessions_file = Path.home() / '.openclaw' / 'agents' / 'main' / 'sessions' / 'sessions.json'\n        if sessions_file.exists():\n            ecosystem_status[\"sessions_available\"] = True\n        \n        # Check if error-learning-loop skill exists\n        error_skill_dir = WORKSPACE / 'skills' / 'error-learning-loop'\n        if error_skill_dir.exists():\n            ecosystem_status[\"error_learning_loop_available\"] = True\n        \n        # Check if workspace-janitor skill exists\n        janitor_skill_dir = WORKSPACE / 'skills' / 'workspace-janitor'\n        if janitor_skill_dir.exists():\n            ecosystem_status[\"workspace_janitor_available\"] = True\n        \n        # Check if vector-memory skill exists\n        memory_skill_dir = WORKSPACE / 'skills' / 'vector-memory'\n        if memory_skill_dir.exists():\n            ecosystem_status[\"vector_memory_available\"] = True\n        \n        return ecosystem_status\n    \n    def register_with_watchdog(self):\n        \"\"\"Register this integration system with the watchdog itself.\"\"\"\n        registration_file = WATCHDOG_DIR / 'integration_registry.json'\n        \n        registration_data = {\n            \"registered_at\": datetime.utcnow().isoformat(),\n            \"integration_type\": \"real_monitoring_recovery\",\n            \"version\": \"1.0\",\n            \"components\": {\n                \"monitor\": self.monitor is not None,\n                \"recovery\": self.recovery is not None\n            },\n            \"status\": \"active\" if self.running else \"inactive\"\n        }\n        \n        try:\n            with open(registration_file, 'w') as f:\n                json.dump(registration_data, f, indent=2)\n            self.log_integration(\"Registered with watchdog\")\n        except Exception as e:\n            self.log_integration(f\"Error registering with watchdog: {e}\", level=\"ERROR\")\n    \n    def emit_operational_metrics(self):\n        \"\"\"Emit operational metrics for observability.\"\"\"\n        metrics_file = WATCHDOG_DIR / 'operational_metrics.json'\n        \n        if not self.monitor:\n            return\n        \n        metrics = {\n            \"timestamp\": datetime.utcnow().isoformat(),\n            \"integration_status\": {\n                \"running\": self.running,\n                \"monitor_available\": self.monitor is not None,\n                \"recovery_available\": self.recovery is not None\n            },\n            \"session_metrics\": {\n                \"total_sessions\": len(self.monitor.sessions) if self.monitor else 0,\n                \"active_sessions\": len([s for s in self.monitor.sessions.values() if s.state == \"active\"]) if self.monitor else 0,\n                \"stalled_sessions\": len([s for s in self.monitor.sessions.values() if s.state == \"stalled\"]) if self.monitor else 0\n            },\n            \"recovery_metrics\": {\n                \"total_recoveries\": len(self.recovery.recovery_history) if self.recovery else 0,\n                \"successful_recoveries\": len([r for r in self.recovery.recovery_history if r.get(\"success\")]) if self.recovery else 0\n            },\n            \"ecosystem_status\": self.check_openclaw_ecosystem()\n        }\n        \n        try:\n            with open(metrics_file, 'w') as f:\n                json.dump(metrics, f, indent=2)\n        except Exception as e:\n            self.log_integration(f\"Error emitting operational metrics: {e}\", level=\"ERROR\")\n    \n    def integration_loop(self):\n        \"\"\"Main integration loop.\"\"\"\n        self.log_integration(\"Starting watchdog integration system\")\n        \n        # Register with watchdog\n        self.register_with_watchdog()\n        \n        # Start monitoring if available\n        if self.monitor:\n            self.monitor.start()\n        \n        while self.running:\n            try:\n                # Emit operational metrics\n                self.emit_operational_metrics()\n                \n                # Check ecosystem status\n                ecosystem_status = self.check_openclaw_ecosystem()\n                \n                # Log status periodically\n                self.log_integration(f\"Ecosystem status: {json.dumps(ecosystem_status)}\")\n                \n                # If recovery system is available, run recovery cycles\n                if self.recovery:\n                    recovery_results = self.recovery.run_recovery_cycle()\n                    if recovery_results:\n                        self.log_integration(f\"Performed {len(recovery_results)} recoveries\")\n                \n                # Wait for next cycle\n                time.sleep(60)  # Check every minute\n                \n            except Exception as e:\n                self.log_integration(f\"Error in integration loop: {e}\", level=\"ERROR\")\n                time.sleep(10)  # Shorter sleep on error\n    \n    def start(self):\n        \"\"\"Start the integration system.\"\"\"\n        if self.running:\n            self.log_integration(\"Integration already running\")\n            return\n        \n        if not REAL_SYSTEMS_AVAILABLE:\n            self.log_integration(\"ERROR: Real systems not available. Cannot start integration.\", level=\"ERROR\")\n            return\n        \n        self.running = True\n        self.integration_thread = threading.Thread(target=self.integration_loop, daemon=True)\n        self.integration_thread.start()\n        self.log_integration(\"Watchdog integration system started\")\n    \n    def stop(self):\n        \"\"\"Stop the integration system.\"\"\"\n        self.running = False\n        \n        # Stop monitoring\n        if self.monitor:\n            self.monitor.stop()\n        \n        # Wait for thread to finish\n        if self.integration_thread:\n            self.integration_thread.join(timeout=5)\n        \n        # Emit final metrics\n        self.emit_operational_metrics()\n        \n        self.log_integration(\"Watchdog integration system stopped\")\n    \n    def test_integration(self):\n        \"\"\"Test the integration system.\"\"\"\n        self.log_integration(\"Running integration test\")\n        \n        # Test 1: Check ecosystem\n        ecosystem_status = self.check_openclaw_ecosystem()\n        self.log_integration(f\"Ecosystem test: {json.dumps(ecosystem_status)}\")\n        \n        # Test 2: Check if real systems are available\n        if not REAL_SYSTEMS_AVAILABLE:\n            self.log_integration(\"FAIL: Real systems not available\", level=\"ERROR\")\n            return False\n        \n        # Test 3: Test monitoring\n        if self.monitor:\n            discovered = self.monitor.discover_sessions()\n            self.log_integration(f\"Monitoring test: Discovered {len(discovered)} sessions\")\n        \n        # Test 4: Test recovery\n        if self.recovery:\n            stalled = self.recovery.get_stalled_sessions()\n            self.log_integration(f\"Recovery test: Found {len(stalled)} stalled sessions\")\n        \n        # Test 5: Emit test metrics\n        self.emit_operational_metrics()\n        self.log_integration(\"Test metrics emitted\")\n        \n        self.log_integration(\"Integration test completed successfully\")\n        return True\n\ndef main():\n    \"\"\"Command-line interface for watchdog integration.\"\"\"\n    import argparse\n    \n    parser = argparse.ArgumentParser(description=\"Watchdog Integration System\")\n    parser.add_argument(\"--start\", action=\"store_true\", help=\"Start integration system\")\n    parser.add_argument(\"--stop\", action=\"store_true\", help=\"Stop integration system\")\n    parser.add_argument(\"--status\", action=\"store_true\", help=\"Show integration status\")\n    parser.add_argument(\"--test\", action=\"store_true\", help=\"Run integration test\")\n    parser.add_argument(\"--ecosystem\", action=\"store_true\", help=\"Check ecosystem status\")\n    parser.add_argument(\"--metrics\", action=\"store_true\", help=\"Show operational metrics\")\n    \n    args = parser.parse_args()\n    \n    integration = WatchdogIntegration()\n    \n    if args.start:\n        integration.start()\n        try:\n            # Keep running until interrupted\n            while True:\n                time.sleep(1)\n        except KeyboardInterrupt:\n            integration.stop()\n    \n    elif args.stop:\n        integration.stop()\n    \n    elif args.status:\n        if integration.monitor:\n            print(f\"Monitor: {'Running' if integration.monitor.running else 'Stopped'}\")\n            print(f\"Sessions: {len(integration.monitor.sessions)}\")\n        else:\n            print(\"Monitor: Not available\")\n        \n        if integration.recovery:\n            print(f\"Recovery: Available\")\n            print(f\"History: {len(integration.recovery.recovery_history)} incidents\")\n        else:\n            print(\"Recovery: Not available\")\n        \n        print(f\"Integration: {'Running' if integration.running else 'Stopped'}\")\n    \n    elif args.test:\n        success = integration.test_integration()\n        if success:\n            print(\"Integration test: PASS\")\n        else:\n            print(\"Integration test: FAIL\")\n    \n    elif args.ecosystem:\n        status = integration.check_openclaw_ecosystem()\n        print(\"OpenClaw Ecosystem Status:\")\n        for component, available in status.items():\n            print(f\"  {component}: {'✓' if available else '✗'}\")\n    \n    elif args.metrics:\n        metrics_file = WATCHDOG_DIR / 'operational_metrics.json'\n        if metrics_file.exists():\n            with open(metrics_file, 'r') as f:\n                metrics = json.load(f)\n            print(json.dumps(metrics, indent=2))\n        else:\n            print(\"No metrics available\")\n    \n    else:\n        parser.print_help()\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":59,"output":2725,"cacheRead":62976,"cacheWrite":0,"totalTokens":65760,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101265723}}
