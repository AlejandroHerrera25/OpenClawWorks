{"type":"message","id":"3ac5520f","parentId":"23d89daa","timestamp":"2026-03-10T00:07:58.569Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_00_2JmIabeywdBCjQRxyo6j3Uhd","name":"write","arguments":{"path":"~/.openclaw/workspace/fixtures/real_salesforce_samples/AccountViewController.cls","content":"/**\n * AccountViewController - Visualforce controller with mixed patterns\n */\npublic with sharing class AccountViewController {\n    \n    public Account account { get; set; }\n    public List<Contact> contacts { get; set; }\n    public List<Opportunity> opportunities { get; set; }\n    public String selectedContactId { get; set; }\n    public String viewState { get; set; }\n    \n    public Integer contactCount { get { return contacts != null ? contacts.size() : 0; } }\n    public Integer opportunityCount { get { return opportunities != null ? opportunities.size() : 0; } }\n    public Decimal totalRevenue { \n        get {\n            Decimal total = 0;\n            if(opportunities != null) {\n                for(Opportunity opp : opportunities) {\n                    total += opp.Amount != null ? opp.Amount : 0;\n                }\n            }\n            return total;\n        }\n    }\n    \n    // BAD: Constructor doing too much work\n    public AccountViewController() {\n        // BAD: Hardcoded ID for demo\n        String accountId = ApexPages.currentPage().getParameters().get('id');\n        \n        if(String.isNotBlank(accountId)) {\n            // BAD: Multiple queries in constructor\n            account = [SELECT Id, Name, Industry, AnnualRevenue, Rating, Type, OwnerId \n                      FROM Account WHERE Id = :accountId LIMIT 1];\n            \n            // BAD: Queries that could be large\n            contacts = [SELECT Id, Name, Email, Phone, Title, AccountId \n                       FROM Contact WHERE AccountId = :accountId \n                       ORDER BY Name LIMIT 1000];\n            \n            opportunities = [SELECT Id, Name, Amount, StageName, CloseDate \n                            FROM Opportunity WHERE AccountId = :accountId \n                            ORDER BY CloseDate DESC LIMIT 1000];\n        } else {\n            account = new Account();\n            contacts = new List<Contact>();\n            opportunities = new List<Opportunity>();\n        }\n        \n        // BAD: Initializing view state\n        viewState = 'initialized';\n    }\n    \n    // GOOD: Action method with proper structure\n    public PageReference save() {\n        try {\n            // BAD: No FLS check\n            upsert account;\n            \n            // GOOD: Success message\n            ApexPages.addMessage(new ApexPages.Message(\n                ApexPages.Severity.CONFIRM, \n                'Account saved successfully.'\n            ));\n            \n            // Refresh data\n            refreshData();\n            \n        } catch(DmlException e) {\n            // BAD: Generic error handling\n            ApexPages.addMessage(new ApexPages.Message(\n                ApexPages.Severity.ERROR, \n                'Error saving account: ' + e.getMessage()\n            ));\n        }\n        \n        return null;\n    }\n    \n    // GOOD: Simple cancel action\n    public PageReference cancel() {\n        return new PageReference('/' + (account.Id != null ? account.Id : '001'));\n    }\n    \n    // BAD: Action method doing multiple things\n    public PageReference deleteContact() {\n        if(String.isNotBlank(selectedContactId)) {\n            try {\n                // BAD: Query in action method\n                Contact toDelete = [SELECT Id FROM Contact WHERE Id = :selectedContactId LIMIT 1];\n                \n                // BAD: No sharing check\n                delete toDelete;\n                \n                ApexPages.addMessage(new ApexPages.Message(\n                    ApexPages.Severity.CONFIRM, \n                    'Contact deleted successfully.'\n                ));\n                \n                // Refresh contacts\n                contacts = [SELECT Id, Name, Email, Phone, Title, AccountId \n                           FROM Contact WHERE AccountId = :account.Id \n                           ORDER BY Name LIMIT 1000];\n                \n            } catch(Exception e) {\n                ApexPages.addMessage(new ApexPages.Message(\n                    ApexPages.Severity.ERROR, \n                    'Error deleting contact: ' + e.getMessage()\n                ));\n            }\n        }\n        \n        return null;\n    }\n    \n    // GOOD: Separate method for data refresh\n    private void refreshData() {\n        if(account.Id != null) {\n            account = [SELECT Id, Name, Industry, AnnualRevenue, Rating, Type, OwnerId \n                      FROM Account WHERE Id = :account.Id LIMIT 1];\n            \n            contacts = [SELECT Id, Name, Email, Phone, Title, AccountId \n                       FROM Contact WHERE AccountId = :account.Id \n                       ORDER BY Name LIMIT 1000];\n            \n            opportunities = [SELECT Id, Name, Amount, StageName, CloseDate \n                            FROM Opportunity WHERE AccountId = :account.Id \n                            ORDER BY CloseDate DESC LIMIT 1000];\n        }\n    }\n    \n    // BAD: Action methods that should be @future or queueable\n    public PageReference createTask() {\n        Task newTask = new Task(\n            WhatId = account.Id,\n            Subject = 'Follow up on account',\n            Status = 'Not Started',\n            Priority = 'Normal'\n        );\n        \n        // BAD: DML in UI action\n        insert newTask;\n        \n        ApexPages.addMessage(new ApexPages.Message(\n            ApexPages.Severity.INFO, \n            'Task created successfully.'\n        ));\n        \n        return null;\n    }\n    \n    public PageReference sendEmail() {\n        // BAD: Complex logic in UI controller\n        List<Messaging.SingleEmailMessage> emails = new List<Messaging.SingleEmailMessage>();\n        \n        for(Contact con : contacts) {\n            if(String.isNotBlank(con.Email)) {\n                Messaging.SingleEmailMessage email = new Messaging.SingleEmailMessage();\n                email.setToAddresses(new String[]{con.Email});\n                email.setSubject('Update on ' + account.Name);\n                email.setPlainTextBody('Hello ' + con.Name + ',\\\\n\\\\nThis is an update regarding ' + account.Name + '.');\n                emails.add(email);\n            }\n        }\n        \n        if(!emails.isEmpty()) {\n            try {\n                Messaging.sendEmail(emails);\n                ApexPages.addMessage(new ApexPages.Message(\n                    ApexPages.Severity.CONFIRM, \n                    'Emails sent to ' + emails.size() + ' contacts.'\n                ));\n            } catch(Exception e) {\n                ApexPages.addMessage(new ApexPages.Message(\n                    ApexPages.Severity.ERROR, \n                    'Error sending emails: ' + e.getMessage()\n                ));\n            }\n        }\n        \n        return null;\n    }\n    \n    public PageReference generateReport() {\n        // Placeholder for report generation\n        ApexPages.addMessage(new ApexPages.Message(\n            ApexPages.Severity.INFO, \n            'Report generation would be implemented here.'\n        ));\n        \n        return null;\n    }\n    \n    // GOOD: Chart data provider\n    public List<ChartData> getChartData() {\n        List<ChartData> data = new List<ChartData>();\n        \n        data.add(new ChartData('Contacts', contactCount));\n        data.add(new ChartData('Opportunities', opportunityCount));\n        data.add(new ChartData('Open Tasks', 5)); // Hardcoded for demo\n        \n        return data;\n    }\n    \n    // GOOD: Wrapper class for chart data\n    public class ChartData {\n        public String label { get; set; }\n        public Integer value { get; set; }\n        \n        public ChartData(String label, Integer value) {\n            this.label = label;\n            this.value = value;\n        }\n    }\n}"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":83,"output":1668,"cacheRead":23808,"cacheWrite":0,"totalTokens":25559,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101230038}}
