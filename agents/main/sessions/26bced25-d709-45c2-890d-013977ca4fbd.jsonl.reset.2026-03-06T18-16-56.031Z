{"type":"message","id":"64c7c264","parentId":"2eb7c5db","timestamp":"2026-03-06T15:49:51.736Z","message":{"role":"toolResult","toolCallId":"call_00_ABFUXcnFcyVrElxhv4P85BlJ","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\ncommon.py – Shared utilities for error-learning-loop scripts.\nIncludes parsing, deduplication, incident emission, and index generation.\n\"\"\"\n\nimport re\nimport sys\nfrom pathlib import Path\nfrom datetime import datetime\nfrom collections import defaultdict\n\n# Fixed domain sections (in order)\nDOMAIN_SECTIONS = [\n    \"tools\",\n    \"requirements\",\n    \"planning\",\n    \"multi-agent\",\n    \"validation\",\n    \"other\"\n]\n\ndef classify_domain(pattern_key):\n    \"\"\"Map Pattern‑Key's first segment to a fixed domain section.\"\"\"\n    if '|' not in pattern_key:\n        return \"other\"\n    first = pattern_key.split('|')[0].strip().lower()\n    # Direct mapping for known domains\n    if first == \"validation\":\n        return \"validation\"\n    if first == \"multi_agent\":\n        return \"multi-agent\"\n    if first in (\"model\", \"tool\", \"tools\", \"exec\", \"browser\", \"web\", \"tts\", \"image\", \"pdf\"):\n        return \"tools\"\n    if first in (\"requirement\", \"requirements\", \"spec\", \"specification\"):\n        return \"requirements\"\n    if first in (\"plan\", \"planning\", \"strategy\", \"design\"):\n        return \"planning\"\n    return \"other\"\n\ndef generate_tags(pattern_key, learning_entry):\n    \"\"\"Produce 3–6 contextual tags from Pattern‑Key, focused on tool/domain/action.\"\"\"\n    parts = [p.strip() for p in pattern_key.split('|') if p.strip()]\n    tags = set()\n    \n    # Helper to split snake_case into words and add meaningful ones\n    def add_meaningful(text, exclude_generic=True):\n        words = text.lower().split('_')\n        generic = {\"error\", \"failure\", \"handoff\", \"missing\", \"required\", \"content\", \n                   \"field\", \"report\", \"contract\", \"enforced\", \"excessive\", \"workload\",\n\n[513 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1772812191726}}
