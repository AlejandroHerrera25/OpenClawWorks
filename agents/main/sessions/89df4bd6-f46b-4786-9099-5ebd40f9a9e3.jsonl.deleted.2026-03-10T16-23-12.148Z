{"type":"message","id":"2336b0ce","parentId":"d513fd06","timestamp":"2026-03-10T01:24:22.109Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create the fix. I'll modify the `_generate_action_instructions` method to handle complex task patterns:"},{"type":"toolCall","id":"call_00_eW81zoKVSncjWwKdzcnehYTX","name":"edit","arguments":{"path":"~/.openclaw/workspace/skills/long-prompt-orchestrator/scripts/plan_generator.py","oldText":"    def _generate_action_instructions(self, task_data: Dict[str, Any], action_type: str) -> str:\n        \"\"\"Generate executable instructions based on action type.\"\"\"\n        objective = task_data.get('objective', '')\n        description = task_data.get('description', '')\n        outputs = task_data.get('outputs', [])\n        \n        if action_type == \"exec\":\n            # Convert objective to shell command\n            obj_lower = objective.lower()\n            if \"list\" in obj_lower or \"inventory\" in obj_lower:\n                if \"skill\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace/skills -type f -name 'SKILL.md' -exec basename {} \\\\; | sort\"\n                elif \"file\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace -type f -name '*.md' -o -name '*.py' | head -20\"\n                else:\n                    return \"ls -la /home/openclaw/.openclaw/workspace | head -20\"\n            elif \"search\" in obj_lower or \"find\" in obj_lower:\n                # Extract search terms from objective\n                import re\n                terms = re.findall(r'\\\"([^\\\"]+)\\\"|\\'([^\\']+)\\'|for\\s+([a-zA-Z0-9_]+)', objective)\n                search_terms = [term for group in terms for term in group if term]\n                if search_terms:\n                    term = search_terms[0]\n                    return f\"grep -r '{term}' /home/openclaw/.openclaw/workspace --include='*.md' --include='*.py' | head -10\"\n                else:\n                    return \"grep -r 'TODO\\\\|FIXME' /home/openclaw/.openclaw/workspace --include='*.py' --include='*.md' | head -10\"\n            elif \"count\" in obj_lower or \"measure\" in obj_lower:\n                if \"line\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace -type f -name '*.py' -exec wc -l {} \\\\; | tail -1\"\n                elif \"file\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace -type f | wc -l\"\n                else:\n                    return \"find /home/openclaw/.openclaw/workspace -type f -name '*.py' | wc -l\"\n            elif \"check\" in obj_lower or \"verify\" in obj_lower:\n                return \"python3 -m py_compile /home/openclaw/.openclaw/workspace/skills/*/scripts/*.py 2>&1 | head -10\"\n            else:\n                # Generic command based on objective\n                return f\"# Execute: {objective[:80]}\\necho 'Starting task: {objective[:80]}...'\\ndate\"","newText":"    def _generate_action_instructions(self, task_data: Dict[str, Any], action_type: str) -> str:\n        \"\"\"Generate executable instructions based on action type.\"\"\"\n        objective = task_data.get('objective', '')\n        description = task_data.get('description', '')\n        outputs = task_data.get('outputs', [])\n        \n        if action_type == \"exec\":\n            # Convert objective to shell command\n            obj_lower = objective.lower()\n            \n            # Check for complex task patterns first\n            complex_pattern_result = self._handle_complex_task_patterns(objective, obj_lower, outputs)\n            if complex_pattern_result:\n                return complex_pattern_result\n            \n            # Original simple patterns\n            if \"list\" in obj_lower or \"inventory\" in obj_lower:\n                if \"skill\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace/skills -type f -name 'SKILL.md' -exec basename {} \\\\; | sort\"\n                elif \"file\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace -type f -name '*.md' -o -name '*.py' | head -20\"\n                else:\n                    return \"ls -la /home/openclaw/.openclaw/workspace | head -20\"\n            elif \"search\" in obj_lower or \"find\" in obj_lower:\n                # Extract search terms from objective\n                import re\n                terms = re.findall(r'\\\"([^\\\"]+)\\\"|\\'([^\\']+)\\'|for\\s+([a-zA-Z0-9_]+)', objective)\n                search_terms = [term for group in terms for term in group if term]\n                if search_terms:\n                    term = search_terms[0]\n                    return f\"grep -r '{term}' /home/openclaw/.openclaw/workspace --include='*.md' --include='*.py' | head -10\"\n                else:\n                    return \"grep -r 'TODO\\\\|FIXME' /home/openclaw/.openclaw/workspace --include='*.py' --include='*.md' | head -10\"\n            elif \"count\" in obj_lower or \"measure\" in obj_lower:\n                if \"line\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace -type f -name '*.py' -exec wc -l {} \\\\; | tail -1\"\n                elif \"file\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace -type f | wc -l\"\n                else:\n                    return \"find /home/openclaw/.openclaw/workspace -type f -name '*.py' | wc -l\"\n            elif \"check\" in obj_lower or \"verify\" in obj_lower:\n                return \"python3 -m py_compile /home/openclaw/.openclaw/workspace/skills/*/scripts/*.py 2>&1 | head -10\"\n            else:\n                # For truly generic tasks, provide specific guidance instead of echo\n                return self._generate_specific_guidance(objective, description, outputs)"}}],"api":"openai-completions","provider":"custom-api-deepseek-c