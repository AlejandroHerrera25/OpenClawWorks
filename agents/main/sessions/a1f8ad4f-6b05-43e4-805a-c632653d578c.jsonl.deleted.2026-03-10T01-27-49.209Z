{"type":"message","id":"196a752b","parentId":"a2a17c43","timestamp":"2026-03-10T00:28:05.080Z","message":{"role":"toolResult","toolCallId":"call_00_8G2Z2p2VnLfQvWwemyHESfLZ","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nPlan Generator for long-prompt-orchestrator skill.\nGenerates structured plans for main agent execution.\nReplaces incorrect spawning code with proper planning interface.\n\"\"\"\n\nimport json\nimport os\nimport uuid\nimport time\nfrom typing import Dict, List, Any, Optional, Tuple\nfrom dataclasses import dataclass, asdict\nfrom enum import Enum\n\nWORKSPACE = os.path.expanduser(\"~/.openclaw/workspace\")\n\nclass TaskPriority(Enum):\n    LOW = \"low\"\n    MEDIUM = \"medium\"\n    HIGH = \"high\"\n    CRITICAL = \"critical\"\n\n@dataclass\nclass PlanTask:\n    \"\"\"Task representation in a plan.\"\"\"\n    task_id: str\n    objective: str\n    description: str\n    execution_mode: str  # \"main\" | \"subagent\" | \"mixed\"\n    action_type: str  # \"exec\" | \"python\" | \"skill_invocation\" | \"file_operation\"\n    action_instructions: str  # Specific, executable instructions\n    required_inputs: List[str]\n    expected_outputs: List[str]\n    dependencies: List[str]\n    validation_method: str  # How to validate task completion\n    estimated_tokens: int\n    estimated_runtime_seconds: int\n    complexity_score: int\n    recommended_skill_or_role: Optional[str]  # Which skill/sub-agent should handle this\n    artifact_destination: Optional[str]  # Where to store outputs\n    priority: TaskPriority = TaskPriority.MEDIUM\n    execution_hints: Optional[Dict[str, Any]] = None\n    \n    def to_dict(self) -> Dict[str, Any]:\n        \"\"\"Convert to dictionary for JSON serialization.\"\"\"\n        data = asdict(self)\n        data['priority'] = self.priority.value\n        if self.execution_hints is None:\n            data['execution_hints'] = self._default_execution_hints()\n        return data\n    \n    def _default_execution_hints(self) -> Dict[str, Any]:\n        \"\"\"Generate default execution hints based on task properties.\"\"\"\n        return {\n            \"parallelizable\": len(self.dependencies) == 0,\n            \"requires_isolation\": self.complexity_score >= 7,\n            \"risk_level\": \"high\" if self.complexity_score >= 7 else \"medium\" if self.complexity_score >= 4 else \"low\",\n            \"retry_policy\": \"exponential_backoff_3\" if self.complexity_score >= 5 else \"immediate_2\"\n        }\n\nclass PlanGenerator:\n    \"\"\"Generates structured plans for main agent execution.\"\"\"\n    \n    def __init__(self, original_prompt: str):\n        self.original_prompt = original_prompt\n        self.plan_id = f\"plan_{int(time.time())}_{uuid.uuid4().hex[:8]}\"\n        self.tasks: List[PlanTask] = []\n        self.created_at = time.strftime(\"%Y-%m-%dT%H:%M:%SZ\", time.gmtime())\n    \n    def add_task(self, task_data: Dict[str, Any]) -> str:\n        \"\"\"Add a task to the plan.\"\"\"\n        # Generate task_id if not provided\n        task_id = task_data.get('id', f\"task_{len(self.tasks)+1:02d}\")\n        \n        # Determine execution mode based on complexity and requirements\n        execution_mode = self._determine_execution_mode(task_data)\n        \n        # Determine action type based on task content\n        action_type = self._determine_action_type(task_data)\n        \n        # Generate executable instructions\n        action_instructions = self._generate_action_instructions(task_data, action_type)\n        \n        # Generate validation method\n        validation_method = self._generate_validation_method(task_data)\n        \n        # Determine artifact destination\n        artifact_destination = self._determine_artifact_destination(task_data, task_id)\n        \n        # Create PlanTask object\n        task = PlanTask(\n            task_id=task_id,\n            objective=task_data.get('objective', ''),\n            description=task_data.get('description', task_data.get('objective', '')),\n            execution_mode=execution_mode,\n            action_type=action_type,\n            action_instructions=action_instructions,\n            required_inputs=task_data.get('inputs', []),\n            expected_outputs=task_data.get('outputs', []),\n            dependencies=task_data.get('dependencies', []),\n            validation_method=validation_method,\n            estimated_tokens=task_data.get('estimated_tokens', 1000),\n            estimated_runtime_seconds=task_data.get('estimated_runtime', 60),\n            complexity_score=task_data.get('complexity_score', 0),\n            recommended_skill_or_role=self._recommend_skill_or_role(task_data),\n            artifact_destination=artifact_destination,\n            priority=self._determine_priority(task_data)\n        )\n        \n        self.tasks.append(task)\n        return task_id\n    \n    def _should_require_subagent(self, task_data: Dict[str, Any]) -> bool:\n        \"\"\"Determine if task requires sub-agent.\"\"\"\n        # Always require subagent if explicitly specified\n        if task_data.get('subagent_required', False):\n            return True\n        \n        # Require subagent for complex tasks\n        complexity_score = task_data.get('complexity_score', 0)\n        if complexity_score >= 5:\n            return True\n        \n        # Require subagent for specialized tasks\n        if self._recommend_skill_or_role(task_data) is not None:\n            return True\n        \n        # Require subagent for long-running tasks\n        estimated_runtime = task_data.get('estimated_runtime', 0)\n        if estimated_runtime > 300:  # 5 minutes\n            return True\n        \n        return False\n    \n\n    \n    def _determine_priority(self, task_data: Dict[str, Any]) -> TaskPriority:\n        \"\"\"Determine task priority.\"\"\"\n        complexity_score = task_data.get('complexity_score', 0)\n        \n        if complexity_score >= 8:\n            return TaskPriority.CRITICAL\n        elif complexity_score >= 5:\n            return TaskPriority.HIGH\n        elif complexity_score >= 3:\n            return TaskPriority.MEDIUM\n        else:\n            return TaskPriority.LOW\n    \n\n[488 more lines in file. Use offset=151 to continue.]"}],"isError":false,"timestamp":1773102485074}}
{"type":"message","id":"a567a29d","parentId":"196a752b","timestamp":"2026-03-10T00:28:56.101Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me run a test to see if the LPO generates executable plans. First, let me create a simple test script:"},{"type":"toolCall","id":"call_00_c1zW7YHrkVxQbFXqsCCM5cYr","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/test_lpo_executable.py","content":"#!/usr/bin/env python3\n\"\"\"\nTest script to validate LPO generates executable plans.\n\"\"\"\n\nimport sys\nimport os\nimport json\n\n# Add skill scripts directory to path\nsys.path.insert(0, '/home/openclaw/.openclaw/workspace/skills/long-prompt-orchestrator/scripts')\n\nfrom plan_generator import PlanGenerator\n\ndef test_basic_plan():\n    \"\"\"Test generating a basic executable plan.\"\"\"\n    print(\"=== Test 1: Basic Plan Generation ===\")\n    \n    # Create a plan generator\n    prompt = \"Inventory workspace skills\"\n    generator = PlanGenerator(prompt)\n    \n    # Add a simple task\n    task_data = {\n        'id': 'task_01',\n        'objective': 'Inventory all skills in workspace',\n        'description': 'List all available skills with their status and dependencies',\n        'inputs': [],\n        'outputs': ['list of SKILL.md files'],\n        'dependencies': [],\n        'estimated_tokens': 800,\n        'estimated_runtime': 60,\n        'complexity_score': 3\n    }\n    \n    task_id = generator.add_task(task_data)\n    \n    # Generate the plan\n    plan = generator.generate_plan()\n    \n    # Check if plan has executable fields\n    print(f\"Plan ID: {plan.get('plan_id')}\")\n    print(f\"Number of tasks: {len(plan.get('tasks', []))}\")\n    \n    if plan.get('tasks'):\n        task = plan['tasks'][0]\n        print(f\"\\nTask fields:\")\n        print(f\"  execution_mode: {task.get('execution_mode')}\")\n        print(f\"  action_type: {task.get('action_type')}\")\n        print(f\"  action_instructions: {task.get('action_instructions')[:100]}...\")\n        print(f\"  validation_method: {task.get('validation_method')}\")\n        print(f\"  artifact_destination: {task.get('artifact_destination')}\")\n        \n        # Check if all required fields are present\n        required_fields = ['execution_mode', 'action_type', 'action_instructions', 'validation_method']\n        missing = [field for field in required_fields if not task.get(field)]\n        \n        if missing:\n            print(f\"\\n❌ Missing required fields: {missing}\")\n            return False\n        else:\n            print(\"\\n✅ All required executable fields present\")\n            return True\n    \n    return False\n\ndef test_mixed_plan():\n    \"\"\"Test generating a plan with mixed execution modes.\"\"\"\n    print(\"\\n=== Test 2: Mixed Execution Plan ===\")\n    \n    prompt = \"Analyze workspace and research AI trends\"\n    generator = PlanGenerator(prompt)\n    \n    # Add main task\n    main_task = {\n        'id': 'task_01',\n        'objective': 'Inventory workspace skills',\n        'description': 'List all skills in workspace',\n        'inputs': [],\n        'outputs': ['skills_list.txt'],\n        'dependencies': [],\n        'estimated_tokens': 800,\n        'estimated_runtime': 60,\n        'complexity_score': 3\n    }\n    \n    # Add subagent task\n    subagent_task = {\n        'id': 'task_02',\n        'objective': 'Research AI trends',\n        'description': 'Research latest AI developments using web search',\n        'inputs': [],\n        'outputs': ['research_report.md'],\n        'dependencies': ['task_01'],\n        'estimated_tokens': 1500,\n        'estimated_runtime': 120,\n        'complexity_score': 6,\n        'subagent_required': True\n    }\n    \n    generator.add_task(main_task)\n    generator.add_task(subagent_task)\n    \n    plan = generator.generate_plan()\n    \n    print(f\"Plan has {len(plan.get('tasks', []))} tasks\")\n    \n    execution_modes = []\n    for task in plan.get('tasks', []):\n        execution_modes.append(task.get('execution_mode'))\n        print(f\"  Task {task.get('task_id')}: {task.get('execution_mode')} - {task.get('action_type')}\")\n    \n    if 'main' in execution_modes and 'subagent' in execution_modes:\n        print(\"✅ Mixed execution modes present\")\n        return True\n    else:\n        print(f\"❌ Missing mixed execution modes. Found: {execution_modes}\")\n        return False\n\ndef test_complex_orchestration():\n    \"\"\"Test generating a complex orchestration plan.\"\"\"\n    print(\"\\n=== Test 3: Complex Orchestration Plan ===\")\n    \n    prompt = \"Audit workspace skills and generate documentation\"\n    generator = PlanGenerator(prompt)\n    \n    tasks = [\n        {\n            'id': 'task_01',\n            'objective': 'Inventory skills',\n            'description': 'List all skills',\n            'inputs': [],\n            'outputs': ['inventory.json'],\n            'dependencies': [],\n            'estimated_tokens': 800,\n            'estimated_runtime': 60,\n            'complexity_score': 3\n        },\n        {\n            'id': 'task_02',\n            'objective': 'Validate skill functionality',\n            'description': 'Test each skill to ensure it works',\n            'inputs': ['inventory.json'],\n            'outputs': ['validation_report.md'],\n            'dependencies': ['task_01'],\n            'estimated_tokens': 2000,\n            'estimated_runtime': 300,\n            'complexity_score': 7,\n            'subagent_required': True\n        },\n        {\n            'id': 'task_03',\n            'objective': 'Generate documentation',\n            'description': 'Create comprehensive documentation for all skills',\n            'inputs': ['inventory.json', 'validation_report.md'],\n            'outputs': ['documentation/'],\n            'dependencies': ['task_02'],\n            'estimated_tokens': 2500,\n            'estimated_runtime': 180,\n            'complexity_score': 5\n        }\n    ]\n    \n    for task in tasks:\n        generator.add_task(task)\n    \n    plan = generator.generate_plan()\n    \n    print(f\"Plan has {len(plan.get('tasks', []))} tasks\")\n    print(f\"Dependency graph: {plan.get('dependency_graph', {}).get('edges', [])}\")\n    \n    # Check if tasks have dependencies\n    has_dependencies = False\n    for task in plan.get('tasks', []):\n        if task.get('dependencies'):\n            has_dependencies = True\n            print(f\"  Task {task.get('task_id')} depends on: {task.get('dependencies')}\")\n    \n    if has_dependencies:\n        print(\"✅ Dependency management present\")\n        return True\n    else:\n        print(\"❌ No dependencies found\")\n        return False\n\ndef main():\n    \"\"\"Run all tests.\"\"\"\n    print(\"Testing LPO Executable Plan Generation\")\n    print(\"=\" * 50)\n    \n    results = []\n    \n    # Test 1\n    results.append((\"Basic Plan\", test_basic_plan()))\n    \n    # Test 2\n    results.append((\"Mixed Execution\", test_mixed_plan()))\n    \n    # Test 3\n    results.append((\"Complex Orchestration\", test_complex_orchestration()))\n    \n    # Summary\n    print(\"\\n\" + \"=\" * 50)\n    print(\"TEST SUMMARY:\")\n    \n    all_passed = True\n    for test_name, passed in results:\n        status = \"✅ PASS\" if passed else \"❌ FAIL\"\n        print(f\"  {test_name}: {status}\")\n        if not passed:\n            all_passed = False\n    \n    if all_passed:\n        print(\"\\n🎉 All tests passed! LPO generates executable plans.\")\n    else:\n        print(\"\\n⚠ Some tests failed. LPO may not generate fully executable plans.\")\n    \n    return all_passed\n\nif __name__ == \"__main__\":\n    success = main()\n    sys.exit(0 if success else 1)"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":1364,"output":1783,"cacheRead":19328,"cacheWrite":0,"totalTokens":22475,"cost":{