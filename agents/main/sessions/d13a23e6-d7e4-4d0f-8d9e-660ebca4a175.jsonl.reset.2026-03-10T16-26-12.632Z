{"type":"message","id":"38d018bb","parentId":"c0af034e","timestamp":"2026-03-10T02:08:56.155Z","message":{"role":"assistant","content":[{"type":"text","text":"## 🎯 **CONTINUANDO CON FIX COMPLETO DE AGENT-WATCHDOG**\n\n### **Paso 1: Crear script de monitoring REAL simplificado**"},{"type":"toolCall","id":"call_00_uFmi9TL2uNizXss7PCGl5bLp","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/agent-watchdog/scripts/watchdog_monitor_real_simple.py","content":"#!/usr/bin/env python3\n\"\"\"\nREAL OpenClaw Session Monitor - Simple Version\nReads REAL OpenClaw sessions from sessions.json file.\n\"\"\"\n\nimport os\nimport json\nimport time\nimport logging\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nimport sys\n\n# Configuration\nWATCHDOG_DIR = Path.home() / \".openclaw\" / \"workspace\" / \".watchdog\"\nSESSIONS_FILE = Path.home() / \".openclaw\" / \"agents\" / \"main\" / \"sessions\" / \"sessions.json\"\nSESSION_REGISTRY = WATCHDOG_DIR / \"session_registry.json\"\nMONITORING_LOG = WATCHDOG_DIR / \"monitoring.log\"\nALERTS_FILE = WATCHDOG_DIR / \"alerts.json\"\n\n# Ensure watchdog directory exists\nWATCHDOG_DIR.mkdir(parents=True, exist_ok=True)\n\n# Setup logging\nlogging.basicConfig(\n    level=logging.INFO,\n    format='[%(asctime)s] [%(levelname)s] %(message)s',\n    handlers=[\n        logging.FileHandler(MONITORING_LOG, mode='a'),\n        logging.StreamHandler(sys.stdout)\n    ]\n)\nlogger = logging.getLogger(__name__)\n\nclass RealSessionMonitor:\n    \"\"\"Monitor REAL OpenClaw sessions from sessions.json\"\"\"\n    \n    def __init__(self):\n        self.sessions = self.load_sessions()\n        self.stall_threshold = 300  # 5 minutes in seconds\n        \n    def load_sessions(self):\n        \"\"\"Load existing session registry\"\"\"\n        if SESSION_REGISTRY.exists():\n            try:\n                with open(SESSION_REGISTRY, 'r') as f:\n                    return json.load(f)\n            except (json.JSONDecodeError, IOError):\n                return {\"sessions\": [], \"last_updated\": None}\n        return {\"sessions\": [], \"last_updated\": None}\n    \n    def save_sessions(self):\n        \"\"\"Save session registry\"\"\"\n        self.sessions[\"last_updated\"] = datetime.now(timezone.utc).isoformat()\n        with open(SESSION_REGISTRY, 'w') as f:\n            json.dump(self.sessions, f, indent=2)\n    \n    def get_openclaw_sessions(self):\n        \"\"\"Get REAL OpenClaw sessions from sessions.json file\"\"\"\n        sessions = []\n        \n        if not SESSIONS_FILE.exists():\n            logger.warning(f\"Sessions file not found: {SESSIONS_FILE}\")\n            return sessions\n        \n        try:\n            with open(SESSIONS_FILE, 'r') as f:\n                sessions_data = json.load(f)\n            \n            now = datetime.now(timezone.utc)\n            \n            for session_key, session_info in sessions_data.items():\n                # Skip if not a session object\n                if not isinstance(session_info, dict):\n                    continue\n                \n                # Extract session info\n                session_id = session_info.get(\"sessionId\", \"unknown\")\n                updated_at = session_info.get(\"updatedAt\")\n                label = session_info.get(\"label\", \"Unnamed session\")\n                \n                # Determine session type\n                if \"subagent\" in session_key:\n                    session_type = \"subagent\"\n                elif \"main\" in session_key:\n                    session_type = \"main\"\n                else:\n                    session_type = \"other\"\n                \n                # Calculate age\n                age_seconds = None\n                if updated_at:\n                    # updatedAt is in milliseconds\n                    updated_time = datetime.fromtimestamp(updated_at / 1000, timezone.utc)\n                    age_seconds = (now - updated_time).total_seconds()\n                \n                # Determine status\n                status = \"active\"\n                if age_seconds and age_seconds > self.stall_threshold:\n                    status = \"stalled\"\n                \n                session_obj = {\n                    \"session_id\": session_id,\n                    \"session_key\": session_key,\n                    \"agent_id\": session_type,\n                    \"created_at\": datetime.fromtimestamp(updated_at / 1000, timezone.utc).isoformat() if updated_at else now.isoformat(),\n                    \"last_activity\": datetime.fromtimestamp(updated_at / 1000, timezone.utc).isoformat() if updated_at else now.isoformat(),\n                    \"updated_at_ms\": updated_at,\n                    \"age_seconds\": age_seconds,\n                    \"status\": status,\n                    \"source\": \"openclaw_sessions_json\",\n                    \"description\": f\"{session_type}: {label}\",\n                    \"label\": label\n                }\n                \n                sessions.append(session_obj)\n                logger.debug(f\"Found session: {session_key} ({status}, age: {age_seconds:.1f}s)\")\n            \n            logger.info(f\"Loaded {len(sessions)} sessions from {SESSIONS_FILE}\")\n            \n        except (json.JSONDecodeError, IOError, KeyError) as e:\n            logger.error(f\"Error reading sessions file: {e}\")\n        \n        return sessions\n    \n    def update_session_activity(self, session_id, activity=\"heartbeat\"):\n        \"\"\"Update last activity for a session\"\"\"\n        for session in self.sessions.get(\"sessions\", []):\n            if session[\"session_id\"] == session_id:\n                session[\"last_activity\"] = datetime.now(timezone.utc).isoformat()\n                session[\"last_activity_type\"] = activity\n                logger.info(f\"Updated activity for session {session_id}: {activity}\")\n                return True\n        return False\n    \n    def check_for_stalls(self):\n        \"\"\"Check for stalled sessions\"\"\"\n        stalls = []\n        now = datetime.now(timezone.utc)\n        \n        for session in self.sessions.get(\"sessions\", []):\n            if \"last_activity\" in session:\n                try:\n                    last_activity = datetime.fromisoformat(session[\"last_activity\"].replace('Z', '+00:00'))\n                    time_diff = (now - last_activity).total_seconds()\n                    \n                    if time_diff > self.stall_threshold and session[\"status\"] == \"active\":\n                        stalls.append({\n                            \"session_id\": session[\"session_id\"],\n                            \"session_key\": session[\"session_key\"],\n                            \"stall_duration\": time_diff,\n                            \"last_activity\": session[\"last_activity\"],\n                            \"description\": session.get(\"description\", \"Unknown session\")\n                        })\n                        session[\"status\"] = \"stalled\"\n                except (ValueError, KeyError) as e:\n                    logger.warning(f\"Error parsing date for session {session.get('session_id')}: {e}\")\n        \n        return stalls\n    \n    def generate_alert(self, stall_info):\n        \"\"\"Generate alert for stalled session\"\"\"\n        alert = {\n            \"alert_id\": f\"stall_{stall_info['session_id']}_{int(time.time())}\",\n            \"type\": \"session_stall\",\n            \"severity\": \"high\",\n            \"session_id\": stall_info[\"session_id\"],\n            \"session_key\": stall_info[\"session_key\"],\n            \"stall_duration\": stall_info[\"stall_duration\"],\n            \"detected_at\": datetime.now(timezone.utc).isoformat(),\n            \"description\": f\"Session stalled for {stall_info['stall_duration']:.1f} seconds: {stall_info['description']}\",\n            \"action_required\": \"Investigate session stall\"\n        }\n        \n        # Load existing alerts\n        alerts = []\n        if ALERTS_FILE.exists():\n            try:\n                with open(ALERTS_FILE, 'r') as f:\n                    alerts = json.load(f)\n            except (json.JSONDecodeError, IOError):\n                alerts = []\n        \n        # Add new alert\n        alerts.append(alert)\n        \n        # Save alerts (keep last 100)\n        if len(alerts) > 100:\n            alerts = alerts[-100:]\n        \n        with open(ALERTS_FILE, 'w') as f:\n            json.dump(alerts, f, indent=2)\n        \n        logger.warning(f\"ALERT: {alert['description']}\")\n        return alert\n    \n    def run_monitoring_cycle(self):\n        \"\"\"Run one monitoring cycle\"\"\"\n        logger.info(\"=== Starting REAL monitoring cycle ===\")\n        \n        # Get current sessions from OpenClaw\n        current_sessions = self.get_openclaw_sessions()\n        \n        # Update registry\n        existing_ids = {s[\"session_id\"] for s in self.sessions.get(\"sessions\", [])}\n        \n        new_sessions = 0\n        for session in current_sessions:\n            if session[\"session_id\"] not in existing_ids:\n                self.sessions.setdefault(\"sessions\", []).append(session)\n                new_sessions += 1\n                logger.info(f\"📝 Registered NEW session: {session['session_key']} - {session['description']}\")\n        \n        # Check for stalls\n        stalls = self.check_for_stalls()\n        \n        for stall in stalls:\n            self.generate_alert(stall)\n        \n        # Save updated registry\n        self.save_sessions()\n        \n        # Log summary\n        active_count = sum(1 for s in self.sessions.get(\"sessions\", []) if s.get(\"status\") == \"active\")\n        stalled_count = sum(1 for s in self.sessions.get(\"sessions\", []) if s.get(\"status\") == \"stalled\")\n        \n        logger.info(f\"📊 Monitoring cycle complete:\")\n        logger.info(f\"   Total sessions: {len(self.sessions.get('sessions', []))}\")\n        logger.info(f\"   Active sessions: {active_count}\")\n        logger.info(f\"   Stalled sessions: {stalled_count}\")\n        logger.info(f\"   New sessions: {new_sessions}\")\n        logger.info(f\"   New stalls: {len(stalls)}\")\n        \n        return {\n            \"total_sessions\": len(self.sessions.get(\"sessions\", [])),\n            \"active_sessions\": active_count,\n            \"stalled_sessions\": stalled_count,\n            \"new_sessions\": new_sessions,\n            \"new_stalls\": len(stalls)\n        }\n\ndef main():\n    \"\"\"Main monitoring loop\"\"\"\n    monitor = RealSessionMonitor()\n    \n    logger.info(\"=\" * 60)\n    logger.info(\"REAL OpenClaw Session Monitor - SIMPLE VERSION\")\n    logger.info(f\"Monitoring sessions from: {SESSIONS_FILE}\")\n    logger.info(f\"Watchdog directory: {WATCHDOG_DIR}\")\n    logger.info(f\"Stall threshold: {monitor.stall_threshold} seconds\")\n    logger.info(\"=\" * 60)\n    \n    try:\n        cycle_count = 0\n        while True:\n            cycle_count += 1\n            logger.info(f\"--- Cycle #{cycle_count} ---\")\n            \n            try:\n                result = monitor.run_monitoring_cycle()\n                logger.debug(f\"Cycle result: {result}\")\n            except Exception as e:\n                logger.error(f\"Error in monitoring cycle: {e}\")\n            \n            # Wait before next cycle\n            logger.info(f\"Waiting 30 seconds before next cycle...\")\n            time.sleep(30)\n            \n    except KeyboardInterrupt:\n        logger.info(\"Monitor stopped by user\")\n    except Exception as e:\n        logger.error(f\"Fatal error: {e}\")\n        raise\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":6435,"output":2497,"cacheRead":78592,"cacheWrite":0,"totalTokens":87524,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773108438283}}
