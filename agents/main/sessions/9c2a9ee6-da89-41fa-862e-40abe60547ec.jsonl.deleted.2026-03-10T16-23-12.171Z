urn False\n\ndef test_subprocess_integration():\n    \"\"\"Test subprocess integration (calling other skill scripts).\"\"\"\n    print(\"Testing subprocess integration...\")\n    \n    # Try to call a simple script\n    test_script = workspace / 'skills' / 'tavily-web-search' / 'scripts' / 'tavily_integrations.py'\n    \n    if not test_script.exists():\n        print(\"⚠ Subprocess test SKIPPED (script not found)\")\n        return None\n    \n    try:\n        result = subprocess.run(\n            [sys.executable, str(test_script), '--help'],\n            capture_output=True,\n            text=True,\n            timeout=10\n        )\n        if result.returncode == 0 or result.returncode == 2:  # 2 is typical for --help\n            print(\"✅ Subprocess integration test PASSED\")\n            return True\n        else:\n            print(f\"❌ Subprocess integration test FAILED: Exit code {result.returncode}\")\n            print(f\"Stderr: {result.stderr[:200]}\")\n            return False\n    except subprocess.TimeoutExpired:\n        print(\"❌ Subprocess integration test TIMEOUT\")\n        return False\n    except Exception as e:\n        print(f\"❌ Subprocess integration test ERROR: {e}\")\n        return False\n\ndef test_module_import_integration():\n    \"\"\"Test module import integration.\"\"\"\n    print(\"Testing module import integration...\")\n    \n    # Try to import from tavily-web-search\n    skill_path = workspace / 'skills' / 'tavily-web-search' / 'scripts'\n    \n    if not skill_path.exists():\n        print(\"⚠ Module import test SKIPPED (skill not found)\")\n        return None\n    \n    original_path = sys.path.copy()\n    sys.path.insert(0, str(skill_path))\n    \n    try:\n        from tavily_integrations import load_config\n        config = load_config()\n        if config:\n            print(\"✅ Module import integration test PASSED\")\n            sys.path = original_path  # Restore path\n            return True\n        else:\n            print(\"❌ Module import integration test FAILED: No config loaded\")\n            sys.path = original_path\n            return False\n    except ImportError as e:\n        print(f\"❌ Module import integration test FAILED: {e}\")\n        sys.path = original_path\n        return False\n    except Exception as e:\n        print(f\"❌ Module import integration test ERROR: {e}\")\n        sys.path = original_path\n        return False\n\ndef test_watchdog_integration():\n    \"\"\"Test watchdog integration pattern.\"\"\"\n    print(\"Testing watchdog integration pattern...\")\n    \n    # Check if watchdog integration module exists\n    watchdog_integration = workspace / 'skills' / 'vector-memory' / 'scripts' / 'watchdog_integration.py'\n    \n    if not watchdog_integration.exists():\n        print(\"⚠ Watchdog integration test SKIPPED (script not found)\")\n        return None\n    \n    try:\n        # Read the file to verify it contains integration code\n        with open(watchdog_integration, 'r') as f:\n            content = f.read()\n        \n        # Check for key integration patterns\n        patterns = [\n            'register_with_watchdog',\n            'WATCHDOG_SCRIPT',\n            'agent-watchdog'\n        ]\n        \n        found_patterns = [p for p in patterns if p in content]\n        \n        if len(found_patterns) >= 2:\n            print(f\"✅ Watchdog integration test PASSED (found patterns: {found_patterns})\")\n            return True\n        else:\n            print(f\"❌ Watchdog integration test FAILED: Missing patterns\")\n            return False\n    except Exception as e:\n        print(f\"❌ Watchdog integration test ERROR: {e}\")\n        return False\n\ndef main():\n    \"\"\"Run all integration tests.\"\"\"\n    print(\"=\" * 60)\n    print(\"OpenClaw Skill Integration Test Suite\")\n    print(\"=\" * 60)\n    \n    results = {\n        \"file_based\": test_file_based_integration(),\n        \"subprocess\": test_subprocess_i