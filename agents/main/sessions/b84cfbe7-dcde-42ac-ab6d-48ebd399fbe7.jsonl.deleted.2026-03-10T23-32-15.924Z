{"type":"message","id":"a9c92f90","parentId":"a55f2cb1","timestamp":"2026-03-09T23:30:37.122Z","message":{"role":"toolResult","toolCallId":"call_00_611PCo5ceut0WAlGmClFPcNf","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"Auto-curate MEMORY.md based on recent daily notes.\"\"\"\nimport argparse, glob, json, os, re, sys, subprocess, datetime, tempfile, textwrap\nfrom pathlib import Path\n\nWORKSPACE = os.path.expanduser(\"~/.openclaw/workspace\")\nMEMORY_PATH = os.path.join(WORKSPACE, \"MEMORY.md\")\nMEMORY_DIR = os.path.join(WORKSPACE, \"memory\")\nPROJECTS_PATH = os.path.join(MEMORY_DIR, \"projects.md\")\nFLUSH_SCRIPT = os.path.join(os.path.dirname(__file__), \"memory_flush.py\")\n\ndef read_file(path):\n    \"\"\"Read file content.\"\"\"\n    if not os.path.exists(path):\n        return \"\"\n    with open(path, 'r') as f:\n        return f.read()\n\ndef write_file(path, content):\n    \"\"\"Write content to file.\"\"\"\n    with open(path, 'w') as f:\n        f.write(content)\n\ndef get_recent_daily_notes(count=7):\n    \"\"\"Get the most recent daily note files.\"\"\"\n    # Get all markdown files in memory directory\n    all_files = glob.glob(os.path.join(MEMORY_DIR, \"*.md\"))\n    \n    # Filter out non-daily files (projects.md, janitor_log.md, etc.)\n    daily_files = []\n    for f in all_files:\n        fname = os.path.basename(f)\n        # Skip known non-daily files\n        if fname in [\"projects.md\", \"janitor_log.md\"]:\n            continue\n        # Skip files with special suffixes\n        if \"-gemini-config.md\" in fname or \"-request-timed-out-\" in fname:\n            continue\n        daily_files.append(f)\n    \n    # Sort by modification time (newest first)\n    daily_files.sort(key=os.path.getmtime, reverse=True)\n    \n    # Return the most recent ones\n    return daily_files[:count]\n\ndef extract_sections_from_memory(memory_content):\n    \"\"\"Extract sections from MEMORY.md.\"\"\"\n    sections = {}\n    lines = memory_content.split('\\n')\n    \n    # First line is the title\n    if lines and lines[0].startswith('# '):\n        title_line = lines[0]\n        # Extract the date if present\n        date_match = re.search(r'\\*\\*Last updated: (.*?)\\*\\*', memory_content)\n        last_updated = date_match.group(1) if date_match else datetime.datetime.now().strftime(\"%Y-%m-%d\")\n        sections[\"MEMORY.md - Curated Long-Term Memory\"] = f\"{title_line}\\n\\n**Last updated: {last_updated}**\"\n    \n    current_section = None\n    current_content = []\n    \n    for line in lines:\n        # Check for section headers (starting with ##)\n        if line.startswith('## '):\n            # Save previous section\n            if current_section:\n                sections[current_section] = '\\n'.join(current_content).strip()\n            \n            # Start new section\n            current_section = line.strip('# ').strip()\n            current_content = [line]\n        elif current_section:\n            current_content.append(line)\n    \n    # Save the last section\n    if current_section:\n        sections[current_section] = '\\n'.join(current_content).strip()\n    \n    return sections\n\ndef analyze_daily_notes(daily_files):\n    \"\"\"Analyze daily notes for significant events and updates.\"\"\"\n    events = []\n    project_updates = {}\n    \n    for filepath in daily_files:\n        content = read_file(filepath)\n        filename = os.path.basename(filepath)\n        \n        # Extract date from filename\n        date_match = re.search(r'(\\d{4}-\\d{2}-\\d{2})', filename)\n        date = date_match.group(1) if date_match else \"unknown\"\n        \n        # Look for significant events\n        lines = content.split('\\n')\n        for line in lines:\n            # Look for milestone markers, decisions, or important notes\n            if any(marker in line.lower() for marker in [\n                'milestone', 'completed', 'finished', 'launched', \n\n[25