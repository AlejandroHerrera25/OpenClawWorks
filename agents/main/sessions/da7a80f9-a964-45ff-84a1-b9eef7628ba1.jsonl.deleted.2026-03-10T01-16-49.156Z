{"type":"message","id":"5c768818","parentId":"afa17462","timestamp":"2026-03-10T00:16:21.736Z","message":{"role":"toolResult","toolCallId":"call_00_X6WbDp33bYjyUbpAqw70x85x","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nBuild dependency graph between classes, methods, triggers, and integrations.\n\"\"\"\n\nimport argparse\nimport os\nimport re\nfrom pathlib import Path\nfrom utils_fs import read_file, write_json, read_json, list_files\n\nWORKSPACE_ROOT = Path(os.getenv('WORKSPACE', '/home/openclaw/.openclaw/workspace'))\n\ndef get_case_root(project_key, case_id):\n    return WORKSPACE_ROOT / 'projects' / project_key / 'code_audit' / case_id\n\ndef extract_apex_class_name(path):\n    \"\"\"Extract class name from file path (stem).\"\"\"\n    return Path(path).stem\n\ndef parse_apex_dependencies(content):\n    \"\"\"\n    Extract class dependencies from Apex code.\n    Returns dict with keys: 'extends', 'implements', 'method_calls', 'soql_objects', 'dml_objects'.\n    \"\"\"\n    deps = {\n        'extends': None,\n        'implements': [],\n        'method_calls': [],  # class.method references\n        'soql_objects': [],\n        'dml_objects': [],\n        'callouts': False\n    }\n    lines = content.split('\\n')\n    class_def = ''\n    for line in lines:\n        # class MyClass extends ParentClass implements Intf1, Intf2\n        if ' class ' in line and (' extends ' in line or ' implements ' in line):\n            class_def = line\n            break\n    if class_def:\n        # extends\n        match = re.search(r'extends\\s+(\\w+)', class_def)\n        if match:\n            deps['extends'] = match.group(1)\n        # implements\n        match = re.search(r'implements\\s+([^{]+)', class_def)\n        if match:\n            impl = match.group(1).strip()\n            deps['implements'] = [i.strip() for i in impl.split(',')]\n\n[161 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1773101781729}}
