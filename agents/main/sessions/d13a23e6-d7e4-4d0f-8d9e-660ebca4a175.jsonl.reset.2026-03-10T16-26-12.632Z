t_evidence',\n+644                 'description': f'Insufficient evidence: {evidence.get(\"evidence_count\", 0)}/{evidence.get(\"minimum_required\", 3)}',\n+645                 'details': ['Add more evidence with proper citations']\n+646             })\n+647         \n+648         # Check handoff completeness\n+649         handoff = validation_details.get('handoff_completeness', {})\n+650         if handoff.get('score', 1.0) < thresholds.get('minimum_handoff_score', 0.8):\n+651             missing = handoff.get('missing_elements', [])\n+652             if missing:\n+653                 issues.append({\n+654                     'severity': 'WARNING',\n+655                     'type': 'incomplete_handoff',\n+656                     'description': f'Handoff incomplete: missing {len(missing)} elements',\n+657                     'details': missing[:5]\n+658                 })\n+659         \n+660         # Add warnings for near-threshold scores\n+661         for component, details in validation_details.items():\n+662             score = details.get('score', 1.0)\n+663             if thresholds.get('warning_threshold', 0.9) > score >= thresholds.get('blocking_threshold', 0.8):\n+664                 issues.append({\n+665                     'severity': 'WARNING',\n+666                     'type': f'{component}_needs_improvement',\n+667                     'description': f'{component.replace(\"_\", \" \").title()} could be improved',\n+668                     'details': [f'Current score: {score:.2f}, target: {thresholds.get(\"warning_threshold\", 0.9):.2f}']\n+669                 })\n+670         \n+671         return issues\n+672     \n+673     def _generate_recommendations(self, validation_details: Dict) -> List[str]:\n+674         \"\"\"Generate recommendations for improvement.\"\"\"\n+675         recommendations = []\n+676         \n+677         # Field recommendations\n+678         fields = validation_details.get('required_fields', {})\n+679         missing_fields = fields.get('missing', [])\n+680         if missing_fields:\n+681             recommendations.append(f\"Add documentation for: {', '.join(missing_fields[:3])}\")\n+682         \n+683         # Section recommendations\n+684         sections = validation_details.get('required_sections', {})\n+685         missing_sections = sections.get('missing', [])\n+686         if missing_sections:\n+687             recommendations.append(f\"Add section(s): {', '.join(missing_sections[:3])}\")\n+688         \n+689         # Evidence recommendations\n+690         evidence = validation_details.get('evidence', {})\n+691         if evidence.get('evidence_count', 0) < evidence.get('minimum_required', 3):\n+692             recommendations.append(f\"Add {evidence.get('minimum_required', 3) - evidence.get('evidence_count', 0)} more pieces of evidence\")\n+693         \n+694         # Handoff recommendations\n+695         handoff = validation_details.get('handoff_completeness', {})\n+696         missing_elements = handoff.get('missing_elements', [])\n+697         if missing_elements:\n+698             recommendations.append(f\"Complete handoff by adding: {', '.join(missing_elements[:3])}\")\n+699         \n+700         # General recommendations\n+701         if not recommendations:\n+702             recommendations.append(\"Consider adding more detailed analysis and examples\")\n+703             recommendations.append(\"Include specific next steps with owners and timelines\")\n+704         \n+705         return recommendations\n+706 \n+707 # Utility functions for easy integration\n+708 def validate_artifacts(role_name: str, artifacts: Dict, artifact_type: str = None) -> Dict:\n+709     \"\"\"Convenience function to validate artifacts.\"\"\"\n+710     validator = DoDValidator()\n+711     return validator.validate(role_name, artifacts, artifact_type)\n+712 \n+713 def is_dod_compliant(role_name: str, artifacts: Dict, artifact_type: str = None) -> Tuple[bool, str]:\n+714     \"\"\"Check if artifacts are DoD compliant with simple yes/no.\"\"\"\n+715     validator = DoDValidator()\n+716     results = validator.validate(role_name, artifacts, artifact_type)\n+717     \n+718     if results['is_compliant']:\n+719         return True, f\"DoD compliant with score {results['overall_score']:.2f}\"\n+720     else:\n+721         issues = len(results['issues'])\n+722         return False, f\"DoD not compliant: {issues} issues found, score {results['overall_score']:.2f}\"\n+723 \n+724 if __name__ == '__main__':\n+725     # Test the DoD validator\n+726     test_artifacts = {\n+727         'design_doc.md': \"\"\"\n+728 # Functional Design Document\n+729 \n+730 ## Executive Summary\n+731 This document outlines the integration between Salesforce and ERP system.\n+732 \n+733 ## Detailed Analysis\n+734 The integration will use REST API with OAuth 2.0 authentication.\n+735 \n+736 ## Assumptions\n+737 - ERP system supports REST API\n+738 - OAuth 2.0 is available\n+739 - Data volume is under 10,000 records/day\n+740 \n+741 ## Evidence\n+742 - Salesforce REST API documentation\n+743 - ERP API specifications\n+744 - Security assessment report\n+745 \n+746 ## Recommendations\n+747 1. Implement REST API integration\n+748 2. Use OAuth 2.0 for authentication\n+749 3. Add error handling with retry logic\n+750 \n+751 ## Next Actions\n+752 - Create technical design document\n+753 - Develop integration components\n+754 - Test with sample data\n+755 \"\"\"\n+756     }\n+757     \n+758     validator = DoDValidator()\n+759     results = validator.validate('Integration Developer', test_artifacts, 'design')\n+760     \n+761     print(f\"Role: {results['role']}\")\n+762     print(f\"Artifact Type: {results['artifact_type']}\")\n+763     print(f\"Overall Score: {results['overall_score']:.2f}\")\n+764     print(f\"Compliant: {results['is_compliant']}\")\n+765     print(f\"Issues: {len(results['issues'])}\")\n+766     \n+767     for issue in results['issues']:\n+768         print(f\"  - {issue['severity']}: {issue['description']}\")\n+769     \n+770     print(f\"Recommendations:\")\n+771     for rec in results['recommendations']:\n+772         print(f\"  - {rec}\")","firstChangedLine":490},"isError":false,"timestamp":1773082110753}}
