{"type":"message","id":"db5e96bc","parentId":"48a7ee78","timestamp":"2026-03-09T16:05:58.448Z","message":{"role":"assistant","content":[{"type":"text","text":"¡Perfecto! Ahora funciona sin errores.\n\n## 3. **Vector Memory - Mejor práctica recomendada**\n\nPara Vector Memory, la mejor práctica sería crear un script `vector_status.py` que proporcione información del estado del sistema de memoria. Esto es óptimo porque:\n\n1. **Centraliza la verificación** del estado en un solo script\n2. **Proporciona información útil** sobre la salud del sistema\n3. **Facilita el debugging** y monitoreo\n4. **Sigue el patrón** de otros scripts del skill\n\nVoy a crear el script:"},{"type":"toolCall","id":"call_00_n4C6Rmz7EKIv32V67EdV3LSd","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/vector-memory/scripts/vector_status.py","content":"#!/usr/bin/env python3\n\"\"\"\nVector Memory Status Check\nProvides status information about the vector memory system.\n\"\"\"\n\nimport os\nimport sys\nimport json\nfrom pathlib import Path\nfrom datetime import datetime\n\n# Add parent directory to path for imports\nsys.path.insert(0, str(Path(__file__).parent.parent))\n\ndef check_postgres_connection():\n    \"\"\"Check if PostgreSQL is accessible.\"\"\"\n    try:\n        import psycopg2\n        # Try to connect with default parameters\n        conn = psycopg2.connect(\n            host=\"localhost\",\n            database=\"openclaw_memory\",\n            user=\"openclaw\",\n            password=os.environ.get(\"PGPASSWORD\", \"\")\n        )\n        conn.close()\n        return True, \"PostgreSQL connection successful\"\n    except ImportError:\n        return False, \"psycopg2 not installed\"\n    except Exception as e:\n        return False, f\"PostgreSQL connection failed: {str(e)}\"\n\ndef check_memory_files():\n    \"\"\"Check if memory files exist and are accessible.\"\"\"\n    workspace = Path.home() / \".openclaw\" / \"workspace\"\n    memory_files = {\n        \"MEMORY.md\": workspace / \"MEMORY.md\",\n        \"projects.md\": workspace / \"memory\" / \"projects.md\",\n        \"daily_notes\": workspace / \"memory\" / f\"{datetime.now().strftime('%Y-%m-%d')}.md\"\n    }\n    \n    results = {}\n    for name, path in memory_files.items():\n        if path.exists():\n            size = path.stat().st_size\n            results[name] = {\n                \"exists\": True,\n                \"size_bytes\": size,\n                \"size_human\": f\"{size / 1024:.1f} KB\" if size < 1024*1024 else f\"{size / (1024*1024):.1f} MB\"\n            }\n        else:\n            results[name] = {\"exists\": False}\n    \n    return results\n\ndef check_embeddings_api():\n    \"\"\"Check if embeddings API is accessible.\"\"\"\n    try:\n        import google.generativeai as genai\n        api_key = os.environ.get(\"GEMINI_API_KEY\")\n        if not api_key:\n            return False, \"GEMINI_API_KEY not set\"\n        \n        genai.configure(api_key=api_key)\n        # Simple test - list models\n        models = genai.list_models()\n        return True, f\"Gemini API accessible ({len(list(models))} models available)\"\n    except ImportError:\n        return False, \"google-generativeai not installed\"\n    except Exception as e:\n        return False, f\"Gemini API error: {str(e)}\"\n\ndef check_scripts():\n    \"\"\"Check if all vector memory scripts exist.\"\"\"\n    script_dir = Path(__file__).parent\n    scripts = [\n        \"memory_store.py\",\n        \"memory_search.py\", \n        \"memory_auto_curate.py\",\n        \"memory_flush.py\",\n        \"memory_curation_wrapper.py\"\n    ]\n    \n    results = {}\n    for script in scripts:\n        path = script_dir / script\n        results[script] = {\n            \"exists\": path.exists(),\n            \"executable\": os.access(path, os.X_OK) if path.exists() else False\n        }\n    \n    return results\n\ndef main():\n    \"\"\"Main status check function.\"\"\"\n    print(\"=\" * 60)\n    print(\"VECTOR MEMORY SYSTEM STATUS CHECK\")\n    print(\"=\" * 60)\n    \n    # Check PostgreSQL\n    print(\"\\n1. PostgreSQL Database:\")\n    pg_ok, pg_msg = check_postgres_connection()\n    print(f\"   Status: {'✅' if pg_ok else '❌'} {pg_msg}\")\n    \n    # Check Embeddings API\n    print(\"\\n2. Embeddings API (Gemini):\")\n    api_ok, api_msg = check_embeddings_api()\n    print(f\"   Status: {'✅' if api_ok else '❌'} {api_msg}\")\n    \n    # Check Memory Files\n    print(\"\\n3. Memory Files:\")\n    files = check_memory_files()\n    for name, info in files.items():\n        if info[\"exists\"]:\n            print(f\"   {name}: ✅ {info['size_human']}\")\n        else:\n            print(f\"   {name}: ❌ Missing\")\n    \n    # Check Scripts\n    print(\"\\n4. Scripts:\")\n    scripts = check_scripts()\n    for name, info in scripts.items():\n        status = \"✅\" if info[\"exists\"] else \"❌\"\n        exec_status = \" (executable)\" if info.get(\"executable\") else \"\"\n        print(f\"   {name}: {status}{exec_status}\")\n    \n    # Overall Status\n    print(\"\\n\" + \"=\" * 60)\n    \n    all_checks = [\n        pg_ok,\n        api_ok,\n        all(info[\"exists\"] for info in files.values() if name != \"daily_notes\"),\n        all(info[\"exists\"] for info in scripts.values())\n    ]\n    \n    if all(all_checks):\n        print(\"OVERALL STATUS: ✅ HEALTHY\")\n        print(\"All systems operational.\")\n    else:\n        print(\"OVERALL STATUS: ⚠️  DEGRADED\")\n        print(\"Some components require attention.\")\n    \n    print(\"=\" * 60)\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":198,"output":1351,"cacheRead":50240,"cacheWrite":0,"totalTokens":51789,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773072283643}}
