lCall","id":"call_00_bcHoRcdzd0hzRCA4eMrRuc5E","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/long-prompt-orchestrator/scripts/orchestrate.py","content":"#!/usr/bin/env python3\n\"\"\"\nMain orchestrator for long prompt decomposition and execution.\nSupports demo modes (basic, complex) and real orchestration.\n\"\"\"\n\nimport sys\nimport os\nimport json\nimport argparse\nimport tempfile\nimport shutil\nfrom typing import Dict, List, Any, Optional\n\n# Add skill scripts directory to path\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\n\nfrom decompose import detect_and_decompose\nfrom todo import Checklist\nfrom token_budget import TokenBudget\nfrom validate import validate_final_output\nfrom recovery import recover_from_interruption\nfrom learning_emit import emit_incident\n\n# Configuration defaults\nMAX_PROMPT_TOKENS = 4000\nMAX_MINI_TASKS = 20\nGLOBAL_TOKEN_BUDGET = 16000\nINPUT_TOKEN_LIMIT = 4000\nOUTPUT_TOKEN_LIMIT = 2000\n\nWORKSPACE = os.path.expanduser(\"~/.openclaw/workspace\")\nTASKBOARDS_DIR = os.path.join(WORKSPACE, \".taskboards\")\n\ndef ensure_taskboards_dir():\n    \"\"\"Ensure .taskboards directory exists.\"\"\"\n    os.makedirs(TASKBOARDS_DIR, exist_ok=True)\n    os.makedirs(os.path.join(TASKBOARDS_DIR, \"checkpoints\"), exist_ok=True)\n\ndef simulate_model_call(context: str, max_output_tokens: int) -> str:\n    \"\"\"\n    Simulate a model call for demo purposes.\n    In production, replace with actual OpenClaw tooling.\n    \"\"\"\n    # For demo, just echo the objective and produce a placeholder output.\n    lines = context.split('\\n')\n    objective = next((line for line in lines if 'Objective:' in line), '')\n    return f\"Simulated output for {objective[:50]}...\\nThis output satisfies the acceptance criteria.\"\n\ndef run_demo_basic():\n    \"\"\"Run basic demo from example_basic.md.\"\"\"\n    print(\"=== Running Basic Demo ===\")\n    ensure_taskboards_dir()\n    \n    # Load example prompt\n    example_path = os.path.join(os.path.dirname(__file__), '../examples/example_basic.md')\n    with open(example_path, 'r') as f:\n        content = f.read()\n    # Extract the prompt (crude extraction for demo)\n    lines = content.split('\\n')\n    prompt = ''\n    in_prompt = False\n    for line in lines:\n        if line.startswith('```'):\n            if not in_prompt:\n                in_prompt = True\n                continue\n            else:\n                break\n        if in_prompt and line:\n            prompt += line + '\\n'\n    if not prompt:\n        prompt = \"Create a comprehensive report about climate change impacts on agriculture...\"\n    \n    print(f\"Original prompt length: {len(prompt)} chars\")\n    \n    # Detect and decompose\n    tasks = detect_and_decompose(prompt, max_prompt_tokens=MAX_PROMPT_TOKENS, max_mini_tasks=MAX_MINI_TASKS)\n    if not tasks:\n        print(\"No decomposition needed.\")\n        return\n    \n    print(f\"Decomposed into {len(tasks)} mini-tasks.\")\n    for task in tasks:\n        print(f\"  {task['id']}: {task['objective'][:60]}...\")\n    \n    # Create checklist\n    task_id = \"demo_basic_\" + str(int(os.times().elapsed))\n    checklist = Checklist(task_id, prompt[:200])\n    for task in tasks:\n        checklist.add_item(\n            task['id'],\n            task['objective'],\n            task['dependencies'],\n            artifacts=task.get('outputs', [])\n        )\n    checklist_path = os.path.join(TASKBOARDS_DIR, f\"{task_id}.md\")\n    checklist.save(checklist_path)\n    print(f\"Checklist saved to {checklist_path}\")\n    \n    # Token budget\n    budget = TokenBudget(\n        global_budget=GLOBAL_TOKEN_BUDGET,\n        input_limit=INPUT_TOKEN_LIMIT,\n        output_limit=OUTPUT_TOKEN_LIMIT\n    )\n    \n    # Execute tasks in topological order (simple dependency sort)\n    executed = {}\n    for task in tasks:\n        # Wait for dependencies\n        deps = task['dependencies']\n        if deps and any(dep not in executed for dep in deps):\n            print(f\"Skipping {task['id']} — dependencies not ready\")\n            continue\n        \n        print(f\"Executing {task['id']}...\")\n        checklist.update_state(task['id'], 'in_progress')\n        \n        # Assemble context (simplified)\n        context = f\"Objective: {task['objective']}\\n\"\n        for dep in deps:\n            if dep in executed:\n                context += f\"Output from {dep}: {executed[dep][:100]}...\\n\"\n        \n        # Check token budget\n        input_tokens = budget.estimate_tokens(context)\n        if not budget.can_consume(input_tokens, task['max_token_budget']):\n            emit_incident(\n                \"tokens|BUDGET|token_budget|input_overflow|truncate_required\",\n                \"Input token overflow\",\n                f\"step_id={task['id']}, input_tokens={input_tokens}, limit={INPUT_TOKEN_LIMIT}\"\n            )\n            print(\"Token budget exceeded — stopping.\")\n            break\n        \n        # Simulate model call\n        output = simulate_model_call(context, task['max_token_budget'])\n        output_tokens = budget.estimate_tokens(output)\n        budget.consume(input_tokens + output_tokens)\n        \n        executed[task['id']] = output\n        checklist.update_state(task['id'], 'complete', artifacts=[f\"{task['id']}_output.txt\"])\n        \n        # Write checkpoint\n        checkpoint = {\n            'task_id': task['id'],\n            'output': output,\n            'input_tokens': input_tokens,\n            'output_tokens': output_tokens\n        }\n        checkpoint_path = os.path.join(TASKBOARDS_DIR, 'checkpoints', f\"{task_id}_{task['id']}.json\")\n        with open(checkpoint_path, 'w') as f:\n            json.dump(checkpoint, f)\n        print(f\"  Checkpoint saved.\")\n    \n    # Simulate recovery\n    print(\"\\n--- Simulating recovery ---\")\n    # Corrupt checklist (rename)\n    corrupted_path = checklist_path + '.corrupted'\n    shutil.move(checklist_path, corrupted_path)\n    try:\n        recovered = recover_from_interruption(task_id)\n        if recovered:\n            print(\"Recovery succeeded.\")\n        else:\n            print(\"Recovery failed — emitting incident.\")\n            emit_incident(\n                \"recovery|FAILURE|recovery|resume|checkpoint_missing|cannot_continue\",\n                \"Checkpoint missing, cannot continue\",\n                f\"task_id={task_id}\"\n            )\n    finally:\n        shutil.move(corrupted_path, checklist_path)\n    \n    # Validate final output (simulate)\n    final_output = \"\\n\".join(executed.values())\n    validation_ok = validate_final_output(final_output, prompt, tasks)\n    if validation_ok:\n        print(\"Validation passed.\")\n    else:\n        print(\"Validation failed — emitting incident.\")\n        emit_incident(\n            \"validation|FAILURE|validate|final_output|criteria_not_met|repair_failed\",\n            \"Final output validation failed\",\n            f\"task_id={task_id}\"\n        )\n    \n    print(\"Basic demo completed.\")\n\ndef run_demo_complex():\n    \"\"\"Run complex demo from example_complex.md.\"\"\"\n    print(\"=== Running Complex Demo ===\")\n    ensure_taskboards_dir()\n    \n    # Load example prompt\n    example_path = os.path.join(os.path.dirname(__file__), '../examples/example_complex.md')\n    with open(example_path, 'r') as f:\n        content = f.read()\n    lines = content.split('\\n')\n    prompt = ''\n    in_prompt = False\n    for line in lines:\n        if line.startswith('```'):\n            if not in_prompt:\n                in_prompt = True\n                continue\n            else:\n                break\n        if in_prompt and line:\n            prompt += line + '\\n'\n    if not prompt:\n        prompt = \"Build a small Python project for data analysis of sales records...\"\n    \n    print(f\"Original prompt length: {len(prompt)} chars\")\n    \n    # Detect and decompose\n    tasks = detect_and_decompose(prompt, max_prompt_tokens=MAX_PROMPT_TOKENS, max_mini_tasks=MAX_MINI_TASKS)\n    if not tasks:\n        print(\"No decomposition needed.\")\n        return\n    \n    print(f\"Decomposed into {len(tasks)} mini-tasks.\")\n    \n    # Create checklist\n    task_id = \"demo_complex_\" + str(int(os.times().elapsed))\n    checklist = Checklist(task_id, prompt[:200])\n    for task in tasks:\n        checklist.add_item(\n            task['id'],\n            task['objective'],\n            task['dependencies'],\n            artifacts=task.get('outputs', [])\n        )\n    checklist_path = os.path.join(TASKBOARDS_DIR, f\"{task_id}.md\")\n    checklist.save(checklist_path)\n    print(f\"Checklist saved to {checklist_path}\")\n    \n    # Simulate a few steps, then trigger a token budget incident\n    budget = TokenBudget(\n        global_budget=GLOBAL_TOKEN_BUDGET,\n        input_limit=INPUT_TOKEN_LIMIT,\n        output_limit=OUTPUT_TOKEN_LIMIT\n    )\n    \n    # Deliberately exceed token budget\n    print(\"\\n--- Triggering token budget incident ---\")\n    emit_incident(\n        \"tokens|BUDGET|token_budget|input_overflow|truncate_required\",\n        \"Input token overflow (demo)\",\n        f\"step_id=task_05, input_tokens=4500, limit=4000\"\n    )\n    \n    # Simulate checklist corruption incident\n    print(\"\\n--- Simulating checklist corruption incident ---\")\n    emit_incident(\n        \"checklist|FAILURE|todo|state_corrupt|rebuild_failed|manual_needed\",\n        \"Checklist state corrupt, rebuild failed\",\n        f\"task_id={task_id}, error=FileNotFoundError\"\n    )\n    \n    print(\"Complex demo completed.\")\n\ndef orchestrate_real(prompt: str, task_id: Optional[str] = None):\n    \"\"\"Real orchestration for a given prompt.\"\"\"\n    ensure_taskboards_dir()\n    \n    # If task_id is provided, attempt recovery\n    if task_id and os.path.exists(os.path.join(TASKBOARDS_DIR, f\"{task_id}.md\")):\n        print(f\"Resuming existing task {task_id}\")\n        tasks = recover_from_interruption(task_id)\n        if not tasks:\n            print(\"Recovery failed.\")\n            return\n    else:\n        # Detect and decompose\n        tasks = detect_and_decompose(prompt, max_prompt_tokens=MAX_PROMPT_TOKENS, max_mini_tasks=MAX_MINI_TASKS)\n        if not tasks:\n            # No decomposition needed; execute directly (outside this script)\n            print(\"Prompt within limits; no decomposition needed.\")\n            return\n        \n        # Create new task_id\n        import time\n        task_id = f\"task_{int(time.time())}\"\n        checklist = Checklist(task_id, prompt[:200])\n        for task in tasks:\n            checklist.add_item(\n                task['id'],\n                task['objective'],\n                task['dependencies'],\n                artifacts=task.get('outputs', [])\n            )\n        checklist_path = os.path.join(TASKBOARDS_DIR, f\"{task_id}.md\")\n        checklist.save(checklist_path)\n        print(f\"Checklist created at {checklist_path}\")\n    \n    # TODO: Implement full execution loop with real model calls.\n    print(\"Real orchestration not fully implemented in demo.\")\n    print(f\"Would execute {len(tasks)} tasks.\")\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Long Prompt Orchestrator\")\n    parser.add_argument('--demo', choices=['basic', 'complex'], help=\"Run demo mode\")\n    parser.add_argument('--prompt', type=str, help=\"Original prompt to orchestrate\")\n    parser.add_argument('--task-id', type=str, help=\"Existing task ID to resume\")\n    args = parser.parse_args()\n    \n    if args.demo == 'basic':\n        run_demo_basic()\n    elif args.demo == 'complex':\n        run_demo_complex()\n    elif args.prompt:\n        orchestrate_real(args.prompt, args.task_id)\n    else:\n        parser.print_help()\n\nif __name__ == '__main__':\n    main()"}}],"api":"openai-complet