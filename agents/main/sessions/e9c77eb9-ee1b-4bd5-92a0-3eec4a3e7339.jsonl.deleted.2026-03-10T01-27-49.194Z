    \"stall_detections\": 1,\n      \"recovery_attempts\": 0,\n      \"last_stall_time\": \"2026-03-10T00:15:05.524411\"\n    },\n    \"session_data_summary\": {}\n  },\n  \"68036537-9eac-43eb-926c-8bc0fd642d25\": {\n    \"session_id\": \"68036537-9eac-43eb-926c-8bc0fd642d25\",\n    \"source\": \"main_sessions\",\n    \"registered_at\": \"2026-03-10T00:11:23.925750\",\n    \"last_activity\": \"2026-03-10T00:11:23.925750\",\n    \"state\": \"stalled\",\n    \"stall_count\": 1,\n    \"recovery_attempts\": 0,\n    \"metrics\": {\n      \"total_uptime\": 0,\n      \"stall_detections\": 1,\n      \"recovery_attempts\": 0,\n      \"last_stall_time\": \"2026-03-10T00:15:05.524424\"\n    },\n    \"session_data_summary\": {}\n  },\n  \"b84cfbe7-dcde-42ac-ab6d-48ebd399fbe7\": {\n    \"session_id\": \"b84cfbe7-dcde-42ac-ab6d-48ebd399fbe7\",\n    \"source\": \"main_sessions\",\n    \"registered_at\": \"2026-03-10T00:11:23.925762\",\n    \"last_activity\": \"2026-03-10T00:11:23.925762\",\n    \"state\": \"stalled\",\n    \"stall_count\": 1,\n    \"recovery_attempts\": 0,\n    \"metrics\": {\n      \"total_uptime\": 0,\n      \"stall_detections\": 1,\n      \"recovery_attempts\": 0,\n      \"last_stall_time\": \"2026-03-10T00:15:05.524436\"\n    },\n    \"session_data_summary\": {}\n  },\n  \"42cbca95-0ae4-44ea-96ef-2ad3403ce967\": {\n    \"session_id\": \"42cbca95-0ae4-44ea-96ef-2ad3403ce967\",\n    \"source\": \"main_sessions\",\n    \"registered_at\": \"2026-03-10T00:11:23.925783\",\n    \"last_activity\": \"2026-03-10T00:11:23.925784\",\n    \"state\": \"stalled\",\n    \"stall_count\": 1,\n    \"recovery_attempts\": 0,\n    \"metrics\": {\n      \"total_uptime\": 0,\n      \"stall_detections\": 1,\n      \"recovery_attempts\": 0,\n      \"last_stall_time\": \"2026-03-10T00:15:05.524449\"\n    },\n    \"session_data_summary\": {}\n  },\n  \"4e6cd99c-a4fb-4cd1-882e-fd0750fe58e7\": {\n    \"session_id\": \"4e6cd99c-a4fb-4cd1-882e-fd0750fe58e7\",\n    \"source\": \"main_sessions\",\n    \"registered_at\": \"2026-03-10T00:11:23.925804\",\n    \"last_activity\": \"2026-03-10T00:11:23.925805\",\n    \"state\": \"stalled\",\n    \"stall_count\": 1,\n    \"recovery_attempts\": 0,\n    \"metrics\": {\n      \"total_uptime\": 0,\n      \"stall_detections\": 1,\n      \"recovery_attempts\": 0,\n      \"last_stall_time\": \"2026-03-10T00:15:05.524463\"\n    },\n    \"session_data_summary\": {}\n  },\n  \"82f1e28f-065c-4a8c-a752-454ccc3ebe82\": {\n    \"session_id\": \"82f1e28f-065c-4a8c-a752-454ccc3ebe82\",\n    \"source\": \"main_sessions\",\n    \"registered_at\": \"2026-03-10T00:11:23.925820\",\n    \"last_activity\": \"2026-03-10T00:11:23.925820\",\n    \"state\": \"stalled\",\n    \"stall_count\": 1,\n    \"recovery_attempts\": 0,\n    \"metrics\": {\n      \"total_uptime\": 0,\n      \"stall_detections\": 1,\n      \"recovery_attempts\": 0,\n      \"last_stall_time\": \"2026-03-10T00:15:05.524476\"\n    },\n    \"session_data_summary\": {}\n  },\n  \"bb6731bc-3dc6-4f46-a165-8857c3a44802\": {\n    \"session_id\": \"bb6731bc-3dc6-4f46-a165-8857c3a44802\",\n    \"source\": \"main_sessions\",\n    \"registered_at\": \"2026-03-10T00:11:23.925831\",\n    \"last_activity\": \"2026-03-10T00:11:23.925832\",\n    \"state\": \"stalled\",\n    \"stall_count\": 1,\n    \"recovery_attempts\": 0,\n    \"metrics\": {\n      \"total_uptime\": 0,\n      \"stall_detections\": 1,\n      \"recovery_attempts\": 0,\n      \"last_stall_time\": \"2026-03-10T00:15:05.524488\"\n    },\n    \"session_data_summary\": {}\n  },\n  \"sess_3755862c\": {\n    \"session_id\": \"sess_3755862c\",\n    \"source\": \"active_sessions\",\n    \"registered_at\": \"2026-03-10T00:11:23.925920\",\n    \"last_activity\": \"2026-03-10T00:11:23.925921\",\n    \"state\": \"stalled\",\n    \"stall_count\": 1,\n    \"recovery_attempts\": 0,\n    \"metrics\": {\n      \"total_uptime\": 0,\n      \"stall_detections\": 1,\n      \"recovery_attempts\": 0,\n      \"last_stall_time\": \"2026-03-10T