{"type":"message","id":"12d3680d","parentId":"41a93640","timestamp":"2026-03-10T00:05:42.487Z","message":{"role":"assistant","content":[{"type":"text","text":"Now I need to add the new helper methods. Let me add them after the `_determine_priority` method:"},{"type":"toolCall","id":"call_00_sZJgbtnvJ2g7o6i7eNjuxFkc","name":"edit","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/long-prompt-orchestrator/scripts/plan_generator.py","oldText":"    def _determine_priority(self, task_data: Dict[str, Any]) -> TaskPriority:\n        \"\"\"Determine task priority.\"\"\"\n        complexity_score = task_data.get('complexity_score', 0)\n        \n        if complexity_score >= 8:\n            return TaskPriority.CRITICAL\n        elif complexity_score >= 5:\n            return TaskPriority.HIGH\n        elif complexity_score >= 3:\n            return TaskPriority.MEDIUM\n        else:\n            return TaskPriority.LOW","newText":"    def _determine_priority(self, task_data: Dict[str, Any]) -> TaskPriority:\n        \"\"\"Determine task priority.\"\"\"\n        complexity_score = task_data.get('complexity_score', 0)\n        \n        if complexity_score >= 8:\n            return TaskPriority.CRITICAL\n        elif complexity_score >= 5:\n            return TaskPriority.HIGH\n        elif complexity_score >= 3:\n            return TaskPriority.MEDIUM\n        else:\n            return TaskPriority.LOW\n    \n    def _determine_execution_mode(self, task_data: Dict[str, Any]) -> str:\n        \"\"\"Determine execution mode: main, subagent, or mixed.\"\"\"\n        requires_subagent = self._should_require_subagent(task_data)\n        complexity_score = task_data.get('complexity_score', 0)\n        \n        if requires_subagent:\n            return \"subagent\"\n        elif complexity_score >= 5:\n            return \"mixed\"  # Could be done by main but might need subagent help\n        else:\n            return \"main\"\n    \n    def _determine_action_type(self, task_data: Dict[str, Any]) -> str:\n        \"\"\"Determine action type based on task content.\"\"\"\n        objective = task_data.get('objective', '').lower()\n        description = task_data.get('description', '').lower()\n        \n        # Check for skill invocation\n        if self._recommend_skill_or_role(task_data) is not None:\n            return \"skill_invocation\"\n        \n        # Check for file operations\n        file_keywords = ['file', 'create', 'write', 'read', 'edit', 'save', 'generate']\n        if any(keyword in objective or keyword in description for keyword in file_keywords):\n            return \"file_operation\"\n        \n        # Check for Python scripts\n        python_keywords = ['python', 'script', 'code', 'program', 'run python', 'execute script']\n        if any(keyword in objective or keyword in description for keyword in python_keywords):\n            return \"python\"\n        \n        # Default to exec for shell commands\n        return \"exec\"\n    \n    def _generate_action_instructions(self, task_data: Dict[str, Any], action_type: str) -> str:\n        \"\"\"Generate executable instructions based on action type.\"\"\"\n        objective = task_data.get('objective', '')\n        \n        if action_type == \"exec\":\n            # Convert objective to shell command\n            if \"list\" in objective.lower() or \"inventory\" in objective.lower():\n                return \"find /home/openclaw/.openclaw/workspace/skills -type f -name 'SKILL.md' | sort\"\n            elif \"search\" in objective.lower() or \"find\" in objective.lower():\n                return \"grep -r 'pattern' /home/openclaw/.openclaw/workspace --include='*.md' --include='*.py' | head -20\"\n            elif \"count\" in objective.lower() or \"measure\" in objective.lower():\n                return \"find /home/openclaw/.openclaw/workspace -type f -name '*.py' | wc -l\"\n            else:\n                return f\"echo 'Executing: {objective[:100]}...'\"\n        \n        elif action_type == \"python\":\n            # Generate Python script instructions\n            return f\"\"\"# Python script to: {objective[:100]}\nimport os\nimport sys\n\n# TODO: Implement based on objective\nprint(\"Task: {objective[:100]}...\")\"\"\"\n        \n        elif action_type == \"skill_invocation\":\n            skill = self._recommend_skill_or_role(task_data)\n            if skill:\n                return f\"Invoke {skill} skill with objective: {objective[:100]}...\"\n            else:\n                return f\"Invoke appropriate skill for: {objective[:100]}...\"\n        \n        elif action_type == \"file_operation\":\n            # Generate file operation instructions\n            if \"create\" in objective.lower() or \"write\" in objective.lower():\n                return f\"Create file with content based on: {objective[:100]}...\"\n            elif \"read\" in objective.lower() or \"analyze\" in objective.lower():\n                return f\"Read and analyze relevant files for: {objective[:100]}...\"\n            else:\n                return f\"Perform file operation: {objective[:100]}...\"\n        \n        return f\"Execute: {objective[:100]}...\"\n    \n    def _generate_validation_method(self, task_data: Dict[str, Any]) -> str:\n        \"\"\"Generate validation method for task completion.\"\"\"\n        outputs = task_data.get('outputs', [])\n        acceptance_criteria = task_data.get('acceptance_criteria', [])\n        \n        if outputs:\n            return f\"Check that output files exist: {', '.join(outputs)}\"\n        elif acceptance_criteria:\n            return f\"Validate acceptance criteria: {acceptance_criteria[0][:100]}...\"\n        else:\n            return \"Verify task completion by checking output quality\"\n    \n    def _determine_artifact_destination(self, task_data: Dict[str, Any], task_id: str) -> str:\n        \"\"\"Determine where to store task artifacts.\"\"\"\n        outputs = task_data.get('outputs', [])\n        \n        if outputs:\n            # Use first output as artifact destination\n            return f\"projects/{{project_key}}/{outputs[0]}\"\n        else:\n            return f\"projects/{{project_key}}/{task_id}_output.txt\"\n    \n    def _recommend_skill_or_role(self, task_data: Dict[str, Any]) -> Optional[str]:\n        \"\"\"Recommend skill or role for task (replaces _recommend_skill).\"\"\"\n        objective = task_data.get('objective', '').lower()\n        description = task_data.get('description', '').lower()\n        \n        # Check for Salesforce-related content\n        salesforce_keywords = ['salesforce', 'apex', 'lwc', 'visualforce', 'soql', 'flow']\n        if any(keyword in objective or keyword in description for keyword in salesforce_keywords):\n            return \"salesforce-architect\"\n        \n        # Check for web search/research\n        search_keywords = ['search', 'research', 'find', 'look up', 'web', 'internet']\n        if any(keyword in objective or keyword in description for keyword in search_keywords):\n            return \"tavily-web-search\"\n        \n        # Check for code auditing\n        audit_keywords = ['audit', 'review', 'check', 'validate', 'security', 'code quality']\n        if any(keyword in objective or keyword in description for keyword in audit_keywords):\n            return \"salesforce-code-auditor\"\n        \n        # Check for workspace maintenance\n        maintenance_keywords = ['clean', 'organize', 'tidy', 'maintain', 'janitor']\n        if any(keyword in objective or keyword in description for keyword in maintenance_keywords):\n            return \"workspace-janitor\"\n        \n        # Check for planning/orchestration\n        planning_keywords = ['plan', 'orchestrate', 'coordinate', 'decompose', 'schedule']\n        if any(keyword in objective or keyword in description for keyword in planning_keywords):\n            return \"long-prompt-orchestrator\"\n        \n        return None"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":60,"output":1746,"cacheRead":36608,"cacheWrite":0,"totalTokens":38414,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101091661}}
