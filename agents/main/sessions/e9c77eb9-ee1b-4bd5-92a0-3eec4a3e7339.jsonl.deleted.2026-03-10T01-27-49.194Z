{"type":"message","id":"ab47f672","parentId":"a4317b97","timestamp":"2026-03-10T00:30:18.781Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create the sub-agent monitoring integration:"},{"type":"toolCall","id":"call_00_blTuhrm90XgQqnUii9ZXduid","name":"write","arguments":{"path":"~/.openclaw/workspace/integration/subagent_monitoring.py","content":"#!/usr/bin/env python3\n\"\"\"\nSub-agent Monitoring Integration\nRegisters and monitors sub-agent sessions with watchdog.\n\"\"\"\n\nimport os\nimport json\nimport time\nimport sys\nimport uuid\nfrom datetime import datetime\nfrom pathlib import Path\n\n# Workspace paths\nWORKSPACE = Path.home() / '.openclaw' / 'workspace'\nWATCHDOG_DIR = WORKSPACE / '.watchdog'\nSESSION_REGISTRY = WATCHDOG_DIR / 'session_registry.json'\nMONITORING_LOG = WATCHDOG_DIR / 'monitoring.log'\n\nclass SubAgentMonitor:\n    \"\"\"Sub-agent monitoring integration.\"\"\"\n    \n    def __init__(self, subagent_id=None, parent_session_id=None):\n        self.subagent_id = subagent_id\n        self.parent_session_id = parent_session_id\n        self.session_id = None\n        self.task_description = None\n        self.expected_runtime = None\n        self.start_time = None\n        \n    def log_monitoring(self, message, level=\"INFO\"):\n        \"\"\"Log monitoring activity.\"\"\"\n        timestamp = datetime.utcnow().isoformat()\n        log_entry = f\"[{timestamp}] [SUBAGENT] [{level}] {message}\\n\"\n        \n        # Write to monitoring log\n        try:\n            with open(MONITORING_LOG, 'a') as f:\n                f.write(log_entry)\n        except Exception as e:\n            print(f\"Failed to write to monitoring log: {e}\")\n        \n        # Also print to console\n        print(log_entry.strip())\n    \n    def register_subagent_session(self, task_description, expected_runtime_minutes=3, parent_session_id=None):\n        \"\"\"Register sub-agent session with watchdog.\"\"\"\n        # Use provided subagent ID or generate one\n        if not self.subagent_id:\n            self.subagent_id = f\"sub_{uuid.uuid4().hex[:8]}\"\n        \n        # Use provided parent session ID or try to detect\n        if parent_session_id:\n            self.parent_session_id = parent_session_id\n        \n        self.session_id = f\"subagent_{self.subagent_id}\"\n        self.task_description = task_description\n        self.expected_runtime = expected_runtime_minutes\n        self.start_time = datetime.utcnow().isoformat()\n        \n        # Create session entry\n        session_entry = {\n            \"session_id\": self.session_id,\n            \"source\": \"subagent_integration\",\n            \"registered_at\": self.start_time,\n            \"last_activity\": self.start_time,\n            \"state\": \"active\",\n            \"task_description\": task_description,\n            \"expected_runtime_minutes\": expected_runtime_minutes,\n            \"parent_session\": self.parent_session_id,\n            \"subagent_id\": self.subagent_id,\n            \"stall_count\": 0,\n            \"recovery_attempts\": 0,\n            \"metrics\": {\n                \"total_uptime\": 0,\n                \"stall_detections\": 0,\n                \"recovery_attempts\": 0,\n                \"last_activity\": self.start_time\n            },\n            \"session_data_summary\": {\n                \"agent_type\": \"subagent\",\n                \"task_type\": \"execution\",\n                \"integration_level\": \"monitored\"\n            }\n        }\n        \n        # Load existing registry\n        registry = {}\n        if SESSION_REGISTRY.exists():\n            try:\n                with open(SESSION_REGISTRY, 'r') as f:\n                    registry = json.load(f)\n            except Exception as e:\n                self.log_monitoring(f\"Error loading registry: {e}\", level=\"ERROR\")\n        \n        # Add or update session\n        registry[self.session_id] = session_entry\n        \n        # Save registry\n        try:\n            with open(SESSION_REGISTRY, 'w') as f:\n                json.dump(registry, f, indent=2)\n        except Exception as e:\n            self.log_monitoring(f\"Error saving registry: {e}\", level=\"ERROR\")\n            return False\n        \n        self.log_monitoring(f\"Registered sub-agent session: {self.session_id} - {task_description}\")\n        return True\n    \n    def update_activity(self, activity_description=None, progress_percentage=None):\n        \"\"\"Update activity timestamp for sub-agent session.\"\"\"\n        if not self.session_id:\n            self.log_monitoring(\"No active sub-agent session to update\", level=\"WARNING\")\n            return False\n        \n        current_time = datetime.utcnow().isoformat()\n        \n        # Load registry\n        if not SESSION_REGISTRY.exists():\n            self.log_monitoring(\"Registry file not found\", level=\"ERROR\")\n            return False\n        \n        try:\n            with open(SESSION_REGISTRY, 'r') as f:\n                registry = json.load(f)\n        except Exception as e:\n            self.log_monitoring(f\"Error loading registry: {e}\", level=\"ERROR\")\n            return False\n        \n        # Update session\n        if self.session_id in registry:\n            registry[self.session_id][\"last_activity\"] = current_time\n            registry[self.session_id][\"state\"] = \"active\"\n            \n            # Add activity description if provided\n            if activity_description:\n                if \"recent_activities\" not in registry[self.session_id]:\n                    registry[self.session_id][\"recent_activities\"] = []\n                registry[self.session_id][\"recent_activities\"].append({\n                    \"timestamp\": current_time,\n                    \"description\": activity_description\n                })\n                # Keep only last 10 activities\n                if len(registry[self.session_id][\"recent_activities\"]) > 10:\n                    registry[self.session_id][\"recent_activities\"] = registry[self.session_id][\"recent_activities\"][-10:]\n            \n            # Update progress if provided\n            if progress_percentage is not None:\n                registry[self.session_id][\"progress_percentage\"] = progress_percentage\n                registry[self.session_id][\"last_progress_update\"] = current_time\n            \n            # Save registry\n            try:\n                with open(SESSION_REGISTRY, 'w') as f:\n                    json.dump(registry, f, indent=2)\n            except Exception as e:\n                self.log_monitoring(f\"Error saving registry: {e}\", level=\"ERROR\")\n                return False\n            \n            self.log_monitoring(f\"Updated activity for sub-agent {self.session_id}: {activity_description or 'heartbeat'}\")\n            return True\n        else:\n            self.log_monitoring(f\"Sub-agent session {self.session_id} not found in registry\", level=\"WARNING\")\n            return False\n    \n    def complete_session(self, outcome=\"success\", completion_notes=None, handoff_report=None):\n        \"\"\"Mark sub-agent session as completed.\"\"\"\n        if not self.session_id:\n            self.log_monitoring(\"No active sub-agent session to complete\", level=\"WARNING\")\n            return False\n        \n        current_time = datetime.utcnow().isoformat()\n        \n        # Load registry\n        if not SESSION_REGISTRY.exists():\n            self.log_monitoring(\"Registry file not found\", level=\"ERROR\")\n            return False\n        \n        try:\n            with open(SESSION_REGISTRY, 'r') as f:\n                registry = json.load(f)\n        except Exception as e:\n            self.log_monitoring(f\"Error loading registry: {e}\", level=\"ERROR\")\n            return False\n        \n        # Update session\n        if self.session_id in registry:\n            registry[self.session_id][\"state\"] = \"completed\"\n            registry[self.session_id][\"completed_at\"] = current_time\n            registry[self.session_id][\"outcome\"] = outcome\n            \n            if completion_notes:\n                registry[self.session_id][\"completion_notes\"] = completion_notes\n            \n            if handoff_report:\n                registry[self.session_id][\"handoff_report\"] = handoff_report\n            \n            # Calculate runtime\n            start_time = datetime.fromisoformat(registry[self.session_id][\"registered_at\"])\n            end_time = datetime.fromisoformat(current_time)\n            runtime_seconds = (end_time - start_time).total_seconds()\n            registry[self.session_id][\"metrics\"][\"total_uptime\"] = runtime_seconds\n            \n            # Update parent session if it exists\n            parent_session_id = registry[self.session_id].get(\"parent_session\")\n            if parent_session_id and parent_session_id in registry:\n                # Find this sub-agent in parent's subagents list\n                if \"subagents\" in registry[parent_session_id]:\n                    for subagent in registry[parent_session_id][\"subagents\"]:\n                        if subagent.get(\"subagent_id\") == self.subagent_id:\n                            subagent[\"completed_at\"] = current_time\n                            subagent[\"status\"] = \"completed\"\n                            subagent[\"outcome\"] = outcome\n                            break\n            \n            # Save registry\n            try:\n                with open(SESSION_REGISTRY, 'w') as f:\n                    json.dump(registry, f, indent=2)\n            except Exception as e:\n                self.log_monitoring(f\"Error saving registry: {e}\", level=\"ERROR\")\n                return False\n            \n            self.log_monitoring(f\"Completed sub-agent session: {self.session_id} - Outcome: {outcome}\")\n            \n            # Reset session ID\n            self.session_id = None\n            return True\n        else:\n            self.log_monitoring(f\"Sub-agent session {self.session_id} not found\", level=\"WARNING\")\n            return False\n    \n    def detect_stall(self, timeout_minutes=5):\n        \"\"\"Check if sub-agent has stalled.\"\"\"\n        if not self.session_id:\n            return False\n        \n        if not SESSION_REGISTRY.exists():\n            return False\n        \n        try:\n            with open(SESSION_REGISTRY, 'r') as f:\n                registry = json.load(f)\n        except Exception:\n            return False\n        \n        if self.session_id not in registry:\n            return False\n        \n        session = registry[self.session_id]\n        if session.get(\"state\") != \"active\":\n            return False\n        \n        last_activity_str = session.get(\"last_activity\")\n        if not last_activity_str:\n            return False\n        \n        try:\n            last_activity = datetime.fromisoformat(last_activity_str)\n            current_time = datetime.utcnow()\n            inactive_seconds = (current_time - last_activity).total_seconds()\n            \n            if inactive_seconds > (timeout_minutes * 60):\n                # Mark as stalled\n                session[\"state\"] = \"stalled\"\n                session[\"stall_count\"] = session.get(\"stall_count\", 0) + 1\n                session[\"last_stall_time\"] = current_time.isoformat()\n                \n                # Save registry\n                with open(SESSION_REGISTRY, 'w') as f:\n                    json.dump(registry, f, indent=2)\n                \n                self.log_monitoring(f\"Detected stall for sub-agent {self.session_id}: inactive for {inactive_seconds:.0f} seconds\", level=\"WARNING\")\n                return True\n        except Exception as e:\n            self.log_monitoring(f\"Error detecting stall: {e}\", level=\"ERROR\")\n        \n        return False\n\n# Global instance for easy import\nsubagent_monitor = SubAgentMonitor()\n\nif __name__ == \"__main__\":\n    # Test the sub-agent monitoring integration\n    monitor = SubAgentMonitor(subagent_id=\"test_subagent_456\", parent_session_id=\"main_test_123\")\n    \n    # Test 1: Register sub-agent session\n    print(\"Test 1: Registering sub-agent session...\")\n    if monitor.register_subagent_session(\"Test sub-agent monitoring\", expected_runtime_minutes=5):\n        print(\"✓ Sub-agent session registered\")\n    else:\n        print(\"✗ Failed to register sub-agent session\")\n    \n    # Test 2: Update activity with progress\n    print(\"\\nTest 2: Updating activity with progress...\")\n    if monitor.update_activity(\"Processing data\", progress_percentage=25):\n        print(\"✓ Activity updated with progress\")\n    else:\n        print(\"✗ Failed to update activity\")\n    \n    # Test 3: Complete session with handoff report\n    print(\"\\nTest 3: Completing session with handoff report...\")\n    handoff_report = {\n        \"outcome\": \"success\",\n        \"files_created\": [\"test_output.txt\"],\n        \"incidents\": [],\n        \"next_actions\": [\"Review results\"]\n    }\n    if monitor.complete_session(\"success\", \"Test completed successfully\", handoff_report):\n        print(\"✓ Session completed with handoff report\")\n    else:\n        print(\"✗ Failed to complete session\")"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":72,"output":2682,"cacheRead":24192,"cacheWrite":0,"totalTokens":26946,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773102542143}}
