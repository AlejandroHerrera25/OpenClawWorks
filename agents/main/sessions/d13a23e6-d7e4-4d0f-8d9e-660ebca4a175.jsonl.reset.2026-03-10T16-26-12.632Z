{"type":"message","id":"7ce986a8","parentId":"268c0afd","timestamp":"2026-03-09T18:56:56.086Z","message":{"role":"assistant","content":[{"type":"text","text":"Necesito completar el archivo:"},{"type":"toolCall","id":"call_00_yS9GADP5PvtlDqXZcTWHbFg0","name":"edit","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/project_control.py","oldText":"        self._save_control_file()\n        self._sync_readme_with_control()\n        \n        logger.info('Updated","newText":"        self._save_control_file()\n        self._sync_readme_with_control()\n        \n        logger.info('Updated project info: %s', list(kwargs.keys()))\n        return True\n    \n    def add_incident(self, incident_type: str, description: str, \n                    severity: str = 'medium', evidence: str = None) -> str:\n        \"\"\"\n        Add an incident record.\n        \n        Args:\n            incident_type: Type of incident\n            description: Incident description\n            severity: Severity level (critical, high, medium, low)\n            evidence: Evidence or context\n            \n        Returns:\n            Incident ID\n        \"\"\"\n        incident_id = f'incident_{len(self.control_data[\"incidents\"]) + 1:03d}'\n        \n        incident = {\n            'id': incident_id,\n            'type': incident_type,\n            'description': description,\n            'severity': severity,\n            'evidence': evidence,\n            'timestamp': datetime.now().isoformat(),\n            'resolved': False,\n            'resolution': None\n        }\n        \n        self.control_data['incidents'].append(incident)\n        \n        # Save and sync\n        self._save_control_file()\n        self._sync_readme_with_control()\n        \n        logger.info('Added incident: %s (%s)', incident_type, severity)\n        return incident_id\n    \n    def resolve_incident(self, incident_id: str, resolution: str) -> bool:\n        \"\"\"\n        Mark an incident as resolved.\n        \n        Args:\n            incident_id: Incident ID to resolve\n            resolution: Resolution description\n            \n        Returns:\n            True if successful, False otherwise\n        \"\"\"\n        for incident in self.control_data['incidents']:\n            if incident['id'] == incident_id:\n                incident['resolved'] = True\n                incident['resolution'] = resolution\n                incident['resolved_timestamp'] = datetime.now().isoformat()\n                \n                # Save and sync\n                self._save_control_file()\n                self._sync_readme_with_control()\n                \n                logger.info('Resolved incident: %s', incident_id)\n                return True\n        \n        logger.warning('Incident not found: %s', incident_id)\n        return False\n    \n    def assign_specialist(self, role: str, specialist_id: str, \n                         task_description: str = None) -> str:\n        \"\"\"\n        Assign a specialist to the project.\n        \n        Args:\n            role: Specialist role\n            specialist_id: Specialist identifier\n            task_description: Task description\n            \n        Returns:\n            Assignment ID\n        \"\"\"\n        assignment_id = f'assignment_{len(self.control_data[\"specialist_assignments\"]) + 1:03d}'\n        \n        assignment = {\n            'id': assignment_id,\n            'role': role,\n            'specialist_id': specialist_id,\n            'task_description': task_description,\n            'assigned': datetime.now().isoformat(),\n            'completed': False,\n            'completion_date': None,\n            'artifacts_produced': []\n        }\n        \n        self.control_data['specialist_assignments'].append(assignment)\n        \n        # Save and sync\n        self._save_control_file()\n        self._sync_readme_with_control()\n        \n        logger.info('Assigned specialist: %s as %s', specialist_id, role)\n        return assignment_id\n    \n    def complete_assignment(self, assignment_id: str, artifacts: List[str] = None) -> bool:\n        \"\"\"\n        Mark a specialist assignment as completed.\n        \n        Args:\n            assignment_id: Assignment ID to complete\n            artifacts: List of artifacts produced\n            \n        Returns:\n            True if successful, False otherwise\n        \"\"\"\n        for assignment in self.control_data['specialist_assignments']:\n            if assignment['id'] == assignment_id:\n                assignment['completed'] = True\n                assignment['completion_date'] = datetime.now().isoformat()\n                \n                if artifacts:\n                    assignment['artifacts_produced'].extend(artifacts)\n                \n                # Save and sync\n                self._save_control_file()\n                self._sync_readme_with_control()\n                \n                logger.info('Completed assignment: %s', assignment_id)\n                return True\n        \n        logger.warning('Assignment not found: %s', assignment_id)\n        return False\n    \n    def get_project_summary(self) -> Dict:\n        \"\"\"Get a summary of project status.\"\"\"\n        current_state = self.control_data['current_state']\n        artifact_versions = self.control_data['artifact_versions']\n        next_actions = self.control_data['next_actions']\n        code_audits = self.control_data['code_audits']\n        \n        # Count completed vs pending actions\n        completed_actions = sum(1 for a in next_actions if a.get('completed', False))\n        pending_actions = len(next_actions) - completed_actions\n        \n        # Count open incidents\n        open_incidents = sum(1 for i in self.control_data['incidents'] if not i.get('resolved', True))\n        \n        # Count active assignments\n        active_assignments = sum(1 for a in self.control_data['specialist_assignments'] \n                                if not a.get('completed', True))\n        \n        summary = {\n            'project_name': self.control_data['project']['name'],\n            'current_state': current_state['state'],\n            'state_entered': current_state['entered'],\n            'artifact_count': sum(len(info.get('files', [])) for info in artifact_versions.values()),\n            'code_audit_count': len(code_audits),\n            'open_audits': sum(1 for a in code_audits if a.get('status') in ['open', 'in_remediation']),\n            'actions_completed': completed_actions,\n            'actions_pending': pending_actions,\n            'open_incidents': open_incidents,\n            'active_assignments': active_assignments,\n            'last_updated': self.control_data['project']['last_updated']\n        }\n        \n        return summary\n    \n    def export_control_data(self, format: str = 'yaml') -> str:\n        \"\"\"\n        Export control data in specified format.\n        \n        Args:\n            format: Export format (yaml, json)\n            \n        Returns:\n            Exported data as string\n        \"\"\"\n        if format.lower() == 'json':\n            return json.dumps(self.control_data, indent=2, ensure_ascii=False)\n        else:  # yaml\n            import yaml\n            return yaml.dump(self.control_data, default_flow_style=False, allow_unicode=True)\n    \n    def validate_state_transition(self, target_state: str, \n                                 context: Dict = None) -> Tuple[bool, List[str]]:\n        \"\"\"\n        Validate if transition to target state is allowed.\n        This integrates with the state machine engine.\n        \n        Args:\n            target_state: Target state name\n            context: Transition context\n            \n        Returns:\n            (is_valid, reasons)\n        \"\"\"\n        # This would integrate with the StateMachineEngine\n        # For now, do basic validation\n        current_state = self.control_data['current_state']['state']\n        \n        if current_state == target_state:\n            return True, ['State unchanged']\n        \n        # Simple validation logic - in production would use StateMachineEngine\n        allowed_transitions = {\n            'DISCOVERY': ['REQUIREMENTS', 'FIT_GAP'],\n            'REQUIREMENTS': ['FIT_GAP', 'DESIGN'],\n            'FIT_GAP': ['DESIGN', 'REQUIREMENTS'],\n            'DESIGN': ['DATA_MODEL', 'ARCH_REVIEW', 'FIT_GAP'],\n            'DATA_MODEL': ['ARCH_REVIEW', 'DESIGN', 'CODE_AUDIT'],\n            'ARCH_REVIEW': ['CODE_AUDIT', 'REMEDIATION', 'FINALIZED', 'DESIGN', 'DATA_MODEL'],\n            'CODE_AUDIT': ['REMEDIATION', 'ARCH_REVIEW', 'FINALIZED'],\n            'REMEDIATION': ['CODE_AUDIT', 'ARCH_REVIEW', 'FINALIZED'],\n            'FINALIZED': []\n        }\n        \n        if target_state in allowed_transitions.get(current_state, []):\n            return True, ['Transition allowed']\n        \n        # Check for regression (moving to earlier state)\n        state_order = ['DISCOVERY', 'REQUIREMENTS', 'FIT_GAP', 'DESIGN', \n                      'DATA_MODEL', 'ARCH_REVIEW', 'CODE_AUDIT', 'REMEDIATION', 'FINALIZED']\n        \n        current_idx = state_order.index(current_state) if current_state in state_order else -1\n        target_idx = state_order.index(target_state) if target_state in state_order else -1\n        \n        if target_idx < current_idx:\n            # Regression - check context\n            if context and context.get('regression_reason'):\n                return True, [f'Regression allowed: {context[\"regression_reason\"]}']\n            else:\n                return False, ['Regression requires valid reason']\n        \n        return False, [f'Transition {current_state} → {target_state} not allowed']\n\n# Utility functions for easy integration\ndef get_project_control(project_root: Path) -> ProjectControl:\n    \"\"\"Get or create project control for a project.\"\"\"\n    return ProjectControl(project_root)\n\ndef update_project_state(project_root: Path, new_state: str, **kwargs) -> bool:\n    \"\"\"Convenience function to update project state.\"\"\"\n    control = ProjectControl(project_root)\n    return control.update_state(new_state, **kwargs)\n\ndef get_project_summary(project_root: Path) -> Dict:\n    \"\"\"Convenience function to get project summary.\"\"\"\n    control = ProjectControl(project_root)\n    return control.get_project_summary()\n\nif __name__ == '__main__':\n    # Test the project control system\n    test_project = Path.home() / '.openclaw' / 'workspace' / 'projects' / 'test_control_system'\n    \n    # Clean up any existing test\n    import shutil\n    if test_project.exists():\n        shutil.rmtree(test_project)\n    \n    try:\n        # Create project control\n        control = ProjectControl(test_project)\n        \n        print('✅ Project control created')\n        print(f'Project: {control.control_data[\"project\"][\"name\"]}')\n        print(f'Initial state: {control.control_data[\"current_state\"][\"state\"]}')\n        \n        # Update state\n        control.update_state('REQUIREMENTS', trigger='discovery_complete')\n        print('✅ State updated to REQUIREMENTS')\n        \n        # Register artifacts\n        control.register_artifact('discovery', 'Discovery_Report.md', version_increment=True)\n        control.register_artifact('discovery', 'Discovery_QA.xlsx')\n        print('✅ Artifacts registered')\n        \n        # Add next actions\n        action_id = control.add_next_action(\n            title='Complete requirements gathering',\n            description='Interview stakeholders and document requirements',\n            priority='high',\n            assigned_to='Functional Consultant',\n            due_date='2026-03-10'\n        )\n        print(f'✅ Next action added: {action_id}')\n        \n        # Add code audit\n        control.add_code_audit(\n            case_id='AUDIT-001',\n            mode='A',\n            findings_summary='3 critical security issues found',\n            status='open'\n        )\n        print('✅ Code audit added')\n        \n        # Assign specialist\n        assignment_id = control.assign_specialist(\n            role='Functional Consultant',\n            specialist_id='FC-001',\n            task_description='Requirements analysis'\n        )\n        print(f'✅ Specialist assigned: {assignment_id}')\n        \n        # Get summary\n        summary = control.get_project_summary()\n        print('\\n📊 Project Summary:')\n        for key, value in summary.items():\n            print(f'  {key}: {value}')\n        \n        # Export control data\n        yaml_export = control.export_control_data('yaml')\n        print(f'\\n📄 Control data size: {len(yaml_export)} bytes')\n        \n        # Validate README exists\n        readme_path = test_project / 'README.md'\n        if readme_path.exists():\n            readme_content = readme_path.read_text(encoding='utf-8')\n            print(f'\\n📖 README.md created ({len(readme_content)} bytes)')\n            print('First 5 lines:')\n            for line in readme_content.split('\\n')[:5]:\n                print(f'  {line}')\n        \n        print('\\n🎉 Project control system test completed successfully')\n        \n    finally:\n        # Cleanup\n        if test_project.exists():\n            shutil.rmtree(test_project)\n            print('\\n🧹 Test project cleaned up')"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":21473,"output":2845,"cacheRead":81728,"cacheWrite":0,"totalTokens":106046,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773082520688}}
