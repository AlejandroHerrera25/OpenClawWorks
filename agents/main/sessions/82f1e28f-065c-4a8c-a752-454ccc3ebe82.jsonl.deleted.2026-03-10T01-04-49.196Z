{"type":"message","id":"c4c481f9","parentId":"14b0d9a8","timestamp":"2026-03-10T00:04:32.045Z","message":{"role":"assistant","content":[{"type":"text","text":"Let me create realistic APEX classes with both good and bad patterns:"},{"type":"toolCall","id":"call_00_L1jsyBxg54JNv2HidZG75Mtd","name":"write","arguments":{"path":"~/.openclaw/workspace/fixtures/real_salesforce_samples/AccountController.cls","content":"/**\n * AccountController - Example with BAD patterns for testing\n * Contains SOQL in loops, missing FLS checks, poor error handling\n */\npublic with sharing class AccountController {\n    \n    // BAD: SOQL in loop\n    public static void updateAccountContacts(List<Id> accountIds) {\n        List<Account> accounts = [SELECT Id, Name FROM Account WHERE Id IN :accountIds];\n        \n        for(Account acc : accounts) {\n            // BAD: SOQL inside loop\n            List<Contact> contacts = [SELECT Id, FirstName, LastName FROM Contact WHERE AccountId = :acc.Id];\n            \n            for(Contact con : contacts) {\n                con.Description = 'Updated by AccountController';\n            }\n            \n            // BAD: DML in loop\n            update contacts;\n        }\n    }\n    \n    // BAD: Missing FLS check\n    public static Account createAccount(String name, String industry) {\n        Account acc = new Account();\n        acc.Name = name;\n        acc.Industry = industry;\n        acc.AnnualRevenue = 1000000;\n        \n        // BAD: No FLS check before insert\n        insert acc;\n        return acc;\n    }\n    \n    // BAD: Weak error handling\n    public static void processOpportunities(List<Id> accountIds) {\n        try {\n            List<Opportunity> opps = [SELECT Id, Name, Amount FROM Opportunity WHERE AccountId IN :accountIds];\n            \n            for(Opportunity opp : opps) {\n                opp.StageName = 'Closed Won';\n                opp.CloseDate = Date.today();\n            }\n            \n            update opps;\n        } catch(Exception e) {\n            // BAD: Generic catch, no specific handling\n            System.debug('Error: ' + e.getMessage());\n        }\n    }\n    \n    // BAD: Mixed concerns - both UI and business logic\n    public static String getAccountSummary(Id accountId) {\n        Account acc = [SELECT Id, Name, Industry, AnnualRevenue FROM Account WHERE Id = :accountId];\n        \n        // Business logic mixed with presentation\n        String summary = 'Account: ' + acc.Name + '\\\\n';\n        summary += 'Industry: ' + acc.Industry + '\\\\n';\n        summary += 'Revenue: $' + acc.AnnualRevenue;\n        \n        return summary;\n    }\n}"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":56,"output":581,"cacheRead":17792,"cacheWrite":0,"totalTokens":18429,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101054036}}
