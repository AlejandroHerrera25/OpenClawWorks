from findings.\"\"\"\n        concerns = []\n        critical_findings = [f for f in self.findings['findings'] if f['severity'] == 'CRITICAL']\n        \n        for finding in critical_findings[:3]:  # Top 3 concerns\n            if 'SOQL' in finding['pattern']:\n                concerns.append(\"performance/scalability\")\n            elif 'FLS' in finding['pattern']:\n                concerns.append(\"security\")\n            elif 'RECURSION' in finding['pattern']:\n                concerns.append(\"reliability\")\n        \n        return \", \".join(set(concerns)) if concerns else \"code quality\"\n    \n    def _get_evidence_based_recommendations(self):\n        \"\"\"Get evidence-based recommendations.\"\"\"\n        recommendations = []"}],"details":{"status":"completed","exitCode":0,"durationMs":63,"aggregated":"def _get_risk_analysis(self):\n        \"\"\"Get risk analysis.\"\"\"\n        analysis = []\n        \n        overall = self.risk_assessment['risk_assessment']['overall_risk']\n        \n        analysis.append(\"#### Risk of Current Architecture:\")\n        analysis.append(f\"- **Current Risk Level**: {overall['level']} ({overall['score']}/100)\")\n        \n        if overall['level'] in ['CRITICAL', 'HIGH']:\n            analysis.append(\"- **Risk Assessment**: Architecture carries significant risk\")\n            analysis.append(\"- **Primary Concerns**: \" + self._get_primary_concerns())\n        else:\n            analysis.append(\"- **Risk Assessment**: Architecture is relatively low risk\")\n            analysis.append(\"- **Minor Concerns**: Review medium findings for optimization\")\n        \n        analysis.append(\"\\n#### Risk of Proposed Changes:\")\n        analysis.append(\"- **Implementation Risk**: Low to Medium (standard refactoring)\")\n        analysis.append(\"- **Regression Risk**: Medium (requires thorough testing)\")\n        analysis.append(\"- **Timeline Risk**: Depends on remediation scope\")\n        \n        analysis.append(\"\\n#### Risk of No Changes:\")\n        if overall['level'] in ['CRITICAL', 'HIGH']:\n            analysis.append(\"- **High Risk**: System failures, security vulnerabilities likely\")\n            analysis.append(\"- **Business Impact**: Potential data loss, performance issues\")\n        else:\n            analysis.append(\"- **Low Risk**: System functional but suboptimal\")\n            analysis.append(\"- **Business Impact**: Technical debt accumulation\")\n        \n        return \"\\n\".join(analysis)\n    \n    def _get_primary_concerns(self):\n        \"\"\"Get primary concerns from findings.\"\"\"\n        concerns = []\n        critical_findings = [f for f in self.findings['findings'] if f['severity'] == 'CRITICAL']\n        \n        for finding in critical_findings[:3]:  # Top 3 concerns\n            if 'SOQL' in finding['pattern']:\n                concerns.append(\"performance/scalability\")\n            elif 'FLS' in finding['pattern']:\n                concerns.append(\"security\")\n            elif 'RECURSION' in finding['pattern']:\n                concerns.append(\"reliability\")\n        \n        return \", \".join(set(concerns)) if concerns else \"code quality\"\n    \n    def _get_evidence_based_recommendations(self):\n        \"\"\"Get evidence-based recommendations.\"\"\"\n        recommendations = []","cwd":"/home/openclaw/.openclaw/workspace"},"isError":false,"timestamp":1773103197549}}
{"type":"message","id":"e2fc5340","parentId":"76f16b55","timestamp":"2026-03-10T00:41:55.840Z","message":{"role":"assistant","content":[{"type":"text","text":"The file is corrupted - it's missing the class definition and starts with a method. Let me recreate it properly:"},{"type":"toolCall","id":"call_00_S4qJPK7pWCkRlBdwH0Ym6uMg","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/salesforce-code-auditor/scripts/report_generator.py","content":"#!/usr/bin/env python3\n\"\"\"\nComplete Audit Report Generator - Produce architect-consumable reports.\n\"\"\"\n\nimport argparse\nimport os\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom utils_fs import read_file, write_file, read_json, write_json\n\nWORKSPACE_ROOT = Path(os.getenv('WORKSPACE', '/home/openclaw/.openclaw/workspace'))\n\nclass ReportGenerator:\n    \"\"\"Generate complete audit reports for architect consumption.\"\"\"\n    \n    def __init__(self, project_key, case_id, mode='A'):\n        self.project_key = project_key\n        self.case_id = case_id\n        self.mode = mode  # A, B, or C\n        self.case_root = WORKSPACE_ROOT / 'projects' / project_key / 'code_audit' / case_id\n        \n    def load_all_data(self):\n        \"\"\"Load all audit data.\"\"\"\n        self.manifest = read_json(self.case_root / 'MANIFEST.json')\n        self.dependency_graph = read_json(self.case_root / 'DEPENDENCY_GRAPH.json')\n        self.entrypoints = read_json(self.case_root / 'ENTRYPOINTS.json')\n        self.findings = read_json(self.case_root / 'FINDINGS_DETAILED.json')\n        self.risk_assessment = read_json(self.case_root / 'RISK_ASSESSMENT.json')\n        \n        # Try to load execution trace and test matrix\n        try:\n            self.execution_trace = read_file(self.case_root / 'EXECUTION_TRACE.md')\n        except:\n            self.execution_trace = \"Execution trace not available\"\n            \n        try:\n            self.test_matrix = read_file(self.case_root / 'TEST_MATRIX.md')\n        except:\n            self.test_matrix = \"Test matrix not available\"\n    \n    def generate_architect_report(self):\n        \"\"\"Generate architect-consumable report based on mode.\"\"\"\n        if self.mode == 'A':\n            return self._generate_mode_a_report()\n        elif self.mode == 'B':\n            return self._generate_mode_b_report()\n        elif self.mode == 'C':\n            return self._generate_mode_c_report()\n        else:\n            return self._generate_generic_report()\n    \n    def _generate_mode_a_report(self):\n        \"\"\"Generate Mode A report: Architecture → Code Audit.\"\"\"\n        report = f\"\"\"## Code Audit Report - Mode A\n\n**Project**: {self.project_key}\n**Audit Case ID**: {self.case_id}\n**Mode**: Architecture → Code Audit\n**Report Date**: {datetime.utcnow().isoformat()}Z\n\n### Executive Summary\n\"\"\"\n        \n        # Overall assessment\n        total_findings = self.findings['metadata']['total_findings']\n        critical_count = self.findings['metadata']['severity_counts']['CRITICAL']\n        high_count = self.findings['metadata']['severity_counts']['HIGH']\n        overall_risk = self.risk_assessment['risk_assessment']['overall_risk']\n        \n        report += f\"- **Code Health**: {self._get_code_health_assessment()}\\n\"\n        report += f\"- **Overall Risk**: {overall_risk['level']} ({overall_risk['score']}/100)\\n\"\n        report += f\"- **Total Findings**: {total_findings}\\n\"\n        report += f\"- **Critical Findings**: {critical_count}\\n\"\n        report += f\"- **High Findings**: {high_count}\\n\"\n        report += f\"- **Architectural Implications**: {self._get_architectural_implications()}\\n\\n\"\n        \n        # Technical Assessment\n        report += \"### Technical Assessment\\n\"\n        report += self._get_technical_assessment() + \"\\n\\n\"\n        \n        # Constraints & Limitations\n        report += \"### Constraints & Limitations\\n\"\n        report += self._get_constraints_limitations() + \"\\n\\n\"\n        \n        # Risk Assessment\n        report += \"### Risk Assessment\\n\"\n        report += self._get_risk_assessment_summary() + \"\\n\\n\"\n        \n        # Recommendations for Architecture\n        report += \"### Recommendations for Architecture\\n\"\n        report += self._get_architectural_recommendations() + \"\\n\\n\"\n        \n        # Evidence\n        report += \"### Evidence\\n\"\n        report += self._get_evidence_section() + \"\\n\"\n        \n        return report\n    \n    def _generate_mode_b_report(self):\n        \"\"\"Generate Mode B report: Code Audit → Architecture.\"\"\"\n        report = f\"\"\"## Code Audit Report - Mode B\n\n**Project**: {self.project_key}\n**Audit Case ID**: {self.case_id}\n**Mode**: Code Audit → Architecture\n**Report Date**: {datetime.utcnow().isoformat()}Z\n\n### Critical Findings Summary\n\"\"\"\n        \n        # Get critical and high findings\n        critical_findings = []\n        high_findings = []\n        \n        for finding in self.findings['findings']:\n            if finding['severity'] == 'CRITICAL':\n                critical_findings.append(finding)\n            elif finding['severity'] == 'HIGH':\n                high_findings.append(finding)\n        \n        report += f\"- **Critical Findings Requiring Architectural Changes**: {len(critical_findings)}\\n\"\n        report += f\"- **High Impact Findings**: {len(high_findings)}\\n\"\n        report += f\"- **Immediate Risks**: {self._get_immediate_risks()}\\n\\n\"\n        \n        # List critical findings\n        if critical_findings:\n            report += \"#### Critical Findings:\\n\"\n            for finding in critical_findings:\n                report += f\"- **{finding['pattern']}** in `{finding['file']}:{finding['line']}`\\n\"\n                report += f\"  - {finding['description']}\\n\"\n                report += f\"  - Impact: {finding['impact']}\\n\"\n            report += \"\\n\"\n        \n        # Architectural Impact Assessment\n        report += \"### Architectural Impact Assessment\\n\"\n        report += self._get_architectural_impact() + \"\\n\\n\"\n        \n        # Remediation Options\n        report += \"### Remediation Options\\n\"\n        report += self._get_remediation_options() + \"\\n\\n\"\n        \n        # Risk Analysis\n        report += \"### Risk Analysis\\n\"\n        report += self._get_risk_analysis() + \"\\n\\n\"\n        \n        # Evidence-Based Recommendations\n        report += \"### Evidence-Based Recommendations\\n\"\n        report += self._get_evidence_based_recommendations() + \"\\n\\n\"\n        \n        # Evidence\n        report += \"### Evidence\\n\"\n        report += self._get_detailed_evidence() + \"\\n\"\n        \n        return report\n    \n    def _generate_mode_c_report(self):\n        \"\"\"Generate Mode C report: Design Validation.\"\"\"\n        report = f\"\"\"## Code Audit Report - Mode C\n\n**Project**: {self.project_key}\n**Audit Case ID**: {self.case_id}\n**Mode**: Design Validation\n**Report Date**: {datetime.utcnow().isoformat()}Z\n\n### Design Feasibility Assessment\n\"\"\"\n        \n        # Feasibility assessment\n        feasibility = self._assess_design_feasibility()\n        report += f\"- **Overall Feasibility**: {feasibility['overall']}\\n\"\n        report += f\"- **Key Feasibility Concerns**: {feasibility['concerns']}\\n\"\n        report += f\"- **Supporting Evidence**: {feasibility['evidence']}\\n\\n\"\n        \n        # Gap Analysis\n        report += \"### Gap Analysis\\n\"\n        report += self._get_gap_analysis() + \"\\n\\n\"\n        \n        # Implementation Complexity\n        report += \"### Implementation Complexity\\n\"\n        report += self._get_implementation_complexity() + \"\\n\\n\"\n        \n        # Recommendations\n        report += \"### Recommendations\\n\"\n        report += self._get_design_recommendations() + \"\\n\\n\"\n        \n        # Evidence\n        report += \"### Evidence\\n\"\n        report += self._get_design_evidence() + \"\\n\"\n        \n        return report\n    \n    def _generate_generic_report(self):\n        \"\"\"Generate generic audit report.\"\"\"\n        report = f\"\"\"# Complete Audit Report\n\n**Project**: {self.project_key}\n**Audit Case ID**: {self.case_id}\n**Report Date**: {datetime.utcnow().isoformat()}Z\n\n## Executive Summary\n{self._get_executive_summary()}\n\n## Technical Assessment\n{self._get_technical_assessment()}\n\n## Risk Assessment\n{self._get_risk_assessment_summary()}\n\n## Findings by Severity\n{self._get_findings_by_severity()}\n\n## Recommendations\n{self._get_all_recommendations()}\n\n## Evidence\n{self._get_complete_evidence()}\n\"\"\"\n        return report\n    \n    # Helper methods for report sections\n    def _get_code_health_assessment(self):\n        \"\"\"Assess overall code health.\"\"\"\n        total_findings = self.findings['metadata']['total_findings']\n        critical_count = self.findings['metadata']['severity_counts']['CRITICAL']\n        \n        if critical_count > 0:\n            return \"POOR - Critical issues require immediate attention\"\n        elif total_findings > 10:\n            return \"FAIR - Multiple issues need addressing\"\n        elif total_findings > 5:\n            return \"GOOD - Some improvements needed\"\n        else:\n            return \"EXCELLENT - Minimal issues found\"\n    \n    def _get_architectural_implications(self):\n        \"\"\"Get architectural implications.\"\"\"\n        blockers = self.risk_assessment['risk_assessment']['blocking_conditions']\n        critical_blockers = len(blockers['critical_blockers'])\n        \n        if critical_blockers > 0:\n            return f\"{critical_blockers} critical findings block architectural decisions\"\n        else:\n            return \"No critical blockers found; architecture can proceed with review of high/medium findings\"\n    \n    def _get_technical_assessment(self):\n        \"\"\"Generate technical assessment.\"\"\"\n        assessment = []\n        \n        # UI Layer\n        ui_components = len([ep for ep in self.entrypoints.get('entrypoints', []) \n                           if ep['type'] in ['vf_page', 'lwc', 'apex_aura']])\n        assessment.append(f\"- **UI Layer**: {ui_components} entry points identified\")\n        \n        # Controller Layer\n        apex_files = len([node for node in self.dependency_graph.get('nodes', [])\n                         if node.get('type') == 'apex'])\n        assessment.append(f\"- **Controller Layer**: {apex_files} Apex classes analyzed\")\n        \n        # Dependencies\n        edges = len(self.dependency_graph.get('edges', []))\n        assessment.append(f\"- **Dependencies**: {edges} dependency relationships mapped\")\n        \n        # Code patterns\n        patterns = set(f['pattern'] for f in self.findings['findings'])\n        assessment.append(f\"- **Patterns Detected**: {len(patterns)} distinct issue patterns\")\n        \n        return \"\\n\".join(assessment)\n    \n    def _get_constraints_limitations(self):\n        \"\"\"Get constraints and limitations.\"\"\"\n        constraints = []\n        \n        # Technical constraints from findings\n        critical_patterns = ['SOQL_IN_LOOP', 'GOVERNOR_LIMIT', 'PERFORMANCE']\n        for finding in self.findings['findings']:\n            if finding['severity'] == 'CRITICAL' and any(p in finding['pattern'] for p in critical_patterns):\n                constraints.append(f\"- {finding['description']} in {finding['file']}\")\n        \n        if not constraints:\n            constraints.append(\"- No critical technical constraints identified\")\n            constraints.append(\"- Review high/medium findings for optimization opportunities\")\n        \n        # Integration limitations\n        integration_files = [node for node in self.dependency_graph.get('nodes', [])\n                           if 'integration' in node.get('type', '').lower() or \n                           'callout' in node.get('name', '').lower()]\n        if integration_files:\n            constraints.append(f\"- {len(integration_files)} integration points identified - review error handling\")\n        \n        return \"\\n\".join(constraints)\n    \n    def _get_risk_assessment_summary(self):\n        \"\"\"Get risk assessment summary.\"\"\"\n        overall = self.risk_assessment['risk_assessment']['overall_risk']\n        blockers = self.risk_assessment['risk_assessment']['blocking_conditions']\n        \n        summary = []\n        summary.append(f\"- **Overall Risk Level**: {overall['level']} ({overall['score']}/100)\")\n        \n        # Risk by category\n        for category, stats in overall['by_category'].items():\n            summary.append(f\"- **{category} Risk**: {stats['average_score']:.1f}/100 ({stats['finding_count']} findings)\")\n        \n        # Blocking conditions\n        if blockers['critical_blockers']:\n            summary.append(f\"- **Critical Blockers**: {len(blockers['critical_blockers'])} findings must be addressed\")\n        if blockers['high_blockers']:\n            summary.append(f\"- **High Blockers**: {len(blockers['high_blockers'])} findings should be addressed\")\n        \n        return \"\\n\".join(summary)\n    \n    def _get_architectural_recommendations(self):\n        \"\"\"Get architectural recommendations.\"\"\"\n        recommendations = []\n        priority = 1\n        \n        # Critical findings first\n        for finding in self.findings['findings']:\n            if finding['severity'] == 'CRITICAL':\n                recommendations.append(f\"{priority}. **{finding['pattern']}** in `{finding['file']}`: {finding['recommendation']}\")\n                priority += 1\n        \n        # High findings next\n        for finding in self.findings['findings']:\n            if finding['severity'] == 'HIGH':\n                recommendations.append(f\"{priority}. **{finding['pattern']}** in `{finding['file']}`: {finding['recommendation']}\")\n                priority += 1\n        \n        if not recommendations:\n            recommendations.append(\"1. No critical or high findings - proceed with current architecture\")\n            recommendations.append(\"2. Review medium findings for optimization opportunities\")\n        \n        return \"\\n\".join(recommendations)\n    \n    def _get_evidence_section(self):\n        \"\"\"Get evidence section.\"\"\"\n        evidence = []\n        \n        # Code snippets\n        critical_findings = [f for f in self.findings['findings'] if f['severity'] in ['CRITICAL', 'HIGH']]\n        if critical_findings:\n            evidence.append(\"#### Code Snippets with Issues:\")\n            for finding in critical_findings[:3]:  # Show top 3\n                evidence.append(f\"- `{finding['file']}:{finding['line']}` - {finding['pattern']}\")\n                evidence.append(f\"  ```\\n  {finding['code_snippet'][:100]}...\\n  ```\")\n        \n        # Dependency graph summary\n        nodes = len(self.dependency_graph.get('nodes', []))\n        edges = len(self.dependency_graph.get('edges', []))\n        evidence.append(f\"\\n#### Dependency Analysis:\")\n        evidence.append(f\"- **Files Analyzed**: {nodes}\")\n        evidence.append(f\"- **Relationships Mapped**: {edges}\")\n        \n        # Performance metrics\n        evidence.append(\"\\n#### Performance Indicators:\")\n        soql_issues = len([f for f in self.findings['findings'] if 'SOQL' in f['pattern']])\n        fls_issues = len([f for f in self.findings['findings'] if 'FLS' in f['pattern']])\n        evidence.append(f\"- **SOQL Issues**: {soql_issues}\")\n        evidence.append(f\"- **Security Issues**: {fls_issues}\")\n        \n        return \"\\n\".join(evidence)\n    \n    # Additional helper methods for Mode B and C\n    def _get_immediate_risks(self):\n        \"\"\"Get immediate risks.\"\"\"\n        risks = []\n        for finding in self.findings['findings']:\n            if finding['severity'] == 'CRITICAL':\n                if 'SOQL_IN_LOOP' in finding['pattern']:\n                    risks.append(\"Governor limit exhaustion\")\n                elif 'FLS' in finding['pattern']:\n                    risks.append(\"Security vulnerability\")\n                elif 'RECURSION' in finding['pattern']:\n                    risks.append(\"Infinite loop risk\")\n        \n        if not risks:\n            return \"No immediate critical risks identified\"\n        return \", \".join(set(risks))\n    \n    def _get_architectural_impact(self):\n        \"\"\"Get architectural impact assessment.\"\"\"\n        impact = []\n        \n        # Analyze impact of critical findings\n        critical_patterns = set()\n        for finding in self.findings['findings']:\n            if finding['severity'] == 'CRITICAL':\n                critical_patterns.add(finding['pattern'])\n        \n        if 'SOQL_IN_LOOP' in critical_patterns:\n            impact.append(\"- **Performance Architecture**: Current design may not scale; requires query optimization\")\n        if 'FLS_MISSING' in critical_patterns:\n            impact.append(\"- **Security Architecture**: Missing security layer; requires security pattern implementation\")\n        if 'RECURSION_RISK' in critical_patterns:\n            impact.append(\"- **Trigger Architecture**: Risk of infinite recursion; requires guard pattern\")\n        \n        if not impact:\n            impact.append(\"- **Minimal Architectural Impact**: No critical findings requiring architectural changes\")\n            impact.append(\"- **Review High Findings**: Some findings may require design pattern adjustments\")\n        \n        return \"\\n\".join(impact)\n    \n    def _get_remediation_options(self):\n        \"\"\"Get remediation options.\"\"\"\n        options = []\n        \n        # Option A: Immediate fixes\n        options.append(\"#### Option A: Immediate Critical Fixes\")\n        options.append(\"- **Description**: Address only CRITICAL findings before proceeding\")\n        options.append(\"- **Effort**: Low to Medium\")\n        options.append(\"- **Impact**: Removes blocking conditions, allows architecture to proceed\")\n        options.append(\"- **Risk**: Medium - some technical debt remains\")\n        \n        # Option B: Comprehensive remediation\n        options.append(\"\\n#### Option B: Comprehensive Remediation\")\n        options.append(\"- **Description**: Address all CRITICAL and HIGH findings\")\n        options.append(\"- **Effort**: Medium to High\")\n        options.append(\"- **Impact**: Significant improvement in code quality and security\")\n        options.append(\"- **Risk**: Low - reduces technical debt substantially\")\n        \n        # Option C: Phased approach\n        options.append(\"\\n#### Option C: Phased Approach\")\n        options.append(\"- **Description**: Address CRITICAL now, HIGH in next release, MEDIUM/LOW as capacity allows\")\n        options.append(\"- **Effort**: Spread across multiple releases\")\n        options.append(\"- **Impact**: Balanced approach, manageable workload\")\n        options.append(\"- **Risk**: Low to Medium - some issues"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":541,"output":4096,"cacheRead":52672,"cacheWrite":0,"totalTokens":57309,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"length","timestamp":1773103197555}}
