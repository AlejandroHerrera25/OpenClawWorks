{"type":"message","id":"f0caf618","parentId":"3bef8e8a","timestamp":"2026-03-10T00:16:31.160Z","message":{"role":"toolResult","toolCallId":"call_00_URucI26Jh7REON5L5WUSCc2m","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nTest script for Architect ↔ Auditor Integration.\nValidates all integration components work together.\n\"\"\"\n\nimport os\nimport sys\nimport tempfile\nimport shutil\nimport json\nfrom pathlib import Path\n\n# Add script directory to path\nsys.path.insert(0, str(Path(__file__).parent))\n\nfrom auditor_integration import AuditorIntegration, invoke_auditor_with_control\nfrom state_machine_engine_enhanced import EnhancedStateMachineEngine\nfrom state_machine_engine import State\nfrom dod_auditor_validator import validate_auditor_output_comprehensive, get_auditor_validation_summary\n\ndef test_integration():\n    \"\"\"Test the complete architect ↔ auditor integration.\"\"\"\n    \n    print(\"🧪 Testing Architect ↔ Auditor Integration\")\n    print(\"=\" * 60)\n    \n    # Create test project\n    test_project = Path(tempfile.mkdtemp(prefix='test_auditor_integration_'))\n    print(f\"Test project: {test_project}\")\n    \n    all_tests_passed = True\n    test_results = []\n    \n    try:\n        # Test 1: Auditor Integration Initialization\n        print(\"\\n1️⃣ Testing AuditorIntegration initialization...\")\n        try:\n            integration = AuditorIntegration(test_project)\n            print(\"  ✅ AuditorIntegration initialized successfully\")\n            test_results.append((\"AuditorIntegration init\", \"PASS\"))\n        except Exception as e:\n            print(f\"  ❌ AuditorIntegration init failed: {e}\")\n            test_results.append((\"AuditorIntegration init\", \"FAIL\"))\n            all_tests_passed = False\n        \n        # Test 2: Mode A Audit Invocation\n        print(\"\\n2️⃣ Testing Mode A audit invocation...\")\n        try:\n            result_a = integration.invoke_auditor(\n                mode='A',\n                audit_objectives=[\n                    'Assess current code health',\n                    'Identify technical constraints'\n                ],\n                scope={\n                    'included': ['apex_classes', 'triggers'],\n                    'excluded': ['test_classes'],\n                    'depth': 'detailed_analysis'\n                },\n                context={\n                    'business_process': 'Order management',\n                    'current_pain_points': ['Performance issues']\n                }\n            )\n            \n            print(f\"  ✅ Mode A audit invoked\")\n            print(f\"    Case ID: {result_a['case_id']}\")\n            print(f\"    Validation: {result_a['validation_result']['validation_status']}\")\n            print(f\"    Compliance: {result_a['validation_result']['compliance_percentage']}%\")\n            \n            # Check project control registration\n            audits = integration.hardening.project_control.control_data['code_audits']\n            audit_registered = any(a['case_id'] == result_a['case_id'] for a in audits)\n            print(f\"    Project control registered: {'✅ Yes' if audit_registered else '❌ No'}\")\n            \n            test_results.append((\"Mode A invocation\", \"PASS\"))\n            \n        except Exception as e:\n            print(f\"  ❌ Mode A invocation failed: {e}\")\n            test_results.append((\"Mode A invocation\", \"FAIL\"))\n            all_tests_passed = False\n        \n        # Test 3: Mode B Audit Invocation\n        print(\"\\n3️⃣ Testing Mode B audit invocation...\")\n        try:\n            result_b = integration.invoke_auditor(\n                mode='B',\n                audit_objectives=[\n                    'Identify security vulnerabilities',\n                    'Assess architectural impact'\n                ],\n                scope={\n                    'included': ['security_layer', 'authentication'],\n                    'depth': 'security_focus'\n                },\n                context={\n                    'trigger': 'Security review required',\n                    'architectural_context': 'Auth system redesign'\n                }\n            )\n            \n            print(f\"  ✅ Mode B audit invoked\")\n            print(f\"    Case ID: {result_b['case_id']}\")\n            print(f\"    Validation: {result_b['validation_result']['validation_status']}\")\n            print(f\"    Blocks transition: {result_b['blocking_status']['blocks_transition']}\")\n            \n            test_results.append((\"Mode B invocation\", \"PASS\"))\n            \n        except Exception as e:\n            print(f\"  ❌ Mode B invocation failed: {e}\")\n            test_results.append((\"Mode B invocation\", \"FAIL\"))\n            all_tests_passed = False\n        \n        # Test 4: Enhanced State Machine with Audit Blocking\n        print(\"\\n4️⃣ Testing enhanced state machine with audit blocking...\")\n        try:\n            engine = EnhancedStateMachineEngine(test_project)\n            \n            # Check transition with blocking audit\n            is_valid, reasons = engine.validate_transition(\n                State.ARCH_REVIEW\n            )\n            \n            print(f\"  ✅ Enhanced state machine initialized\")\n            print(f\"    Current state: {engine.current_state.value}\")\n            print(f\"    ARCH_REVIEW transition valid: {'✅ Yes' if is_valid else '❌ No'}\")\n            \n            if not is_valid and reasons:\n                print(f\"    Blocking reasons: {reasons[:2]}\")\n            \n            # Get audit blocking summary\n            summary = engine.get_audit_blocking_summary()\n            print(f\"    Total audits: {summary['total_audits']}\")\n            print(f\"    Blocking audits: {summary['blocking_audits']}\")\n            \n            test_results.append((\"Enhanced state machine\", \"PASS\"))\n            \n        except Exception as e:\n            print(f\"  ❌ Enhanced state machine failed: {e}\")\n            test_results.append((\"Enhanced state machine\", \"FAIL\"))\n            all_tests_passed = False\n        \n        # Test 5: DoD Auditor Validator\n        print(\"\\n5️⃣ Testing DoD auditor validator...\")\n        try:\n            # Create test audit output\n            test_audit = {\n                'executive_summary': 'Code has security vulnerabilities',\n                'technical_assessment': 'Found critical issues in auth',\n                'constraints_limitations': ['Governor limits'],\n                'risk_assessment': {'critical': 1, 'high': 2},\n                'recommendations_for_architecture': ['Implement OAuth'],\n                'evidence': 'Code snippets with line numbers'\n            }\n            \n            validation = validate_auditor_output_comprehensive(test_audit, 'A')\n            \n            print(f\"  ✅ DoD auditor validator executed\")\n            print(f\"    Validation status: {validation['status']}\")\n            print(f\"    Overall score: {validation['overall_score'] * 100:.1f}%\")\n            \n            # Print summary\n            summary = get_auditor_validation_summary(validation)\n            print(f\"    Summary:\\n{summary}\")\n            \n            test_results.append((\"DoD auditor validator\", \"PASS\"))\n            \n        except Exception as e:\n            print(f\"  ❌ DoD auditor validator failed: {e}\")\n            test_results.append((\"DoD auditor validator\", \"FAIL\"))\n            all_tests_passed = False\n        \n        # Test 6: Incident Generation\n        print(\"\\n6️⃣ Testing incident generation for failed audit...\")\n        try:\n            incident_id = integration.generate_incident_for_failed_audit(\n                result_b['case_id'],\n                result_b['audit_result'],\n                result_b['validation_result']\n            )\n            \n            print(f\"  ✅ Incident generated: {incident_id}\")\n            \n            # Check incident in project control\n            incidents = integration.hardening.project_control.control_data['incidents']\n            incident_found = any(i['id'] == incident_id for i in incidents)\n            print(f\"    Incident in project control: {'✅ Yes' if incident_found else '❌ No'}\")\n            \n            test_results.append((\"Incident generation\", \"PASS\"))\n            \n        except Exception as e:\n            print(f\"  ❌ Incident generation failed: {e}\")\n            test_results.append((\"Incident generation\", \"FAIL\"))\n            all_tests_passed = False\n        \n        # Test 7: Convenience Functions\n        print(\"\\n7️⃣ Testing convenience functions...\")\n        try:\n            # Test invoke_auditor_with_control\n            result_c = invoke_auditor_with_control(\n                test_project,\n                mode='C',\n                audit_objectives=['Validate design feasibility'],\n                scope={'included': ['design_components']},\n                context={'design': 'New order processing system'}\n            )\n            \n            print(f\"  ✅ Convenience function executed\")\n            print(f\"    Case ID: {result_c['case_id']}\")\n            print(f\"    Mode: {result_c['mode']}\")\n            \n            test_results.append((\"Convenience functions\", \"PASS\"))\n            \n        except Exception as e:\n            print(f\"  ❌ Convenience functions failed: {e}\")\n            test_results.append((\"Convenience functions\", \"FAIL\"))\n            all_tests_passed = False\n        \n        # Summary\n        print(\"\\n\" + \"=\" * 60)\n        print(\"📊 TEST SUMMARY\")\n        print(\"=\" * 60)\n        \n        for test_name, result in test_results:\n            status = \"✅ PASS\" if result == \"PASS\" else \"❌ FAIL\"\n            print(f\"{status} {test_name}\")\n        \n        if all_tests_passed:\n            print(\"\\n🎉 All integration tests passed!\")\n            \n            # Save test artifacts for inspection\n            artifacts_dir = test_project / 'test_artifacts'\n            artifacts_dir.mkdir(exist_ok=True)\n            \n            # Save project control data\n            control_data = integration.hardening.project_control.control_data\n            with open(artifacts_dir / 'project_control.json', 'w') as f:\n                json.dump(control_data, f, indent=2)\n            \n            print(f\"\\n📁 Test artifacts saved to: {artifacts_dir}\")\n            \n        else:\n            print(\"\\n⚠️ Some tests failed. Check errors above.\")\n        \n    except Exception as e:\n        print(f\"\\n❌ Integration test suite failed: {e}\")\n        import traceback\n        traceback.print_exc()\n        all_tests_passed = False\n    \n    finally:\n        # Optional: Keep test project for inspection\n        keep_project = False  # Set to True to keep project for debugging\n        \n        if not keep_project and test_project.exists():\n            shutil.rmtree(test_project)\n            print(f\"\\n🧹 Cleaned up test project\")\n        elif keep_project:\n            print(f\"\\n📁 Test project kept for inspection: {test_project}\")\n    \n    return all_tests_passed\n\nif __name__ == '__main__':\n    success = test_integration()\n    sys.exit(0 if success else 1)"}],"isError":false,"timestamp":1773101791154}}
