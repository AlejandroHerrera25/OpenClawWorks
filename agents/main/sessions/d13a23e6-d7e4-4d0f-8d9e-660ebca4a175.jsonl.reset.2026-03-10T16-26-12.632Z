{"type":"message","id":"6e25b464","parentId":"0be12e11","timestamp":"2026-03-09T18:27:42.300Z","message":{"role":"assistant","content":[{"type":"text","text":"Perfecto, voy a continuar. Primero, voy a completar la actualización de `utils_io.py` con las funciones de gobierno necesarias:"},{"type":"toolCall","id":"call_00_6Et6EGpuwubZdQcbig4ZajeO","name":"edit","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/utils_io.py","oldText":"if __name__ == '__main__':\n    # Quick test\n    check_references()\n    print('All references present.')","newText":"# ============================================================================\n# GOVERNANCE FUNCTIONS FOR HARDENED PIPELINE\n# ============================================================================\n\ndef load_governance_reference(reference_name):\n    \"\"\"\n    Load a governance reference file from salesforce-architect/references/.\n    Returns parsed content or raises FileNotFoundError.\n    \"\"\"\n    ref_path = SKILL_ROOT / 'references' / reference_name\n    if not ref_path.exists():\n        raise FileNotFoundError(f'Governance reference not found: {reference_name}')\n    \n    content = ref_path.read_text(encoding='utf-8')\n    \n    # Parse markdown structure into dictionary\n    # This is a simplified parser - in production would use proper markdown parsing\n    sections = {}\n    current_section = None\n    current_content = []\n    \n    for line in content.split('\\n'):\n        if line.startswith('# '):\n            if current_section:\n                sections[current_section] = '\\n'.join(current_content).strip()\n            current_section = line[2:].strip()\n            current_content = []\n        elif line.startswith('## '):\n            if current_section:\n                sections[current_section] = '\\n'.join(current_content).strip()\n            current_section = line[3:].strip()\n            current_content = []\n        elif line.startswith('### '):\n            if current_section:\n                sections[current_section] = '\\n'.join(current_content).strip()\n            current_section = line[4:].strip()\n            current_content = []\n        else:\n            current_content.append(line)\n    \n    if current_section:\n        sections[current_section] = '\\n'.join(current_content).strip()\n    \n    return sections\n\ndef detect_project_state(project_root):\n    \"\"\"\n    Detect current project state based on artifacts in project folder.\n    Returns state name or 'DISCOVERY' if new project.\n    \"\"\"\n    project_root = Path(project_root)\n    \n    # Check README for current state\n    readme_path = project_root / 'README.md'\n    if readme_path.exists():\n        readme_content = readme_path.read_text(encoding='utf-8')\n        for line in readme_content.split('\\n'):\n            if line.startswith('## Current State:'):\n                state = line.split(':')[1].strip()\n                if state:\n                    return state\n    \n    # Fallback: Detect state from artifacts\n    artifact_checks = [\n        ('FINALIZED', lambda p: (p / 'architecture' / 'Final_Approval.md').exists()),\n        ('REMEDIATION', lambda p: (p / 'remediation').exists() and any((p / 'remediation').iterdir())),\n        ('CODE_AUDIT', lambda p: (p / 'code_audit').exists() and any((p / 'code_audit').iterdir())),\n        ('ARCH_REVIEW', lambda p: (p / 'architecture' / 'Architecture_Overview.md').exists()),\n        ('DATA_MODEL', lambda p: (p / 'data_model').exists() and any((p / 'data_model').iterdir())),\n        ('DESIGN', lambda p: (p / 'design').exists() and any((p / 'design').iterdir())),\n        ('FIT_GAP', lambda p: (p / 'fit_gap').exists() and any((p / 'fit_gap').iterdir())),\n        ('REQUIREMENTS', lambda p: (p / 'discovery' / 'Discovery_QA.xlsx').exists()),\n        ('DISCOVERY', lambda p: (p / 'discovery').exists() and any((p / 'discovery').iterdir())),\n    ]\n    \n    for state, check_func in artifact_checks:\n        if check_func(project_root):\n            return state\n    \n    return 'DISCOVERY'\n\ndef validate_state_transition(current_state, target_state, state_machine):\n    \"\"\"\n    Validate if transition from current_state to target_state is allowed.\n    Returns True if allowed, False otherwise.\n    \"\"\"\n    if not state_machine or 'states' not in state_machine:\n        logger.warning('State machine not properly loaded, allowing transition')\n        return True\n    \n    current_def = state_machine['states'].get(current_state, {})\n    allowed_next = current_def.get('allowed_next_states', [])\n    \n    if target_state in allowed_next:\n        return True\n    \n    # Check if target_state is earlier state (regression allowed in some cases)\n    if target_state in ['DISCOVERY', 'REQUIREMENTS', 'FIT_GAP', 'DESIGN']:\n        # Regression to earlier states is allowed if current state is later\n        state_order = ['DISCOVERY', 'REQUIREMENTS', 'FIT_GAP', 'DESIGN', 'DATA_MODEL', \n                      'ARCH_REVIEW', 'CODE_AUDIT', 'REMEDIATION', 'FINALIZED']\n        current_idx = state_order.index(current_state) if current_state in state_order else -1\n        target_idx = state_order.index(target_state) if target_state in state_order else -1\n        \n        if target_idx < current_idx:\n            logger.info('Regression from %s to %s allowed for corrections', current_state, target_state)\n            return True\n    \n    logger.warning('Invalid state transition: %s -> %s', current_state, target_state)\n    return False\n\ndef update_project_readme(project_root, updates):\n    \"\"\"\n    Update project README.md with new information.\n    Updates is a dict with keys like 'current_state', 'state_history', etc.\n    \"\"\"\n    readme_path = Path(project_root) / 'README.md'\n    \n    if not readme_path.exists():\n        # Create new README\n        content = f\"\"\"# Project: {project_root.name}\n\n## Current State: {updates.get('current_state', 'DISCOVERY')}\n- Entered: {updates.get('entered', datetime.now().isoformat())}\n- Validated: {updates.get('validated', 'Pending')}\n\n## State History\n- {updates.get('state_history', 'DISCOVERY: {datetime.now().isoformat()} - ')}\n\n## Artifact Versions\n- Discovery: v0\n- Requirements: v0\n- Fit/Gap: v0\n- Design: v0\n- Data Model: v0\n- Architecture Review: v0\n- Code Audit: v0 (none)\n- Remediation: v0 (none)\n\n## Code Audits\n- No audits yet\n\n## Next Actions\n- [ ] Complete current phase\n\"\"\"\n    else:\n        # Update existing README\n        content = readme_path.read_text(encoding='utf-8')\n        lines = content.split('\\n')\n        updated_lines = []\n        \n        for line in lines:\n            updated_line = line\n            \n            # Update current state\n            if line.startswith('## Current State:'):\n                if 'current_state' in updates:\n                    updated_line = f'## Current State: {updates[\"current_state\"]}'\n            \n            # Update state history\n            elif line.startswith('- ') and 'state_history' in updates:\n                if 'DISCOVERY:' in line and 'DISCOVERY:' in updates['state_history']:\n                    updated_line = updates['state_history']\n                elif any(state in line for state in ['REQUIREMENTS:', 'FIT_GAP:', 'DESIGN:', 'DATA_MODEL:', \n                                                    'ARCH_REVIEW:', 'CODE_AUDIT:', 'REMEDIATION:', 'FINALIZED:']):\n                    # Check if this state is being updated\n                    for state in ['REQUIREMENTS', 'FIT_GAP', 'DESIGN', 'DATA_MODEL', \n                                 'ARCH_REVIEW', 'CODE_AUDIT', 'REMEDIATION', 'FINALIZED']:\n                        if f'{state}:' in line and f'{state}:' in updates.get('state_history', ''):\n                            updated_line = updates['state_history']\n                            break\n            \n            # Update artifact versions\n            elif line.startswith('- ') and any(artifact in line for artifact in \n                                              ['Discovery:', 'Requirements:', 'Fit/Gap:', 'Design:', \n                                               'Data Model:', 'Architecture Review:', 'Code Audit:', 'Remediation:']):\n                if 'artifact_versions' in updates:\n                    for artifact, version in updates['artifact_versions'].items():\n                        if f'{artifact}:' in line:\n                            updated_line = f'- {artifact}: v{version}'\n                            break\n            \n            updated_lines.append(updated_line)\n        \n        content = '\\n'.join(updated_lines)\n    \n    readme_path.write_text(content, encoding='utf-8')\n    logger.info('Project README updated at %s', readme_path)\n\ndef get_role_from_model(role_name, role_model):\n    \"\"\"\n    Get role definition from role model.\n    Returns role definition dict or None if not found.\n    \"\"\"\n    if not role_model:\n        return None\n    \n    # Search for role in model sections\n    for section_name, section_content in role_model.items():\n        if role_name.lower() in section_name.lower():\n            # Parse role details from section\n            role_details = {\n                'name': role_name,\n                'purpose': '',\n                'domain_ownership': [],\n                'analyzes': [],\n                'does_not_decide': [],\n                'evidence_required': [],\n                'artifacts_produced': [],\n                'escalation_triggers': [],\n                'handoff_expectations': []\n            }\n            \n            lines = section_content.split('\\n')\n            current_field = None\n            \n            for line in lines:\n                line = line.strip()\n                if not line:\n                    continue\n                \n                # Check for field markers\n                if 'Purpose:' in line:\n                    current_field = 'purpose'\n                    role_details[current_field] = line.split(':', 1)[1].strip()\n                elif 'Domain Ownership:' in line:\n                    current_field = 'domain_ownership'\n                elif 'What the role analyzes:' in line:\n                    current_field = 'analyzes'\n                elif 'What the role does not decide alone:' in line:\n                    current_field = 'does_not_decide'\n                elif 'Required evidence:' in line:\n                    current_field = 'evidence_required'\n                elif 'Artifacts produced:' in line:\n                    current_field = 'artifacts_produced'\n                elif 'Escalation triggers:' in line:\n                    current_field = 'escalation_triggers'\n                elif 'Handoff expectations:' in line:\n                    current_field = 'handoff_expectations'\n                elif line.startswith('- '):\n                    if current_field and current_field in role_details:\n                        if isinstance(role_details[current_field], str):\n                            role_details[current_field] = [line[2:].strip()]\n                        else:\n                            role_details[current_field].append(line[2:].strip())\n            \n            return role_details\n    \n    return None\n\ndef validate_against_dod(role_name, artifacts, dod_by_role):\n    \"\"\"\n    Validate artifacts against Definition of Done for specific role.\n    Returns (is_valid, issues_found).\n    \"\"\"\n    if not dod_by_role:\n        logger.warning('DoD reference not loaded, skipping validation')\n        return True, []\n    \n    # Find DoD for role\n    role_dod = None\n    for section_name, section_content in dod_by_role.items():\n        if role_name.lower() in section_name.lower():\n            role_dod = section_content\n            break\n    \n    if not role_dod:\n        logger.warning('DoD not found for role: %s', role_name)\n        return True, []  # Can't validate without DoD\n    \n    issues = []\n    \n    # Parse DoD requirements\n    lines = role_dod.split('\\n')\n    requirements = []\n    \n    for line in lines:\n        line = line.strip()\n        if line.startswith('- **') and '**:' in line:\n            # Extract requirement\n            req = line.split('**:', 1)[0].replace('- **', '').strip()\n            requirements.append(req)\n    \n    # Simple validation: check if artifacts mention requirements\n    # In production, this would be more sophisticated\n    artifacts_text = ' '.join(str(artifacts)).lower()\n    \n    for req in requirements:\n        req_lower = req.lower()\n        # Check if requirement is mentioned in artifacts\n        if req_lower not in artifacts_text:\n            issues.append(f'DoD requirement not addressed: {req}')\n    \n    is_valid = len(issues) == 0\n    return is_valid, issues\n\nif __name__ == '__main__':\n    # Quick test\n    check_references()\n    print('All references present.')\n    \n    # Test governance functions\n    try:\n        role_model = load_governance_reference('SALESFORCE_ROLE_MODEL.md')\n        print(f'Role model loaded with {len(role_model)} sections')\n        \n        # Test project state detection\n        test_project = PROJECTS_ROOT / 'test_project'\n        test_project.mkdir(exist_ok=True)\n        state = detect_project_state(test_project)\n        print(f'Detected project state: {state}')\n        \n        # Cleanup\n        shutil.rmtree(test_project)\n        \n    except Exception as e:\n        print(f'Governance test failed: {e}')"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":66538,"output":2984,"cacheRead":26048,"cacheWrite":0,"totalTokens":95570,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773080735074}}
{"type":"message","id":"89c0264f","parentId":"6e25b464","timestamp":"2026-03-09T18:27:42.355Z","message":{"role":"toolResult","toolCallId":"call_00_6Et6EGpuwubZdQcbig4ZajeO","toolName":"edit","content":[{"type":"text","text":"Successfully replaced text in /home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/utils_io.py."}],"details":{"diff":"     ...\n 166         if field not in inputs or not inputs[field]:\n 167             missing.append(field)\n 168     return missing\n 169 \n+170 # ============================================================================\n+171 # GOVERNANCE FUNCTIONS FOR HARDENED PIPELINE\n+172 # ============================================================================\n+173 \n+174 def load_governance_reference(reference_name):\n+175     \"\"\"\n+176     Load a governance reference file from salesforce-architect/references/.\n+177     Returns parsed content or raises FileNotFoundError.\n+178     \"\"\"\n+179     ref_path = SKILL_ROOT / 'references' / reference_name\n+180     if not ref_path.exists():\n+181         raise FileNotFoundError(f'Governance reference not found: {reference_name}')\n+182     \n+183     content = ref_path.read_text(encoding='utf-8')\n+184     \n+185     # Parse markdown structure into dictionary\n+186     # This is a simplified parser - in production would use proper markdown parsing\n+187     sections = {}\n+188     current_section = None\n+189     current_content = []\n+190     \n+191     for line in content.split('\\n'):\n+192         if line.startswith('# '):\n+193             if current_section:\n+194                 sections[current_section] = '\\n'.join(current_content).strip()\n+195             current_section = line[2:].strip()\n+196             current_content = []\n+197         elif line.startswith('## '):\n+198             if current_section:\n+199                 sections[current_section] = '\\n'.join(current_content).strip()\n+200             current_section = line[3:].strip()\n+201             current_content = []\n+202         elif line.startswith('### '):\n+203             if current_section:\n+204                 sections[current_section] = '\\n'.join(current_content).strip()\n+205             current_section = line[4:].strip()\n+206             current_content = []\n+207         else:\n+208             current_content.append(line)\n+209     \n+210     if current_section:\n+211         sections[current_section] = '\\n'.join(current_content).strip()\n+212     \n+213     return sections\n+214 \n+215 def detect_project_state(project_root):\n+216     \"\"\"\n+217     Detect current project state based on artifacts in project folder.\n+218     Returns state name or 'DISCOVERY' if new project.\n+219     \"\"\"\n+220     project_root = Path(project_root)\n+221     \n+222     # Check README for current state\n+223     readme_path = project_root / 'README.md'\n+224     if readme_path.exists():\n+225         readme_content = readme_path.read_text(encoding='utf-8')\n+226         for line in readme_content.split('\\n'):\n+227             if line.startswith('## Current State:'):\n+228                 state = line.split(':')[1].strip()\n+229                 if state:\n+230                     return state\n+231     \n+232     # Fallback: Detect state from artifacts\n+233     artifact_checks = [\n+234         ('FINALIZED', lambda p: (p / 'architecture' / 'Final_Approval.md').exists()),\n+235         ('REMEDIATION', lambda p: (p / 'remediation').exists() and any((p / 'remediation').iterdir())),\n+236         ('CODE_AUDIT', lambda p: (p / 'code_audit').exists() and any((p / 'code_audit').iterdir())),\n+237         ('ARCH_REVIEW', lambda p: (p / 'architecture' / 'Architecture_Overview.md').exists()),\n+238         ('DATA_MODEL', lambda p: (p / 'data_model').exists() and any((p / 'data_model').iterdir())),\n+239         ('DESIGN', lambda p: (p / 'design').exists() and any((p / 'design').iterdir())),\n+240         ('FIT_GAP', lambda p: (p / 'fit_gap').exists() and any((p / 'fit_gap').iterdir())),\n+241         ('REQUIREMENTS', lambda p: (p / 'discovery' / 'Discovery_QA.xlsx').exists()),\n+242         ('DISCOVERY', lambda p: (p / 'discovery').exists() and any((p / 'discovery').iterdir())),\n+243     ]\n+244     \n+245     for state, check_func in artifact_checks:\n+246         if check_func(project_root):\n+247             return state\n+248     \n+249     return 'DISCOVERY'\n+250 \n+251 def validate_state_transition(current_state, target_state, state_machine):\n+252     \"\"\"\n+253     Validate if transition from current_state to target_state is allowed.\n+254     Returns True if allowed, False otherwise.\n+255     \"\"\"\n+256     if not state_machine or 'states' not in state_machine:\n+257         logger.warning('State machine not properly loaded, allowing transition')\n+258         return True\n+259     \n+260     current_def = state_machine['states'].get(current_state, {})\n+261     allowed_next = current_def.get('allowed_next_states', [])\n+262     \n+263     if target_state in allowed_next:\n+264         return True\n+265     \n+266     # Check if target_state is earlier state (regression allowed in some cases)\n+267     if target_state in ['DISCOVERY', 'REQUIREMENTS', 'FIT_GAP', 'DESIGN']:\n+268         # Regression to earlier states is allowed if current state is later\n+269         state_order = ['DISCOVERY', 'REQUIREMENTS', 'FIT_GAP', 'DESIGN', 'DATA_MODEL', \n+270                       'ARCH_REVIEW', 'CODE_AUDIT', 'REMEDIATION', 'FINALIZED']\n+271         current_idx = state_order.index(current_state) if current_state in state_order else -1\n+272         target_idx = state_order.index(target_state) if target_state in state_order else -1\n+273         \n+274         if target_idx < current_idx:\n+275             logger.info('Regression from %s to %s allowed for corrections', current_state, target_state)\n+276             return True\n+277     \n+278     logger.warning('Invalid state transition: %s -> %s', current_state, target_state)\n+279     return False\n+280 \n+281 def update_project_readme(project_root, updates):\n+282     \"\"\"\n+283     Update project README.md with new information.\n+284     Updates is a dict with keys like 'current_state', 'state_history', etc.\n+285     \"\"\"\n+286     readme_path = Path(project_root) / 'README.md'\n+287     \n+288     if not readme_path.exists():\n+289         # Create new README\n+290         content = f\"\"\"# Project: {project_root.name}\n+291 \n+292 ## Current State: {updates.get('current_state', 'DISCOVERY')}\n+293 - Entered: {updates.get('entered', datetime.now().isoformat())}\n+294 - Validated: {updates.get('validated', 'Pending')}\n+295 \n+296 ## State History\n+297 - {updates.get('state_history', 'DISCOVERY: {datetime.now().isoformat()} - ')}\n+298 \n+299 ## Artifact Versions\n+300 - Discovery: v0\n+301 - Requirements: v0\n+302 - Fit/Gap: v0\n+303 - Design: v0\n+304 - Data Model: v0\n+305 - Architecture Review: v0\n+306 - Code Audit: v0 (none)\n+307 - Remediation: v0 (none)\n+308 \n+309 ## Code Audits\n+310 - No audits yet\n+311 \n+312 ## Next Actions\n+313 - [ ] Complete current phase\n+314 \"\"\"\n+315     else:\n+316         # Update existing README\n+317         content = readme_path.read_text(encoding='utf-8')\n+318         lines = content.split('\\n')\n+319         updated_lines = []\n+320         \n+321         for line in lines:\n+322             updated_line = line\n+323             \n+324             # Update current state\n+325             if line.startswith('## Current State:'):\n+326                 if 'current_state' in updates:\n+327                     updated_line = f'## Current State: {updates[\"current_state\"]}'\n+328             \n+329             # Update state history\n+330             elif line.startswith('- ') and 'state_history' in updates:\n+331                 if 'DISCOVERY:' in line and 'DISCOVERY:' in updates['state_history']:\n+332                     updated_line = updates['state_history']\n+333                 elif any(state in line for state in ['REQUIREMENTS:', 'FIT_GAP:', 'DESIGN:', 'DATA_MODEL:', \n+334                                                     'ARCH_REVIEW:', 'CODE_AUDIT:', 'REMEDIATION:', 'FINALIZED:']):\n+335                     # Check if this state is being updated\n+336                     for state in ['REQUIREMENTS', 'FIT_GAP', 'DESIGN', 'DATA_MODEL', \n+337                                  'ARCH_REVIEW', 'CODE_AUDIT', 'REMEDIATION', 'FINALIZED']:\n+338                         if f'{state}:' in line and f'{state}:' in updates.get('state_history', ''):\n+339                             updated_line = updates['state_history']\n+340                             break\n+341             \n+342             # Update artifact versions\n+343             elif line.startswith('- ') and any(artifact in line for artifact in \n+344                                               ['Discovery:', 'Requirements:', 'Fit/Gap:', 'Design:', \n+345                                                'Data Model:', 'Architecture Review:', 'Code Audit:', 'Remediation:']):\n+346                 if 'artifact_versions' in updates:\n+347                     for artifact, version in updates['artifact_versions'].items():\n+348                         if f'{artifact}:' in line:\n+349                             updated_line = f'- {artifact}: v{version}'\n+350                             break\n+351             \n+352             updated_lines.append(updated_line)\n+353         \n+354         content = '\\n'.join(updated_lines)\n+355     \n+356     readme_path.write_text(content, encoding='utf-8')\n+357     logger.info('Project README updated at %s', readme_path)\n+358 \n+359 def get_role_from_model(role_name, role_model):\n+360     \"\"\"\n+361     Get role definition from role model.\n+362     Returns role definition dict or None if not found.\n+363     \"\"\"\n+364     if not role_model:\n+365         return None\n+366     \n+367     # Search for role in model sections\n+368     for section_name, section_content in role_model.items():\n+369         if role_name.lower() in section_name.lower():\n+370             # Parse role details from section\n+371             role_details = {\n+372                 'name': role_name,\n+373                 'purpose': '',\n+374                 'domain_ownership': [],\n+375                 'analyzes': [],\n+376                 'does_not_decide': [],\n+377                 'evidence_required': [],\n+378                 'artifacts_produced': [],\n+379                 'escalation_triggers': [],\n+380                 'handoff_expectations': []\n+381             }\n+382             \n+383             lines = section_content.split('\\n')\n+384             current_field = None\n+385             \n+386             for line in lines:\n+387                 line = line.strip()\n+388                 if not line:\n+389                     continue\n+390                 \n+391                 # Check for field markers\n+392                 if 'Purpose:' in line:\n+393                     current_field = 'purpose'\n+394                     role_details[current_field] = line.split(':', 1)[1].strip()\n+395                 elif 'Domain Ownership:' in line:\n+396                     current_field = 'domain_ownership'\n+397                 elif 'What the role analyzes:' in line:\n+398                     current_field = 'analyzes'\n+399                 elif 'What the role does not decide alone:' in line:\n+400                     current_field = 'does_not_decide'\n+401                 elif 'Required evidence:' in line:\n+402                     current_field = 'evidence_required'\n+403                 elif 'Artifacts produced:' in line:\n+404                     current_field = 'artifacts_produced'\n+405                 elif 'Escalation triggers:' in line:\n+406                     current_field = 'escalation_triggers'\n+407                 elif 'Handoff expectations:' in line:\n+408                     current_field = 'handoff_expectations'\n+409                 elif line.startswith('- '):\n+410                     if current_field and current_field in role_details:\n+411                         if isinstance(role_details[current_field], str):\n+412                             role_details[current_field] = [line[2:].strip()]\n+413                         else:\n+414                             role_details[current_field].append(line[2:].strip())\n+415             \n+416             return role_details\n+417     \n+418     return None\n+419 \n+420 def validate_against_dod(role_name, artifacts, dod_by_role):\n+421     \"\"\"\n+422     Validate artifacts against Definition of Done for specific role.\n+423     Returns (is_valid, issues_found).\n+424     \"\"\"\n+425     if not dod_by_role:\n+426         logger.warning('DoD reference not loaded, skipping validation')\n+427         return True, []\n+428     \n+429     # Find DoD for role\n+430     role_dod = None\n+431     for section_name, section_content in dod_by_role.items():\n+432         if role_name.lower() in section_name.lower():\n+433             role_dod = section_content\n+434             break\n+435     \n+436     if not role_dod:\n+437         logger.warning('DoD not found for role: %s', role_name)\n+438         return True, []  # Can't validate without DoD\n+439     \n+440     issues = []\n+441     \n+442     # Parse DoD requirements\n+443     lines = role_dod.split('\\n')\n+444     requirements = []\n+445     \n+446     for line in lines:\n+447         line = line.strip()\n+448         if line.startswith('- **') and '**:' in line:\n+449             # Extract requirement\n+450             req = line.split('**:', 1)[0].replace('- **', '').strip()\n+451             requirements.append(req)\n+452     \n+453     # Simple validation: check if artifacts mention requirements\n+454     # In production, this would be more sophisticated\n+455     artifacts_text = ' '.join(str(artifacts)).lower()\n+456     \n+457     for req in requirements:\n+458         req_lower = req.lower()\n+459         # Check if requirement is mentioned in artifacts\n+460         if req_lower not in artifacts_text:\n+461             issues.append(f'DoD requirement not addressed: {req}')\n+462     \n+463     is_valid = len(issues) == 0\n+464     return is_valid, issues\n+465 \n 170 if __name__ == '__main__':\n 171     # Quick test\n 172     check_references()\n-173     print('All references present.')\n+469     print('All references present.')\n+470     \n+471     # Test governance functions\n+472     try:\n+473         role_model = load_governance_reference('SALESFORCE_ROLE_MODEL.md')\n+474         print(f'Role model loaded with {len(role_model)} sections')\n+475         \n+476         # Test project state detection\n+477         test_project = PROJECTS_ROOT / 'test_project'\n+478         test_project.mkdir(exist_ok=True)\n+479         state = detect_project_state(test_project)\n+480         print(f'Detected project state: {state}')\n+481         \n+482         # Cleanup\n+483         shutil.rmtree(test_project)\n+484         \n+485     except Exception as e:\n+486         print(f'Governance test failed: {e}')","firstChangedLine":170},"isError":false,"timestamp":1773080862335}}
