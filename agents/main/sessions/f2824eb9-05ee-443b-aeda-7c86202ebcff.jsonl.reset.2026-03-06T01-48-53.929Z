Test A and Test B\". I'll create a new test script that does both.\n\nLet me write the test script now. I'll place it in the same scripts directory. Let me first check if there's already a test_validation.py (I created earlier). Yes, I created test_validation.py. I'll update that script to include the new tests, but to keep things separate, I'll create a new script test_hardening.py.\n\nLet me write it. First, I need to import the necessary modules. Let me create the file.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_ox9kcHcoeqbv7zSIye0FsNU5","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/agent-watchdog/scripts/test_hardening.py","content":"#!/usr/bin/env python3\n\"\"\"\nTest hardening improvements for watchdog + learning system.\nTests:\n1. Rate limiting (max 5 incidents per pattern per hour)\n2. Self-protection (watchdog failure incident and restart)\n\"\"\"\n\nimport sys\nimport os\nimport time\nimport json\nimport shutil\nfrom datetime import datetime, timedelta\nfrom pathlib import Path\n\n# Add parent directory to path\nsys.path.insert(0, str(Path(__file__).parent))\n\n# Import the watchdog orchestrator\nfrom watchdog_orchestrator import AgentWatchdog, RATE_LIMIT_CACHE_PATH, MAX_INCIDENTS_PER_PATTERN_PER_HOUR\n\ndef backup_file(path):\n    \"\"\"Create backup of a file.\"\"\"\n    if path.exists():\n        backup = path.with_suffix('.bak')\n        shutil.copy2(path, backup)\n        return backup\n    return None\n\ndef restore_file(path, backup):\n    \"\"\"Restore file from backup.\"\"\"\n    if backup and backup.exists():\n        shutil.copy2(backup, path)\n        backup.unlink()\n        return True\n    return False\n\ndef get_file_timestamp(path):\n    \"\"\"Get the last modified time of a file.\"\"\"\n    if path.exists():\n        return datetime.fromtimestamp(path.stat().st_mtime)\n    return None\n\ndef count_incidents_in_errors(pattern_key):\n    \"\"\"Count incidents with given pattern_key in ERRORS.md.\"\"\"\n    workspace = Path.home() / '.openclaw' / 'workspace'\n    errors_path = workspace / '.learnings' / 'ERRORS.md'\n    if not errors_path.exists():\n        return 0\n    with open(errors_path, 'r', encoding='utf-8') as f:\n        content = f.read()\n        return content.count(f'### Pattern-Key: {pattern_key}')\n\ndef test_rate_limiting():\n    \"\"\"Test A: Rate limiting - max 5 incidents per pattern per hour.\"\"\"\n    print(\"\\n\" + \"=\"*60)\n    print(\"TEST A: Rate Limiting\")\n    print(\"=\"*60)\n    \n    workspace = Path.home() / '.openclaw' / 'workspace'\n    errors_path = workspace / '.learnings' / 'ERRORS.md'\n    cache_path = RATE_LIMIT_CACHE_PATH\n    \n    # Backup files\n    errors_backup = backup_file(errors_path)\n    cache_backup = backup_file(cache_path) if cache_path.exists() else None\n    \n    try:\n        # Ensure cache file is fresh\n        if cache_path.exists():\n            cache_path.unlink()\n        \n        # Create watchdog instance\n        watchdog = AgentWatchdog()\n        \n        # Create a unique pattern key for this test\n        test_pattern = f\"test|RATE_LIMIT|{datetime.utcnow().timestamp()}\"\n        \n        print(f\"Test pattern key: {test_pattern}\")\n        print(f\"Max incidents per hour: {MAX_INCIDENTS_PER_PATTERN_PER_HOUR}\")\n        \n        # Count initial incidents with this pattern\n        initial_count = count_incidents_in_errors(test_pattern)\n        print(f\"Initial incidents with pattern: {initial_count}\")\n        \n        # Simulate 6 incidents (one more than limit)\n        incidents_appended = 0\n        incidents_skipped = 0\n        \n        for i in range(6):\n            incident = {\n                'pattern_key': test_pattern,\n                'timestamp': datetime.utcnow().isoformat(),\n                'model': 'test-model',\n                'stall_duration': 100,\n                'recovery_level': 1,\n                'success': True,\n                'runtime_type': 'subagent',\n                'task_type': 'rate-limit-test',\n                'items_count': 0\n            }\n            \n            # Call append_to_errors directly\n            # We need to capture print output to detect rate limit skip\n            # Instead, we'll check the cache and count after each call\n            watchdog.append_to_errors(incident, trigger_learning=False)\n            \n            # Count current incidents\n            current_count = count_incidents_in_errors(test_pattern)\n            if current_count > incidents_appended:\n                incidents_appended = current_count\n                print(f\"  Incident {i+1}: APPENDED\")\n            else:\n                incidents_skipped += 1\n                print(f\"  Incident {i+1}: SKIPPED (rate limit)\")\n        \n        # Verify results\n        final_count = count_incidents_in_errors(test_pattern)\n        expected = MAX_INCIDENTS_PER_PATTERN_PER_HOUR\n        print(f\"\\nResults:\")\n        print(f\"  Total incidents attempted: 6\")\n        print(f\"  Incidents appended: {incidents_appended}\")\n        print(f\"  Incidents skipped: {incidents_skipped}\")\n        print(f\"  Final count in ERRORS.md: {final_count}\")\n        \n        if incidents_appended == expected and incidents_skipped == 6 - expected:\n            print(\"✅ Rate limiting working correctly\")\n        else:\n            print(\"❌ Rate limiting failed\")\n            print(f\"   Expected {expected} appended, got {incidents_appended}\")\n        \n        # Check cache file exists and has correct data\n        if cache_path.exists():\n            with open(cache_path, 'r', encoding='utf-8') as f:\n                cache = json.load(f)\n                if test_pattern in cache:\n                    timestamps = cache[test_pattern]\n                    print(f\"  Cache entries for pattern: {len(timestamps)}\")\n                    if len(timestamps) == expected:\n                        print(\"✅ Cache correctly populated\")\n                    else:\n                        print(\"⚠️  Cache has unexpected number of timestamps\")\n                else:\n                    print(\"❌ Pattern not found in cache\")\n        else:\n            print(\"❌ Cache file not created\")\n        \n        return incidents_appended == expected\n        \n    finally:\n        # Restore backups\n        if errors_backup:\n            restore_file(errors_path, errors_backup)\n        if cache_backup and cache_path.exists():\n            restore_file(cache_path, cache_backup)\n\ndef test_self_protection():\n    \"\"\"Test B: Self-protection - watchdog failure incident and restart.\"\"\"\n    print(\"\\n\" + \"=\"*60)\n    print(\"TEST B: Self-Protection\")\n    print(\"=\"*60)\n    \n    workspace = Path.home() / '.openclaw' / 'workspace'\n    errors_path = workspace / '.learnings' / 'ERRORS.md'\n    \n    # Backup files\n    errors_backup = backup_file(errors_path)\n    \n    try:\n        # Count initial watchdog failure incidents\n        initial_failures = count_incidents_in_errors('watchdog|FAILURE|orchestrator|runtime_error')\n        print(f\"Initial watchdog failure incidents: {initial_failures}\")\n        \n        # Create watchdog instance\n        watchdog = AgentWatchdog()\n        \n        # Force an exception in monitoring cycle by monkey-patching\n        original_detect_stalls = watchdog.detect_stalls\n        def failing_detect_stalls():\n            raise RuntimeError(\"Simulated watchdog failure for testing\")\n        \n        watchdog.detect_stalls = failing_detect_stalls\n        \n        print(\"Running monitoring cycle with simulated failure...\")\n        \n        # Capture output to check restart messages\n        import io\n        import contextlib\n        \n        f = io.StringIO()\n        with contextlib.redirect_stdout(f):\n            watchdog.run_monitoring_cycle()\n        output = f.getvalue()\n        \n        # Check for expected messages\n        if \"CRITICAL: Monitoring cycle failed\" in output:\n            print(\"✅ Exception caught and logged\")\n        else:\n            print(\"❌ Exception not caught\")\n            print(f\"Output snippet: {output[:200]}\")\n        \n        if \"Self-protection: emitted watchdog failure incident\" in output:\n            print(\"✅ Watchdog failure incident emitted\")\n        else:\n            print(\"❌ Watchdog failure incident not emitted\")\n        \n        # Check restart attempt\n        if \"Self-restart attempt\" in output:\n            print(\"✅ Self-restart attempted\")\n        else:\n            print(\"⚠️  Self-restart not attempted (may be due to restart count)\")\n        \n        # Count final watchdog failure incidents\n        final_failures = count_incidents_in_errors('watchdog|FAILURE|orchestrator|runtime_error')\n        print(f\"Final watchdog failure incidents: {final_failures}\")\n        \n        if final_failures > initial_failures:\n            print(\"✅ Watchdog failure incident appended to ERRORS.md\")\n        else:\n            print(\"❌ No new watchdog failure incident appended\")\n        \n        # Check INDEX.md timestamp (should be updated if fallback rebuild triggered)\n        index_path = workspace / '.learnings' / 'INDEX.md'\n        initial_index_time = get_file_timestamp(index_path)\n        print(f\"INDEX.md timestamp before: {initial_index_time}\")\n        \n        # Wait a moment for possible rebuild\n        time.sleep(1)\n        final_index_time = get_file_timestamp(index_path)\n        print(f\"INDEX.md timestamp after: {final_index_time}\")\n        \n        if final_index_time and initial_index_time:\n            if final_index_time > initial_index_time:\n                print(\"✅ INDEX.md updated (fallback rebuild triggered)\")\n            else:\n                print(\"⚠️  INDEX.md not updated (may be debounced)\")\n        else:\n            print(\"⚠️  Could not compare timestamps\")\n        \n        # Check restart count\n        print(f\"Watchdog restart count: {watchdog.watchdog_restart_count}\")\n        if watchdog.watchdog_restart_count == 1:\n            print(\"✅ Restart count correctly incremented\")\n        else:\n            print(f\"⚠️  Restart count is {watchdog.watchdog_restart_count}, expected 1\")\n        \n        return final_failures > initial_failures\n        \n    finally:\n        # Restore backup\n        if errors_backup:\n            restore_file(errors_path, errors_backup)\n\ndef main():\n    \"\"\"Run all hardening tests.\"\"\"\n    print(\"=\"*60)\n    print(\"HARDENING IMPROVEMENTS VALIDATION\")\n    print(\"=\"*60)\n    \n    # Test A: Rate limiting\n    rate_limit_pass = test_rate_limiting()\n    \n    # Test B: Self-protection\n    self_protection_pass = test_self_protection()\n    \n    print(\"\\n\" + \"=\"*60)\n    print(\"VALIDATION SUMMARY\")\n    print(\"=\"*60)\n    \n    if rate_limit_pass:\n        print(\"✅ Rate limiting: PASS\")\n    else:\n        print(\"❌ Rate limiting: FAIL\")\n    \n    if self_protection_pass:\n        print(\"✅ Self-protection: PASS\")\n    else:\n        print(\"❌ Self-protection: FAIL\")\n    \n    # Show final status of key files\n    workspace = Path.home() / '.openclaw' / 'workspace'\n    errors_path = workspace / '.learnings' / 'ERRORS.md'\n    cache_path = RATE_LIMIT_CACHE_PATH\n    \n    if errors_path.exists():\n        print(f\"\\nERRORS.md size: {errors_path.stat().st_size} bytes\")\n    \n    if cache_path.exists():\n        print(f\"Rate limit cache size: {cache_path.stat().st_size} bytes\")\n        with open(cache_path, 'r', encoding='utf-8') as f:\n            cache = json.load(f)\n            print(f\"Patterns in cache: {len(cache)}\")\n\nif __name__ == '__main__':\n    main()"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-reasoner","usage":{"input":330,"output":3477,"cacheRead":97920,"cacheWrite":0,"totalTokens":101727,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772744019711}}
