{"type":"message","id":"0e903ca7","parentId":"c20683e3","timestamp":"2026-03-10T00:13:20.803Z","message":{"role":"assistant","content":[{"type":"text","text":"Excellent! Real operational metrics showing:\n- 16 real sessions being monitored\n- All sessions active (0 stalled)\n- Ecosystem integration working\n- All components available\n\nNow let me create a test to demonstrate stall detection. I'll create a test script that simulates a stalled session:"},{"type":"toolCall","id":"call_00_MgnkfZcIW6rk58KwvWuTSI9H","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/agent-watchdog/scripts/test_stall_detection.py","content":"#!/usr/bin/env python3\n\"\"\"\nTest script to demonstrate real stall detection.\nCreates a simulated stalled session and shows watchdog detection.\n\"\"\"\n\nimport json\nimport time\nfrom datetime import datetime, timedelta\nfrom pathlib import Path\n\n# Workspace paths\nWORKSPACE = Path.home() / '.openclaw' / 'workspace'\nWATCHDOG_DIR = WORKSPACE / '.watchdog'\nREGISTRY_FILE = WATCHDOG_DIR / 'session_registry.json'\n\ndef create_stalled_session_test():\n    \"\"\"Create a test stalled session in the registry.\"\"\"\n    \n    print(\"=== Testing Real Stall Detection ===\")\n    \n    # Load current registry\n    if REGISTRY_FILE.exists():\n        with open(REGISTRY_FILE, 'r') as f:\n            registry = json.load(f)\n    else:\n        registry = {}\n    \n    # Create a test stalled session\n    test_session_id = \"test_stalled_session_12345\"\n    \n    # Create session that was last active 5 minutes ago (should be detected as stalled)\n    five_minutes_ago = (datetime.utcnow() - timedelta(minutes=5)).isoformat()\n    \n    test_session = {\n        \"session_id\": test_session_id,\n        \"source\": \"test\",\n        \"registered_at\": five_minutes_ago,\n        \"last_activity\": five_minutes_ago,  # Last active 5 minutes ago\n        \"state\": \"active\",  # Still marked as active (should be detected as stalled)\n        \"stall_count\": 0,\n        \"recovery_attempts\": 0,\n        \"metrics\": {\n            \"total_uptime\": 300,  # 5 minutes\n            \"stall_detections\": 0,\n            \"recovery_attempts\": 0,\n            \"last_stall_time\": None\n        },\n        \"session_data_summary\": {\n            \"label\": \"Test Stalled Session\",\n            \"updated_at\": int(time.time() * 1000) - 300000,  # 5 minutes ago\n            \"model\": \"test-model\"\n        }\n    }\n    \n    # Add test session to registry\n    registry[test_session_id] = test_session\n    \n    # Save updated registry\n    with open(REGISTRY_FILE, 'w') as f:\n        json.dump(registry, f, indent=2)\n    \n    print(f\"Created test stalled session: {test_session_id}\")\n    print(f\"Last activity: {five_minutes_ago} (5 minutes ago)\")\n    print(f\"Session state: {test_session['state']}\")\n    print()\n    \n    return test_session_id\n\ndef run_stall_detection_test():\n    \"\"\"Run the stall detection test.\"\"\"\n    \n    # Step 1: Create test stalled session\n    test_session_id = create_stalled_session_test()\n    \n    # Step 2: Run monitor to detect stall\n    print(\"=== Running Monitor Stall Detection ===\")\n    \n    # Import and use the real monitor\n    import sys\n    sys.path.insert(0, str(Path(__file__).parent))\n    \n    try:\n        from watchdog_monitor_real import RealSessionMonitor\n        \n        monitor = RealSessionMonitor()\n        \n        # Load the test session\n        monitor.load_registry()\n        \n        # Check if test session is in registry\n        if test_session_id in monitor.sessions:\n            session = monitor.sessions[test_session_id]\n            print(f\"Test session loaded: {session.session_id}\")\n            print(f\"Session state: {session.state}\")\n            \n            # Check if session is stalled\n            is_stalled = session.is_stalled(timeout_seconds=60)  # 1 minute timeout for test\n            print(f\"Is stalled (1min timeout)?: {is_stalled}\")\n            \n            if is_stalled:\n                print(\"✓ SUCCESS: Stall detection working!\")\n                print(f\"  Session {test_session_id} correctly detected as stalled\")\n                \n                # Mark as stalled\n                session.mark_stall()\n                print(f\"  Session marked as stalled\")\n                \n                # Save registry\n                monitor.save_registry()\n                \n                # Check updated registry\n                with open(REGISTRY_FILE, 'r') as f:\n                    updated_registry = json.load(f)\n                \n                if updated_registry[test_session_id][\"state\"] == \"stalled\":\n                    print(\"✓ SUCCESS: Registry updated with stalled state\")\n                else:\n                    print(\"✗ FAIL: Registry not updated\")\n            else:\n                print(\"✗ FAIL: Stall not detected (might need more time)\")\n        \n        else:\n            print(f\"✗ FAIL: Test session not found in monitor\")\n    \n    except ImportError as e:\n        print(f\"✗ FAIL: Could not import monitor: {e}\")\n    \n    # Step 3: Check if recovery would trigger\n    print()\n    print(\"=== Testing Recovery Trigger ===\")\n    \n    try:\n        from watchdog_recovery_real import RealRecoverySystem\n        \n        recovery = RealRecoverySystem()\n        \n        # Check if recovery is needed\n        sessions_needing_recovery = recovery.check_recovery_needed()\n        \n        if sessions_needing_recovery:\n            print(f\"✓ SUCCESS: Recovery needed for {len(sessions_needing_recovery)} sessions\")\n            for session in sessions_needing_recovery:\n                if session[\"session_id\"] == test_session_id:\n                    print(f\"  Test session {test_session_id} needs recovery\")\n                    print(f\"  Inactivity: {session['inactivity_seconds']:.0f} seconds\")\n                    \n                    # Test recovery\n                    print(\"  Testing recovery action...\")\n                    recovery_result = recovery.perform_real_recovery(session)\n                    print(f\"  Recovery result: {recovery_result['success']}\")\n                    print(f\"  Action: {recovery_result['action']}\")\n                    \n                    # Check incidents\n                    if recovery.recovery_history:\n                        print(f\"  Incidents created: {len(recovery.recovery_history)}\")\n                        print(\"✓ SUCCESS: Incident emission working!\")\n        else:\n            print(\"✗ FAIL: No sessions need recovery (might be timing issue)\")\n    \n    except ImportError as e:\n        print(f\"✗ FAIL: Could not import recovery system: {e}\")\n    \n    # Step 4: Clean up test session\n    print()\n    print(\"=== Cleaning Up Test ===\")\n    \n    if REGISTRY_FILE.exists():\n        with open(REGISTRY_FILE, 'r') as f:\n            registry = json.load(f)\n        \n        # Remove test session\n        if test_session_id in registry:\n            del registry[test_session_id]\n            \n            with open(REGISTRY_FILE, 'w') as f:\n                json.dump(registry, f, indent=2)\n            \n            print(f\"Cleaned up test session: {test_session_id}\")\n    \n    print()\n    print(\"=== Test Complete ===\")\n    print(\"This test demonstrates:\")\n    print(\"1. Real session monitoring with actual data\")\n    print(\"2. Real stall detection based on inactivity\")\n    print(\"3. Real recovery triggering based on monitoring data\")\n    print(\"4. Real incident emission to error-learning-loop\")\n\nif __name__ == \"__main__\":\n    run_stall_detection_test()"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":223,"output":1662,"cacheRead":61568,"cacheWrite":0,"totalTokens":63453,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0