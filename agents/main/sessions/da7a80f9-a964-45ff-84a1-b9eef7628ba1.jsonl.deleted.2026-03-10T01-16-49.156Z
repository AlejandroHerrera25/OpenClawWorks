s/debate_mode.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/stage3_fit_gap.py"}],"details":{"status":"completed","exitCode":0,"durationMs":9,"aggregated":"/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/learning_emit.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/state_machine_engine.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/stage6_arch_validation.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/project_control.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/run_pipeline_integrated.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/official_docs_retrieval.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/stage5_data_model.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/validate_hardening.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/test_auditor_integration.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/dod_auditor_validator.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/run_pipeline_hardened.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/stage7_export.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/stage4_functional_design.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/stage2_requirements.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/run_pipeline.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/dod_validator.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/integrated_hardening.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/auditor_integration.py\n/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/debate_mode.py\n/home/openclaw/.openclaw