{"type":"message","id":"66d72d8e","parentId":"3a09ed86","timestamp":"2026-03-10T00:43:53.378Z","message":{"role":"assistant","content":[{"type":"text","text":"The file got cut off again. Let me create a simpler, complete version:"},{"type":"toolCall","id":"call_00_sojFNGU7FDwjCYHB6mhQtKdg","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/salesforce-code-auditor/scripts/report_generator.py","content":"#!/usr/bin/env python3\n\"\"\"\nComplete Audit Report Generator - Produce architect-consumable reports.\nSimplified version that works.\n\"\"\"\n\nimport argparse\nimport os\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom utils_fs import read_file, write_file, read_json, write_json\n\nWORKSPACE_ROOT = Path(os.getenv('WORKSPACE', '/home/openclaw/.openclaw/workspace'))\n\nclass ReportGenerator:\n    \"\"\"Generate complete audit reports for architect consumption.\"\"\"\n    \n    def __init__(self, project_key, case_id, mode='A'):\n        self.project_key = project_key\n        self.case_id = case_id\n        self.mode = mode\n        self.case_root = WORKSPACE_ROOT / 'projects' / project_key / 'code_audit' / case_id\n        \n    def load_all_data(self):\n        \"\"\"Load all audit data.\"\"\"\n        try:\n            self.manifest = read_json(self.case_root / 'MANIFEST.json')\n            self.dependency_graph = read_json(self.case_root / 'DEPENDENCY_GRAPH.json')\n            self.entrypoints = read_json(self.case_root / 'ENTRYPOINTS.json')\n            self.findings = read_json(self.case_root / 'FINDINGS_DETAILED.json')\n            self.risk_assessment = read_json(self.case_root / 'RISK_ASSESSMENT.json')\n            return True\n        except Exception as e:\n            print(f\"Error loading data: {e}\")\n            return False\n    \n    def generate_report(self):\n        \"\"\"Generate complete audit report.\"\"\"\n        if not self.load_all_data():\n            return \"Error: Could not load audit data.\"\n        \n        if self.mode == 'A':\n            return self._generate_mode_a()\n        elif self.mode == 'B':\n            return self._generate_mode_b()\n        elif self.mode == 'C':\n            return self._generate_mode_c()\n        else:\n            return self._generate_generic()\n    \n    def _generate_mode_a(self):\n        \"\"\"Mode A: Architecture → Code Audit.\"\"\"\n        overall = self.risk_assessment['risk_assessment']['overall_risk']\n        blockers = self.risk_assessment['risk_assessment']['blocking_conditions']\n        \n        report = f\"\"\"## Code Audit Report - Mode A\n\n**Project**: {self.project_key}\n**Audit Case ID**: {self.case_id}\n**Mode**: Architecture → Code Audit\n**Report Date**: {datetime.utcnow().isoformat()}Z\n\n### Executive Summary\n- **Code Health**: {self._get_health()}\n- **Overall Risk**: {overall['level']} ({overall['score']}/100)\n- **Total Findings**: {self.findings['metadata']['total_findings']}\n- **Critical Findings**: {self.findings['metadata']['severity_counts']['CRITICAL']}\n- **High Findings**: {self.findings['metadata']['severity_counts']['HIGH']}\n- **Architectural Implications**: {self._get_implications()}\n\n### Technical Assessment\n{self._get_tech_assessment()}\n\n### Constraints & Limitations\n{self._get_constraints()}\n\n### Risk Assessment\n{self._get_risk_summary()}\n\n### Recommendations for Architecture\n{self._get_recommendations()}\n\n### Evidence\n{self._get_evidence()}\n\"\"\"\n        return report\n    \n    def _generate_mode_b(self):\n        \"\"\"Mode B: Code Audit → Architecture.\"\"\"\n        overall = self.risk_assessment['risk_assessment']['overall_risk']\n        \n        report = f\"\"\"## Code Audit Report - Mode B\n\n**Project**: {self.project_key}\n**Audit Case ID**: {self.case_id}\n**Mode**: Code Audit → Architecture\n**Report Date**: {datetime.utcnow().isoformat()}Z\n\n### Critical Findings Summary\n{self._get_critical_summary()}\n\n### Architectural Impact Assessment\n{self._get_arch_impact()}\n\n### Remediation Options\n{self._get_remediation()}\n\n### Risk Analysis\n{self._get_risk_analysis()}\n\n### Evidence-Based Recommendations\n{self._get_evidence_recommendations()}\n\n### Evidence\n{self._get_detailed_evidence()}\n\"\"\"\n        return report\n    \n    def _generate_mode_c(self):\n        \"\"\"Mode C: Design Validation.\"\"\"\n        report = f\"\"\"## Code Audit Report - Mode C\n\n**Project**: {self.project_key}\n**Audit Case ID**: {self.case_id}\n**Mode**: Design Validation\n**Report Date**: {datetime.utcnow().isoformat()}Z\n\n### Design Feasibility Assessment\n{self._get_feasibility()}\n\n### Gap Analysis\n{self._get_gap_analysis()}\n\n### Implementation Complexity\n{self._get_complexity()}\n\n### Recommendations\n{self._get_design_recommendations()}\n\n### Evidence\n{self._get_design_evidence()}\n\"\"\"\n        return report\n    \n    def _generate_generic(self):\n        \"\"\"Generic audit report.\"\"\"\n        overall = self.risk_assessment['risk_assessment']['overall_risk']\n        \n        report = f\"\"\"# Complete Audit Report\n\n**Project**: {self.project_key}\n**Audit Case ID**: {self.case_id}\n**Report Date**: {datetime.utcnow().isoformat()}Z\n\n## Executive Summary\n{self._get_exec_summary()}\n\n## Technical Assessment\n{self._get_tech_assessment()}\n\n## Risk Assessment\n{self._get_risk_summary()}\n\n## Findings by Severity\n{self._get_findings_by_severity()}\n\n## Recommendations\n{self._get_all_recommendations()}\n\n## Evidence\n{self._get_complete_evidence()}\n\"\"\"\n        return report\n    \n    # Helper methods\n    def _get_health(self):\n        total = self.findings['metadata']['total_findings']\n        critical = self.findings['metadata']['severity_counts']['CRITICAL']\n        if critical > 0:\n            return \"POOR - Critical issues need immediate attention\"\n        elif total > 10:\n            return \"FAIR - Multiple issues to address\"\n        elif total > 5:\n            return \"GOOD - Some improvements needed\"\n        else:\n            return \"EXCELLENT - Minimal issues\"\n    \n    def _get_implications(self):\n        blockers = self.risk_assessment['risk_assessment']['blocking_conditions']\n        critical = len(blockers['critical_blockers'])\n        if critical > 0:\n            return f\"{critical} critical findings block architectural decisions\"\n        return \"No critical blockers found\"\n    \n    def _get_tech_assessment(self):\n        ui = len([ep for ep in self.entrypoints.get('entrypoints', []) \n                 if ep['type'] in ['vf_page', 'lwc', 'apex_aura']])\n        apex = len([n for n in self.dependency_graph.get('nodes', []) \n                   if n.get('type') == 'apex'])\n        edges = len(self.dependency_graph.get('edges', []))\n        patterns = len(set(f['pattern'] for f in self.findings['findings']))\n        \n        return f\"\"\"- **UI Layer**: {ui} entry points\n- **Controller Layer**: {apex} Apex classes\n- **Dependencies**: {edges} relationships\n- **Patterns Detected**: {patterns} issue patterns\"\"\"\n    \n    def _get_constraints(self):\n        constraints = []\n        for f in self.findings['findings']:\n            if f['severity'] == 'CRITICAL' and any(p in f['pattern'] for p in ['SOQL', 'FLS', 'RECURSION']):\n                constraints.append(f\"- {f['description']} in {f['file']}\")\n        \n        if not constraints:\n            constraints.append(\"- No critical technical constraints\")\n            constraints.append(\"- Review high/medium findings for optimizations\")\n        \n        return \"\\n\".join(constraints)\n    \n    def _get_risk_summary(self):\n        overall = self.risk_assessment['risk_assessment']['overall_risk']\n        blockers = self.risk_assessment['risk_assessment']['blocking_conditions']\n        \n        summary = [f\"- **Overall Risk**: {overall['level']} ({overall['score']}/100)\"]\n        \n        for cat, stats in overall['by_category'].items():\n            summary.append(f\"- **{cat} Risk**: {stats['average_score']:.1f}/100 ({stats['finding_count']} findings)\")\n        \n        if blockers['critical_blockers']:\n            summary.append(f\"- **Critical Blockers**: {len(blockers['critical_blockers'])}\")\n        if blockers['high_blockers']:\n            summary.append(f\"- **High Blockers**: {len(blockers['high_blockers'])}\")\n        \n        return \"\\n\".join(summary)\n    \n    def _get_recommendations(self):\n        recs = []\n        priority = 1\n        \n        for f in self.findings['findings']:\n            if f['severity'] == 'CRITICAL':\n                recs.append(f\"{priority}. **{f['pattern']}** in `{f['file']}`: {f['recommendation']}\")\n                priority += 1\n        \n        for f in self.findings['findings']:\n            if f['severity'] == 'HIGH':\n                recs.append(f\"{priority}. **{f['pattern']}** in `{f['file']}`: {f['recommendation']}\")\n                priority += 1\n        \n        if not recs:\n            recs.append(\"1. No critical/high findings - proceed with architecture\")\n            recs.append(\"2. Review medium findings for optimizations\")\n        \n        return \"\\n\".join(recs)\n    \n    def _get_evidence(self):\n        evidence = []\n        critical = [f for f in self.findings['findings'] if f['severity'] in ['CRITICAL', 'HIGH']]\n        \n        if critical:\n            evidence.append(\"#### Code Snippets with Issues:\")\n            for f in critical[:3]:\n                evidence.append(f\"- `{f['file']}:{f['line']}` - {f['pattern']}\")\n                evidence.append(f\"  ```\\n  {f['code_snippet'][:100]}...\\n  ```\")\n        \n        nodes = len(self.dependency_graph.get('nodes', []))\n        edges = len(self.dependency_graph.get('edges', []))\n        evidence.append(f\"\\n#### Dependency Analysis:\")\n        evidence.append(f\"- **Files**: {nodes}\")\n        evidence.append(f\"- **Relationships**: {edges}\")\n        \n        soql = len([f for f in self.findings['findings'] if 'SOQL' in f['pattern']])\n        fls = len([f for f in self.findings['findings'] if 'FLS' in f['pattern']])\n        evidence.append(f\"\\n#### Metrics:\")\n        evidence.append(f\"- **SOQL Issues**: {soql}\")\n        evidence.append(f\"- **Security Issues**: {fls}\")\n        \n        return \"\\n\".join(evidence)\n    \n    # Mode B helpers\n    def _get_critical_summary(self):\n        critical = [f for f in self.findings['findings'] if f['severity'] == 'CRITICAL']\n        high = [f for f in self.findings['findings'] if f['severity'] == 'HIGH']\n        \n        summary = [f\"- **Critical Findings**: {len(critical)}\"]\n        summary.append(f\"- **High Findings**: {len(high)}\")\n        \n        risks = []\n        for f in critical:\n            if 'SOQL' in f['pattern']:\n                risks.append(\"governor limits\")\n            elif 'FLS' in f['pattern']:\n                risks.append(\"security\")\n            elif 'RECURSION' in f['pattern']:\n                risks.append(\"infinite loops\")\n        \n        if risks:\n            summary.append(f\"- **Immediate Risks**: {', '.join(set(risks))}\")\n        else:\n            summary.append(\"- **Immediate Risks**: None identified\")\n        \n        if critical:\n            summary.append(\"\\n#### Critical Findings:\")\n            for f in critical:\n                summary.append(f\"- **{f['pattern']}** in `{f['file']}:{f['line']}`\")\n                summary.append(f\"  - {f['description']}\")\n        \n        return \"\\n\".join(summary)\n    \n    def _get_arch_impact(self):\n        impact = []\n        patterns = set(f['pattern'] for f in self.findings['findings'] if f['severity'] == 'CRITICAL')\n        \n        if 'SOQL_IN_LOOP' in patterns:\n            impact.append(\"- **Performance**: Query optimization needed\")\n        if 'FLS_MISSING' in patterns:\n            impact.append(\"- **Security**: Security layer implementation needed\")\n        if 'RECURSION_RISK' in patterns:\n            impact.append(\"- **Reliability**: Recursion guards needed\")\n        \n        if not impact:\n            impact.append(\"- **Minimal Impact**: No critical architectural changes required\")\n        \n        return \"\\n\".join(impact)\n    \n    def _get_remediation(self):\n        critical = len([f for f in self.findings['findings'] if f['severity'] == 'CRITICAL'])\n        high = len([f for f in self.findings['findings'] if f['severity'] == 'HIGH'])\n        \n        options = []\n        options.append(\"#### Option A: Immediate Critical Fixes\")\n        options.append(f\"- **Scope**: {critical} critical findings\")\n        options.append(\"- **Effort**: Low-Medium\")\n        options.append(\"- **Risk**: Medium\")\n        \n        options.append(\"\\n#### Option B: Comprehensive Remediation\")\n        options.append(f\"- **Scope**: {critical} critical + {high} high findings\")\n        options.append(\"- **Effort**: Medium-High\")\n        options.append(\"- **Risk**: Low\")\n        \n        options.append(\"\\n#### Option C: Phased Approach\")\n        options.append(\"- **Scope**: Critical now, high next release, medium/low later\")\n        options.append(\"- **Effort**: Spread across releases\")\n        options.append(\"- **Risk**: Low-Medium\")\n        \n        return \"\\n\".join(options)\n    \n    def _get_risk_analysis(self):\n        overall = self.risk_assessment['risk_assessment']['overall_risk']\n        \n        analysis = []\n        analysis.append(f\"#### Current Risk: {overall['level']} ({overall['score']}/100)\")\n        \n        if overall['level'] in ['CRITICAL', 'HIGH']:\n            analysis.append(\"- **Assessment**: Significant risk present\")\n        else:\n            analysis.append(\"- **Assessment**: Acceptable risk level\")\n        \n        analysis.append(\"\\n#### Risk of Changes:\")\n        analysis.append(\"- **Implementation**: Low-Medium\")\n        analysis.append(\"- **Regression**: Medium\")\n        \n        analysis.append(\"\\n#### Risk of No Changes:\")\n        if overall['level'] in ['CRITICAL', 'HIGH']:\n            analysis.append(\"- **High**: System failures likely\")\n        else:\n            analysis.append(\"- **Low**: Technical debt accumulation\")\n        \n        return \"\\n\".join(analysis)\n    \n    def _get_evidence_recommendations(self):\n        recs = []\n        \n        # Group by pattern\n        patterns = {}\n        for f in self.findings['findings']:\n            p = f['pattern']\n            if p not in patterns:\n                patterns[p] = []\n            patterns[p].append(f)\n        \n        for p, findings in patterns.items():\n            if findings:\n                count = len(findings)\n                f = findings[0]\n                recs.append(f\"#### {p} ({count} occurrences)\")\n                recs.append(f\"- **Example**: `{f['file']}:{f['line']}`\")\n                recs.append(f\"- **Recommendation**: {f['recommendation']}\")\n                recs.append(\"\")\n        \n        return \"\\n\".join(recs)\n    \n    def _get_detailed_evidence(self):\n        evidence = []\n        critical = [f for f in self.findings['findings'] if f['severity'] == 'CRITICAL']\n        \n        if critical:\n            evidence.append(\"#### Critical Findings Evidence:\")\n            for f in critical:\n                evidence.append(f\"##### {f['pattern']} in `{f['file']}:{f['line']}`\")\n                evidence.append(f\"**Code**:\")\n                evidence.append(f\"```\\n{f['code_snippet']}\\n```\")\n                evidence.append(f\"**Fix**: {f['recommendation']}\")\n                evidence.append(\"\")\n        else:\n            evidence.append(\"No critical findings requiring detailed evidence.\")\n        \n        return \"\\n\".join(evidence)\n    \n    # Mode C helpers\n    def _get_feasibility(self):\n        blockers = self.risk_assessment['risk_assessment']['blocking_conditions']\n        critical = len(blockers['critical_blockers'])\n        \n        if critical > 0:\n            return f\"\"\"- **Feasibility**: NOT FEASIBLE without changes\n- **Concerns**: {critical} critical issues block implementation\n- **Evidence**: See critical findings\"\"\"\n        else:\n            return f\"\"\"- **Feasibility**: FEASIBLE with considerations\n- **Concerns**: Review high/medium findings\n- **Evidence**: No critical blockers\"\"\"\n    \n    def _get_gap_analysis(self):\n        gaps = []\n        \n        has_test = any('TEST' in f['pattern'] for f in self.findings['findings'])\n        has_docs = any('COMMENT' in f['pattern'] or 'DOC' in f['pattern'] for f in self.findings['findings'])\n        \n        if not has_test:\n            gaps.append(\"- **Testing**: Limited test coverage\")\n        if not has_docs:\n            gaps.append(\"- **Documentation**: Insufficient comments\")\n        \n        apex_count = len([n for n in self.dependency_graph.get('nodes', []) if n.get('type') == 'apex'])\n        if apex_count > 5 and len(self.dependency_graph.get('edges', [])) < 10:\n            gaps.append(\"- **Architecture**: Limited separation of concerns\")\n        \n        if not gaps:\n            gaps.append(\"- **Minimal Gaps**: Implementation aligns with design patterns\")\n        \n        return \"\\n\".join(gaps)\n    \n    def _get_complexity(self):\n        critical = self.findings['metadata']['severity_counts']['CRITICAL']\n        high = self.findings['metadata']['severity_counts']['HIGH']\n        \n        complexity = []\n        complexity.append(\"- **Effort Estimation**:\")\n        \n        if critical > 0:\n            complexity.append(f\"  - Critical fixes: {critical} × 2-4 hours\")\n        if high > 0:\n            complexity.append(f\"  - High fixes: {high} × 1-2 hours\")\n        \n        total = (critical *"}}],"