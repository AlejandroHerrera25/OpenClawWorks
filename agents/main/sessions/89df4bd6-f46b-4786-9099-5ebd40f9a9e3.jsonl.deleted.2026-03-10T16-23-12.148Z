{"type":"message","id":"6b1d92d7","parentId":"df2899fa","timestamp":"2026-03-10T01:21:48.457Z","message":{"role":"toolResult","toolCallId":"call_00_hTUgwsLH5akHtLMwidUqvYhk","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nPlan Generator for long-prompt-orchestrator skill.\nGenerates structured plans for main agent execution.\nReplaces incorrect spawning code with proper planning interface.\n\"\"\"\n\nimport json\nimport os\nimport uuid\nimport time\nfrom typing import Dict, List, Any, Optional, Tuple\nfrom dataclasses import dataclass, asdict\nfrom enum import Enum\n\nWORKSPACE = os.path.expanduser(\"~/.openclaw/workspace\")\n\nclass TaskPriority(Enum):\n    LOW = \"low\"\n    MEDIUM = \"medium\"\n    HIGH = \"high\"\n    CRITICAL = \"critical\"\n\n@dataclass\nclass PlanTask:\n    \"\"\"Task representation in a plan.\"\"\"\n    task_id: str\n    objective: str\n    description: str\n    execution_mode: str  # \"main\" | \"subagent\" | \"mixed\"\n    action_type: str  # \"exec\" | \"python\" | \"skill_invocation\" | \"file_operation\"\n    action_instructions: str  # Specific, executable instructions\n    required_inputs: List[str]\n    expected_outputs: List[str]\n    dependencies: List[str]\n    validation_method: str  # How to validate task completion\n    estimated_tokens: int\n    estimated_runtime_seconds: int\n    complexity_score: int\n    recommended_skill_or_role: Optional[str]  # Which skill/sub-agent should handle this\n    artifact_destination: Optional[str]  # Where to store outputs\n    priority: TaskPriority = TaskPriority.MEDIUM\n    execution_hints: Optional[Dict[str, Any]] = None\n    \n    def to_dict(self) -> Dict[str, Any]:\n        \"\"\"Convert to dictionary for JSON serialization.\"\"\"\n        data = asdict(self)\n        data['priority'] = self.priority.value\n        if self.execution_hints is None:\n            data['execution_hints'] = self._default_execution_hints()\n        return data\n    \n    def _default_execution_hints(self) -> Dict[str, Any]:\n        \"\"\"Generate default execution hints based on task properties.\"\"\"\n        return {\n            \"parallelizable\": len(self.dependencies) == 0,\n            \"requires_isolation\": self.complexity_score >= 7,\n            \"risk_level\": \"high\" if self.complexity_score >= 7 else \"medium\" if self.complexity_score >= 4 else \"low\",\n            \"retry_policy\": \"exponential_backoff_3\" if self.complexity_score >= 5 else \"immediate_2\"\n        }\n\nclass PlanGenerator:\n    \"\"\"Generates structured plans for main agent execution.\"\"\"\n    \n    def __init__(self, original_prompt: str):\n        self.original_prompt = original_prompt\n        self.plan_id = f\"plan_{int(time.time())}_{uuid.uuid4().hex[:8]}\"\n        self.tasks: List[PlanTask] = []\n        self.created_at = time.strftime(\"%Y-%m-%dT%H:%M:%SZ\", time.gmtime())\n    \n    def add_task(self, task_data: Dict[str, Any]) -> str:\n        \"\"\"Add a task to the plan.\"\"\"\n        # Generate task_id if not provided\n        task_id = task_data.get('id', f\"task_{len(self.tasks)+1:02d}\")\n        \n        # Determine execution mode based on complexity and requirements\n        execution_mode = self._determine_execution_mode(task_data)\n        \n        # Determine action type based on task content\n        action_type = self._determine_action_type(task_data)\n        \n        # Generate executable instructions\n        action_instructions = self._generate_action_instructions(task_data, action_type)\n        \n        # Generate validation method\n        validation_method = self._generate_validation_method(task_data)\n        \n        # Determine artifact destination\n        artifact_destination = self._determine_artifact_destination(task_data, task_id)\n        \n        # Create PlanTask object\n        task = PlanTask(\n            task_id=task_id,\n            objective=task_data.get('objective', ''),\n            description=task_data.get('description', task_data.get('objective', '')),\n            execution_mode=execution_mode,\n            action_type=action_type,\n            action_instructions=action_instructions,\n            required_inputs=task_data.get('inputs', []),\n            expected_outputs=task_data.get('outputs', []),\n            dependencies=task_data.get('dependencies', []),\n            validation_method=validation_method,\n            estimated_tokens=task_data.get('estimated_tokens', 1000),\n            estimated_runtime_seconds=task_data.get('estimated_runtime', 60),\n            complexity_score=task_data.get('complexity_score', 0),\n            recommended_skill_or_role=self._recommend_skill_or_role(task_data),\n            artifact_destination=artifact_destination,\n            priority=self._determine_priority(task_data)\n        )\n        \n        self.tasks.append(task)\n        return task_id\n    \n    def _should_require_subagent(self, task_data: Dict[str, Any]) -> bool:\n        \"\"\"Determine if task requires sub-agent.\"\"\"\n        # Always require subagent if explicitly specified\n        if task_data.get('subagent_required', False):\n            return True\n        \n        # Require subagent for complex tasks\n        complexity_score = task_data.get('complexity_score', 0)\n        if complexity_score >= 5:\n            return True\n        \n        # Require subagent for specialized tasks\n        if self._recommend_skill_or_role(task_data) is not None:\n            return True\n        \n        # Require subagent for long-running tasks\n        estimated_runtime = task_data.get('estimated_runtime', 0)\n        if estimated_runtime > 300:  # 5 minutes\n            return True\n        \n        return False\n    \n\n    \n    def _determine_priority(self, task_data: Dict[str, Any]) -> TaskPriority:\n        \"\"\"Determine task priority.\"\"\"\n        complexity_score = task_data.get('complexity_score', 0)\n        \n        if complexity_score >= 8:\n            return TaskPriority.CRITICAL\n        elif complexity_score >= 5:\n            return TaskPriority.HIGH\n        elif complexity_score >= 3:\n            return TaskPriority.MEDIUM\n        else:\n            return TaskPriority.LOW\n    \n    def _determine_execution_mode(self, task_data: Dict[str, Any]) -> str:\n        \"\"\"Determine execution mode: main, subagent, or mixed.\"\"\"\n        requires_subagent = self._should_require_subagent(task_data)\n        complexity_score = task_data.get('complexity_score', 0)\n        \n        if requires_subagent:\n            return \"subagent\"\n        elif complexity_score >= 5:\n            return \"mixed\"  # Could be done by main but might need subagent help\n        else:\n            return \"main\"\n    \n    def _determine_action_type(self, task_data: Dict[str, Any]) -> str:\n        \"\"\"Determine action type based on task content.\"\"\"\n        objective = task_data.get('objective', '').lower()\n        description = task_data.get('description', '').lower()\n        \n        # Check for skill invocation\n        if self._recommend_skill_or_role(task_data) is not None:\n            return \"skill_invocation\"\n        \n        # Check for file operations\n        file_keywords = ['file', 'create', 'write', 'read', 'edit', 'save', 'generate']\n        if any(keyword in objective or keyword in description for keyword in file_keywords):\n            return \"file_operation\"\n        \n        # Check for Python scripts\n        python_keywords = ['python', 'script', 'code', 'program', 'run python', 'execute script']\n        if any(keyword in objective or keyword in description for keyword in python_keywords):\n            return \"python\"\n        \n        # Default to exec for shell commands\n        return \"exec\"\n    \n    def _generate_action_instructions(self, task_data: Dict[str, Any], action_type: str) -> str:\n        \"\"\"Generate executable instructions based on action type.\"\"\"\n        objective = task_data.get('objective', '')\n        description = task_data.get('description', '')\n        outputs = task_data.get('outputs', [])\n        \n        if action_type == \"exec\":\n            # Convert objective to shell command\n            obj_lower = objective.lower()\n            if \"list\" in obj_lower or \"inventory\" in obj_lower:\n                if \"skill\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace/skills -type f -name 'SKILL.md' -exec basename {} \\\\; | sort\"\n                elif \"file\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace -type f -name '*.md' -o -name '*.py' | head -20\"\n                else:\n                    return \"ls -la /home/openclaw/.openclaw/workspace | head -20\"\n            elif \"search\" in obj_lower or \"find\" in obj_lower:\n                # Extract search terms from objective\n                import re\n                terms = re.findall(r'\\\"([^\\\"]+)\\\"|\\'([^\\']+)\\'|for\\s+([a-zA-Z0-9_]+)', objective)\n                search_terms = [term for group in terms for term in group if term]\n                if search_terms:\n                    term = search_terms[0]\n                    return f\"grep -r '{term}' /home/openclaw/.openclaw/workspace --include='*.md' --include='*.py' | head -10\"\n                else:\n                    return \"grep -r 'TODO\\\\|FIXME' /home/openclaw/.openclaw/workspace --include='*.py' --include='*.md' | head -10\"\n            elif \"count\" in obj_lower or \"measure\" in obj_lower:\n                if \"line\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace -type f -name '*.py' -exec wc -l {} \\\\; | tail -1\"\n                elif \"file\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace -type f | wc -l\"\n                else:\n                    return \"find /home/openclaw/.openclaw/workspace -type f -name '*.py' | wc -l\"\n            elif \"check\" in obj_lower or \"verify\" in obj_lower:\n                return \"python3 -m py_compile /home/openclaw/.openclaw/workspace/skills/*/scripts/*.py 2>&1 | head -10\"\n            else:\n                # Generic command based on objective\n                return f\"# Execute: {objective[:80]}\\necho 'Starting task: {objective[:80]}...'\\ndate\"\n        \n        elif action_type == \"python\":\n            # Generate Python script instructions\n            if \"analyze\" in objective.lower() or \"process\" in objective.lower():\n                return f\"\"\"# Python script to: {objective[:80]}\nimport json\nimport os\nimport sys\n\ndef main():\n    print(\"Analyzing: {objective[:80]}...\")\n    # TODO: Implement analysis logic\n    result = {{\"status\": \"completed\", \"task\": \"{objective[:80]}\"}}\n    \n    # Save output if specified\n    outputs = {outputs}\n    if outputs:\n        with open(outputs[0], 'w') as f:\n            json.dump(result, f, indent=2)\n    \n    return result\n\nif __name__ == \"__main__\":\n    main()\"\"\"\n            else:\n                return f\"\"\"# Python script to: {objective[:80]}\nimport os\nimport sys\n\ndef main():\n    print(\"Executing: {objective[:80]}...\")\n    # TODO: Implement based on objective\n    return {{\"status\": \"completed\"}}\n\nif __name__ == \"__main__\":\n    main()\"\"\"\n        \n        elif action_type == \"skill_invocation\":\n            skill = self._recommend_skill_or_role(task_data)\n            if skill == \"tavily-web-search\":\n                # Extract search query from objective\n                import re\n                query_terms = re.findall(r'\\\"([^\\\"]+)\\\"|\\'([^\\']+)\\'|about\\s+([a-zA-Z0-9_\\s]+)', objective)\n                query = next((term for group in query_terms for term in group if term), objective[:50])\n                return f\"Invoke tavily-web-search skill with query: '{query}' --max-results 3 --output /tmp/search_results.json\"\n            elif skill == \"salesforce-architect\":\n                return f\"Invoke salesforce-architect skill with requirement: {objective[:80]}...\"\n            elif skill == \"salesforce-code-auditor\":\n                return f\"Invoke salesforce-code-auditor skill to audit: {objective[:80]}...\"\n            elif skill == \"workspace-janitor\":\n                return \"Invoke workspace-janitor skill to clean up temporary files and organize workspace\"\n            elif skill == \"long-prompt-orchestrator\":\n                return f\"Invoke long-prompt-orchestrator skill to plan: {objective[:80]}...\"\n            elif skill:\n                return f\"Invoke {skill} skill with objective: {objective[:80]}...\"\n            else:\n                return f\"# Determine appropriate skill for: {objective[:80]}\\n# Check available skills in /home/openclaw/.openclaw/workspace/skills/\"\n        \n        elif action_type == \"file_operation\":\n            # Generate file operation instructions\n            if outputs:\n                output_file = outputs[0]\n                if output_file.endswith('.md'):\n                    return f\"\"\"# Create markdown file: {output_file}\ncat > {output_file} << 'EOF'\n# {objective}\n\n{description[:200]}\n\n## Details\n- Created: $(date)\n- Task: {objective[:80]}\n- Status: In progress\n\n## Content\nTODO: Add content based on objective.\nEOF\necho \"Created {output_file}\" \"\"\"\n                elif output_file.endswith('.json'):\n                    return f\"\"\"# Create JSON file: {output_file}\ncat > {output_file} << 'EOF'\n{{\n  \"task\": \"{objective[:80]}\",\n  \"status\": \"pending\",\n  \"created_at\": \"$(date -Iseconds)\",\n  \"description\": \"{description[:100]}\"\n}}\nEOF\necho \"Created {output_file}\" \"\"\"\n                else:\n                    return f\"# Create file: {output_file}\\necho 'File: {output_file}' > {output_file}\\necho 'Content for: {objective[:80]}' >> {output_file}\"\n            else:\n                return f\"# File operation for: {objective[:80]}\\n# Determine appropriate file operation based on objective\"\n        \n        return f\"# Execute: {objective[:80]}\\n# Determine appropriate action based on task requirements\"\n    \n    def _generate_validation_method(self, task_data: Dict[str, Any]) -> str:\n        \"\"\"Generate validation method for task completion.\"\"\"\n        outputs = task_data.get('outputs', [])\n        acceptance_criteria = task_data.get('acceptance_criteria', [])\n        action_type = self._determine_action_type(task_data)\n        \n        if outputs:\n            validation_checks = []\n            for output in outputs:\n                if output.endswith('.json'):\n                    validation_checks.append(f\"Check {output} exists and contains valid JSON\")\n                elif output.endswith('.md'):\n                    validation_checks.append(f\"Check {output} exists and has content > 100 characters\")\n                elif output.endswith('.py'):\n                    validation_checks.append(f\"Check {output} exists and is valid Python syntax\")\n                else:\n                    validation_checks.append(f\"Check {output} exists and is not empty\")\n            \n            if acceptance_criteria:\n                validation_checks.append(f\"Validate: {acceptance_criteria[0][:80]}\")\n            \n            return \"; \".join(validation_checks)\n        elif acceptance_criteria:\n            if len(acceptance_criteria) > 1:\n                return f\"Validate: {acceptance_criteria[0][:80]} and {len(acceptance_criteria)-1} more criteria\"\n            else:\n                return f\"Validate: {acceptance_criteria[0][:100]}\"\n        else:\n            # Default validation based on action type\n            if action_type == \"exec\":\n                return \"Check command executed successfully (exit code 0)\"\n            elif action_type == \"python\":\n                return \"Check script ran without errors and produced expected output\"\n            elif action_type == \"skill_invocation\":\n                return \"Check skill invocation completed and returned results\"\n            elif action_type == \"file_operation\":\n                return \"Check file operation completed as expected\"\n            else:\n                return \"Verify task completion by checking output meets objective\"\n    \n    def _determine_artifact_destination(self, task_data: Dict[str, Any], task_id: str) -> str:\n        \"\"\"Determine where to store task artifacts.\"\"\"\n        outputs = task_data.get('outputs', [])\n        \n        if outputs:\n            # Use first output as artifact destination\n            return f\"projects/{{project_key}}/{outputs[0]}\"\n        else:\n            return f\"projects/{{project_key}}/{task_id}_output.txt\"\n    \n    def _recommend_skill_or_role(self, task_data: Dict[str, Any]) -> Optional[str]:\n        \"\"\"Recommend skill or role for task (replaces _recommend_skill).\"\"\"\n        objective = task_data.get('objective', '').lower()\n        description = task_data.get('description', '').lower()\n        full_text = f\"{objective} {description}\"\n        \n        # Check for workspace maintenance/inventory FIRST (most common non-Salesforce task)\n        workspace_keywords = ['workspace', 'inventory', 'list skills', 'clean', 'organize', 'tidy', 'maintain', 'janitor']\n        workspace_priority_keywords = ['workspace audit', 'inventory workspace', 'clean workspace', 'organize workspace']\n        \n        # Check for high-priority workspace phrases first\n        for phrase in workspace_priority_keywords:\n            if phrase in full_text:\n                return \"workspace-janitor\"\n        \n        # Check for individual workspace keywords\n        if any(keyword in full_text for keyword in workspace_keywords):\n            # But check if it's actually a Salesforce task in disguise\n            salesforce_keywords = ['salesforce', 'apex', 'lwc', 'visualforce', 'soql', 'flow', 'sfdc']\n            has_salesforce = any(keyword in full_text for keyword in salesforce_keywords)\n            \n            # If it mentions Salesforce AND workspace, prioritize based on context\n            if has_salesforce:\n                # Check if Salesforce is the primary focus\n                salesforce_primary_indicators = ['salesforce audit', 'apex code', 'lwc component', 'salesforce security']\n                if any(indicator in full_text for indicator in salesforce_primary_indicators):\n                    audit_keywords = ['audit', 'review', 'check', 'validate', 'security', 'code quality', 'inspect']\n                    if any(keyword in full_text for keyword in audit_keywords):\n                        return \"salesforce-code-auditor\"\n                    else:\n                        return \"salesforce-architect\"\n                else:\n                    # Workspace is primary, Salesforce is secondary\n                    return \"workspace-janitor\"\n            else:\n                # Pure workspace task\n                return \"workspace-janitor\"\n        \n        # Check for Salesforce-related content (without workspace context)\n        salesforce_keywords = ['salesforce', 'apex', 'lwc', 'visualforce', 'soql', 'flow', 'sfdc']\n        if any(keyword in full_text for keyword in salesforce_keywords):\n            # Salesforce-specific tasks\n            audit_keywords = ['audit', 'review', 'check', 'validate', 'security', 'code quality', 'inspect']\n            if any(keyword in full_text for keyword in audit_keywords):\n                return \"salesforce-code-auditor\"\n            else:\n                return \"salesforce-architect\"\n        \n        # Check for web search/research\n        search_keywords = ['search', 'research', 'find', 'look up', 'web', 'internet', 'google', 'browse']\n        if any(keyword in full_text for keyword in search_keywords):\n            return \"tavily-web-search\"\n        \n        # Check for system health/monitoring\n        system_keywords = ['system health', 'check system', 'monitor', 'watchdog', 'agent-watchdog']\n        if any(keyword in full_text for keyword in system_keywords):\n            return \"agent-watchdog\"\n        \n        # Check for memory/vector operations\n        memory_keywords = ['memory', 'vector', 'embedding', 'semantic', 'retrieval']\n        if any(keyword in full_text for keyword in memory_keywords):\n            return \"vector-memory\"\n        \n        # Check for error handling/learning\n        error_keywords = ['error', 'incident', 'learning loop', 'guardrail', 'mistake']\n        if any(keyword in full_text for keyword in error_keywords):\n            return \"error-learning-loop\"\n        \n        # Check for planning/orchestration\n        planning_keywords = ['plan', 'orchestrate', 'coordinate', 'decompose', 'schedule', 'long prompt']\n        if any(keyword in full_text for keyword in planning_keywords):\n            return \"long-prompt-orchestrator\"\n        \n        return None\n    \n    def build_dependency_graph(self) -> Dict[str, Any]:\n        \"\"\"Build dependency graph from tasks.\"\"\"\n        nodes = [task.task_id for task in self.tasks]\n        edges = []\n        \n        for task in self.tasks:\n            for dep in task.dependencies:\n                edges.append([dep, task.task_id])\n        \n        # Calculate topological order (simplified Kahn's algorithm)\n        topological_order = self._calculate_topological_order(nodes, edges)\n        \n        return {\n            \"nodes\": nodes,\n            \"edges\": edges,\n            \"topological_order\": topological_order\n        }\n    \n    def _calculate_topological_order(self, nodes: List[str], edges: List[List[str]]) -> List[str]:\n        \"\"\"Calculate topological order using Kahn's algorithm.\"\"\"\n        from collections import defaultdict, deque\n        \n        # Build adjacency list and in-degree count\n        graph = defaultdict(list)\n        in_degree = defaultdict(int)\n        \n        for node in nodes:\n            in_degree[node] = 0\n        \n        for from_node, to_node in edges:\n            graph[from_node].append(to_node)\n            in_degree[to_node] += 1\n        \n        # Initialize queue with nodes having no incoming edges\n        queue = deque([node for node in nodes if in_degree[node] == 0])\n        topological_order = []\n        \n        # Process queue\n        while queue:\n            node = queue.popleft()\n            topological_order.append(node)\n            \n            for neighbor in graph[node]:\n                in_degree[neighbor] -= 1\n                if in_degree[neighbor] == 0:\n                    queue.append(neighbor)\n        \n        # Check for cycles\n        if len(topological_order) != len(nodes):\n            # Graph has a cycle, return nodes in original order\n            return nodes\n        \n        return topological_order\n    \n    def calculate_resource_allocation(self) -> Dict[str, Any]:\n        \"\"\"Calculate resource allocation recommendations.\"\"\"\n        total_tokens = sum(task.estimated_tokens for task in self.tasks)\n        total_runtime = sum(task.estimated_runtime_seconds for task in self.tasks)\n        \n        # Count tasks that can run in parallel (no dependencies)\n        parallelizable_tasks = sum(1 for task in self.tasks if len(task.dependencies) == 0)\n        \n        # Calculate max concurrent tasks (simplified)\n        max_concurrent = min(parallelizable_tasks, 5)  # Cap at 5 concurrent\n        \n        # Calculate token budget per phase\n        token_budget_per_phase = min(4000, total_tokens // 3)\n        \n        return {\n            \"max_concurrent_tasks\": max_concurrent,\n            \"token_budget_per_phase\": token_budget_per_phase,\n            \"recommended_batch_size\": min(3, max_concurrent)\n        }\n    \n    def generate_validation_protocol(self) -> Dict[str, Any]:\n        \"\"\"Generate validation protocol for the plan.\"\"\"\n        return {\n            \"pre_execution_checks\": [\n                \"Verify workspace has write permissions\",\n                \"Check available token budget\",\n                \"Validate task dependencies are acyclic\"\n            ],\n            \"post_execution_validation\": [\n                \"Validate each task's acceptance criteria\",\n                \"Check output files exist and are readable\",\n                \"Verify task outputs match expected formats\"\n            ],\n            \"final_synthesis_requirements\": [\n                \"Combine all task outputs into final result\",\n                \"Validate final result against original prompt requirements\",\n                \"Ensure proper formatting and structure\"\n            ]\n        }\n    \n    def generate_plan(self) -> Dict[str, Any]:\n        \"\"\"Generate complete plan in standard format.\"\"\"\n        # Calculate total resources\n        total_tokens = sum(task.estimated_tokens for task in self.tasks)\n        total_runtime = sum(task.estimated_runtime_seconds for task in self.tasks)\n        \n        # Build plan structure\n        plan = {\n            \"plan_id\": self.plan_id,\n            \"original_prompt\": self.original_prompt[:1000] + \"...\" if len(self.original_prompt) > 1000 else self.original_prompt,\n            \"created_at\": self.created_at,\n            \"estimated_total_tokens\": total_tokens,\n            \"estimated_total_runtime_seconds\": total_runtime,\n            \"global_token_budget\": 16000,  # Default budget\n            \"tasks\": [task.to_dict() for task in self.tasks],\n            \"dependency_graph\": self.build_dependency_graph(),\n            \"resource_allocation\": self.calculate_resource_allocation(),\n            \"validation_protocol\": self.generate_validation_protocol()\n        }\n        \n        return plan\n    \n    def save_plan(self, output_path: Optional[str] = None) -> str:\n        \"\"\"Save plan to file.\"\"\"\n        if output_path is None:\n            output_path = os.path.join(WORKSPACE, f\"{self.plan_id}.json\")\n        \n        plan = self.generate_plan()\n        \n        with open(output_path, 'w') as f:\n            json.dump(plan, f, indent=2)\n        \n        return output_path\n\ndef generate_plan_from_decomposed_tasks(original_prompt: str, decomposed_tasks: List[Dict[str, Any]]) -> Dict[str, Any]:\n    \"\"\"\n    Generate a plan from decomposed tasks.\n    \n    Args:\n        original_prompt: The original prompt\n        decomposed_tasks: List of decomposed tasks from decompose.py\n        \n    Returns:\n        Structured plan in standard format\n    \"\"\"\n    generator = PlanGenerator(original_prompt)\n    \n    for task_data in decomposed_tasks:\n        generator.add_task(task_data)\n    \n    return generator.generate_plan()\n\ndef demo_plan_generation():\n    \"\"\"Demo plan generation with example tasks.\"\"\"\n    print(\"=== Demo: Plan Generation ===\")\n    \n    # Example decomposed tasks\n    example_tasks = [\n        {\n            'id': 'task_01_introduction',\n            'objective': 'Write introduction section',\n            'description': 'Create a 300-word introduction that provides an overview of climate change and its relevance to agriculture.',\n            'inputs': [],\n            'outputs': ['introduction.md'],\n            'dependencies': [],\n            'acceptance_criteria': [\n                'File exists: introduction.md',\n                'Word count >= 250',\n                'Contains keywords: climate, agriculture, overview'\n            ],\n            'estimated_tokens': 800,\n            'estimated_runtime': 60,\n            'complexity_score': 3\n        },\n        {\n            'id': 'task_02_research',\n            'objective': 'Research temperature effects',\n            'description': 'Research how rising temperatures affect crop yields, soil moisture, and pest dynamics.',\n            'inputs': [],\n            'outputs': ['research_notes.json', 'statistics.csv'],\n            'dependencies': [],\n            'acceptance_criteria': [\n                'File exists: research_notes.json',\n                'Contains at least 5 data points',\n                'Includes citations to recent studies'\n            ],\n            'estimated_tokens': 1500,\n            'estimated_runtime': 120,\n            'complexity_score': 6,\n            'subagent_required': True\n        },\n        {\n            'id': 'task_03_synthesis',\n            'objective': 'Synthesize findings into report',\n            'description': 'Combine introduction and research findings into comprehensive report section.',\n            'inputs': ['introduction.md', 'research_notes.json'],\n            'outputs': ['temperature_effects_section.md'],\n            'dependencies': ['task_01_introduction', 'task_02_research'],\n            'acceptance_criteria': [\n                'File exists: temperature_effects_section.md',\n                'Word count >= 500',\n                'Integrates data from research notes'\n            ],\n            'estimated_tokens': 1200,\n            'estimated_runtime': 90,\n            'complexity_score': 4\n        }\n    ]\n    \n    original_prompt = \"Create a comprehensive report about climate change impacts on agriculture.\"\n    \n    generator = PlanGenerator(original_prompt)\n    \n    for task in example_tasks:\n        generator.add_task(task)\n    \n    plan = generator.generate_plan()\n    \n    print(f\"Generated plan: {plan['plan_id']}\")\n    print(f\"Total tasks: {len(plan['tasks'])}\")\n    print(f\"Estimated tokens: {plan['estimated_total_tokens']}\")\n    print(f\"Estimated runtime: {plan['estimated_total_runtime_seconds']} seconds\")\n    \n    print(\"\\nTasks by execution mode:\")\n    for task in plan['tasks']:\n        print(f\"  - {task['task_id']}: {task['objective'][:50]}...\")\n        print(f\"    Execution mode: {task['execution_mode']}, Action type: {task['action_type']}\")\n        if task['recommended_skill_or_role']:\n            print(f\"    Recommended skill/role: {task['recommended_skill_or_role']}\")\n        print(f\"    Action instructions: {task['action_instructions'][:80]}...\")\n    \n    print(\"\\nDependency graph:\")\n    print(f\"  Nodes: {len(plan['dependency_graph']['nodes'])}\")\n    print(f\"  Edges: {len(plan['dependency_graph']['edges'])}\")\n    print(f\"  Topological order: {plan['dependency_graph']['topological_order']}\")\n    \n    # Save plan to file\n    output_path = generator.save_plan()\n    print(f\"\\nPlan saved to: {output_path}\")\n    \n    return plan\n\nif __name__ == \"__main__\":\n    demo_plan_generation()"}],"isError":false,"timestamp":1773105708450}}
