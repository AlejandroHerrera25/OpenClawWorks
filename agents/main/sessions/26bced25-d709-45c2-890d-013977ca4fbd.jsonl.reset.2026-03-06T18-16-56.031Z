{"type":"message","id":"0e079ebf","parentId":"71930857","timestamp":"2026-03-06T16:15:21.106Z","message":{"role":"toolResult","toolCallId":"call_00_aQTclXlMBSdrsW1cXEORgZLa","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nGenerate all audit reports: EXECUTION_TRACE.md, FINDINGS.md, TEST_MATRIX.md, AUDIT_REPORT.md.\n\"\"\"\n\nimport argparse\nimport os\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom utils_fs import read_file, write_file, read_json, write_json\n\nWORKSPACE_ROOT = Path(os.getenv('WORKSPACE', '/home/openclaw/.openclaw/workspace'))\n\ndef get_case_root(project_key, case_id):\n    return WORKSPACE_ROOT / 'projects' / project_key / 'code_audit' / case_id\n\ndef generate_execution_trace(project_key, case_id):\n    \"\"\"Generate EXECUTION_TRACE.md based on entrypoints and dependency graph.\"\"\"\n    case_root = get_case_root(project_key, case_id)\n    entrypoints_path = case_root / 'ENTRYPOINTS.json'\n    graph_path = case_root / 'DEPENDENCY_GRAPH.json'\n    if not entrypoints_path.exists() or not graph_path.exists():\n        print(\"Missing entrypoints or graph. Run detect_entrypoints.py and build_dependency_graph.py first.\")\n        return\n\n    entrypoints = read_json(entrypoints_path)\n    graph = read_json(graph_path)\n\n    trace = \"# Execution Trace\\n\\n\"\n    trace += \"## Entry Points\\n\"\n    for ep in entrypoints.get('entrypoints', []):\n        if ep['type'] == 'vf_page':\n            trace += f\"- Visualforce page `{ep['file']}` using controller `{ep.get('controller', '?')}`\\n\"\n        elif ep['type'] == 'lwc':\n            trace += f\"- LWC component `{ep['component']}` referencing Apex classes: \"\n            for ref in ep.get('apex_references', []):\n                trace += f\"`{ref['class']}.{ref['method']}` \"\n            trace += \"\\n\"\n        elif ep['type'] == 'apex_aura':\n            trace += f\"- Apex class `{ep['class']}` with @AuraEnabled methods: {', '.join(ep.get('aura_enabled_methods', []))}\\n\"\n\n    trace += \"\\n## Typical Flow\\n\"\n    # Simplified: just list UI -> Controller -> Service -> Integration -> Trigger\n    trace += \"1. UI event (button click, page load)\\n\"\n    trace += \"2. Controller method invoked\\n\"\n    trace += \"3. Service/validation logic\\n\"\n    trace += \"4. DML operation\\n\"\n    trace += \"5. Trigger execution\\n\"\n    trace += \"6. Integration callouts (if any)\\n\"\n    trace += \"7. Response returned to UI\\n\"\n\n    # Add actual dependencies from graph\n    trace += \"\\n## Dependencies Identified\\n\"\n    for edge in graph.get('edges', []):\n        from_node = graph['nodes'][edge['from']]\n        to_node = graph['nodes'][edge['to']]\n        trace += f\"- `{from_node.get('name', '?')}` → `{to_node.get('name', '?')}` ({edge.get('type', '?')})\\n\"\n\n    write_file(case_root / 'EXECUTION_TRACE.md', trace)\n    print(f\"Written {case_root / 'EXECUTION_TRACE.md'}\")\n\ndef generate_findings(project_key, case_id):\n    \"\"\"Generate FINDINGS.md with common issues (placeholder).\"\"\"\n    case_root = get_case_root(project_key, case_id)\n    # In a real implementation, this would analyze code for patterns.\n    # For now, create a template.\n    findings = \"# Audit Findings\\n\\n\"\n    findings += \"## Security\\n\"\n    findings += \"- [ ] FLS/CRUD checks missing\\n\"\n    findings += \"- [ ] SOQL injection risk\\n\"\n    findings += \"- [ ] Secrets in code\\n\"\n    findings += \"\\n## Governor Limits\\n\"\n    findings += \"- [ ] SOQL in loops\\n\"\n    findings += \"- [ ] DML in loops\\n\"\n    findings += \"- [ ] Heap size risk\\n\"\n    findings += \"\\n## Performance\\n\"\n    findings += \"- [ ] Non‑selective queries\\n\"\n    findings += \"- [ ] Missing indexes\\n\"\n    findings += \"- [ ] View state bloated\\n\"\n\n[140 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1772813721101}}
