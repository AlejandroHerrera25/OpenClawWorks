{"type":"message","id":"e8c666ec","parentId":"51cf162d","timestamp":"2026-03-06T15:43:40.514Z","message":{"role":"toolResult","toolCallId":"call_00_EKXIbMpufvjzDFjIxxo8EIC0","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nTest validation for watchdog + learning system.\nSimulates:\n1. Watchdog stall incident\n2. Deadlock starvation incident\n\"\"\"\n\nimport sys\nimport os\nimport time\nfrom datetime import datetime, timedelta\nfrom pathlib import Path\n\n# Add parent directory to path\nsys.path.insert(0, str(Path(__file__).parent))\n\n# Import the watchdog orchestrator\nfrom watchdog_orchestrator import AgentWatchdog\nfrom watchdog_monitor import Session\nfrom watchdog_learning_adapter import generate_incident, generate_deadlock_incident\n\ndef backup_file(path):\n    \"\"\"Create backup of a file.\"\"\"\n    if path.exists():\n        backup = path.with_suffix('.bak')\n        import shutil\n        shutil.copy2(path, backup)\n        return backup\n    return None\n\ndef restore_file(path, backup):\n    \"\"\"Restore file from backup.\"\"\"\n    if backup and backup.exists():\n        import shutil\n        shutil.copy2(backup, path)\n        backup.unlink()\n        return True\n    return False\n\ndef get_file_timestamp(path):\n    \"\"\"Get the last modified time of a file.\"\"\"\n    if path.exists():\n        return datetime.fromtimestamp(path.stat().st_mtime)\n    return None\n\ndef test_watchdog_stall():\n    \"\"\"Test 1: Simulate watchdog stall incident.\"\"\"\n    print(\"\\n\" + \"=\"*60)\n    print(\"TEST 1: Watchdog Stall Incident\")\n    print(\"=\"*60)\n    \n    # Backup files\n    workspace = Path.home() / '.openclaw' / 'workspace'\n    errors_path = workspace / '.learnings' / 'ERRORS.md'\n    index_path = workspace / '.learnings' / 'INDEX.md'\n    \n    errors_backup = backup_file(errors_path)\n    index_backup = backup_file(index_path)\n    \n    try:\n        # Get initial state\n        initial_index_time = get_file_timestamp(index_path)\n        print(f\"Initial INDEX.md timestamp: {initial_index_time}\")\n        \n        # Create watchdog instance\n        watchdog = AgentWatchdog()\n        \n        # Register a session and manually set last_activity to be stale\n        session = watchdog.register_session(\n            session_id=\"test_stall_session\",\n            run_id=\"test_stall_run\",\n            task_description=\"test validation stall\",\n            expected_runtime=5,\n            model=\"deepseek-reasoner\",\n            runtime_type=\"subagent\"\n        )\n        \n        # Force stale activity (2.5 minutes ago, exceeding 120s timeout)\n        stale_time = datetime.utcnow() - timedelta(seconds=150)\n        session.last_activity = stale_time\n        \n        print(f\"Registered session with stale last_activity: {stale_time}\")\n        \n        # Run monitoring cycle (should detect stall and emit incident)\n        print(\"Running monitoring cycle...\")\n        watchdog.run_monitoring_cycle()\n        \n        # Check if ERRORS.md was updated\n        if errors_path.exists():\n            with open(errors_path, 'r', encoding='utf-8') as f:\n                content = f.read()\n                if 'model|STALL|deepseek-reasoner|no_response|runtime_stuck' in content:\n                    print(\"✅ Stall incident appended to ERRORS.md\")\n                    # Find the new entry\n                    lines = content.split('\\n')\n                    for i, line in enumerate(lines[-20:]):\n                        if 'Pattern-Key:' in line and 'deepseek-reasoner' in line:\n                            print(f\"   Found: {line.strip()}\")\n                else:\n                    print(\"❌ Stall incident NOT found in ERRORS.md\")\n        \n        # Check if INDEX.md was rebuilt (timestamp should be newer)\n        time.sleep(1)  # Small delay for file system\n        final_index_time = get_file_timestamp(index_path)\n        print(f\"Final INDEX.md timestamp: {final_index_time}\")\n        \n        if final_index_time and initial_index_time:\n            if final_index_time > initial_index_time:\n                print(\"✅ INDEX.md timestamp updated (automatic rebuild)\")\n            else:\n                print(\"⚠️  INDEX.md timestamp NOT updated\")\n        else:\n            print(\"⚠️  Could not compare timestamps\")\n        \n        return True\n        \n    finally:\n        # Restore backups (optional for test, but keep changes for verification)\n        # restore_file(errors_path, errors_backup)\n        # restore_file(index_path, index_backup)\n        pass\n\ndef test_deadlock_starvation():\n    \"\"\"Test 2: Simulate deadlock starvation incident.\"\"\"\n    print(\"\\n\" + \"=\"*60)\n    print(\"TEST 2: Deadlock Starvation Incident\")\n    print(\"=\"*60)\n    \n    workspace = Path.home() / '.openclaw' / 'workspace'\n    errors_path = workspace / '.learnings' / 'ERRORS.md'\n    index_path = workspace / '.learnings' / 'INDEX.md'\n    \n    # Get initial state (after first test)\n    initial_index_time = get_file_timestamp(index_path)\n    print(f\"Initial INDEX.md timestamp: {initial_index_time}\")\n    \n    # Create watchdog instance\n    watchdog = AgentWatchdog()\n    \n    # Register multiple sessions and make them all stale\n    sessions = []\n    for i in range(3):\n        session = watchdog.register_session(\n            session_id=f\"test_starvation_{i}\",\n            run_id=f\"test_starvation_run_{i}\",\n            task_description=f\"starvation test {i}\",\n            expected_runtime=10,\n            model=\"gpt-4\",\n            runtime_type=\"subagent\"\n        )\n        # Force very stale activity (3.5 minutes ago, exceeding 180s starvation timeout)\n        stale_time = datetime.utcnow() - timedelta(seconds=190)\n        session.last_activity = stale_time\n        sessions.append(session)\n        print(f\"Registered session {session.session_id} with stale activity\")\n    \n    # Run monitoring cycle (should detect starvation deadlock)\n    print(\"Running monitoring cycle...\")\n    watchdog.run_monitoring_cycle()\n    \n    # Check if ERRORS.md was updated with starvation incident\n    if errors_path.exists():\n        with open(errors_path, 'r', encoding='utf-8') as f:\n            content = f.read()\n            if 'multi_agent|DEADLOCK|progress_starvation|agents_no_progress' in content:\n                print(\"✅ Starvation deadlock incident appended to ERRORS.md\")\n                # Find the new entry\n                lines = content.split('\\n')\n                for i, line in enumerate(lines[-30:]):\n                    if 'Pattern-Key:' in line and 'progress_starvation' in line:\n                        print(f\"   Found: {line.strip()}\")\n            else:\n                print(\"❌ Starvation incident NOT found in ERRORS.md\")\n    \n    # Check if INDEX.md was rebuilt again\n    time.sleep(1)\n    final_index_time = get_file_timestamp(index_path)\n    print(f\"Final INDEX.md timestamp: {final_index_time}\")\n    \n    if final_index_time and initial_index_time:\n        if final_index_time > initial_index_time:\n            print(\"✅ INDEX.md timestamp updated again (automatic rebuild)\")\n        else:\n            print(\"⚠️  INDEX.md timestamp NOT updated\")\n    else:\n        print(\"⚠️  Could not compare timestamps\")\n    \n    return True\n\ndef main():\n    \"\"\"Run all tests.\"\"\"\n    print(\"=\"*60)\n    print(\"WATCHDOG + LEARNING SYSTEM VALIDATION\")\n    print(\"=\"*60)\n    \n    # Test 1: Watchdog stall incident\n    test_watchdog_stall()\n    \n    # Test 2: Deadlock starvation incident\n    test_deadlock_starvation()\n    \n    print(\"\\n\" + \"=\"*60)\n    print(\"VALIDATION COMPLETE\")\n    print(\"=\"*60)\n    \n    # Show final status of key files\n    workspace = Path.home() / '.openclaw' / 'workspace'\n    errors_path = workspace / '.learnings' / 'ERRORS.md'\n    index_path = workspace / '.learnings' / 'INDEX.md'\n    \n    if errors_path.exists():\n        print(f\"\\nERRORS.md size: {errors_path.stat().st_size} bytes\")\n        # Count incidents\n        with open(errors_path, 'r', encoding='utf-8') as f:\n            content = f.read()\n            incident_count = content.count('### Pattern-Key:')\n            print(f\"Total incidents in ERRORS.md: {incident_count}\")\n    \n    if index_path.exists():\n        print(f\"INDEX.md last modified: {get_file_timestamp(index_path)}\")\n        with open(index_path, 'r', encoding='utf-8') as f:\n            first_lines = [f.readline().strip() for _ in range(5) if f.readline()]\n            print(f\"INDEX.md first line: {first_lines[0] if first_lines else 'empty'}\")\n\nif __name__ == '__main__':\n    main()"}],"isError":false,"timestamp":1772811820511}}
