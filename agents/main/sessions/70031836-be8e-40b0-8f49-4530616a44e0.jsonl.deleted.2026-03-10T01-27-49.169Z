{"type":"message","id":"77377a8a","parentId":"1df2e76d","timestamp":"2026-03-10T00:39:40.139Z","message":{"role":"assistant","content":[{"type":"text","text":"I need to update the main function to use the new reporting layer:"},{"type":"toolCall","id":"call_00_JYf292v5WXm2YrkHDBKqZ1Pr","name":"edit","arguments":{"path":"~/.openclaw/workspace/skills/salesforce-code-auditor/scripts/generate_reports.py","oldText":"def emit_incidents(project_key, case_id):\n    \"\"\"If critical issues found, emit incident via unified emitter.\"\"\"\n    # Path to the unified incident emitter script\n    script_path = WORKSPACE_ROOT / 'skills' / 'error-learning-loop' / 'scripts' / 'emit_incident.py'\n    if not script_path.exists():\n        print(f\"Error: emit_incident script not found at {script_path}\")\n        return False\n\n    # Parameters for the placeholder incident (same as before)\n    pattern_key = \"security|FLS_MISSING|apex\"\n    severity = \"S2\"\n    source_skill = \"salesforce-code-auditor\"\n    description = \"Missing FLS checks in Apex class\"\n    evidence = \"DemoController.cls line 5\"\n    incident_type = \"ERROR\"\n\n    # Build command\n    cmd = [\n        sys.executable, str(script_path),\n        pattern_key,\n        severity,\n        source_skill,\n        description,\n        evidence,\n        '--type', incident_type,\n        # trigger_learning is default True, no need to add --no-trigger\n    ]\n\n    try:\n        result = subprocess.run(cmd, check=True, capture_output=True, text=True)\n        print(result.stdout)\n        if result.stderr:\n            print(result.stderr)\n        print(f\"Incident emitted via unified emitter: {pattern_key}\")\n        return True\n    except subprocess.CalledProcessError as e:\n        print(f\"Failed to emit incident: {e}\")\n        print(f\"stderr: {e.stderr}\")\n        return False\n\ndef main():\n    parser = argparse.ArgumentParser(description='Generate audit reports.')\n    parser.add_argument('--project-key', required=True, help='Project identifier')\n    parser.add_argument('--case-id', required=True, help='Case identifier')\n    parser.add_argument('--emit-incidents', action='store_true', help='Emit incidents to learning system')\n    args = parser.parse_args()\n\n    generate_execution_trace(args.project_key, args.case_id)\n    generate_findings(args.project_key, args.case_id)\n    generate_test_matrix(args.project_key, args.case_id)\n    generate_audit_report(args.project_key, args.case_id)\n    if args.emit_incidents:\n        emit_incidents(args.project_key, args.case_id)\n\n    print(\"\\nAll reports generated. Review and edit AUDIT_REPORT.md with actual findings.\")\n\nif __name__ == '__main__':\n    main()","newText":"def emit_incidents_based_on_findings(project_key, case_id):\n    \"\"\"Emit incidents based on actual findings.\"\"\"\n    case_root = get_case_root(project_key, case_id)\n    findings_path = case_root / 'FINDINGS_DETAILED.json'\n    \n    if not findings_path.exists():\n        print(\"No findings data available. Run findings synthesis first.\")\n        return False\n    \n    # Path to the unified incident emitter script\n    script_path = WORKSPACE_ROOT / 'skills' / 'error-learning-loop' / 'scripts' / 'emit_incident.py'\n    if not script_path.exists():\n        print(f\"Error: emit_incident script not found at {script_path}\")\n        return False\n    \n    findings_data = read_json(findings_path)\n    findings = findings_data.get('findings', [])\n    \n    incidents_emitted = 0\n    \n    # Emit incidents for critical findings\n    for finding in findings:\n        if finding['severity'] == 'CRITICAL':\n            pattern_key = f\"salesforce|CODE_AUDIT|{finding['pattern']}|critical\"\n            severity = \"S1\"\n            source_skill = \"salesforce-code-auditor\"\n            description = finding['description']\n            evidence = f\"{finding['file']}:{finding['line']}\"\n            incident_type = \"ERROR\"\n            \n            cmd = [\n                sys.executable, str(script_path),\n                pattern_key,\n                severity,\n                source_skill,\n                description,\n                evidence,\n                '--type', incident_type,\n            ]\n            \n            try:\n                result = subprocess.run(cmd, check=True, capture_output=True, text=True)\n                print(f\"Incident emitted: {pattern_key}\")\n                incidents_emitted += 1\n            except subprocess.CalledProcessError as e:\n                print(f\"Failed to emit incident for {pattern_key}: {e}\")\n    \n    print(f\"\\nEmitted {incidents_emitted} incidents based on critical findings.\")\n    return incidents_emitted > 0\n\ndef main():\n    parser = argparse.ArgumentParser(description='Generate complete audit reports using new reporting layer.')\n    parser.add_argument('--project-key', required=True, help='Project identifier')\n    parser.add_argument('--case-id', required=True, help='Case identifier')\n    parser.add_argument('--mode', choices=['A', 'B', 'C'], default='A', \n                       help='Handoff mode: A=Arch→Audit, B=Audit→Arch, C=Design Validation')\n    parser.add_argument('--skip-basic', action='store_true', \n                       help='Skip basic reports (execution trace, test matrix)')\n    parser.add_argument('--emit-incidents', action='store_true', \n                       help='Emit incidents to learning system based on findings')\n    args = parser.parse_args()\n    \n    print(\"=\"*70)\n    print(\"SALESFORCE CODE AUDITOR - COMPLETE REPORTING LAYER\")\n    print(\"=\"*70)\n    print(f\"Project: {args.project_key}\")\n    print(f\"Case: {args.case_id}\")\n    print(f\"Mode: {args.mode}\")\n    print(\"=\"*70)\n    \n    # Step 1: Generate basic reports if not skipped\n    if not args.skip_basic:\n        print(\"\\n📝 Generating basic reports...\")\n        generate_execution_trace(args.project_key, args.case_id)\n        generate_test_matrix(args.project_key, args.case_id)\n    \n    # Step 2: Run findings synthesis\n    print(\"\\n🔍 Running findings synthesis...\")\n    if not run_findings_synthesis(args.project_key, args.case_id):\n        print(\"ERROR: Findings synthesis failed. Cannot proceed.\")\n        sys.exit(1)\n    \n    # Step 3: Run risk assessment\n    print(\"\\n⚠️  Running risk assessment...\")\n    if not run_risk_assessment(args.project_key, args.case_id):\n        print(\"ERROR: Risk assessment failed. Cannot proceed.\")\n        sys.exit(1)\n    \n    # Step 4: Generate architect report\n    print(\"\\n📊 Generating architect report...\")\n    if not run_report_generation(args.project_key, args.case_id, args.mode):\n        print(\"ERROR: Report generation failed.\")\n        sys.exit(1)\n    \n    # Step 5: Emit incidents if requested\n    if args.emit_incidents:\n        print(\"\\n🚨 Emitting incidents to learning system...\")\n        emit_incidents_based_on_findings(args.project_key, args.case_id)\n    \n    # Summary\n    case_root = get_case_root(args.project_key, args.case_id)\n    print(\"\\n\" + \"=\"*70)\n    print(\"REPORT GENERATION COMPLETE\")\n    print(\"=\"*70)\n    print(f\"\\nGenerated reports in: {case_root}\")\n    print(\"\\n📁 Key Files Generated:\")\n    print(f\"  • FINDINGS_DETAILED.json - Detailed findings with code locations\")\n    print(f\"  • FINDINGS.md - Markdown findings report\")\n    print(f\"  • RISK_ASSESSMENT.json - Risk assessment data\")\n    print(f\"  • RISK_ASSESSMENT.md - Risk assessment report\")\n    print(f\"  • ARCHITECT_AUDIT_REPORT.md - Complete architect report (Mode {args.mode})\")\n    \n    if not args.skip_basic:\n        print(f\"  • EXECUTION_TRACE.md - Execution flow analysis\")\n        print(f\"  • TEST_MATRIX.md - Test scenarios matrix\")\n    \n    print(\"\\n✅ Salesforce Code Auditor reporting layer is now fully functional!\")\n    print(\"   The skill can now generate specific, actionable findings with risk assessment.\")\n    print(f\"   Reports are formatted for architect consumption (Mode {args.mode}).\")\n\nif __name__ == '__main__':\n    main()"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":647,"output":1882,"cacheRead":48960,"cacheWrite":0,"totalTokens":51489,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773103124111}}
