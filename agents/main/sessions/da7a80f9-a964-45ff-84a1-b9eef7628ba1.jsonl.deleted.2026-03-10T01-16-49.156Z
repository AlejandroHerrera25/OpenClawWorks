{"type":"message","id":"809af3a1","parentId":"c2599bf9","timestamp":"2026-03-10T00:21:16.457Z","message":{"role":"toolResult","toolCallId":"call_00_BkvOAdf7IGWstSijveCzSzS2","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nRobust Project Control File System.\nMaintains README.md as single source of truth for project state.\n\"\"\"\n\nimport os\nimport sys\nimport yaml\nimport json\nimport logging\nfrom pathlib import Path\nfrom datetime import datetime\nfrom typing import Dict, List, Optional, Any, Tuple\nfrom enum import Enum\n\n# Configure logging\nlogging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')\nlogger = logging.getLogger(__name__)\n\nclass ProjectControl:\n    \"\"\"Robust project control file management.\"\"\"\n    \n    def __init__(self, project_root: Path):\n        self.project_root = Path(project_root)\n        self.readme_path = self.project_root / 'README.md'\n        self.control_file_path = self.project_root / '.project_control.yaml'\n        \n        # Ensure project directory exists\n        self.project_root.mkdir(parents=True, exist_ok=True)\n        \n        # Initialize or load control file\n        self.control_data = self._load_or_initialize_control()\n        \n        # Ensure README is in sync\n        self._sync_readme_with_control()\n    \n    def _load_or_initialize_control(self) -> Dict:\n        \"\"\"Load existing control file or initialize new one.\"\"\"\n        if self.control_file_path.exists():\n            try:\n                with open(self.control_file_path, 'r', encoding='utf-8') as f:\n                    control_data = yaml.safe_load(f)\n                \n                # Validate structure\n                if self._validate_control_structure(control_data):\n                    logger.info('Loaded existing project control file')\n                    return control_data\n                else:\n                    logger.warning('Control file structure invalid, reinitializing')\n\n[802 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1773102076449}}
