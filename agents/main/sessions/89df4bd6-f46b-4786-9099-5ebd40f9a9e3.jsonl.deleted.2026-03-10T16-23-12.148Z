{"type":"message","id":"60c1cbf0","parentId":"ff22cbc1","timestamp":"2026-03-10T01:21:54.743Z","message":{"role":"toolResult","toolCallId":"call_00_nlEpcU4neCR89NcKqb2badoO","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nDistributed Plan Generator for long-prompt-orchestrator skill.\nGenerates enhanced plans with distributed execution recommendations.\nMain agent handles actual spawning and coordination.\n\"\"\"\n\nimport sys\nimport os\nimport json\nimport time\nimport uuid\nfrom typing import List, Dict, Any, Optional, Tuple\nfrom dataclasses import dataclass\nfrom enum import Enum\n\n# Add skill scripts directory to path\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\n\nfrom decompose import detect_and_decompose, estimate_tokens\nfrom todo import Checklist, ItemState, ChecklistStatus\nfrom token_budget import TokenBudget, ContextLedger\nfrom validate import validate_subagent_output, validate_final_output\nfrom recovery import recover_from_interruption\nfrom learning_emit import emit_incident\nfrom plan_generator import PlanGenerator, PlanTask, generate_plan_from_decomposed_tasks\n\nWORKSPACE = os.path.expanduser(\"~/.openclaw/workspace\")\nTASKBOARDS_DIR = os.path.join(WORKSPACE, \".taskboards\")\n\nclass TaskPriority(Enum):\n    LOW = \"low\"\n    MEDIUM = \"medium\"\n    HIGH = \"high\"\n    CRITICAL = \"critical\"\n\n@dataclass\nclass EnhancedTaskAnalysis:\n    \"\"\"Enhanced task analysis for distributed planning.\"\"\"\n    task_id: str\n    objective: str\n    dependencies: List[str]\n    acceptance_criteria: List[str]\n    outputs: List[str]\n    max_token_budget: int\n    complexity_score: int\n    estimated_tokens: int\n    estimated_runtime: int\n    requires_subagent: bool\n    priority: TaskPriority = TaskPriority.MEDIUM\n    recommended_skill: Optional[str] = None\n    recommended_model: Optional[str] = None\n    execution_hints: Optional[Dict[str, Any]] = None\n    \n    def to_plan_task(self) -> Dict[str, Any]:\n        \"\"\"Convert to PlanTask-compatible dictionary.\"\"\"\n        return {\n            'id': self.task_id,\n            'objective': self.objective,\n            'description': self.objective,  # Can be enhanced\n            'inputs': [],  # Would need actual input analysis\n            'outputs': self.outputs,\n            'dependencies': self.dependencies,\n            'acceptance_criteria': self.acceptance_criteria,\n            'estimated_tokens': self.estimated_tokens,\n            'estimated_runtime': self.estimated_runtime,\n            'complexity_score': self.complexity_score,\n            'subagent_required': self.requires_subagent\n        }\n\nclass DistributedPlanGenerator:\n    \"\"\"Generates enhanced plans with distributed execution recommendations.\"\"\"\n    \n    def __init__(self, task_id: str, original_prompt: str):\n        self.task_id = task_id\n        self.original_prompt = original_prompt\n        self.plan_generator = PlanGenerator(original_prompt)\n        self.enhanced_tasks = []  # List of EnhancedTaskAnalysis\n        \n    def analyze_tasks_for_distribution(self, decomposed_tasks: List[Dict[str, Any]]) -> List[EnhancedTaskAnalysis]:\n        \"\"\"Analyze tasks for distributed execution potential.\"\"\"\n        enhanced_tasks = []\n        \n        for task_data in decomposed_tasks:\n            # Analyze task for distribution\n            requires_subagent = self._analyze_subagent_requirement(task_data)\n            priority = self._analyze_priority(task_data)\n            recommended_skill = self._analyze_skill_recommendation(task_data)\n            recommended_model = self._analyze_model_recommendation(task_data)\n            execution_hints = self._generate_execution_hints(task_data)\n            \n            task = EnhancedTaskAnalysis(\n                task_id=task_data['id'],\n                objective=task_data['objective'],\n                dependencies=task_data.get('dependencies', []),\n                acceptance_criteria=task_data.get('acceptance_criteria', []),\n                outputs=task_data.get('outputs', []),\n                max_token_budget=task_data.get('max_token_budget', 1000),\n                complexity_score=task_data.get('complexity_score', 0),\n                estimated_tokens=task_data.get('estimated_tokens', 0),\n                estimated_runtime=task_data.get('estimated_runtime', 60),\n                requires_subagent=requires_subagent,\n                priority=priority,\n                recommended_skill=recommended_skill,\n                recommended_model=recommended_model,\n                execution_hints=execution_hints\n            )\n            \n            enhanced_tasks.append(task)\n            self.enhanced_tasks.append(task)\n        \n        return enhanced_tasks\n    \n    def _analyze_subagent_requirement(self, task_data: Dict[str, Any]) -> bool:\n        \"\"\"Analyze if task requires sub-agent.\"\"\"\n        # Check explicit requirement\n        if task_data.get('subagent_required', False):\n            return True\n        \n        # Check complexity\n        complexity_score = task_data.get('complexity_score', 0)\n        if complexity_score >= 5:\n            return True\n        \n        # Check runtime\n        estimated_runtime = task_data.get('estimated_runtime', 0)\n        if estimated_runtime > 300:  # 5 minutes\n            return True\n        \n        # Check outputs\n        outputs = task_data.get('outputs', [])\n        if len(outputs) > 3:\n            return True\n        \n        return False\n    \n    def _analyze_priority(self, task_data: Dict[str, Any]) -> TaskPriority:\n        \"\"\"Analyze task priority.\"\"\"\n        complexity_score = task_data.get('complexity_score', 0)\n        \n        if complexity_score >= 8:\n            return TaskPriority.CRITICAL\n        elif complexity_score >= 5:\n            return TaskPriority.HIGH\n        elif complexity_score >= 3:\n            return TaskPriority.MEDIUM\n        else:\n            return TaskPriority.LOW\n    \n    def _analyze_skill_recommendation(self, task_data: Dict[str, Any]) -> Optional[str]:\n        \"\"\"Analyze and recommend skill for task.\"\"\"\n        objective = task_data.get('objective', '').lower()\n        description = task_data.get('description', '').lower()\n        full_text = f\"{objective} {description}\"\n        \n        # Check for workspace maintenance/inventory FIRST (most common non-Salesforce task)\n        workspace_keywords = ['workspace', 'inventory', 'list skills', 'clean', 'organize', 'tidy', 'maintain', 'janitor']\n        workspace_priority_keywords = ['workspace audit', 'inventory workspace', 'clean workspace', 'organize workspace']\n        \n        # Check for high-priority workspace phrases first\n        for phrase in workspace_priority_keywords:\n            if phrase in full_text:\n                return \"workspace-janitor\"\n        \n        # Check for individual workspace keywords\n        if any(keyword in full_text for keyword in workspace_keywords):\n            # But check if it's actually a Salesforce task in disguise\n            salesforce_keywords = ['salesforce', 'apex', 'lwc', 'visualforce', 'soql', 'flow', 'sfdc']\n            has_salesforce = any(keyword in full_text for keyword in salesforce_keywords)\n            \n            # If it mentions Salesforce AND workspace, prioritize based on context\n            if has_salesforce:\n                # Check if Salesforce is the primary focus\n                salesforce_primary_indicators = ['salesforce audit', 'apex code', 'lwc component', 'salesforce security']\n                if any(indicator in full_text for indicator in salesforce_primary_indicators):\n                    audit_keywords = ['audit', 'review', 'check', 'validate', 'security', 'code quality', 'inspect']\n                    if any(keyword in full_text for keyword in audit_keywords):\n                        return \"salesforce-code-auditor\"\n                    else:\n                        return \"salesforce-architect\"\n                else:\n                    # Workspace is primary, Salesforce is secondary\n                    return \"workspace-janitor\"\n            else:\n                # Pure workspace task\n                return \"workspace-janitor\"\n        \n        # Check for Salesforce-related content (without workspace context)\n        salesforce_keywords = ['salesforce', 'apex', 'lwc', 'visualforce', 'soql', 'flow', 'sfdc']\n        if any(keyword in full_text for keyword in salesforce_keywords):\n            # Salesforce-specific tasks\n            audit_keywords = ['audit', 'review', 'check', 'validate', 'security', 'code quality', 'inspect']\n            if any(keyword in full_text for keyword in audit_keywords):\n                return \"salesforce-code-auditor\"\n            else:\n                return \"salesforce-architect\"\n        \n        # Check for web search tasks\n        search_keywords = ['search', 'research', 'find', 'look up', 'web', 'internet', 'google', 'browse']\n        if any(keyword in full_text for keyword in search_keywords):\n            return \"tavily-web-search\"\n        \n        # System health/monitoring\n        system_keywords = ['system health', 'check system', 'monitor', 'watchdog', 'agent-watchdog']\n        if any(keyword in full_text for keyword in system_keywords):\n            return \"agent-watchdog\"\n        \n        # Memory/vector operations\n        memory_keywords = ['memory', 'vector', 'embedding', 'semantic', 'retrieval']\n        if any(keyword in full_text for keyword in memory_keywords):\n            return \"vector-memory\"\n        \n        # Error handling/learning\n        error_keywords = ['error', 'incident', 'learning loop', 'guardrail', 'mistake']\n        if any(keyword in full_text for keyword in error_keywords):\n            return \"error-learning-loop\"\n        \n        # Planning/orchestration\n        planning_keywords = ['plan', 'orchestrate', 'coordinate', 'decompose', 'schedule', 'long prompt']\n        if any(keyword in full_text for keyword in planning_keywords):\n            return \"long-prompt-orchestrator\"\n        \n        return None\n    \n    def _analyze_model_recommendation(self, task_data: Dict[str, Any]) -> Optional[str]:\n        \"\"\"Analyze and recommend model for task.\"\"\"\n        complexity_score = task_data.get('complexity_score', 0)\n        \n        if complexity_score >= 8:\n            return \"gpt-4\"\n        elif complexity_score >= 5:\n            return \"deepseek-chat\"\n        else:\n            return None  # Use default\n    \n    def _generate_execution_hints(self, task_data: Dict[str, Any]) -> Dict[str, Any]:\n        \"\"\"Generate execution hints for main agent.\"\"\"\n        complexity_score = task_data.get('complexity_score', 0)\n        dependencies = task_data.get('dependencies', [])\n        \n        hints = {\n            \"parallelizable\": len(dependencies) == 0,\n            \"requires_isolation\": complexity_score >= 7,\n            \"risk_level\": \"high\" if complexity_score >= 7 else \"medium\" if complexity_score >= 4 else \"low\",\n            \"retry_policy\": \"exponential_backoff_3\" if complexity_score >= 5 else \"immediate_2\",\n            \"watchdog_recommended\": complexity_score >= 6 or task_data.get('estimated_runtime', 0) > 300\n        }\n        \n        return hints\n    \n    def generate_enhanced_plan(self, decomposed_tasks: List[Dict[str, Any]]) -> Dict[str, Any]:\n        \"\"\"Generate enhanced plan with distributed execution recommendations.\"\"\"\n        # Analyze tasks for distribution\n        enhanced_tasks = self.analyze_tasks_for_distribution(decomposed_tasks)\n        \n        # Convert to PlanTask format and add to generator\n        for enhanced_task in enhanced_tasks:\n            task_dict = enhanced_task.to_plan_task()\n            self.plan_generator.add_task(task_dict)\n        \n        # Generate base plan\n        base_plan = self.plan_generator.generate_plan()\n        \n        # Enhance plan with distributed execution recommendations\n        enhanced_plan = self._enhance_plan_with_distribution(base_plan, enhanced_tasks)\n        \n        return enhanced_plan\n    \n    def _enhance_plan_with_distribution(self, base_plan: Dict[str, Any], enhanced_tasks: List[EnhancedTaskAnalysis]) -> Dict[str, Any]:\n        \"\"\"Enhance plan with distributed execution recommendations.\"\"\"\n        # Create mapping from task_id to enhanced task\n        enhanced_task_map = {task.task_id: task for task in enhanced_tasks}\n        \n        # Enhance tasks in the plan\n        for task in base_plan['tasks']:\n            task_id = task['task_id']\n            if task_id in enhanced_task_map:\n                enhanced = enhanced_task_map[task_id]\n                \n                # Add enhanced fields\n                task['priority'] = enhanced.priority.value\n                task['recommended_skill'] = enhanced.recommended_skill\n                task['recommended_model'] = enhanced.recommended_model\n                task['execution_hints'] = enhanced.execution_hints\n        \n        # Add distributed execution section\n        base_plan['distributed_execution'] = self._generate_distributed_execution_section(enhanced_tasks)\n        \n        return base_plan\n    \n    def _generate_distributed_execution_section(self, enhanced_tasks: List[EnhancedTaskAnalysis]) -> Dict[str, Any]:\n        \"\"\"Generate distributed execution recommendations section.\"\"\"\n        # Count tasks by type\n        subagent_tasks = [t for t in enhanced_tasks if t.requires_subagent]\n        main_agent_tasks = [t for t in enhanced_tasks if not t.requires_subagent]\n        \n        # Group by recommended skill\n        skill_groups = {}\n        for task in subagent_tasks:\n            skill = task.recommended_skill or \"general\"\n            if skill not in skill_groups:\n                skill_groups[skill] = []\n            skill_groups[skill].append(task.task_id)\n        \n        # Calculate concurrency potential\n        independent_tasks = [t for t in enhanced_tasks if len(t.dependencies) == 0]\n        dependent_tasks = [t for t in enhanced_tasks if len(t.dependencies) > 0]\n        \n        # Generate recommendations\n        recommendations = {\n            \"summary\": {\n                \"total_tasks\": len(enhanced_tasks),\n                \"subagent_tasks\": len(subagent_tasks),\n                \"main_agent_tasks\": len(main_agent_tasks),\n                \"independent_tasks\": len(independent_tasks),\n                \"dependent_tasks\": len(dependent_tasks)\n            },\n            \"skill_groups\": skill_groups,\n            \"concurrency_analysis\": {\n                \"max_possible_concurrent\": len(independent_tasks),\n                \"recommended_batch_size\": min(3, len(independent_tasks)),\n                \"critical_path_tasks\": self._identify_critical_path(enhanced_tasks)\n            },\n            \"execution_strategy\": self._generate_execution_strategy(enhanced_tasks)\n        }\n        \n        return recommendations\n    \n    def _identify_critical_path(self, tasks: List[EnhancedTaskAnalysis]) -> List[str]:\n        \"\"\"Identify critical path tasks (simplified).\"\"\"\n        # Simplified: tasks with high complexity and many dependencies\n        critical_tasks = []\n        \n        for task in tasks:\n            if task.complexity_score >= 7 and len(task.dependencies) >= 2:\n                critical_tasks.append(task.task_id)\n        \n        return critical_tasks[:5]  # Return top 5\n    \n    def _generate_execution_strategy(self, tasks: List[EnhancedTaskAnalysis]) -> Dict[str, Any]:\n        \"\"\"Generate execution strategy for main agent.\"\"\"\n        # Group tasks by phase\n        independent_tasks = [t for t in tasks if len(t.dependencies) == 0]\n        dependent_tasks = [t for t in tasks if len(t.dependencies) > 0]\n        \n        strategy = {\n            \"phase_1\": {\n                \"description\": \"Execute independent tasks in parallel\",\n                \"tasks\": [t.task_id for t in independent_tasks],\n                \"concurrency\": len(independent_tasks),\n                \"recommended_approach\": \"Batch spawn sub-agents for independent tasks\"\n            },\n            \"phase_2\": {\n                \"description\": \"Execute dependent tasks as dependencies are satisfied\",\n                \"tasks\": [t.task_id for t in dependent_tasks],\n                \"concurrency\": \"Dynamic based on dependency completion\",\n                \"recommended_approach\": \"Monitor dependencies and spawn tasks when ready\"\n            },\n            \"phase_3\": {\n                \"description\": \"Final validation and synthesis\",\n                \"tasks\": [\"final_validation\", \"result_synthesis\"],\n                \"concurrency\": 1,\n                \"recommended_approach\": \"Execute in main agent after all tasks complete\"\n            }\n        }\n        \n        return strategy\n\ndef run_demo():\n    \"\"\"Run demo of distributed plan generation.\"\"\"\n    print(\"=== Running Distributed Plan Generation Demo ===\")\n    \n    # Example prompt\n    prompt = \"\"\"Create a comprehensive Salesforce implementation plan including:\n1. Requirements analysis document\n2. Data model design with custom objects and fields\n3. Apex class architecture for business logic\n4. Lightning Web Components for UI\n5. Integration design with external systems\n6. Security model with profiles and permission sets\n7. Deployment strategy with CI/CD pipeline\n8. Testing plan with test classes\n9. User training materials\n10. Go-live checklist\"\"\"\n    \n    print(f\"Original prompt: {len(prompt)} chars\")\n    \n    # Decompose\n    result = detect_and_decompose(prompt, max_prompt_tokens=100, max_mini_tasks=10)\n    if isinstance(result, tuple) and len(result) == 2:\n        tasks, metrics = result\n    else:\n        tasks = result if result else []\n        metrics = {}\n    \n    if not tasks:\n        # Create example tasks\n        tasks = [\n            {'id': 'task_01', 'objective': 'Create requirements analysis document', 'dependencies': [], 'acceptance_criteria': ['Document exists', 'Contains requirements'], 'outputs': ['requirements.md'], 'max_token_budget': 1200, 'complexity_score': 4, 'estimated_tokens': 1200, 'estimated_runtime': 90},\n            {'id': 'task_02', 'objective': 'Design Salesforce data model', 'dependencies': ['task_01'], 'acceptance_criteria': ['Data model diagram exists', 'Includes custom objects'], 'outputs': ['data_model.json', 'data_model_diagram.md'], 'max_token_budget': 1500, 'complexity_score': 7, 'estimated_tokens': 1500, 'estimated_runtime': 180},\n            {'id': 'task_03', 'objective': 'Design Apex class architecture', 'dependencies': ['task_02'], 'acceptance_criteria': ['Architecture document exists', 'Includes class diagrams'], 'outputs': ['apex_architecture.md'], 'max_token_budget': 1400, 'complexity_score': 6, 'estimated_tokens': 1400, 'estimated_runtime': 150},\n            {'id': 'task_04', 'objective': 'Design Lightning Web Components', 'dependencies': ['task_03'], 'acceptance_criteria': ['Component design exists', 'Includes wireframes'], 'outputs': ['lwc_design.md'], 'max_token_budget': 1300, 'complexity_score': 5, 'estimated_tokens': 1300, 'estimated_runtime': 120},\n            {'id': 'task_05', 'objective': 'Research integration patterns', 'dependencies': [], 'acceptance_criteria': ['Research document exists', 'Includes API patterns'], 'outputs': ['integration_research.md'], 'max_token_budget': 1600, 'complexity_score': 6, 'estimated_tokens': 1600, 'estimated_runtime': 200, 'subagent_required': True},\n        ]\n    \n    print(f\"Decomposed into {len(tasks)} tasks\")\n    \n    # Generate enhanced plan\n    task_id = f\"distributed_plan_{int(time.time())}\"\n    generator = DistributedPlanGenerator(task_id, prompt)\n    \n    enhanced_plan = generator.generate_enhanced_plan(tasks)\n    \n    print(f\"\\nGenerated enhanced plan: {enhanced_plan['plan_id']}\")\n    \n    # Show distributed execution recommendations\n    dist = enhanced_plan.get('distributed_execution', {})\n    summary = dist.get('summary', {})\n    \n    print(f\"\\nDistributed Execution Summary:\")\n    print(f\"  Total tasks: {summary.get('total_tasks', 0)}\")\n    print(f\"  Sub-agent tasks: {summary.get('subagent_tasks', 0)}\")\n    print(f\"  Main agent tasks: {summary.get('main_agent_tasks', 0)}\")\n    print(f\"  Independent tasks: {summary.get('independent_tasks', 0)}\")\n    \n    print(f\"\\nSkill Groups:\")\n    skill_groups = dist.get('skill_groups', {})\n    for skill, task_ids in skill_groups.items():\n        print(f\"  {skill}: {len(task_ids)} tasks\")\n    \n    print(f\"\\nExecution Strategy:\")\n    strategy = dist.get('execution_strategy', {})\n    for phase_name, phase_info in strategy.items():\n        print(f\"  {phase_name}: {phase_info.get('description', '')}\")\n        print(f\"    Tasks: {len(phase_info.get('tasks', []))}\")\n        print(f\"    Concurrency: {phase_info.get('concurrency', 1)}\")\n    \n    # Save plan\n    plan_file = os.path.join(TASKBOARDS_DIR, f\"{enhanced_plan['plan_id']}_enhanced.json\")\n    with open(plan_file, 'w') as f:\n        json.dump(enhanced_plan, f, indent=2)\n    \n    print(f\"\\nEnhanced plan saved to: {plan_file}\")\n    print(\"\\n=== Demo Complete ===\")\n    print(\"This plan provides distributed execution recommendations for the main agent.\")\n    print(\"Main agent should use these recommendations to optimize spawning and coordination.\")\n    \n    return enhanced_plan\n\ndef generate_distributed_plan(prompt: str) -> Dict[str, Any]:\n    \"\"\"\n    Generate distributed plan for a prompt.\n    \n    Args:\n        prompt: The original prompt\n        \n    Returns:\n        Enhanced plan with distributed execution recommendations\n    \"\"\"\n    # Decompose prompt\n    result = detect_and_decompose(prompt, max_prompt_tokens=4000, max_mini_tasks=20)\n    if isinstance(result, tuple) and len(result) == 2:\n        tasks, metrics = result\n    else:\n        tasks = result if result else []\n        metrics = {}\n    \n    if not tasks:\n        # Create simple task\n        tasks = [{\n            'id': 'task_01',\n            'objective': 'Execute prompt directly',\n            'description': prompt[:500] + '...' if len(prompt) > 500 else prompt,\n            'dependencies': [],\n            'acceptance_criteria': ['Output generated successfully'],\n            'outputs': ['direct_output.md'],\n            'max_token_budget': len(prompt) // 4,\n            'complexity_score': 1,\n            'estimated_tokens': len(prompt) // 4,\n            'estimated_runtime': 60\n        }]\n    \n    # Generate enhanced plan\n    task_id = f\"distributed_plan_{int(time.time())}\"\n    generator = DistributedPlanGenerator(task_id, prompt)\n    \n    enhanced_plan = generator.generate_enhanced_plan(tasks)\n    \n    # Save plan\n    plan_file = os.path.join(TASKBOARDS_DIR, f\"{enhanced_plan['plan_id']}_enhanced.json\")\n    with open(plan_file, 'w') as f:\n        json.dump(enhanced_plan, f, indent=2)\n    \n    print(f\"Enhanced plan generated: {enhanced_plan['plan_id']}\")\n    print(f\"Plan saved to: {plan_file}\")\n    \n    return enhanced_plan\n\nif __name__ == \"__main__\":\n    run_demo()"}],"isError":false,"timestamp":1773105714738}}
