{"type":"message","id":"79500eff","parentId":"4f85e3bb","timestamp":"2026-03-06T15:43:04.232Z","message":{"role":"toolResult","toolCallId":"call_00_pr4uh9FjRvw4OcEM6pHPoM1H","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nagent‑watchdog orchestrator – Integrates stall detection, recovery escalation,\ndeadlock detection, ACP monitoring, and learning‑loop incident reporting.\n\"\"\"\n\nimport sys\nimport time\nimport json\nimport subprocess\nimport threading\nfrom datetime import datetime, timedelta\nfrom pathlib import Path\n\n# Import local modules\nsys.path.append(str(Path(__file__).parent))\nfrom watchdog_monitor import Session, detect_stall, monitor\nfrom watchdog_recovery import recovery_action\nfrom watchdog_learning_adapter import generate_incident, generate_deadlock_incident\n\n# Constants\nWORKSPACE = Path.home() / '.openclaw' / 'workspace'\nERRORS_PATH = WORKSPACE / '.learnings' / 'ERRORS.md'\nLEARNING_LOOP_SKILL = WORKSPACE / 'skills' / 'error-learning-loop' / 'SKILL.md'\nUPDATE_INDEX_SCRIPT = WORKSPACE / 'skills' / 'error-learning-loop' / 'scripts' / 'update_index.py'\n\n# Timeouts (seconds)\nSTALL_TIMEOUT = 120\nACP_STALL_TIMEOUT = 180\nDEADLOCK_STARVATION_TIMEOUT = 180  # No progress across multiple agents\nREBUILD_DEBOUNCE_SECONDS = 30      # Minimum time between index rebuilds\n\n# Rate limiting\nMAX_INCIDENTS_PER_PATTERN_PER_HOUR = 5\nRATE_LIMIT_WINDOW_SECONDS = 3600\nRATE_LIMIT_CACHE_PATH = WORKSPACE / '.learnings' / '.watchdog_rate_limit.json'\n\n# Self-protection\nMAX_WATCHDOG_SELF_RESTARTS = 1\n\nclass AgentWatchdog:\n    def __init__(self):\n        self.sessions = {}  # session_id -> Session\n        self.agent_graph = {}  # agent_id -> waiting_for_agent_id\n        self.stall_timeout = STALL_TIMEOUT\n        self.monitor_interval = 30\n        self.last_index_rebuild = None  # datetime of last rebuild\n        self.rebuild_lock = threading.Lock()\n    \n    def register_session(self, session_id, run_id, task_description,\n                         expected_runtime, model, runtime_type='subagent'):\n        \"\"\"Register a session for monitoring.\"\"\"\n        session = Session(session_id)\n        session.run_id = run_id\n        session.task_description = task_description\n        session.expected_runtime = expected_runtime\n        session.model = model\n        session.runtime_type = runtime_type\n        session.start_time = datetime.utcnow()\n        session.last_activity = datetime.utcnow()\n        session.state = 'running'\n        \n        self.sessions[session_id] = session\n        print(f\"[Watchdog] Registered session {session_id} ({runtime_type})\")\n        return session\n    \n    def update_activity(self, session_id):\n        \"\"\"Update last activity timestamp for a session.\"\"\"\n        if session_id in self.sessions:\n            self.sessions[session_id].last_activity = datetime.utcnow()\n    \n    def detect_stalls(self):\n        \"\"\"Check all registered sessions for stalls.\"\"\"\n        stalls = []\n        for session_id, session in self.sessions.items():\n            if detect_stall(session):\n                stalls.append(session)\n        return stalls\n    \n    def perform_recovery(self, session, attempt):\n        \"\"\"Execute recovery escalation.\"\"\"\n        action = recovery_action(attempt)\n        print(f\"[Recovery] Attempt {attempt}: {action} on session {session.session_id}\")\n        # Simulate action\n        if action == 'nudge_continue':\n            # Send continue signal\n            pass\n        elif action == 'cancel_and_resume':\n            # Cancel run and resume\n            pass\n        elif action == 'relaunch_agent':\n            # Close session and relaunch\n            pass\n        return action\n    \n    def emit_incident(self, session, stall_duration, recovery_level, success):\n        \"\"\"Generate incident and append to ERRORS.md.\"\"\"\n        incident = generate_incident(\n            session.model,\n            stall_duration,\n            recovery_level,\n            success\n        )\n        # Add extra telemetry fields\n        incident['task_type'] = session.task_description\n        incident['items_count'] = getattr(session, 'items_count', 0)\n        incident['runtime_type'] = session.runtime_type\n        \n        # Append to ERRORS.md (will automatically trigger learning loop)\n        self.append_to_errors(incident, trigger_learning=True)\n        \n        return incident\n    \n    def append_to_errors(self, incident, trigger_learning=True):\n        \"\"\"Append incident to ERRORS.md following the pattern-key format.\n        If trigger_learning=True, also trigger the learning loop.\"\"\"\n        if not ERRORS_PATH.exists():\n            return\n        \n        # Rate limiting check\n        pattern_key = incident.get('pattern_key', 'unknown')\n        if not self._rate_limit_check(pattern_key):\n            print(f\"[Watchdog] Rate limit hit for {pattern_key} — skipped append.\")\n            # Still allow index rebuild if triggered (but debounced)\n            if trigger_learning:\n                result = self.trigger_learning_loop(incident)\n                if result['triggered']:\n                    print(f\"[Watchdog] Learning loop triggered via {result['method']} (rate-limited incident)\")\n            return\n        \n        with open(ERRORS_PATH, 'a', encoding='utf-8') as f:\n            f.write(f\"\\n### Pattern-Key: {pattern_key}\\n\")\n            f.write(f\"- **First Occurrence**: {incident['timestamp'][:10]}\\n\")\n            f.write(f\"- **Latest Occurrence**: {incident['timestamp'][:10]}\\n\")\n            f.write(f\"- **Count**: 1\\n\")\n            f.write(f\"- **Type**: stall\\n\")\n            f.write(f\"- **Severity**: S2\\n\")\n            f.write(f\"- **Model**: {incident.get('model', 'unknown')}\\n\")\n            f.write(f\"- **Stall Duration**: {incident.get('stall_duration', 0)} seconds\\n\")\n            f.write(f\"- **Recovery Level**: {incident.get('recovery_level', 0)}\\n\")\n            f.write(f\"- **Success**: {incident.get('success', False)}\\n\")\n            f.write(f\"- **Runtime Type**: {incident.get('runtime_type', 'subagent')}\\n\")\n            f.write(f\"- **Task Type**: {incident.get('task_type', 'unknown')}\\n\")\n            f.write(f\"- **Items Count**: {incident.get('items_count', 0)}\\n\")\n            f.write(\"\\n\")\n        print(f\"[Watchdog] Incident appended to {ERRORS_PATH}\")\n        \n        # Trigger learning loop unless explicitly disabled\n        if trigger_learning:\n            result = self.trigger_learning_loop(incident)\n            if result['triggered']:\n                print(f\"[Watchdog] Learning loop triggered via {result['method']}\")\n            else:\n                print(f\"[Watchdog] Learning loop NOT triggered: {result.get('error', 'unknown')}\")\n    \n    def trigger_learning_loop(self, incident):\n        \"\"\"Invoke the error-learning-loop skill or fallback to index rebuild.\"\"\"\n        result = {\n            'triggered': False,\n            'method': None,\n            'error': None\n        }\n        \n        # Try to spawn the error-learning-loop skill via OpenClaw sessions_spawn\n        # (This is the preferred method but may not be available in all contexts)\n        skill_invoked = self._try_invoke_learning_skill(incident)\n        if skill_invoked:\n            result['triggered'] = True\n            result['method'] = 'skill'\n            print(f\"[Watchdog] Successfully invoked error-learning-loop skill\")\n            return result\n        \n        # Fallback: rebuild index directly\n        print(f\"[Watchdog] Skill invocation not available, using fallback index rebuild\")\n        fallback_success = self._rebuild_index_fallback()\n        if fallback_success:\n            result['triggered'] = True\n            result['method'] = 'fallback'\n        else:\n            result['error'] = 'Fallback index rebuild failed'\n        \n        return result\n    \n    def _try_invoke_learning_skill(self, incident):\n        \"\"\"Attempt to spawn error-learning-loop skill via OpenClaw sessions_spawn.\"\"\"\n        # This is a placeholder for integration with OpenClaw's sessions_spawn API.\n        # In a production deployment, this would call sessions_spawn with runtime=\"subagent\".\n        # For now, we return False to indicate skill invocation is not available.\n        return False\n    \n    def _rebuild_index_fallback(self):\n        \"\"\"Run update_index.py to rebuild INDEX.md and REPORT.md with debouncing.\"\"\"\n        with self.rebuild_lock:\n            now = datetime.utcnow()\n            if (self.last_index_rebuild is not None and \n                (now - self.last_index_rebuild).total_seconds() < REBUILD_DEBOUNCE_SECONDS):\n                print(f\"[Watchdog] Index rebuild debounced (last rebuild: {self.last_index_rebuild})\")\n                return True  # Consider debounced as success (no need to rebuild again)\n            \n            if not UPDATE_INDEX_SCRIPT.exists():\n                print(f\"[Watchdog] ERROR: update_index.py not found at {UPDATE_INDEX_SCRIPT}\")\n                return False\n            \n            try:\n                cmd = [sys.executable, str(UPDATE_INDEX_SCRIPT), str(WORKSPACE)]\n                print(f\"[Watchdog] Executing: {' '.join(cmd)}\")\n                result = subprocess.run(\n                    cmd,\n                    capture_output=True,\n                    text=True,\n                    timeout=30\n                )\n                if result.returncode == 0:\n                    self.last_index_rebuild = now\n                    print(f\"[Watchdog] Index rebuild successful: {result.stdout.strip()}\")\n                    return True\n                else:\n                    print(f\"[Watchdog] Index rebuild failed (exit {result.returncode}): {result.stderr}\")\n                    return False\n            except subprocess.TimeoutExpired:\n                print(f\"[Watchdog] Index rebuild timed out after 30 seconds\")\n                return False\n            except Exception as e:\n                print(f\"[Watchdog] Index rebuild error: {e}\")\n                return False\n    \n    # Deadlock detection methods\n    def add_dependency(self, agent_id, waiting_for_agent_id):\n        \"\"\"Record that agent_id is waiting for waiting_for_agent_id.\"\"\"\n        self.agent_graph[agent_id] = waiting_for_agent_id\n    \n    def detect_deadlock(self):\n        \"\"\"Check dependency graph for cycles.\"\"\"\n        visited = set()\n        for agent in self.agent_graph:\n            if agent not in visited:\n                cycle = self._find_cycle(agent, [], visited)\n                if cycle:\n                    return cycle\n        return None\n    \n    def _find_cycle(self, agent, path, visited):\n        \"\"\"DFS to find cycle.\"\"\"\n        if agent in path:\n            # Cycle detected\n            cycle_start = path.index(agent)\n            return list(path[cycle_start:]) + [agent]\n        if agent in visited:\n            return None\n        \n        path.append(agent)\n        visited.add(agent)\n        \n        next_agent = self.agent_graph.get(agent)\n        if next_agent:\n            cycle = self._find_cycle(next_agent, path, visited)\n            if cycle:\n                return cycle\n        \n        path.pop()\n        return None\n    \n    def detect_starvation_deadlock(self):\n        \"\"\"Detect deadlock via progress starvation (no activity across multiple agents).\"\"\"\n        now = datetime.utcnow()\n        starving_agents = []\n        for session_id, session in self.sessions.items():\n            if session.state == 'running':\n                inactivity = (now - session.last_activity).total_seconds()\n                if inactivity > DEADLOCK_STARVATION_TIMEOUT:\n                    starving_agents.append(session_id)\n        \n        # Need at least 2 agents starving to consider it a deadlock starvation\n        if len(starving_agents) >= 2:\n            print(f\"[Deadlock] Starvation detected: {starving_agents} inactive > {DEADLOCK_STARVATION_TIMEOUT}s\")\n            return starving_agents\n        return None\n    \n    def handle_starvation_deadlock(self, starving_agents):\n        \"\"\"Attempt recovery from starvation deadlock.\"\"\"\n        print(f\"[Deadlock] Handling starvation for {starving_agents}\")\n        # Level 1: request progress update from all agents\n        for agent in starving_agents:\n            print(f\"[Deadlock] Requesting progress update from {agent}\")\n        \n        # Level 2: nudge \"continue\" to each\n        for agent in starving_agents:\n            print(f\"[Deadlock] Sending continue nudge to {agent}\")\n        \n        # Level 3: restart the smallest-risk agent (first in list)\n        agent_to_restart = starving_agents[0]\n        print(f\"[Deadlock] Restarting agent {agent_to_restart}\")\n        \n        # Emit starvation deadlock incident\n        incident = {\n            'pattern_key': 'multi_agent|DEADLOCK|progress_starvation|agents_no_progress',\n            'timestamp': datetime.utcnow().isoformat(),\n            'agents_involved': starving_agents,\n            'deadlock_timeout': DEADLOCK_STARVATION_TIMEOUT,\n            'recovery_strategy': 'nudge_and_restart',\n            'success': True\n        }\n        self.append_to_errors(incident, trigger_learning=True)\n        \n        return incident\n    \n    def handle_deadlock(self, cycle):\n        \"\"\"Attempt deadlock recovery.\"\"\"\n        print(f\"[Deadlock] Cycle detected: {cycle}\")\n        # Level 1: request progress update\n        for agent in cycle:\n            print(f\"[Deadlock] Requesting progress update from {agent}\")\n        \n        # Level 2: force resolution of one edge\n        if len(cycle) > 1:\n            broken_edge = (cycle[0], cycle[1])\n            print(f\"[Deadlock] Breaking dependency {broken_edge}\")\n            self.agent_graph[broken_edge[0]] = None\n        \n        # Level 3: restart one agent\n        agent_to_restart = cycle[0]\n        print(f\"[Deadlock] Restarting agent {agent_to_restart}\")\n        \n        # Emit deadlock incident using standard generator\n        incident = generate_deadlock_incident(\n            cycle,\n            recovery_strategy='edge_break_and_restart',\n            success=True\n        )\n        self.append_to_errors(incident, trigger_learning=True)\n        \n        return incident\n    \n    def run_monitoring_cycle(self, is_retry=False):\n        \"\"\"Main monitoring loop with self-protection.\"\"\"\n        if is_retry:\n            print(\"[Watchdog] Restarted monitoring cycle after failure\")\n        \n        try:\n            print(\"[Watchdog] Starting monitoring cycle\")\n            # Detect stalls\n            stalls = self.detect_stalls()\n            for session in stalls:\n                stall_duration = (datetime.utcnow() - session.last_activity).total_seconds()\n                print(f\"[Watchdog] Stall detected in session {session.session_id} ({stall_duration}s)\")\n                \n                # Recovery escalation\n                for attempt in range(1, 4):\n                    action = self.perform_recovery(session, attempt)\n                    # Simulate recovery success after third attempt\n                    success = (attempt == 3)\n                    if success:\n                        incident = self.emit_incident(session, stall_duration, attempt, success)\n                        print(f\"[Watchdog] Recovery successful, incident {incident['pattern_key']}\")\n                        break\n                    time.sleep(1)  # Simulate delay between attempts\n            \n            # Deadlock detection (dependency cycles)\n            cycle = self.detect_deadlock()\n            if cycle:\n                self.handle_deadlock(cycle)\n            \n            # Starvation deadlock detection (no progress across multiple agents)\n            starving_agents = self.detect_starvation_deadlock()\n            if starving_agents:\n                self.handle_starvation_deadlock(starving_agents)\n            \n            print(\"[Watchdog] Monitoring cycle complete\")\n            \n        except Exception as e:\n            print(f\"[Watchdog] CRITICAL: Monitoring cycle failed: {e}\")\n            # Emit watchdog failure incident\n            self._emit_watchdog_failure(e)\n            \n            # Decide whether to restart\n            if not self.in_restart and self.watchdog_restart_count < MAX_WATCHDOG_SELF_RESTARTS:\n                self.in_restart = True\n                self.watchdog_restart_count += 1\n                print(f\"[Watchdog] Self-restart attempt {self.watchdog_restart_count}/{MAX_WATCHDOG_SELF_RESTARTS}\")\n                # Restart monitoring cycle\n                self.run_monitoring_cycle(is_retry=True)\n                self.in_restart = False\n            else:\n                print(\"[Watchdog] Maximum self-restarts exceeded, exiting monitoring loop\")\n\ndef main():\n    \"\"\"Example usage.\"\"\"\n    watchdog = AgentWatchdog()\n    \n    # Register example sessions\n    watchdog.register_session(\n        session_id=\"validator_A_session\",\n        run_id=\"validator_A_run\",\n        task_description=\"validate batch items\",\n        expected_runtime=8,\n        model=\"deepseek-reasoner\",\n        runtime_type=\"subagent\"\n    )\n    \n    watchdog.register_session(\n        session_id=\"acp_agent_1\",\n        run_id=\"acp_run_1\",\n        task_description=\"ACP processing task\",\n        expected_runtime=10,\n        model=\"gpt-4\",\n        runtime_type=\"acp\"\n    )\n    \n    # Simulate a dependency (deadlock scenario)\n    watchdog.add_dependency(\"agent_A\", \"agent_B\")\n    watchdog.add_dependency(\"agent_B\", \"agent_C\")\n    watchdog.add_dependency(\"agent_C\", \"agent_A\")\n    \n    # Run one monitoring cycle\n    watchdog.run_monitoring_cycle()\n\nif __name__ == '__main__':\n    main()"}],"isError":false,"timestamp":1772811784226}}
