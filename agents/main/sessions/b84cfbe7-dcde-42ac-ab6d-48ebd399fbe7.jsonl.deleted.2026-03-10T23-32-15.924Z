{"type":"message","id":"1f33a830","parentId":"b35059fd","timestamp":"2026-03-09T23:30:41.971Z","message":{"role":"toolResult","toolCallId":"call_00_fGWuY6SIOORLYNWRfOKVbmud","toolName":"read","content":[{"type":"text","text":"                'milestone', 'completed', 'finished', 'launched', \n                'decision', 'decided', 'important', 'note:', \n                'update:', 'changed', 'added', 'removed'\n            ]):\n                events.append(f\"{date}: {line.strip()}\")\n        \n        # Look for project updates\n        for line in lines:\n            if 'project' in line.lower() and ('status' in line.lower() or 'update' in line.lower()):\n                # Try to extract project name\n                for project_keyword in ['OpenClaw', 'Error Learning', 'Workspace Janitor', \n                                       'Agent Watchdog', 'Salesforce']:\n                    if project_keyword in line:\n                        project_updates.setdefault(project_keyword, []).append(f\"{date}: {line.strip()}\")\n    \n    return events, project_updates\n\ndef update_memory_sections(sections, events, project_updates):\n    \"\"\"Update memory sections with new information.\"\"\"\n    updated_sections = sections.copy()\n    \n    # Update Last Updated date\n    if \"MEMORY.md - Curated Long-Term Memory\" in updated_sections:\n        content = updated_sections[\"MEMORY.md - Curated Long-Term Memory\"]\n        # Update the Last Updated line\n        today = datetime.datetime.now().strftime(\"%Y-%m-%d\")\n        content = re.sub(r'\\*\\*Last updated:.*?\\*\\*', f'**Last updated: {today}**', content)\n        updated_sections[\"MEMORY.md - Curated Long-Term Memory\"] = content\n    \n    # Update Recent Milestones section\n    if \"Recent Milestones\" in updated_sections:\n        # Get existing milestones\n        milestones_content = updated_sections[\"Recent Milestones\"]\n        \n        # Extract existing milestone lines\n        milestone_lines = []\n        for line in milestones_content.split('\\n'):\n            if re.match(r'^- \\d{4}-\\d{2}-\\d{2}:', line) or re.match(r'^\\s*\\d{4}-\\d{2}-\\d{2}:', line):\n                milestone_lines.append(line.strip())\n        \n        # Add new events as milestones (limit to last 10)\n        new_milestones = []\n        for event in events[-10:]:  # Last 10 events\n            if event not in milestone_lines:\n                new_milestones.append(f\"- {event}\")\n        \n        # Combine and deduplicate\n        all_milestones = milestone_lines + new_milestones\n        unique_milestones = []\n        seen = set()\n        for milestone in all_milestones:\n            if milestone not in seen:\n                seen.add(milestone)\n                unique_milestones.append(milestone)\n        \n        # Keep only the most recent 15 milestones\n        recent_milestones = unique_milestones[-15:]\n        \n        # Update section\n        updated_sections[\"Recent Milestones\"] = \"## Recent Milestones\\n\" + \"\\n\".join(recent_milestones)\n    \n    # Update Current Active Projects section based on project updates\n    if \"Current Active Projects\" in updated_sections:\n        content = updated_sections[\"Current Active Projects\"]\n        \n        # Check for project status changes\n        for project, updates in project_updates.items():\n            # Look for completion indicators\n            for update in updates:\n                if any(word in update.lower() for word in ['completed', 'finished', 'done', 'live']):\n                    # Update project status in the list\n                    if project == \"OpenClaw Memory System\":\n                        content = re.sub(r'1\\. \\*\\*OpenClaw Memory System\\*\\*.*?-', \n                                        '1. **OpenClaw Memory System** - Completed: Full memory stack installed', \n                                        content)\n        \n        updated_sections[\"Current Active Projects\"] = content\n    \n    return updated_sections\n\ndef rebuild_memory_content(sections):\n    \"\"\"Rebuild MEMORY.md from sections.\"\"\"\n    # Define section order (based on current MEMORY.md structure)\n    section_order = [\n        \"MEMORY.md - Curated Long-Term Memory\",\n        \"Memory System\",\n        \"Current Active Projects\",\n        \"System Configuration\",\n        \"Recent Milestones\",\n        \"Skills Inventory\",\n        \"Guardrails & Learnings\"\n    ]\n    \n    content_lines = []\n    \n    # Add title section first\n    if \"MEMORY.md - Curated Long-Term Memory\" in sections:\n        content_lines.append(sections[\"MEMORY.md - Curated Long-Term Memory\"])\n        content_lines.append(\"\")  # Blank line after title\n    \n\n[151 more lines in file. Use offset=200 to continue.]"}],"isError":false,"timestamp":1773099041967}}
