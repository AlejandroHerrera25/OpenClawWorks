{"type":"message","id":"1f8d7a15","parentId":"57af626e","timestamp":"2026-03-10T00:06:28.621Z","message":{"role":"toolResult","toolCallId":"call_00_aLhvNZJYm6WBTjpqu8h4qy91","toolName":"read","content":[{"type":"text","text":"            \"max_concurrent_tasks\": max_concurrent,\n            \"token_budget_per_phase\": token_budget_per_phase,\n            \"recommended_batch_size\": min(3, max_concurrent)\n        }\n    \n    def generate_validation_protocol(self) -> Dict[str, Any]:\n        \"\"\"Generate validation protocol for the plan.\"\"\"\n        return {\n            \"pre_execution_checks\": [\n                \"Verify workspace has write permissions\",\n                \"Check available token budget\",\n                \"Validate task dependencies are acyclic\"\n            ],\n            \"post_execution_validation\": [\n                \"Validate each task's acceptance criteria\",\n                \"Check output files exist and are readable\",\n                \"Verify task outputs match expected formats\"\n            ],\n            \"final_synthesis_requirements\": [\n                \"Combine all task outputs into final result\",\n                \"Validate final result against original prompt requirements\",\n                \"Ensure proper formatting and structure\"\n            ]\n        }\n    \n    def generate_plan(self) -> Dict[str, Any]:\n        \"\"\"Generate complete plan in standard format.\"\"\"\n        # Calculate total resources\n        total_tokens = sum(task.estimated_tokens for task in self.tasks)\n        total_runtime = sum(task.estimated_runtime_seconds for task in self.tasks)\n        \n        # Build plan structure\n        plan = {\n            \"plan_id\": self.plan_id,\n            \"original_prompt\": self.original_prompt[:1000] + \"...\" if len(self.original_prompt) > 1000 else self.original_prompt,\n            \"created_at\": self.created_at,\n            \"estimated_total_tokens\": total_tokens,\n            \"estimated_total_runtime_seconds\": total_runtime,\n            \"global_token_budget\": 16000,  # Default budget\n            \"tasks\": [task.to_dict() for task in self.tasks],\n            \"dependency_graph\": self.build_dependency_graph(),\n            \"resource_allocation\": self.calculate_resource_allocation(),\n            \"validation_protocol\": self.generate_validation_protocol()\n        }\n        \n        return plan\n    \n    def save_plan(self, output_path: Optional[str] = None) -> str:\n        \"\"\"Save plan to file.\"\"\"\n        if output_path is None:\n            output_path = os.path.join(WORKSPACE, f\"{self.plan_id}.json\")\n        \n        plan = self.generate_plan()\n        \n        with open(output_path, 'w') as f:\n            json.dump(plan, f, indent=2)\n        \n        return output_path\n\ndef generate_plan_from_decomposed_tasks(original_prompt: str, decomposed_tasks: List[Dict[str, Any]]) -> Dict[str, Any]:\n    \"\"\"\n    Generate a plan from decomposed tasks.\n    \n    Args:\n        original_prompt: The original prompt\n        decomposed_tasks: List of decomposed tasks from decompose.py\n        \n    Returns:\n        Structured plan in standard format\n    \"\"\"\n    generator = PlanGenerator(original_prompt)\n    \n    for task_data in decomposed_tasks:\n        generator.add_task(task_data)\n    \n    return generator.generate_plan()\n\ndef demo_plan_generation():\n    \"\"\"Demo plan generation with example tasks.\"\"\"\n    print(\"=== Demo: Plan Generation ===\")\n    \n    # Example decomposed tasks\n    example_tasks = [\n        {\n            'id': 'task_01_introduction',\n            'objective': 'Write introduction section',\n            'description': 'Create a 300-word introduction that provides an overview of climate change and its relevance to agriculture.',\n            'inputs': [],\n            'outputs': ['introduction.md'],\n            'dependencies': [],\n            'acceptance_criteria': [\n                'File exists: introduction.md',\n                'Word count >= 250',\n                'Contains keywords: climate, agriculture, overview'\n            ],\n            'estimated_tokens': 800,\n            'estimated_runtime': 60,\n            'complexity_score': 3\n        },\n        {\n\n[68 more lines in file. Use offset=450 to continue.]"}],"isError":false,"timestamp":1773101188612}}
