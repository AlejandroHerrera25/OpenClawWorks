ginal_prompt\n        self.plan_id = f\"plan_{int(time.time())}_{uuid.uuid4().hex[:8]}\"\n        self.tasks: List[PlanTask] = []\n        self.created_at = time.strftime(\"%Y-%m-%dT%H:%M:%SZ\", time.gmtime())\n    \n    def add_task(self, task_data: Dict[str, Any]) -> str:\n        \"\"\"Add a task to the plan.\"\"\"\n        # Generate task_id if not provided\n        task_id = task_data.get('id', f\"task_{len(self.tasks)+1:02d}\")\n        \n        # Create PlanTask object\n        task = PlanTask(\n            task_id=task_id,\n            objective=task_data.get('objective', ''),\n\n[327 more lines in file. Use offset=80 to continue.]"}],"isError":false,"timestamp":1773101062041}}
