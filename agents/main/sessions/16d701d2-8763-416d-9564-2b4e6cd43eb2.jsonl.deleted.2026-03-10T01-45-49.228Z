{"type":"message","id":"9176c67f","parentId":"64894a29","timestamp":"2026-03-10T00:51:07.977Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me update the `distributed_orchestrate.py` with similar logic:"},{"type":"toolCall","id":"call_00_wttD7JGphDn2BZDxPmksW4IV","name":"edit","arguments":{"path":"~/.openclaw/workspace/skills/long-prompt-orchestrator/scripts/distributed_orchestrate.py","oldText":"    def _analyze_skill_recommendation(self, task_data: Dict[str, Any]) -> Optional[str]:\n        \"\"\"Analyze and recommend skill for task.\"\"\"\n        objective = task_data.get('objective', '').lower()\n        description = task_data.get('description', '').lower()\n        full_text = f\"{objective} {description}\"\n        \n        # Salesforce tasks - check FIRST\n        salesforce_keywords = ['salesforce', 'apex', 'lwc', 'visualforce', 'soql', 'flow', 'sfdc']\n        if any(keyword in full_text for keyword in salesforce_keywords):\n            # Salesforce-specific tasks\n            audit_keywords = ['audit', 'review', 'check', 'validate', 'security', 'code quality', 'inspect']\n            if any(keyword in full_text for keyword in audit_keywords):\n                return \"salesforce-code-auditor\"\n            else:\n                return \"salesforce-architect\"\n        \n        # Workspace maintenance/inventory\n        workspace_keywords = ['workspace', 'inventory', 'list skills', 'clean', 'organize', 'tidy', 'maintain', 'janitor']\n        if any(keyword in full_text for keyword in workspace_keywords):\n            return \"workspace-janitor\"\n        \n        # Web search tasks\n        search_keywords = ['search', 'research', 'find', 'look up', 'web', 'internet', 'google', 'browse']\n        if any(keyword in full_text for keyword in search_keywords):\n            return \"tavily-web-search\"\n        \n        # System health/monitoring\n        system_keywords = ['system health', 'check system', 'monitor', 'watchdog', 'agent-watchdog']\n        if any(keyword in full_text for keyword in system_keywords):\n            return \"agent-watchdog\"\n        \n        # Memory/vector operations\n        memory_keywords = ['memory', 'vector', 'embedding', 'semantic', 'retrieval']\n        if any(keyword in full_text for keyword in memory_keywords):\n            return \"vector-memory\"\n        \n        # Error handling/learning\n        error_keywords = ['error', 'incident', 'learning loop', 'guardrail', 'mistake']\n        if any(keyword in full_text for keyword in error_keywords):\n            return \"error-learning-loop\"\n        \n        # Planning/orchestration\n        planning_keywords = ['plan', 'orchestrate', 'coordinate', 'decompose', 'schedule', 'long prompt']\n        if any(keyword in full_text for keyword in planning_keywords):\n            return \"long-prompt-orchestrator\"\n        \n        return None","newText":"    def _analyze_skill_recommendation(self, task_data: Dict[str, Any]) -> Optional[str]:\n        \"\"\"Analyze and recommend skill for task.\"\"\"\n        objective = task_data.get('objective', '').lower()\n        description = task_data.get('description', '').lower()\n        full_text = f\"{objective} {description}\"\n        \n        # Check for workspace maintenance/inventory FIRST (most common non-Salesforce task)\n        workspace_keywords = ['workspace', 'inventory', 'list skills', 'clean', 'organize', 'tidy', 'maintain', 'janitor']\n        workspace_priority_keywords = ['workspace audit', 'inventory workspace', 'clean workspace', 'organize workspace']\n        \n        # Check for high-priority workspace phrases first\n        for phrase in workspace_priority_keywords:\n            if phrase in full_text:\n                return \"workspace-janitor\"\n        \n        # Check for individual workspace keywords\n        if any(keyword in full_text for keyword in workspace_keywords):\n            # But check if it's actually a Salesforce task in disguise\n            salesforce_keywords = ['salesforce', 'apex', 'lwc', 'visualforce', 'soql', 'flow', 'sfdc']\n            has_salesforce = any(keyword in full_text for keyword in salesforce_keywords)\n            \n            # If it mentions Salesforce AND workspace, prioritize based on context\n            if has_salesforce:\n                # Check if Salesforce is the primary focus\n                salesforce_primary_indicators = ['salesforce audit', 'apex code', 'lwc component', 'salesforce security']\n                if any(indicator in full_text for indicator in salesforce_primary_indicators):\n                    audit_keywords = ['audit', 'review', 'check', 'validate', 'security', 'code quality', 'inspect']\n                    if any(keyword in full_text for keyword in audit_keywords):\n                        return \"salesforce-code-auditor\"\n                    else:\n                        return \"salesforce-architect\"\n                else:\n                    # Workspace is primary, Salesforce is secondary\n                    return \"workspace-janitor\"\n            else:\n                # Pure workspace task\n                return \"workspace-janitor\"\n        \n        # Check for Salesforce-related content (without workspace context)\n        salesforce_keywords = ['salesforce', 'apex', 'lwc', 'visualforce', 'soql', 'flow', 'sfdc']\n        if any(keyword in full_text for keyword in salesforce_keywords):\n            # Salesforce-specific tasks\n            audit_keywords = ['audit', 'review', 'check', 'validate', 'security', 'code quality', 'inspect']\n            if any(keyword in full_text for keyword in audit_keywords):\n                return \"salesforce-code-auditor\"\n            else:\n                return \"salesforce-architect\"\n        \n        # Check for web search tasks\n        search_keywords = ['search', 'research', 'find', 'look up', 'web', 'internet', 'google', 'browse']\n        if any(keyword in full_text for keyword in search_keywords):\n            return \"tavily-web-search\"\n        \n        # System health/monitoring\n        system_keywords = ['system health', 'check system', 'monitor', 'watchdog', 'agent-watchdog']\n        if any(keyword in full_text for keyword in system_keywords):\n            return \"agent-watchdog\"\n        \n        # Memory/vector operations\n        memory_keywords = ['memory', 'vector', 'embedding', 'semantic', 'retrieval']\n        if any(keyword in full_text for keyword in memory_keywords):\n            return \"vector-memory\"\n        \n        # Error handling/learning\n        error_keywords = ['error', 'incident', 'learning loop', 'guardrail', 'mistake']\n        if any(keyword in full_text for keyword in error_keywords):\n            return \"error-learning-loop\"\n        \n        # Planning/orchestration\n        planning_keywords = ['plan', 'orchestrate', 'coordinate', 'decompose', 'schedule', 'long prompt']\n        if any(keyword in full_text for keyword in planning_keywords):\n            return \"long-prompt-orchestrator\"\n        \n        return None"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":53,"output":1588,"cacheRead":36928,"cacheWrite":0,"totalTokens":38569,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773103817549}}
