{"type":"message","id":"45c7ad92","parentId":"284c98dc","timestamp":"2026-03-09T15:48:08.693Z","message":{"role":"toolResult","toolCallId":"call_00_cakIjW2xtlhlyETN8FISPq7G","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nTavily Web Search - Main search functionality with OpenClaw ecosystem integration.\n\"\"\"\n\nimport os\nimport sys\nimport json\nimport time\nimport hashlib\nimport argparse\nfrom datetime import datetime, timedelta\nfrom pathlib import Path\nfrom typing import Dict, List, Optional, Any\n\n# Add parent directory to path for imports\nsys.path.insert(0, str(Path(__file__).parent.parent))\n\ntry:\n    from tavily import TavilyClient\nexcept ImportError:\n    print(\"ERROR: tavily-python not installed. Run: pip install tavily-python\")\n    sys.exit(1)\n\n# Import integration modules\ntry:\n    from scripts.tavily_integrations import (\n        register_with_watchdog,\n        emit_incident,\n        setup_janitor_cleanup,\n        get_cache_path,\n        load_config\n    )\nexcept ImportError:\n    # Create minimal versions for initial setup\n    def load_config():\n        config_path = Path(__file__).parent.parent / \"config\" / \"tavily_config.json\"\n        with open(config_path) as f:\n            return json.load(f)\n    \n    def register_with_watchdog(session_id, run_id, task_desc, expected_time):\n        print(f\"[WATCHDOG] Registered: {session_id} - {task_desc}\")\n        return True\n    \n    def emit_incident(incident_type, severity, symptom, evidence, pattern_hint=\"\", prevention_rule=\"\"):\n        print(f\"[INCIDENT] {incident_type} - {severity}: {symptom}\")\n        return True\n    \n    def setup_janitor_cleanup(file_patterns, max_age_days):\n        print(f\"[JANITOR] Setup cleanup for patterns: {file_patterns}\")\n\n[395 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1773071288685}}
