{"type":"message","id":"deb8fe85","parentId":"14b16fd2","timestamp":"2026-03-10T00:36:13.960Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create the real-time alerts system:"},{"type":"toolCall","id":"call_00_Io0kxeU6Sl6yK4wvtD5QDUND","name":"write","arguments":{"path":"~/.openclaw/workspace/alerts/real_time_alerts.py","content":"#!/usr/bin/env python3\n\"\"\"\nReal-time Alerts System\nGenerates alerts for critical monitoring events.\n\"\"\"\n\nimport os\nimport json\nimport time\nimport sys\nimport smtplib\nfrom email.mime.text import MIMEText\nfrom email.mime.multipart import MIMEMultipart\nfrom datetime import datetime, timedelta\nfrom pathlib import Path\n\n# Workspace paths\nWORKSPACE = Path.home() / '.openclaw' / 'workspace'\nWATCHDOG_DIR = WORKSPACE / '.watchdog'\nSESSION_REGISTRY = WATCHDOG_DIR / 'session_registry.json'\nINCIDENTS_FILE = WATCHDOG_DIR / 'incidents.json'\nALERTS_FILE = WATCHDOG_DIR / 'alerts.json'\nALERTS_LOG = WATCHDOG_DIR / 'alerts.log'\n\nclass RealTimeAlerts:\n    \"\"\"Real-time alerts system for OpenClaw monitoring.\"\"\"\n    \n    def __init__(self):\n        self.alerts = []\n        self.alert_rules = self._load_alert_rules()\n        self.sent_alerts = self._load_sent_alerts()\n        \n    def _load_alert_rules(self):\n        \"\"\"Load alert rules configuration.\"\"\"\n        rules_file = Path(__file__).parent / 'alert_rules.json'\n        default_rules = {\n            \"critical_stall\": {\n                \"enabled\": True,\n                \"condition\": \"session.state == 'stalled' and session.stall_count >= 1 and session.metrics.total_uptime > 300\",\n                \"severity\": \"critical\",\n                \"message\": \"Critical stall detected: Session {session_id} has been stalled for over 5 minutes\",\n                \"channels\": [\"log\", \"console\"]\n            },\n            \"repeated_failure\": {\n                \"enabled\": True,\n                \"condition\": \"session.recovery_attempts >= 3\",\n                \"severity\": \"high\",\n                \"message\": \"Repeated failures: Session {session_id} has {recovery_attempts} recovery attempts\",\n                \"channels\": [\"log\", \"console\"]\n            },\n            \"system_resource\": {\n                \"enabled\": True,\n                \"condition\": \"False\",  # Placeholder for system resource checks\n                \"severity\": \"medium\",\n                \"message\": \"System resource issue detected\",\n                \"channels\": [\"log\"]\n            },\n            \"cron_job_failure\": {\n                \"enabled\": True,\n                \"condition\": \"session.source == 'cron_integration' and session.outcome == 'failure'\",\n                \"severity\": \"medium\",\n                \"message\": \"Cron job failure: {session.cron_job_name} failed execution\",\n                \"channels\": [\"log\", \"console\"]\n            },\n            \"multiple_stalls\": {\n                \"enabled\": True,\n                \"condition\": \"summary.stalled_sessions >= 3\",\n                \"severity\": \"high\",\n                \"message\": \"Multiple stalls detected: {summary.stalled_sessions} sessions are stalled\",\n                \"channels\": [\"log\", \"console\"]\n            }\n        }\n        \n        if rules_file.exists():\n            try:\n                with open(rules_file, 'r') as f:\n                    user_rules = json.load(f)\n                    # Merge with defaults\n                    for key, rule in default_rules.items():\n                        if key not in user_rules:\n                            user_rules[key] = rule\n                    return user_rules\n            except Exception as e:\n                print(f\"Error loading alert rules: {e}\")\n        \n        return default_rules\n    \n    def _load_sent_alerts(self):\n        \"\"\"Load previously sent alerts.\"\"\"\n        if ALERTS_FILE.exists():\n            try:\n                with open(ALERTS_FILE, 'r') as f:\n                    return json.load(f)\n            except Exception:\n                pass\n        return []\n    \n    def _save_sent_alerts(self):\n        \"\"\"Save sent alerts to file.\"\"\"\n        try:\n            with open(ALERTS_FILE, 'w') as f:\n                json.dump(self.sent_alerts, f, indent=2)\n            return True\n        except Exception as e:\n            print(f\"Error saving alerts: {e}\")\n            return False\n    \n    def log_alert(self, message, severity=\"info\", alert_type=\"system\"):\n        \"\"\"Log an alert.\"\"\"\n        timestamp = datetime.utcnow().isoformat()\n        alert_entry = {\n            \"timestamp\": timestamp,\n            \"severity\": severity,\n            \"type\": alert_type,\n            \"message\": message,\n            \"acknowledged\": False\n        }\n        \n        # Add to alerts list\n        self.alerts.append(alert_entry)\n        \n        # Write to alerts log\n        try:\n            with open(ALERTS_LOG, 'a') as f:\n                log_entry = f\"[{timestamp}] [{severity.upper()}] [{alert_type}] {message}\\n\"\n                f.write(log_entry)\n        except Exception as e:\n            print(f\"Failed to write to alerts log: {e}\")\n        \n        # Print to console for critical/high severity\n        if severity in [\"critical\", \"high\"]:\n            print(f\"🚨 ALERT [{severity.upper()}]: {message}\")\n        \n        return alert_entry\n    \n    def check_session_alerts(self, sessions, summary=None):\n        \"\"\"Check sessions for alert conditions.\"\"\"\n        alerts_triggered = []\n        \n        for session_id, session in sessions.items():\n            # Check each alert rule\n            for rule_name, rule in self.alert_rules.items():\n                if not rule.get(\"enabled\", True):\n                    continue\n                \n                # Evaluate condition (simplified for now)\n                condition_met = False\n                \n                if rule_name == \"critical_stall\":\n                    if (session.get(\"state\") == \"stalled\" and \n                        session.get(\"stall_count\", 0) >= 1):\n                        # Check if stalled for over 5 minutes\n                        last_activity = session.get(\"last_activity\")\n                        if last_activity:\n                            try:\n                                last_active = datetime.fromisoformat(last_activity)\n                                inactive_seconds = (datetime.utcnow() - last_active).total_seconds()\n                                if inactive_seconds > 300:  # 5 minutes\n                                    condition_met = True\n                            except Exception:\n                                pass\n                \n                elif rule_name == \"repeated_failure\":\n                    if session.get(\"recovery_attempts\", 0) >= 3:\n                        condition_met = True\n                \n                elif rule_name == \"cron_job_failure\":\n                    if (session.get(\"source\") == \"cron_integration\" and \n                        session.get(\"outcome\") == \"failure\"):\n                        condition_met = True\n                \n                if condition_met:\n                    # Format message\n                    message = rule[\"message\"].format(\n                        session_id=session_id,\n                        session=session,\n                        recovery_attempts=session.get(\"recovery_attempts\", 0),\n                        cron_job_name=session.get(\"cron_job_name\", \"unknown\")\n                    )\n                    \n                    # Check if we've already sent this alert recently\n                    alert_key = f\"{rule_name}_{session_id}\"\n                    recent_alerts = [a for a in self.sent_alerts \n                                    if a.get(\"key\") == alert_key and \n                                    datetime.fromisoformat(a[\"timestamp\"]) > datetime.utcnow() - timedelta(minutes=30)]\n                    \n                    if not recent_alerts:\n                        # Log alert\n                        alert = self.log_alert(\n                            message=message,\n                            severity=rule[\"severity\"],\n                            alert_type=rule_name\n                        )\n                        \n                        # Add to sent alerts\n                        alert_record = {\n                            \"key\": alert_key,\n                            \"timestamp\": alert[\"timestamp\"],\n                            \"rule\": rule_name,\n                            \"session_id\": session_id,\n                            \"message\": message\n                        }\n                        self.sent_alerts.append(alert_record)\n                        \n                        alerts_triggered.append(alert)\n        \n        # Check summary-based alerts\n        if summary:\n            for rule_name, rule in self.alert_rules.items():\n                if not rule.get(\"enabled\", True):\n                    continue\n                \n                if rule_name == \"multiple_stalls\":\n                    if summary.get(\"stalled_sessions\", 0) >= 3:\n                        message = rule[\"message\"].format(summary=summary)\n                        \n                        # Check if we've already sent this alert recently\n                        alert_key = f\"{rule_name}_summary\"\n                        recent_alerts = [a for a in self.sent_alerts \n                                        if a.get(\"key\") == alert_key and \n                                        datetime.fromisoformat(a[\"timestamp\"]) > datetime.utcnow() - timedelta(minutes=30)]\n                        \n                        if not recent_alerts:\n                            alert = self.log_alert(\n                                message=message,\n                                severity=rule[\"severity\"],\n                                alert_type=rule_name\n                            )\n                            \n                            alert_record = {\n                                \"key\": alert_key,\n                                \"timestamp\": alert[\"timestamp\"],\n                                \"rule\": rule_name,\n                                \"message\": message\n                            }\n                            self.sent_alerts.append(alert_record)\n                            \n                            alerts_triggered.append(alert)\n        \n        # Save sent alerts\n        self._save_sent_alerts()\n        \n        return alerts_triggered\n    \n    def check_incident_alerts(self, incidents):\n        \"\"\"Check incidents for alert conditions.\"\"\"\n        alerts_triggered = []\n        current_time = datetime.utcnow()\n        one_hour_ago = current_time - timedelta(hours=1)\n        \n        # Count recent incidents by severity\n        recent_incidents = {\n            \"S1\": 0,\n            \"S2\": 0,\n            \"S3\": 0,\n            \"S4\": 0\n        }\n        \n        for incident in incidents:\n            timestamp = incident.get(\"timestamp\")\n            if timestamp:\n                try:\n                    incident_time = datetime.fromisoformat(timestamp)\n                    if incident_time > one_hour_ago:\n                        severity = incident.get(\"severity\", \"S3\")\n                        if severity in recent_incidents:\n                            recent_incidents[severity] += 1\n                except Exception:\n                    pass\n        \n        # Alert for multiple high-severity incidents\n        if recent_incidents[\"S1\"] >= 2 or recent_incidents[\"S2\"] >= 5:\n            message = f\"Multiple high-severity incidents in the last hour: S1={recent_incidents['S1']}, S2={recent_incidents['S2']}\"\n            \n            alert_key = f\"multiple_high_severity_incidents\"\n            recent_alerts = [a for a in self.sent_alerts \n                            if a.get(\"key\") == alert_key and \n                            datetime.fromisoformat(a[\"timestamp\"]) > datetime.utcnow() - timedelta(minutes=30)]\n            \n            if not recent_alerts:\n                alert = self.log_alert(\n                    message=message,\n                    severity=\"high\",\n                    alert_type=\"incident_cluster\"\n                )\n                \n                alert_record = {\n                    \"key\": alert_key,\n                    \"timestamp\": alert[\"timestamp\"],\n                    \"rule\": \"multiple_high_severity_incidents\",\n                    \"message\": message\n                }\n                self.sent_alerts.append(alert_record)\n                \n                alerts_triggered.append(alert)\n        \n        return alerts_triggered\n    \n    def send_email_alert(self, alert, recipient=None):\n        \"\"\"Send an email alert (if configured).\"\"\"\n        # Check if email is configured\n        email_config_file = Path(__file__).parent / 'email_config.json'\n        if not email_config_file.exists():\n            return False\n        \n        try:\n            with open(email_config_file, 'r') as f:\n                email_config = json.load(f)\n        except Exception as e:\n            print(f\"Error loading email config: {e}\")\n            return False\n        \n        if not all(key in email_config for key in [\"smtp_server\", \"smtp_port\", \"username\", \"password\", \"sender\"]):\n            print(\"Email configuration incomplete\")\n            return False\n        \n        if not recipient:\n            recipient = email_config.get(\"default_recipient\", email_config[\"sender\"])\n        \n        try:\n            # Create message\n            msg = MIMEMultipart()\n            msg['From'] = email_config[\"sender\"]\n            msg['To'] = recipient\n            msg['Subject'] = f\"OpenClaw Alert: {alert['severity'].upper()} - {alert['type']}\"\n            \n            # Create HTML body\n            html = f\"\"\"\n            <html>\n            <body>\n                <h2>🚨 OpenClaw Alert</h2>\n                <p><strong>Severity:</strong> {alert['severity'].upper()}</p>\n                <p><strong>Type:</strong> {alert['type']}</p>\n                <p><strong>Time:</strong> {alert['timestamp']}</p>\n                <div style=\"background: #f8f9fa; padding: 15px; border-left: 4px solid {'#dc3545' if alert['severity'] == 'critical' else '#fd7e14' if alert['severity'] == 'high' else '#ffc107'}; margin: 15px 0;\">\n                    {alert['message']}\n                </div>\n                <p><small>This is an automated alert from OpenClaw Monitoring System.</small></p>\n            </body>\n            </html>\n            \"\"\"\n            \n            msg.attach(MIMEText(html, 'html'))\n            \n            # Send email\n            with smtplib.SMTP(email_config[\"smtp_server\"], email_config[\"smtp_port\"]) as server:\n                server.starttls()\n                server.login(email_config[\"username\"], email_config[\"password\"])\n                server.send_message(msg)\n            \n            print(f\"Email alert sent to {recipient}\")\n            return True\n            \n        except Exception as e:\n            print(f\"Error sending email alert: {e}\")\n            return False\n    \n    def run_alert_cycle(self):\n        \"\"\"Run a complete alert checking cycle.\"\"\"\n        print(\"Running alert cycle...\")\n        \n        # Load data\n        sessions = {}\n        if SESSION_REGISTRY.exists():\n            try:\n                with open(SESSION_REGISTRY, 'r') as f:\n                    sessions = json.load(f)\n            except Exception as e:\n                print(f\"Error loading sessions: {e}\")\n        \n        incidents = []\n        if INCIDENTS_FILE.exists():\n            try:\n                with open(INCIDENTS_FILE, 'r') as f:\n                    incidents = json.load(f)\n            except Exception as e:\n                print(f\"Error loading incidents: {e}\")\n        \n        # Generate summary\n        summary = {\n            \"stalled_sessions\": sum(1 for s in sessions.values() if s.get(\"state\") == \"stalled\"),\n            \"total_sessions\": len(sessions)\n        }\n        \n        # Check for alerts\n        session_alerts = self.check_session_alerts(sessions, summary)\n        incident_alerts = self.check_incident_alerts(incidents)\n        \n        all_alerts = session_alerts + incident_alerts\n        \n        # Send email for critical alerts\n        for alert in all_alerts:\n            if alert[\"severity\"] == \"critical\":\n                self.send_email_alert(alert)\n        \n        print(f\"Alert cycle complete: {len(all_alerts)} alerts triggered\")\n        return all_alerts\n    \n    def get_recent_alerts(self, hours=24):\n        \"\"\"Get recent alerts from the log.\"\"\"\n        recent_alerts = []\n        cutoff_time = datetime.utcnow() - timedelta(hours=hours)\n        \n        if ALERTS_LOG.exists():\n            try:\n                with open(ALERTS_LOG, 'r') as f:\n                    for line in f:\n                        if line.strip():\n                            # Parse log line\n                            parts = line.strip().split(' ', 3)\n                            if len(parts) >= 4:\n                                timestamp_str = parts[0][1:] + ' ' + parts[1][:-1]\n                                try:\n                                    timestamp = datetime.fromisoformat(timestamp_str.replace(' ', 'T'))\n                                    if timestamp > cutoff_time:\n                                        severity = parts[2][1:-1]\n                                        alert_type = parts[3][1:-1]\n                                        message = parts[4] if len(parts) > 4 else \"\"\n                                        \n                                        recent_alerts.append({\n                                            \"timestamp\": timestamp.isoformat(),\n                                            \"severity\": severity.lower(),\n                                            \"type\": alert_type,\n                                            \"message\": message\n                                        })\n                                except Exception:\n                                    pass\n            except Exception as e:\n                print(f\"Error reading alerts log: {e}\")\n        \n        return recent_alerts\n\n# Global instance for easy import\nalerts_system = RealTimeAlerts()\n\nif __name__ == \"__main__\":\n    # Test the alerts system\n    alerts = RealTimeAlerts()\n    \n    print(\"Testing alerts system...\")\n    \n    # Test 1: Log a test alert\n    print(\"\\nTest 1: Logging test alert...\")\n    test_alert = alerts.log_alert(\n        message=\"Test alert from alerts system\",\n        severity=\"medium\",\n        alert_type=\"test\"\n    )\n    print(f\"✓ Test alert logged: {test_alert['message']}\")\n    \n    # Test 2: Run alert cycle\n    print(\"\\nTest 2: Running alert cycle...\")\n    triggered_alerts = alerts.run_alert_cycle()\n    print(f\"✓ Alert cycle complete: {len(triggered_alerts)} alerts triggered\")\n    \n    # Test 3: Get recent alerts\n    print(\"\\nTest 3: Getting recent alerts...\")\n    recent_alerts = alerts.get_recent_alerts(hours=1)\n    print(f\"✓ Found {len(recent_alerts)} recent alerts\")\n    \n    # Test 4: Display alert summary\n    print(\"\\nTest 4: Alert Summary:\")\n    print(\"=\" * 50)\n    for alert in recent_alerts[:5]:  # Show last 5 alerts\n        print(f\"[{