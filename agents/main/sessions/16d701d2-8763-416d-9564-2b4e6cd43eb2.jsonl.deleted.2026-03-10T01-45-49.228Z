{"type":"message","id":"25d592b1","parentId":"cc0e7333","timestamp":"2026-03-10T00:49:20.366Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create a comprehensive test to verify the fix:"},{"type":"toolCall","id":"call_00_iVx0K1BW7zuW4rx3nDwXln6I","name":"write","arguments":{"path":"/tmp/test_lpo_fix.py","content":"#!/usr/bin/env python3\n\"\"\"\nTest to verify the LPO skill recommendation fix.\n\"\"\"\n\nimport sys\nimport os\n\n# Add the LPO skill directory to path\nsys.path.insert(0, '/home/openclaw/.openclaw/workspace/skills/long-prompt-orchestrator/scripts')\n\nfrom plan_generator import PlanGenerator\nfrom distributed_orchestrate import DistributedPlanGenerator\n\ndef test_fixed_plan_generator():\n    \"\"\"Test the fix in plan_generator.py\"\"\"\n    print(\"=== Testing FIXED plan_generator.py ===\")\n    \n    test_cases = [\n        # Non-Salesforce tasks that were incorrectly recommended salesforce-code-auditor\n        (\"Inventory workspace skills and check system health\", \"workspace-janitor\", \"Workspace inventory with check\"),\n        (\"Check system health\", \"agent-watchdog\", \"System health check\"),\n        (\"Audit workspace files\", \"workspace-janitor\", \"Workspace audit\"),\n        (\"Review code quality\", None, \"Generic code review\"),\n        (\"Validate system configuration\", None, \"Generic validation\"),\n        \n        # Salesforce tasks - should be correctly identified\n        (\"Salesforce audit of Apex code\", \"salesforce-code-auditor\", \"Salesforce audit\"),\n        (\"Review Salesforce Apex triggers\", \"salesforce-code-auditor\", \"Salesforce review\"),\n        (\"Check Salesforce security\", \"salesforce-code-auditor\", \"Salesforce security check\"),\n        (\"Salesforce architecture design\", \"salesforce-architect\", \"Salesforce architecture\"),\n        (\"Design Salesforce data model\", \"salesforce-architect\", \"Salesforce design\"),\n        \n        # Other skill matches\n        (\"Research AI agents\", \"tavily-web-search\", \"Web research\"),\n        (\"Search for OpenClaw docs\", \"tavily-web-search\", \"Web search\"),\n        (\"Clean workspace temp files\", \"workspace-janitor\", \"Workspace cleanup\"),\n        (\"Organize skill directories\", \"workspace-janitor\", \"Workspace organization\"),\n        (\"Monitor agent performance\", \"agent-watchdog\", \"Agent monitoring\"),\n        (\"Analyze vector memory\", \"vector-memory\", \"Vector memory\"),\n        (\"Handle error incidents\", \"error-learning-loop\", \"Error handling\"),\n        (\"Orchestrate complex task\", \"long-prompt-orchestrator\", \"Orchestration\"),\n        \n        # Edge cases\n        (\"Check Salesforce and workspace\", \"salesforce-architect\", \"Mixed but Salesforce first\"),\n        (\"Workspace audit for Salesforce\", \"workspace-janitor\", \"Workspace first\"),\n    ]\n    \n    generator = PlanGenerator(\"Test prompt\")\n    passed = 0\n    failed = 0\n    \n    for objective, expected_skill, description in test_cases:\n        task_data = {\n            'id': 'test_task',\n            'objective': objective,\n            'description': objective,\n            'complexity_score': 3\n        }\n        \n        recommended_skill = generator._recommend_skill_or_role(task_data)\n        correct = recommended_skill == expected_skill\n        \n        if correct:\n            passed += 1\n            status = \"✓\"\n        else:\n            failed += 1\n            status = \"✗\"\n        \n        print(f\"{status} {description}:\")\n        print(f\"  Task: {objective}\")\n        print(f\"  Recommended: {recommended_skill}\")\n        print(f\"  Expected: {expected_skill}\")\n        \n        if not correct:\n            print(f\"  ERROR: Incorrect recommendation!\")\n        print()\n    \n    return passed, failed\n\ndef test_fixed_distributed_orchestrate():\n    \"\"\"Test the fix in distributed_orchestrate.py\"\"\"\n    print(\"\\n=== Testing FIXED distributed_orchestrate.py ===\")\n    \n    test_cases = [\n        # Non-Salesforce tasks that were incorrectly recommended salesforce-code-auditor\n        (\"Inventory workspace skills and check system health\", \"workspace-janitor\", \"Workspace inventory\"),\n        (\"Check system health\", \"agent-watchdog\", \"System health\"),\n        (\"Audit workspace files\", \"workspace-janitor\", \"Workspace audit\"),\n        \n        # Salesforce tasks\n        (\"Salesforce audit of Apex code\", \"salesforce-code-auditor\", \"Salesforce audit\"),\n        (\"Salesforce architecture design\", \"salesforce-architect\", \"Salesforce architecture\"),\n        \n        # Other skills\n        (\"Research AI agents\", \"tavily-web-search\", \"Web research\"),\n        (\"Clean workspace\", \"workspace-janitor\", \"Workspace cleanup\"),\n    ]\n    \n    generator = DistributedPlanGenerator(\"test_plan\", \"Test prompt\")\n    passed = 0\n    failed = 0\n    \n    for objective, expected_skill, description in test_cases:\n        task_data = {\n            'id': 'test_task',\n            'objective': objective,\n            'description': objective,\n            'complexity_score': 3\n        }\n        \n        recommended_skill = generator._analyze_skill_recommendation(task_data)\n        correct = recommended_skill == expected_skill\n        \n        if correct:\n            passed += 1\n            status = \"✓\"\n        else:\n            failed += 1\n            status = \"✗\"\n        \n        print(f\"{status} {description}:\")\n        print(f\"  Task: {objective}\")\n        print(f\"  Recommended: {recommended_skill}\")\n        print(f\"  Expected: {expected_skill}\")\n        \n        if not correct:\n            print(f\"  ERROR: Incorrect recommendation!\")\n        print()\n    \n    return passed, failed\n\ndef test_real_delegation_scenario():\n    \"\"\"Test a real delegation scenario\"\"\"\n    print(\"\\n=== Testing Real Delegation Scenario ===\")\n    \n    # Simulate the original problematic prompt\n    original_prompt = \"Inventory workspace skills and check system health\"\n    \n    # Create a plan generator\n    generator = PlanGenerator(original_prompt)\n    \n    # Add tasks that would be decomposed from this prompt\n    tasks = [\n        {\n            'id': 'task_01',\n            'objective': 'Inventory workspace skills',\n            'description': 'List all skills in the workspace directory',\n            'complexity_score': 2,\n            'outputs': ['skills_inventory.md']\n        },\n        {\n            'id': 'task_02',\n            'objective': 'Check system health',\n            'description': 'Check system health including agent status and resource usage',\n            'complexity_score': 3,\n            'outputs': ['system_health_report.md']\n        }\n    ]\n    \n    print(f\"Original prompt: {original_prompt}\")\n    print(f\"Decomposed into {len(tasks)} tasks:\")\n    \n    for task in tasks:\n        task_id = generator.add_task(task)\n        task_obj = next(t for t in generator.tasks if t.task_id == task_id)\n        \n        print(f\"\\nTask: {task['objective']}\")\n        print(f\"  Recommended skill: {task_obj.recommended_skill_or_role}\")\n        print(f\"  Execution mode: {task_obj.execution_mode}\")\n        print(f\"  Action type: {task_obj.action_type}\")\n        \n        # Check for the bug\n        if task['objective'].lower() == 'inventory workspace skills':\n            if task_obj.recommended_skill_or_role == 'salesforce-code-auditor':\n                print(\"  ❌ BUG STILL PRESENT: Incorrectly recommended salesforce-code-auditor\")\n            elif task_obj.recommended_skill_or_role == 'workspace-janitor':\n                print(\"  ✅ FIXED: Correctly recommended workspace-janitor\")\n            else:\n                print(f\"  ⚠ Recommendation: {task_obj.recommended_skill_or_role}\")\n        \n        if task['objective'].lower() == 'check system health':\n            if task_obj.recommended_skill_or_role == 'salesforce-code-auditor':\n                print(\"  ❌ BUG STILL PRESENT: Incorrectly recommended salesforce-code-auditor\")\n            elif task_obj.recommended_skill_or_role == 'agent-watchdog':\n                print(\"  ✅ FIXED: Correctly recommended agent-watchdog\")\n            else:\n                print(f\"  ⚠ Recommendation: {task_obj.recommended_skill_or_role}\")\n\nif __name__ == \"__main__\":\n    print(\"Verifying LPO skill recommendation fix...\")\n    print(\"=\" * 60)\n    \n    # Test the fixes\n    pg_passed, pg_failed = test_fixed_plan_generator()\n    do_passed, do_failed = test_fixed_distributed_orchestrate()\n    \n    # Test real scenario\n    test_real_delegation_scenario()\n    \n    print(\"=\" * 60)\n    print(\"Test Results:\")\n    print(f\"plan_generator.py: {pg_passed} passed, {pg_failed} failed\")\n    print(f\"distributed_orchestrate.py: {do_passed} passed, {do_failed} failed\")\n    \n    total_passed = pg_passed + do_passed\n    total_failed = pg_failed + do_failed\n    \n    if total_failed == 0:\n        print(\"\\n✅ SUCCESS: All tests passed! The bug is fixed.\")\n    else:\n        print(f\"\\n❌ FAILURE: {total_failed} tests failed. The bug may still be present.\")"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":79,"output":2052,"cacheRead":31936,"cacheWrite":0,"totalTokens":34067,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773103699693}}
