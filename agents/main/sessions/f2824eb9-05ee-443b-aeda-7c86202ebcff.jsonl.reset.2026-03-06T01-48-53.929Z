{"type":"message","id":"7c4a0b83","parentId":"8ee791e0","timestamp":"2026-03-05T20:59:34.408Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Ahora creemos un script de prueba rápido que use directamente el watchdog. Pero primero, necesito importar el módulo correctamente. Hagámoslo paso a paso.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_k2NGxZ3GkPZkYHcJAGO5lBwv","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/agent-watchdog/scripts/test_rate_limit_simple.py","content":"#!/usr/bin/env python3\nimport sys\nimport os\nsys.path.insert(0, os.path.dirname(__file__))\n\nfrom watchdog_orchestrator import AgentWatchdog\nimport time\n\ndef test_rate_limit():\n    print(\"Testing rate limiting...\")\n    watchdog = AgentWatchdog()\n    \n    # Clean cache file\n    from watchdog_orchestrator import RATE_LIMIT_CACHE_PATH\n    if RATE_LIMIT_CACHE_PATH.exists():\n        os.remove(RATE_LIMIT_CACHE_PATH)\n    \n    pattern_key = \"test|RATE_LIMIT|manual\"\n    \n    # Count initial incidents\n    from pathlib import Path\n    workspace = Path.home() / '.openclaw' / 'workspace'\n    errors_path = workspace / '.learnings' / 'ERRORS.md'\n    initial_count = 0\n    if errors_path.exists():\n        with open(errors_path, 'r', encoding='utf-8') as f:\n            content = f.read()\n            initial_count = content.count(f'### Pattern-Key: {pattern_key}')\n    \n    print(f\"Initial incidents with pattern {pattern_key}: {initial_count}\")\n    \n    # Simulate 6 incidents\n    for i in range(6):\n        incident = {\n            'pattern_key': pattern_key,\n            'timestamp': '2026-03-05T00:00:00',\n            'model': 'test-model',\n            'stall_duration': 100,\n            'recovery_level': 1,\n            'success': True,\n            'runtime_type': 'subagent',\n            'task_type': 'rate-limit-test',\n            'items_count': 0\n        }\n        print(f\"Attempting incident {i+1}...\")\n        watchdog.append_to_errors(incident, trigger_learning=False)\n        time.sleep(0.1)\n    \n    # Count final incidents\n    final_count = 0\n    if errors_path.exists():\n        with open(errors_path, 'r', encoding='utf-8') as f:\n            content = f.read()\n            final_count = content.count(f'### Pattern-Key: {pattern_key}')\n    \n    print(f\"Final incidents with pattern {pattern_key}: {final_count}\")\n    print(f\"Incidents added: {final_count - initial_count}\")\n    \n    # Check cache\n    if RATE_LIMIT_CACHE_PATH.exists():\n        import json\n        with open(RATE_LIMIT_CACHE_PATH, 'r', encoding='utf-8') as f:\n            cache = json.load(f)\n        if pattern_key in cache:\n            print(f\"Cache entries for pattern: {len(cache[pattern_key])}\")\n        else:\n            print(\"Pattern not in cache\")\n    else:\n        print(\"Cache file not created\")\n    \n    # Expected: 5 incidents added (max per hour)\n    expected_added = 5\n    actual_added = final_count - initial_count\n    \n    if actual_added == expected_added:\n        print(f\"✅ Rate limiting works: {actual_added} incidents added (6 attempted)\")\n        return True\n    else:\n        print(f\"❌ Rate limiting failed: {actual_added} incidents added, expected {expected_added}\")\n        return False\n\nif __name__ == '__main__':\n    test_rate_limit()"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-reasoner","usage":{"input":456,"output":849,"cacheRead":105856,"cacheWrite":0,"totalTokens":107161,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772744348836}}
