{"type":"message","id":"6bde9fe8","parentId":"e115d03e","timestamp":"2026-03-10T00:05:11.385Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create a trigger with both good and bad patterns:"},{"type":"toolCall","id":"call_00_HOvrfUtca5zm7OKrKcrQxZ9L","name":"write","arguments":{"path":"~/.openclaw/workspace/fixtures/real_salesforce_samples/AccountTrigger.trigger","content":"/**\n * AccountTrigger - Example trigger with mixed patterns\n */\ntrigger AccountTrigger on Account (before insert, before update, after insert, after update) {\n    \n    // BAD: Logic directly in trigger\n    if(Trigger.isBefore && Trigger.isInsert) {\n        for(Account acc : Trigger.new) {\n            // BAD: Validation logic in trigger\n            if(acc.AnnualRevenue == null) {\n                acc.AnnualRevenue.addError('Annual Revenue is required');\n            }\n            \n            // BAD: Business logic in trigger\n            if(acc.Industry == 'Technology') {\n                acc.Rating = 'Hot';\n            }\n        }\n    }\n    \n    // BAD: Recursive trigger risk\n    if(Trigger.isAfter && Trigger.isUpdate) {\n        List<Account> accountsToUpdate = new List<Account>();\n        \n        for(Account acc : Trigger.new) {\n            Account oldAcc = Trigger.oldMap.get(acc.Id);\n            \n            // BAD: Could cause recursion\n            if(acc.AnnualRevenue != oldAcc.AnnualRevenue && acc.AnnualRevenue > 1000000) {\n                acc.Description = 'Large account updated';\n                accountsToUpdate.add(acc);\n            }\n        }\n        \n        // BAD: DML in after trigger\n        if(!accountsToUpdate.isEmpty()) {\n            update accountsToUpdate;\n        }\n    }\n    \n    // GOOD: Call handler class\n    if(Trigger.isAfter && Trigger.isInsert) {\n        AccountTriggerHandler.handleAfterInsert(Trigger.new);\n    }\n}"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":110,"output":410,"cacheRead":19264,"cacheWrite":0,"totalTokens":19784,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101097804}}
{"type":"message","id":"5d704100","parentId":"6bde9fe8","timestamp":"2026-03-10T00:05:11.402Z","message":{"role":"toolResult","toolCallId":"call_00_HOvrfUtca5zm7OKrKcrQxZ9L","toolName":"write","content":[{"type":"text","text":"Successfully wrote 1462 bytes to ~/.openclaw/workspace/fixtures/real_salesforce_samples/AccountTrigger.trigger"}],"isError":false,"timestamp":1773101111395}}
{"type":"message","id":"142e2428","parentId":"5d704100","timestamp":"2026-03-10T00:05:29.757Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_00_xGnahDTBT9kQTs3rzFPflYTJ","name":"write","arguments":{"path":"~/.openclaw/workspace/fixtures/real_salesforce_samples/AccountTriggerHandler.cls","content":"/**\n * AccountTriggerHandler - GOOD pattern trigger handler\n */\npublic with sharing class AccountTriggerHandler {\n    \n    private static Boolean isRecursive = false;\n    \n    // GOOD: Static method to prevent recursion\n    public static void handleAfterInsert(List<Account> newAccounts) {\n        if(isRecursive) return;\n        \n        try {\n            isRecursive = true;\n            \n            // GOOD: Process in bulk\n            createDefaultContacts(newAccounts);\n            sendWelcomeNotifications(newAccounts);\n            \n        } catch(Exception e) {\n            // GOOD: Log error but don't fail transaction\n            System.debug('Error in AccountTriggerHandler: ' + e.getMessage() + '\\\\n' + e.getStackTraceString());\n        } finally {\n            isRecursive = false;\n        }\n    }\n    \n    // GOOD: Separate method for specific functionality\n    private static void createDefaultContacts(List<Account> accounts) {\n        List<Contact> contacts = new List<Contact>();\n        \n        for(Account acc : accounts) {\n            Contact con = new Contact();\n            con.AccountId = acc.Id;\n            con.FirstName = 'Primary';\n            con.LastName = 'Contact';\n            con.Email = 'contact@' + acc.Name.replaceAll('[^a-zA-Z0-9]', '') + '.com';\n            con.Title = 'Account Manager';\n            contacts.add(con);\n        }\n        \n        if(!contacts.isEmpty()) {\n            // GOOD: Check FLS\n            if(Schema.sObjectType.Contact.fields.AccountId.isCreateable() &&\n               Schema.sObjectType.Contact.fields.FirstName.isCreateable() &&\n               Schema.sObjectType.Contact.fields.LastName.isCreateable() &&\n               Schema.sObjectType.Contact.fields.Email.isCreateable() &&\n               Schema.sObjectType.Contact.fields.Title.isCreateable()) {\n                insert contacts;\n            }\n        }\n    }\n    \n    // GOOD: Async operation for notifications\n    @future\n    public static void sendWelcomeNotifications(List<Id> accountIds) {\n        List<Account> accounts = [SELECT Id, Name, OwnerId FROM Account WHERE Id IN :accountIds];\n        \n        // Simulate sending notifications\n        for(Account acc : accounts) {\n            // In real implementation, would create tasks or send emails\n            System.debug('Welcome notification sent for account: ' + acc.Name);\n        }\n    }\n}"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":55,"output":572,"cacheRead":19776,"cacheWrite":0,"totalTokens":20403,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101111401}}
