{"type":"message","id":"b5ed0100","parentId":"b1095385","timestamp":"2026-03-10T00:16:41.240Z","message":{"role":"toolResult","toolCallId":"call_00_QSfHKvlD1hfJy6yd8cpjCySB","toolName":"read","content":[{"type":"text","text":"/**\n * AccountController - Example with BAD patterns for testing\n * Contains SOQL in loops, missing FLS checks, poor error handling\n */\npublic with sharing class AccountController {\n    \n    // BAD: SOQL in loop\n    public static void updateAccountContacts(List<Id> accountIds) {\n        List<Account> accounts = [SELECT Id, Name FROM Account WHERE Id IN :accountIds];\n        \n        for(Account acc : accounts) {\n            // BAD: SOQL inside loop\n            List<Contact> contacts = [SELECT Id, FirstName, LastName FROM Contact WHERE AccountId = :acc.Id];\n            \n            for(Contact con : contacts) {\n                con.Description = 'Updated by AccountController';\n            }\n            \n            // BAD: DML in loop\n            update contacts;\n        }\n    }\n    \n    // BAD: Missing FLS check\n    public static Account createAccount(String name, String industry) {\n        Account acc = new Account();\n        acc.Name = name;\n        acc.Industry = industry;\n        acc.AnnualRevenue = 1000000;\n        \n\n[34 more lines in file. Use offset=31 to continue.]"}],"isError":false,"timestamp":1773101801237}}
