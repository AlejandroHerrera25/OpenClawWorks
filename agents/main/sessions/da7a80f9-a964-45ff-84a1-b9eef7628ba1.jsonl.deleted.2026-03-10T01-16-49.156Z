ning {script_name}: {e}\")\n+350     \n+351     def _load_audit_results(self, case_dir: Path) -> Dict[str, Any]:\n+352         \"\"\"Load and compile audit results from various output files.\"\"\"\n+353         audit_result = {\n+354             'executive_summary': '',\n+355             'technical_assessment': '',\n+356             'constraints_limitations': [],\n+357             'risk_assessment': {'critical': 0, 'high': 0, 'medium': 0, 'low': 0},\n+358             'recommendations_for_architecture': [],\n+359             'evidence': 'Real code analysis completed'\n+360         }\n+361         \n+362         # Try to load dependency graph\n+363         graph_file = case_dir / 'dependency_graph.json'\n+364         if graph_file.exists():\n+365             try:\n+366                 with open(graph_file, 'r') as f:\n+367                     graph_data = json.load(f)\n+368                 \n+369                 # Extract insights from dependency graph\n+370                 if 'nodes' in graph_data and 'edges' in graph_data:\n+371                     node_count = len(graph_data['nodes'])\n+372                     edge_count = len(graph_data['edges'])\n+373                     \n+374                     audit_result['executive_summary'] = f\"Analyzed {node_count} code elements with {edge_count} dependencies\"\n+375                     audit_result['technical_assessment'] = f\"Complexity score: {edge_count / max(node_count, 1):.1f} edges per node\"\n+376                     \n+377                     # Identify potential issues\n+378                     if edge_count > node_count * 3:\n+379                         audit_result['constraints_limitations'].append('High coupling detected')\n+380                         audit_result['risk_assessment']['high'] += 1\n+381                     \n+382                     if node_count > 20:\n+383                         audit_result['constraints_limitations'].append('Large codebase may have maintainability issues')\n+384         