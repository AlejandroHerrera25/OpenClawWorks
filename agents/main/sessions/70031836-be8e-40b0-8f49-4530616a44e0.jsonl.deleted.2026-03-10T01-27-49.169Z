{"type":"message","id":"d65f1f47","parentId":"0d2ffd0b","timestamp":"2026-03-10T00:31:42.723Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create the risk assessor:"},{"type":"toolCall","id":"call_00_0IhbYvl7vbAs9Mr5goiQQw1O","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/salesforce-code-auditor/scripts/risk_assessor.py","content":"#!/usr/bin/env python3\n\"\"\"\nRisk Assessor - Implement risk scoring system for audit findings.\n\"\"\"\n\nimport argparse\nimport os\nimport json\nfrom pathlib import Path\nfrom utils_fs import read_file, write_file, read_json, write_json\n\nWORKSPACE_ROOT = Path(os.getenv('WORKSPACE', '/home/openclaw/.openclaw/workspace'))\n\nclass RiskAssessor:\n    \"\"\"Assess risk levels for audit findings.\"\"\"\n    \n    # Risk patterns and their severity mappings\n    RISK_PATTERNS = {\n        # CRITICAL patterns\n        'SOQL_IN_LOOP': {\n            'severity': 'CRITICAL',\n            'category': 'Performance',\n            'description': 'SOQL query inside loop - governor limit exhaustion',\n            'impact_score': 9,\n            'likelihood_score': 7,\n            'remediation_effort': 'Medium',\n            'business_impact': 'System failure, data loss'\n        },\n        'DATA_LOSS_RISK': {\n            'severity': 'CRITICAL',\n            'category': 'Security',\n            'description': 'Risk of data loss or corruption',\n            'impact_score': 10,\n            'likelihood_score': 6,\n            'remediation_effort': 'High',\n            'business_impact': 'Data integrity compromise'\n        },\n        'UNAUTHORIZED_ACCESS': {\n            'severity': 'CRITICAL',\n            'category': 'Security',\n            'description': 'Security vulnerability allowing unauthorized access',\n            'impact_score': 10,\n            'likelihood_score': 8,\n            'remediation_effort': 'High',\n            'business_impact': 'Security breach, compliance violation'\n        },\n        \n        # HIGH patterns\n        'FLS_MISSING': {\n            'severity': 'HIGH',\n            'category': 'Security',\n            'description': 'Missing Field Level Security (FLS) or CRUD checks',\n            'impact_score': 8,\n            'likelihood_score': 9,\n            'remediation_effort': 'Low',\n            'business_impact': 'Data access control failure'\n        },\n        'RECURSION_RISK': {\n            'severity': 'HIGH',\n            'category': 'Performance',\n            'description': 'Trigger recursion without guard',\n            'impact_score': 7,\n            'likelihood_score': 8,\n            'remediation_effort': 'Low',\n            'business_impact': 'Infinite loops, governor limits'\n        },\n        'TRIGGER_NOT_BULKIFIED': {\n            'severity': 'HIGH',\n            'category': 'Performance',\n            'description': 'Trigger not handling bulk operations',\n            'impact_score': 8,\n            'likelihood_score': 9,\n            'remediation_effort': 'Medium',\n            'business_impact': 'Governor limit failures in bulk data scenarios'\n        },\n        'SOQL_INJECTION': {\n            'severity': 'HIGH',\n            'category': 'Security',\n            'description': 'SOQL injection vulnerability',\n            'impact_score': 9,\n            'likelihood_score': 6,\n            'remediation_effort': 'Medium',\n            'business_impact': 'Data exposure, unauthorized access'\n        },\n        \n        # MEDIUM patterns\n        'VIEW_STATE_BLOAT': {\n            'severity': 'MEDIUM',\n            'category': 'Performance',\n            'description': 'Large Visualforce view state',\n            'impact_score': 6,\n            'likelihood_score': 8,\n            'remediation_effort': 'Medium',\n            'business_impact': 'Poor user experience, slow page loads'\n        },\n        'VALIDATION_MISSING': {\n            'severity': 'MEDIUM',\n            'category': 'Data Quality',\n            'description': 'Missing data validation',\n            'impact_score': 5,\n            'likelihood_score': 7,\n            'remediation_effort': 'Low',\n            'business_impact': 'Data quality issues'\n        },\n        'HARDCODED_VALUES': {\n            'severity': 'MEDIUM',\n            'category': 'Maintainability',\n            'description': 'Hardcoded configuration values',\n            'impact_score': 4,\n            'likelihood_score': 9,\n            'remediation_effort': 'Low',\n            'business_impact': 'Deployment complexity, configuration errors'\n        },\n        'LONG_METHOD': {\n            'severity': 'MEDIUM',\n            'category': 'Maintainability',\n            'description': 'Method exceeds recommended length',\n            'impact_score': 3,\n            'likelihood_score': 8,\n            'remediation_effort': 'Medium',\n            'business_impact': 'Code maintainability issues'\n        },\n        \n        # LOW patterns\n        'INLINE_SCRIPT': {\n            'severity': 'LOW',\n            'category': 'Maintainability',\n            'description': 'Inline JavaScript in Visualforce',\n            'impact_score': 2,\n            'likelihood_score': 7,\n            'remediation_effort': 'Low',\n            'business_impact': 'Code organization, caching inefficiency'\n        },\n        'MISSING_COMMENTS': {\n            'severity': 'LOW',\n            'category': 'Documentation',\n            'description': 'Insufficient code comments',\n            'impact_score': 2,\n            'likelihood_score': 9,\n            'remediation_effort': 'Low',\n            'business_impact': 'Knowledge transfer challenges'\n        },\n        'CODE_STYLE_ISSUE': {\n            'severity': 'LOW',\n            'category': 'Code Quality',\n            'description': 'Code style violation',\n            'impact_score': 1,\n            'likelihood_score': 8,\n            'remediation_effort': 'Low',\n            'business_impact': 'Readability, consistency'\n        }\n    }\n    \n    def __init__(self, project_key, case_id):\n        self.project_key = project_key\n        self.case_id = case_id\n        self.case_root = WORKSPACE_ROOT / 'projects' / project_key / 'code_audit' / case_id\n        \n    def assess_findings(self):\n        \"\"\"Assess risk for all findings.\"\"\"\n        findings_path = self.case_root / 'FINDINGS_DETAILED.json'\n        if not findings_path.exists():\n            print(f\"Error: Findings not found at {findings_path}\")\n            print(\"Run findings_synthesizer.py first.\")\n            return None\n        \n        findings_data = read_json(findings_path)\n        findings = findings_data.get('findings', [])\n        \n        # Assess each finding\n        assessed_findings = []\n        for finding in findings:\n            assessed = self._assess_single_finding(finding)\n            assessed_findings.append(assessed)\n        \n        # Calculate overall risk score\n        overall_risk = self._calculate_overall_risk(assessed_findings)\n        \n        # Generate risk assessment report\n        risk_report = {\n            'metadata': findings_data.get('metadata', {}),\n            'risk_assessment': {\n                'overall_risk_score': overall_risk['score'],\n                'overall_risk_level': overall_risk['level'],\n                'risk_by_category': overall_risk['by_category'],\n                'blocking_conditions': self._identify_blocking_conditions(assessed_findings)\n            },\n            'assessed_findings': assessed_findings\n        }\n        \n        return risk_report\n    \n    def _assess_single_finding(self, finding):\n        \"\"\"Assess risk for a single finding.\"\"\"\n        pattern = finding.get('pattern', '')\n        \n        # Get pattern details or use defaults\n        if pattern in self.RISK_PATTERNS:\n            pattern_details = self.RISK_PATTERNS[pattern]\n        else:\n            # Default assessment for unknown patterns\n            pattern_details = {\n                'severity': finding.get('severity', 'MEDIUM'),\n                'category': 'Unknown',\n                'description': finding.get('description', ''),\n                'impact_score': 5,\n                'likelihood_score': 5,\n                'remediation_effort': 'Medium',\n                'business_impact': 'Unknown'\n            }\n        \n        # Calculate risk score (impact * likelihood)\n        risk_score = pattern_details['impact_score'] * pattern_details['likelihood_score']\n        \n        # Determine risk level\n        if risk_score >= 70:\n            risk_level = 'CRITICAL'\n        elif risk_score >= 50:\n            risk_level = 'HIGH'\n        elif risk_score >= 30:\n            risk_level = 'MEDIUM'\n        else:\n            risk_level = 'LOW'\n        \n        # Add assessment to finding\n        assessed = finding.copy()\n        assessed.update({\n            'risk_assessment': {\n                'pattern_details': pattern_details,\n                'risk_score': risk_score,\n                'risk_level': risk_level,\n                'impact_score': pattern_details['impact_score'],\n                'likelihood_score': pattern_details['likelihood_score'],\n                'remediation_effort': pattern_details['remediation_effort'],\n                'business_impact': pattern_details['business_impact']\n            }\n        })\n        \n        return assessed\n    \n    def _calculate_overall_risk(self, assessed_findings):\n        \"\"\"Calculate overall risk score and level.\"\"\"\n        if not assessed_findings:\n            return {\n                'score': 0,\n                'level': 'LOW',\n                'by_category': {}\n            }\n        \n        # Calculate weighted average risk score\n        total_score = 0\n        category_scores = {}\n        category_counts = {}\n        \n        for finding in assessed_findings:\n            assessment = finding.get('risk_assessment', {})\n            risk_score = assessment.get('risk_score', 0)\n            category = assessment.get('pattern_details', {}).get('category', 'Unknown')\n            \n            total_score += risk_score\n            \n            if category not in category_scores:\n                category_scores[category] = 0\n                category_counts[category] = 0\n            \n            category_scores[category] += risk_score\n            category_counts[category] += 1\n        \n        # Calculate averages\n        avg_score = total_score / len(assessed_findings)\n        \n        # Calculate category averages\n        category_averages = {}\n        for category in category_scores:\n            category_averages[category] = {\n                'average_score': category_scores[category] / category_counts[category],\n                'finding_count': category_counts[category],\n                'percentage': (category_counts[category] / len(assessed_findings)) * 100\n            }\n        \n        # Determine overall risk level\n        if avg_score >= 70:\n            risk_level = 'CRITICAL'\n        elif avg_score >= 50:\n            risk_level = 'HIGH'\n        elif avg_score >= 30:\n            risk_level = 'MEDIUM'\n        else:\n            risk_level = 'LOW'\n        \n        return {\n            'score': round(avg_score, 2),\n            'level': risk_level,\n            'by_category': category_averages\n        }\n    \n    def _identify_blocking_conditions(self, assessed_findings):\n        \"\"\"Identify findings that block architectural finalization.\"\"\"\n        blocking_conditions = {\n            'critical_blockers': [],\n            'high_blockers': [],\n            'requires_architect_review': [],\n            'non_blocking': []\n        }\n        \n        for finding in assessed_findings:\n            assessment = finding.get('risk_assessment', {})\n            risk_level = assessment.get('risk_level', '')\n            pattern = finding.get('pattern', '')\n            \n            # CRITICAL findings always block\n            if risk_level == 'CRITICAL':\n                blocking_conditions['critical_blockers'].append({\n                    'pattern': pattern,\n                    'file': finding.get('file', ''),\n                    'line': finding.get('line', ''),\n                    'description': finding.get('description', '')\n                })\n            \n            # HIGH findings may block depending on context\n            elif risk_level == 'HIGH':\n                # Security-related HIGH findings typically block\n                if any(sec_pattern in pattern for sec_pattern in ['FLS', 'INJECTION', 'ACCESS']):\n                    blocking_conditions['critical_blockers'].append({\n                        'pattern': pattern,\n                        'file': finding.get('file', ''),\n                        'line': finding.get('line', ''),\n                        'description': finding.get('description', ''),\n                        'note': 'Security-related HIGH finding'\n                    })\n                else:\n                    blocking_conditions['high_blockers'].append({\n                        'pattern': pattern,\n                        'file': finding.get('file', ''),\n                        'line': finding.get('line', ''),\n                        'description': finding.get('description', '')\n                    })\n            \n            # MEDIUM findings may require architect review\n            elif risk_level == 'MEDIUM':\n                blocking_conditions['requires_architect_review'].append({\n                    'pattern': pattern,\n                    'file': finding.get('file', ''),\n                    'line': finding.get('line', ''),\n                    'description': finding.get('description', '')\n                })\n            \n            # LOW findings are non-blocking\n            else:\n                blocking_conditions['non_blocking'].append({\n                    'pattern': pattern,\n                    'file': finding.get('file', ''),\n                    'line': finding.get('line', ''),\n                    'description': finding.get('description', '')\n                })\n        \n        return blocking_conditions\n    \n    def generate_risk_report(self, risk_assessment):\n        \"\"\"Generate markdown risk assessment report.\"\"\"\n        report = \"# Risk Assessment Report\\n\\n\"\n        \n        # Executive Summary\n        overall = risk_assessment['risk_assessment']['overall_risk']\n        report += f\"## Executive Summary\\n\"\n        report += f\"- **Overall Risk Level**: {overall['level']}\\n\"\n        report += f\"- **Overall Risk Score**: {overall['score']}/100\\n\"\n        report += f\"- **Total Findings**: {risk_assessment['metadata']['total_findings']}\\n\"\n        report += f\"- **Critical Findings**: {risk_assessment['metadata']['severity_counts']['CRITICAL']}\\n\"\n        report += f\"- **High Findings**: {risk_assessment['metadata']['severity_counts']['HIGH']}\\n\\n\"\n        \n        # Risk by Category\n        report += \"## Risk by Category\\n\\n\"\n        for category, stats in overall['by_category'].items():\n            report += f\"### {category}\\n\"\n            report += f\"- **Average Risk Score**: {stats['average_score']:.1f}/100\\n\"\n            report += f\"- **Finding Count**: {stats['finding_count']}\\n\"\n            report += f\"- **Percentage of Total**: {stats['percentage']:.1f}%\\n\\n\"\n        \n        # Blocking Conditions\n        blockers = risk_assessment['risk_assessment']['blocking_conditions']\n        report += \"## Blocking Conditions Analysis\\n\\n\"\n        \n        if blockers['critical_blockers']:\n            report += \"### ❌ CRITICAL Blockers (Must be addressed)\\n\"\n            for blocker in blockers['critical_blockers']:\n                report += f\"- **{blocker['pattern']}** in `{blocker['file']}:{blocker['line']}`\\n\"\n                report += f\"  - {blocker['description']}\\n\"\n                if 'note' in blocker:\n                    report += f\"  - *Note: {blocker['note']}*\\n\"\n            report += \"\\n\"\n        \n        if blockers['high_blockers']:\n            report += \"### ⚠️ HIGH Blockers (Should be addressed)\\n\"\n            for blocker in blockers['high_blockers']:\n                report += f\"- **{blocker['pattern']}** in `{blocker['file']}:{blocker['line']}`\\n\"\n                report += f\"  - {blocker['description']}\\n\"\n            report += \"\\n\"\n        \n        if blockers['requires_architect_review']:\n            report += \"### 🔍 Requires Architect Review\\n\"\n            report += \"These findings should be reviewed by the architect for impact assessment:\\n\"\n            for item in blockers['requires_architect_review']:\n                report += f\"- **{item['pattern']}** in `{item['file']}:{item['line']}`\\n\"\n            report += \"\\n\"\n        \n        # Detailed Findings with Risk Assessment\n        report += \"## Detailed Risk Assessment\\n\\n\"\n        \n        for finding in risk_assessment['assessed_findings']:\n            assessment = finding['risk_assessment']\n            pattern_details = assessment['pattern_details']\n            \n            report += f\"### {finding['pattern']} - {assessment['risk_level']} Risk\\n\"\n            report += f\"- **Location**: `{finding['file']}:{finding['line']}`\\n\"\n            report += f\"- **Category**: {pattern_details['category']}\\n\"\n            report += f\"- **Risk Score**: {assessment['risk_score']}/100 \"\n            report += f\"(Impact: {assessment['impact_score']}/10, Likelihood: {assessment['likelihood_score']}/10)\\n\"\n            report += f\"- **Remediation Effort**: {assessment['remediation_effort']}\\n\"\n            report += f\"- **Business Impact**: {assessment['business_impact']}\\n\"\n            report += f\"- **Description**: {finding['description']}\\n\"\n            report += f\"- **Recommendation**: {finding['recommendation']}\\n\"\n            report += f\"- **Code Snippet**:\\n```\\n{finding['code_snippet']}\\n```\\n\\n\"\n        \n        write_file(self.case_root / 'RISK_ASSESSMENT.md', report)\n        print(f\"Written risk assessment to {self.case_root / 'RISK_ASSESSMENT.md'}\")\n        \n        # Also save as JSON for programmatic access\n        write_json(self.case_root / 'RISK_ASSESSMENT.json', risk_assessment)\n        print(f\"Written risk assessment JSON to {self.case_root / 'RISK_ASSESSMENT.json'}\")\n        \n        return report\n\ndef main():\n    parser = argparse.ArgumentParser(description='Assess risk for audit findings.')\n    parser.add_argument('--project-key', required=True, help='Project identifier')\n    parser.add_argument('--case-id', required=True, help='Case identifier')\n    args = parser.parse_args()\n    \n    assessor = RiskAssessor(args.project_key, args.case_id)\n    risk_assessment = assessor.assess_findings()\n    \n    if risk_assessment:\n        assessor.generate_risk_report(risk_assessment)\n        \n        # Print summary\n        overall = risk_assessment['risk_assessment']['overall_risk']\n        blockers = risk_ass"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":100,"output":4096,"cacheRead":29952,"cacheWrite":0,"totalTokens":34148,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"length","timestamp":1773102577977}}
