{"type":"message","id":"f5ec72b5","parentId":"1584f80e","timestamp":"2026-03-10T00:48:07.555Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create a test script to demonstrate the end-to-end functionality:"},{"type":"toolCall","id":"call_00_dc3cGOxwS2N490vg106C1Bdo","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/salesforce-code-auditor/test_reporting_layer.py","content":"#!/usr/bin/env python3\n\"\"\"\nTest script to demonstrate the complete Salesforce Code Auditor reporting layer.\nThis shows end-to-end functionality from code analysis to architect report.\n\"\"\"\n\nimport os\nimport sys\nimport json\nfrom pathlib import Path\nfrom datetime import datetime\n\nWORKSPACE_ROOT = Path(os.getenv('WORKSPACE', '/home/openclaw/.openclaw/workspace'))\nSKILL_DIR = WORKSPACE_ROOT / 'skills' / 'salesforce-code-auditor'\n\ndef run_test():\n    \"\"\"Run complete reporting layer test.\"\"\"\n    print(\"=\"*70)\n    print(\"SALESFORCE CODE AUDITOR - REPORTING LAYER TEST\")\n    print(\"=\"*70)\n    print(f\"Test Date: {datetime.now().isoformat()}\")\n    print(f\"Skill Directory: {SKILL_DIR}\")\n    print(\"=\"*70)\n    \n    # Test case\n    project_key = \"test_report\"\n    case_id = f\"test_{datetime.now().strftime('%Y%m%d_%H%M%S')}\"\n    \n    print(f\"\\n1. Creating test case: {project_key}/{case_id}\")\n    \n    # Create test case directory structure\n    case_root = WORKSPACE_ROOT / 'projects' / project_key / 'code_audit' / case_id\n    case_root.mkdir(parents=True, exist_ok=True)\n    \n    # Create minimal test data\n    _create_test_data(case_root)\n    \n    print(f\"   Created: {case_root}\")\n    \n    # Test findings synthesis\n    print(\"\\n2. Testing Findings Synthesis\")\n    findings = _test_findings_synthesis(case_root, project_key, case_id)\n    \n    if findings:\n        print(f\"   ✓ Generated {len(findings['findings'])} findings\")\n        for f in findings['findings']:\n            print(f\"     - {f['severity']}: {f['pattern']} in {f['file']}:{f['line']}\")\n    else:\n        print(\"   ✗ Findings synthesis failed\")\n        return False\n    \n    # Test risk assessment\n    print(\"\\n3. Testing Risk Assessment\")\n    risk = _test_risk_assessment(case_root, project_key, case_id)\n    \n    if risk:\n        overall = risk['risk_assessment']['overall_risk']\n        print(f\"   ✓ Overall Risk: {overall['level']} ({overall['score']}/100)\")\n        blockers = risk['risk_assessment']['blocking_conditions']\n        print(f\"   ✓ Critical Blockers: {len(blockers['critical_blockers'])}\")\n        print(f\"   ✓ High Blockers: {len(blockers['high_blockers'])}\")\n    else:\n        print(\"   ✗ Risk assessment failed\")\n        return False\n    \n    # Test report generation for all modes\n    print(\"\\n4. Testing Report Generation\")\n    \n    modes = ['A', 'B', 'C']\n    reports = {}\n    \n    for mode in modes:\n        report = _test_report_generation(case_root, project_key, case_id, mode)\n        if report:\n            reports[mode] = report\n            print(f\"   ✓ Mode {mode}: Generated {len(report)} characters\")\n        else:\n            print(f\"   ✗ Mode {mode}: Failed\")\n            return False\n    \n    # Summary\n    print(\"\\n\" + \"=\"*70)\n    print(\"TEST RESULTS SUMMARY\")\n    print(\"=\"*70)\n    print(f\"Test Case: {project_key}/{case_id}\")\n    print(f\"Findings Generated: {len(findings['findings'])}\")\n    print(f\"Risk Assessment: {overall['level']} ({overall['score']}/100)\")\n    print(f\"Reports Generated: {len(reports)} modes (A, B, C)\")\n    print(f\"Files Created in: {case_root}\")\n    print(\"\\nGenerated Files:\")\n    \n    for file in case_root.glob(\"*\"):\n        if file.is_file():\n            size = file.stat().st_size\n            print(f\"  • {file.name} ({size} bytes)\")\n    \n    print(\"\\n\" + \"=\"*70)\n    print(\"✅ REPORTING LAYER TEST PASSED\")\n    print(\"=\"*70)\n    print(\"\\nThe Salesforce Code Auditor reporting layer is fully functional:\")\n    print(\"1. ✓ Findings synthesis converts dependencies → specific findings\")\n    print(\"2. ✓ Risk assessment scores findings and identifies blockers\")\n    print(\"3. ✓ Report generation produces architect-consumable outputs\")\n    print(\"4. ✓ All handoff modes (A, B, C) supported\")\n    print(\"5. ✓ Real code locations and actionable recommendations\")\n    print(\"\\nThe skill is now ready for production use with the salesforce-architect.\")\n    \n    return True\n\ndef _create_test_data(case_root):\n    \"\"\"Create minimal test data.\"\"\"\n    # Create manifest\n    manifest = {\n        \"project_key\": \"test_report\",\n        \"case_id\": case_root.name,\n        \"total_files\": 3,\n        \"created_at\": datetime.now().isoformat()\n    }\n    \n    (case_root / 'MANIFEST.json').write_text(json.dumps(manifest, indent=2))\n    \n    # Create dependency graph\n    graph = {\n        \"nodes\": [\n            {\"id\": 0, \"path\": \"TestController.cls\", \"type\": \"apex\", \"name\": \"TestController\"},\n            {\"id\": 1, \"path\": \"TestPage.page\", \"type\": \"vf_page\", \"name\": \"TestPage\"},\n            {\"id\": 2, \"path\": \"TestTrigger.trigger\", \"type\": \"trigger\", \"name\": \"TestTrigger\"}\n        ],\n        \"edges\": [\n            {\"from\": 1, \"to\": 0, \"type\": \"controller\"},\n            {\"from\": 0, \"to\": 2, \"type\": \"dml\"}\n        ]\n    }\n    \n    (case_root / 'DEPENDENCY_GRAPH.json').write_text(json.dumps(graph, indent=2))\n    \n    # Create entrypoints\n    entrypoints = {\n        \"entrypoints\": [\n            {\n                \"type\": \"vf_page\",\n                \"file\": \"TestPage.page\",\n                \"controller\": \"TestController\"\n            }\n        ]\n    }\n    \n    (case_root / 'ENTRYPOINTS.json').write_text(json.dumps(entrypoints, indent=2))\n    \n    # Create inputs directory with sample code\n    inputs_dir = case_root / 'inputs'\n    inputs_dir.mkdir(exist_ok=True)\n    \n    # Sample Apex class with issues\n    apex_code = \"\"\"public class TestController {\n    public void saveData() {\n        // Missing FLS check - HIGH severity\n        Account acc = new Account(Name='Test');\n        insert acc;\n        \n        // SOQL in loop - CRITICAL severity\n        for (Integer i = 0; i < 10; i++) {\n            List<Account> accounts = [SELECT Id FROM Account LIMIT 10];\n        }\n    }\n}\"\"\"\n    \n    (inputs_dir / 'TestController.cls').write_text(apex_code)\n    \n    # Sample trigger with issues\n    trigger_code = \"\"\"trigger TestTrigger on Account (before insert) {\n    // No recursion guard - HIGH severity\n    for (Account acc : Trigger.new) {\n        acc.Name = acc.Name + ' Processed';\n    }\n    \n    // Missing validation - MEDIUM severity\n    // Should validate data before insert\n}\"\"\"\n    \n    (inputs_dir / 'TestTrigger.trigger').write_text(trigger_code)\n\ndef _test_findings_synthesis(case_root, project_key, case_id):\n    \"\"\"Test findings synthesis.\"\"\"\n    sys.path.append(str(SKILL_DIR / 'scripts'))\n    \n    try:\n        from findings_synthesizer import FindingsSynthesizer\n        \n        synthesizer = FindingsSynthesizer(project_key, case_id)\n        if synthesizer.load_dependencies():\n            synthesizer.analyze_code_patterns()\n            findings = synthesizer.generate_findings_report()\n            return findings\n    except Exception as e:\n        print(f\"   Error: {e}\")\n        return None\n\ndef _test_risk_assessment(case_root, project_key, case_id):\n    \"\"\"Test risk assessment.\"\"\"\n    sys.path.append(str(SKILL_DIR / 'scripts'))\n    \n    try:\n        from risk_assessor import RiskAssessor\n        \n        assessor = RiskAssessor(project_key, case_id)\n        risk = assessor.assess_findings()\n        if risk:\n            assessor.generate_risk_report(risk)\n            return risk\n    except Exception as e:\n        print(f\"   Error: {e}\")\n        return None\n\ndef _test_report_generation(case_root, project_key, case_id, mode):\n    \"\"\"Test report generation.\"\"\"\n    sys.path.append(str(SKILL_DIR / 'scripts'))\n    \n    try:\n        from report_generator import generate_report\n        \n        report = generate_report(project_key, case_id, mode)\n        \n        # Save report\n        report_file = case_root / f'TEST_REPORT_MODE_{mode}.md'\n        report_file.write_text(report)\n        \n        return report\n    except Exception as e:\n        print(f\"   Error: {e}\")\n        return None\n\nif __name__ == '__main__':\n    success = run_test()\n    sys.exit(0 if success else 1)"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":100,"output":2080,"cacheRead":69568,"cacheWrite":0,"totalTokens":71748,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773103620391}}
