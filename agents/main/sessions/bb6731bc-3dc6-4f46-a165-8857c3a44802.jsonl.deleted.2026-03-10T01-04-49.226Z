{"type":"message","id":"aa51c56e","parentId":"5ca689bf","timestamp":"2026-03-10T00:06:39.675Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create a test project and try to invoke the real integration:"},{"type":"toolCall","id":"call_00_4WldlC0qxNpILA9E2TckxfnW","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/test_integration_project.py","content":"#!/usr/bin/env python3\n\"\"\"\nTest real integration between Salesforce Architect and Code Auditor.\nThis test creates a real project and attempts to invoke the auditor.\n\"\"\"\n\nimport os\nimport sys\nimport tempfile\nimport json\nfrom pathlib import Path\n\n# Add script directories to path\nsys.path.insert(0, '/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts')\n\ntry:\n    from auditor_integration import AuditorIntegration, invoke_auditor_with_control\n    print(\"✅ AuditorIntegration module imported successfully\")\nexcept ImportError as e:\n    print(f\"❌ Failed to import AuditorIntegration: {e}\")\n    sys.exit(1)\n\ndef test_real_integration():\n    \"\"\"Test real integration flow.\"\"\"\n    \n    print(\"\\n🧪 Testing REAL Architect ↔ Auditor Integration\")\n    print(\"=\" * 60)\n    \n    # Create a real project directory in workspace\n    workspace_root = Path('/home/openclaw/.openclaw/workspace')\n    test_project_dir = workspace_root / 'projects' / 'test_integration_real'\n    test_project_dir.mkdir(parents=True, exist_ok=True)\n    \n    print(f\"Test project directory: {test_project_dir}\")\n    \n    try:\n        # Test 1: Initialize AuditorIntegration with real project\n        print(\"\\n1️⃣ Initializing AuditorIntegration with real project...\")\n        try:\n            integration = AuditorIntegration(test_project_dir)\n            print(\"  ✅ AuditorIntegration initialized\")\n            \n            # Check if code auditor skill exists\n            code_auditor_dir = workspace_root / 'skills' / 'salesforce-code-auditor'\n            if code_auditor_dir.exists():\n                print(f\"  ✅ Code auditor skill found at: {code_auditor_dir}\")\n            else:\n                print(f\"  ⚠️ Code auditor skill not found at: {code_auditor_dir}\")\n                \n        except Exception as e:\n            print(f\"  ❌ AuditorIntegration initialization failed: {e}\")\n            return False\n        \n        # Test 2: Invoke real Mode A audit\n        print(\"\\n2️⃣ Invoking real Mode A audit...\")\n        try:\n            result = integration.invoke_auditor(\n                mode='A',\n                audit_objectives=[\n                    'Test real integration between architect and auditor',\n                    'Validate data flow between components'\n                ],\n                scope={\n                    'included': ['integration_testing'],\n                    'excluded': [],\n                    'depth': 'integration_validation'\n                },\n                context={\n                    'test_purpose': 'Validate real integration',\n                    'integration_test': True\n                }\n            )\n            \n            print(f\"  ✅ Audit invoked successfully\")\n            print(f\"    Case ID: {result['case_id']}\")\n            print(f\"    Mode: {result['mode']}\")\n            print(f\"    Validation Status: {result['validation_result']['validation_status']}\")\n            print(f\"    Compliance: {result['validation_result']['compliance_percentage']}%\")\n            \n            # Check if audit directory was created\n            audit_dir = test_project_dir / 'code_audit' / result['case_id']\n            if audit_dir.exists():\n                print(f\"  ✅ Audit directory created: {audit_dir}\")\n                \n                # Check for audit artifacts\n                request_file = audit_dir / 'audit_request.json'\n                result_file = audit_dir / 'audit_result.json'\n                \n                if request_file.exists():\n                    print(f\"  ✅ Audit request saved: {request_file}\")\n                    \n                    # Read and display audit request\n                    with open(request_file, 'r') as f:\n                        request_data = json.load(f)\n                    print(f\"    Project: {request_data.get('project')}\")\n                    print(f\"    Mode: {request_data.get('mode')}\")\n                    print(f\"    Objectives: {request_data.get('audit_objectives')}\")\n                    \n                if result_file.exists():\n                    print(f\"  ✅ Audit result saved: {result_file}\")\n                    \n            else:\n                print(f\"  ⚠️ Audit directory not created: {audit_dir}\")\n                \n        except Exception as e:\n            print(f\"  ❌ Audit invocation failed: {e}\")\n            import traceback\n            traceback.print_exc()\n            return False\n        \n        # Test 3: Check project control integration\n        print(\"\\n3️⃣ Checking project control integration...\")\n        try:\n            # Check if project control was updated\n            control_file = test_project_dir / '.project_control.yaml'\n            if control_file.exists():\n                print(f\"  ✅ Project control file exists: {control_file}\")\n                \n                # Try to read project control\n                import yaml\n                with open(control_file, 'r') as f:\n                    control_data = yaml.safe_load(f)\n                \n                if control_data and 'code_audits' in control_data:\n                    audits = control_data['code_audits']\n                    print(f\"  ✅ Found {len(audits)} audit(s) in project control\")\n                    \n                    # Find our audit\n                    for audit in audits:\n                        if audit.get('case_id') == result['case_id']:\n                            print(f\"  ✅ Our audit found in project control\")\n                            print(f\"    Status: {audit.get('status')}\")\n                            print(f\"    Findings: {audit.get('findings_summary', 'N/A')}\")\n                            break\n                else:\n                    print(f\"  ⚠️ No audits found in project control\")\n            else:\n                print(f\"  ⚠️ Project control file not found: {control_file}\")\n                \n        except Exception as e:\n            print(f\"  ⚠️ Project control check failed (may be expected): {e}\")\n        \n        # Test 4: Check if real auditor scripts exist\n        print(\"\\n4️⃣ Checking real auditor scripts...\")\n        try:\n            code_auditor_scripts = workspace_root / 'skills' / 'salesforce-code-auditor' / 'scripts'\n            if code_auditor_scripts.exists():\n                print(f\"  ✅ Code auditor scripts directory exists\")\n                \n                # Check for key scripts\n                scripts_to_check = ['init_case.py', 'index_inputs.py', 'generate_reports.py']\n                for script in scripts_to_check:\n                    script_path = code_auditor_scripts / script\n                    if script_path.exists():\n                        print(f\"    ✅ {script} exists\")\n                    else:\n                        print(f\"    ⚠️ {script} not found\")\n            else:\n                print(f\"  ⚠️ Code auditor scripts directory not found\")\n                \n        except Exception as e:\n            print(f\"  ⚠️ Script check failed: {e}\")\n        \n        # Test 5: Test convenience function\n        print(\"\\n5️⃣ Testing convenience function...\")\n        try:\n            result2 = invoke_auditor_with_control(\n                test_project_dir,\n                mode='B',\n                audit_objectives=['Test convenience function'],\n                scope={'included': ['convenience_test']},\n                context={'test': 'convenience_function'}\n            )\n            \n            print(f\"  ✅ Convenience function executed\")\n            print(f\"    Case ID: {result2['case_id']}\")\n            print(f\"    Mode: {result2['mode']}\")\n            \n        except Exception as e:\n            print(f\"  ❌ Convenience function failed: {e}\")\n            return False\n        \n        print(\"\\n\" + \"=\" * 60)\n        print(\"📊 REAL INTEGRATION TEST RESULTS\")\n        print(\"=\" * 60)\n        \n        # Determine integration classification\n        audit_dir_created = (test_project_dir / 'code_audit' / result['case_id']).exists()\n        audit_request_saved = (test_project_dir / 'code_audit' / result['case_id'] / 'audit_request.json').exists()\n        project_control_updated = (test_project_dir / '.project_control.yaml').exists()\n        code_auditor_exists = (workspace_root / 'skills' / 'salesforce-code-auditor').exists()\n        \n        print(f\"Audit directory created: {'✅ Yes' if audit_dir_created else '❌ No'}\")\n        print(f\"Audit request saved: {'✅ Yes' if audit_request_saved else '❌ No'}\")\n        print(f\"Project control updated: {'✅ Yes' if project_control_updated else '❌ No'}\")\n        print(f\"Code auditor skill exists: {'✅ Yes' if code_auditor_exists else '❌ No'}\")\n        \n        # Classification logic\n        if audit_dir_created and audit_request_saved and project_control_updated:\n            print(\"\\n🎉 INTEGRATION CLASSIFICATION: FUNCTIONAL\")\n            print(\"   - Real data flow between components\")\n            print(\"   - Project routing preserved\")\n            print(\"   - Artifact containment verified\")\n        elif audit_dir_created or audit_request_saved:\n            print(\"\\n⚠️ INTEGRATION CLASSIFICATION: PARTIAL\")\n            print(\"   - Some integration works but gaps exist\")\n            print(\"   - May be missing full data flow\")\n        else:\n            print(\"\\n❌ INTEGRATION CLASSIFICATION: SIMULATED\")\n            print(\"   - No real data flow\")\n            print(\"   - Integration exists only in documentation\")\n        \n        # Save test evidence\n        evidence_dir = test_project_dir / 'integration_test_evidence'\n        evidence_dir.mkdir(exist_ok=True)\n        \n        with open(evidence_dir / 'test_results.json', 'w') as f:\n            json.dump({\n                'audit_dir_created': audit_dir_created,\n                'audit_request_saved': audit_request_saved,\n                'project_control_updated': project_control_updated,\n                'code_auditor_exists': code_auditor_exists,\n                'test_timestamp': '2026-03-09T19:10:00Z',\n                'integration_classification': 'FUNCTIONAL' if audit_dir_created and audit_request_saved and project_control_updated else 'PARTIAL' if audit_dir_created or audit_request_saved else 'SIMULATED'\n            }, f, indent=2)\n        \n        print(f\"\\n📁 Test evidence saved to: {evidence_dir}\")\n        \n        return True\n        \n    except Exception as e:\n        print(f\"\\n❌ Test failed with unexpected error: {e}\")\n        import traceback\n        traceback.print_exc()\n        return False\n\nif __name__ == '__main__':\n    success = test_real_integration()\n    \n    # Keep test project for inspection\n    print(f\"\\n📁 Test project kept for inspection at: /home/openclaw/.openclaw/workspace/projects/test_integration_real\")\n    \n    sys.exit(0 if success else 1)"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":39,"output":2364,"cacheRead":33728,"cacheWrite":0,"totalTokens":36131,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101129824}}
