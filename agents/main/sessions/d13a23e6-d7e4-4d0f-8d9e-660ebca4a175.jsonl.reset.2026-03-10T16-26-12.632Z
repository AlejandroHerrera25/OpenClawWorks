{"type":"message","id":"8d4b32f9","parentId":"8aa2239f","timestamp":"2026-03-09T17:32:02.511Z","message":{"role":"toolResult","toolCallId":"call_00_ixytaWqPeS5ppBGYj2PAoWuO","toolName":"read","content":[{"type":"text","text":"    return matched\n\ndef emit_incident(pattern_key, symptom, evidence='', severity='S2'):\n    \"\"\"\n    Append an incident to workspace/.learnings/ERRORS.md using the unified emitter.\n    \"\"\"\n    # Add error-learning-loop scripts to path\n    script_dir = WORKSPACE_ROOT / 'skills' / 'error-learning-loop' / 'scripts'\n    if script_dir not in sys.path:\n        sys.path.insert(0, str(script_dir))\n    try:\n        from emit_incident import emit_incident as unified_emit\n    except ImportError as e:\n        logger.error('Failed to import unified emitter: %s', e)\n        # Fallback to old method (should not happen in production)\n        errors_file = WORKSPACE_ROOT / '.learnings' / 'ERRORS.md'\n        ensure_dir(errors_file.parent)\n        timestamp = subprocess.run(['date', '-Iseconds'], capture_output=True, text=True).stdout.strip()\n        session_id = os.environ.get('SESSION_ID', 'unknown')\n        entry = f\"\"\"\n## {timestamp} | session:{session_id}\n- Pattern: `{pattern_key}`\n- Symptom: {symptom}\n- Evidence: {evidence}\n- Severity: {severity}\n\"\"\"\n        with open(errors_file, 'a', encoding='utf-8') as f:\n            f.write(entry)\n        logger.warning('Incident emitted via fallback: %s', pattern_key)\n        return\n\n    # Map parameters\n    source_skill = 'salesforce-architect'\n    description = symptom\n    # Call unified emitter\n    success = unified_emit(\n        pattern_key=pattern_key,\n        severity=severity,\n        source_skill=source_skill,\n        description=description,\n        evidence=evidence,\n        incident_type=None,  # let the emitter default to 'INCIDENT'\n        trigger_learning=True,\n        base_dir=WORKSPACE_ROOT\n    )\n    if success:\n        logger.warning('Incident emitted via unified emitter: %s', pattern_key)\n    else:\n        logger.error('Unified emitter failed for pattern: %s', pattern_key)\n\ndef validate_inputs(inputs):\n    \"\"\"\n    Validate mandatory inputs for Stage 0.\n    Returns list of missing fields.\n    \"\"\"\n    mandatory = [\n        'project_name',\n        'industry',\n        'country',\n        'salesforce_clouds_licensed',\n        'user_count',\n        'process_description',\n        'implementation_scope'\n    ]\n    missing = []\n    for field in mandatory:\n        if field not in inputs or not inputs[field]:\n            missing.append(field)\n    return missing\n\nif __name__ == '__main__':\n    # Quick test\n    check_references()\n    print('All references present.')"}],"isError":false,"timestamp":1773077522474}}
