{"type":"message","id":"642ae482","parentId":"aa53314d","timestamp":"2026-03-09T18:44:13.117Z","message":{"role":"assistant","content":[{"type":"text","text":"Ahora voy a crear un motor de state machine robusto:"},{"type":"toolCall","id":"call_00_EExDt6dtkIx67JVdUBhUU7Ug","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/state_machine_engine.py","content":"#!/usr/bin/env python3\n\"\"\"\nState Machine Engine for Salesforce Projects.\nRobust validation of phase transitions and state management.\n\"\"\"\n\nimport os\nimport sys\nimport yaml\nimport logging\nfrom pathlib import Path\nfrom datetime import datetime\nfrom enum import Enum\nfrom typing import Dict, List, Optional, Tuple, Set\n\n# Configure logging\nlogging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')\nlogger = logging.getLogger(__name__)\n\nclass State(Enum):\n    \"\"\"Project state enumeration.\"\"\"\n    DISCOVERY = \"DISCOVERY\"\n    REQUIREMENTS = \"REQUIREMENTS\"\n    FIT_GAP = \"FIT_GAP\"\n    DESIGN = \"DESIGN\"\n    DATA_MODEL = \"DATA_MODEL\"\n    ARCH_REVIEW = \"ARCH_REVIEW\"\n    CODE_AUDIT = \"CODE_AUDIT\"\n    REMEDIATION = \"REMEDIATION\"\n    FINALIZED = \"FINALIZED\"\n\nclass StateMachineEngine:\n    \"\"\"Robust state machine engine for Salesforce projects.\"\"\"\n    \n    def __init__(self, project_root: Path):\n        self.project_root = Path(project_root)\n        self.state_definitions = None\n        self.current_state = None\n        self.state_history = []\n        \n        # Load state machine definition\n        self._load_state_machine()\n        \n        # Detect current state\n        self._detect_current_state()\n    \n    def _load_state_machine(self):\n        \"\"\"Load state machine definition from YAML.\"\"\"\n        state_machine_path = Path(__file__).parent.parent / 'references' / 'state_machine.yaml'\n        \n        if not state_machine_path.exists():\n            logger.error('State machine definition not found: %s', state_machine_path)\n            raise FileNotFoundError(f'State machine definition not found: {state_machine_path}')\n        \n        with open(state_machine_path, 'r', encoding='utf-8') as f:\n            self.state_definitions = yaml.safe_load(f)\n        \n        logger.info('State machine loaded with %d states', len(self.state_definitions.get('states', {})))\n    \n    def _detect_current_state(self):\n        \"\"\"Detect current project state from artifacts and README.\"\"\"\n        # First check README\n        readme_state = self._get_state_from_readme()\n        if readme_state:\n            self.current_state = State(readme_state)\n            logger.info('Current state from README: %s', self.current_state.value)\n            return\n        \n        # Fallback: detect from artifacts\n        artifact_state = self._detect_state_from_artifacts()\n        if artifact_state:\n            self.current_state = State(artifact_state)\n            logger.info('Current state from artifacts: %s', self.current_state.value)\n        else:\n            self.current_state = State.DISCOVERY\n            logger.info('No state detected, defaulting to: %s', self.current_state.value)\n    \n    def _get_state_from_readme(self) -> Optional[str]:\n        \"\"\"Extract current state from project README.\"\"\"\n        readme_path = self.project_root / 'README.md'\n        if not readme_path.exists():\n            return None\n        \n        try:\n            content = readme_path.read_text(encoding='utf-8')\n            for line in content.split('\\n'):\n                if line.startswith('## Current State:'):\n                    state_str = line.split(':', 1)[1].strip()\n                    # Validate it's a known state\n                    try:\n                        State(state_str)\n                        return state_str\n                    except ValueError:\n                        logger.warning('Invalid state in README: %s', state_str)\n                        return None\n        except Exception as e:\n            logger.error('Error reading README: %s', e)\n        \n        return None\n    \n    def _detect_state_from_artifacts(self) -> Optional[str]:\n        \"\"\"Detect state based on artifacts present.\"\"\"\n        artifact_checks = [\n            (State.FINALIZED, self._has_finalized_artifacts),\n            (State.REMEDIATION, self._has_remediation_artifacts),\n            (State.CODE_AUDIT, self._has_code_audit_artifacts),\n            (State.ARCH_REVIEW, self._has_arch_review_artifacts),\n            (State.DATA_MODEL, self._has_data_model_artifacts),\n            (State.DESIGN, self._has_design_artifacts),\n            (State.FIT_GAP, self._has_fit_gap_artifacts),\n            (State.REQUIREMENTS, self._has_requirements_artifacts),\n            (State.DISCOVERY, self._has_discovery_artifacts),\n        ]\n        \n        for state, check_func in artifact_checks:\n            if check_func():\n                return state.value\n        \n        return None\n    \n    def _has_discovery_artifacts(self) -> bool:\n        \"\"\"Check if discovery artifacts exist.\"\"\"\n        discovery_dir = self.project_root / 'discovery'\n        if not discovery_dir.exists():\n            return False\n        \n        # Check for any discovery files\n        return any(discovery_dir.iterdir())\n    \n    def _has_requirements_artifacts(self) -> bool:\n        \"\"\"Check if requirements artifacts exist.\"\"\"\n        # Requirements might be in discovery or separate directory\n        discovery_dir = self.project_root / 'discovery'\n        if discovery_dir.exists():\n            # Check for requirements files\n            req_files = ['Discovery_QA.xlsx', 'requirements.json', 'requirements.md']\n            for file in req_files:\n                if (discovery_dir / file).exists():\n                    return True\n        \n        return False\n    \n    def _has_fit_gap_artifacts(self) -> bool:\n        \"\"\"Check if fit/gap artifacts exist.\"\"\"\n        fit_gap_dir = self.project_root / 'fit_gap'\n        if not fit_gap_dir.exists():\n            return False\n        \n        # Check for fit/gap matrix\n        return any(f.name.startswith('Fit_Gap') for f in fit_gap_dir.iterdir())\n    \n    def _has_design_artifacts(self) -> bool:\n        \"\"\"Check if design artifacts exist.\"\"\"\n        design_dir = self.project_root / 'design'\n        if not design_dir.exists():\n            return False\n        \n        # Check for functional design\n        return any(f.name.startswith('Functional_Design') for f in design_dir.iterdir())\n    \n    def _has_data_model_artifacts(self) -> bool:\n        \"\"\"Check if data model artifacts exist.\"\"\"\n        data_model_dir = self.project_root / 'data_model'\n        if not data_model_dir.exists():\n            return False\n        \n        # Check for data model files\n        return any(f.name.startswith('Data_Model') for f in data_model_dir.iterdir())\n    \n    def _has_arch_review_artifacts(self) -> bool:\n        \"\"\"Check if architecture review artifacts exist.\"\"\"\n        arch_dir = self.project_root / 'architecture'\n        if not arch_dir.exists():\n            return False\n        \n        # Check for architecture review files\n        arch_files = ['Architecture_Overview.md', 'Architecture_Review.md', 'Risk_Assessment.md']\n        return any((arch_dir / f).exists() for f in arch_files)\n    \n    def _has_code_audit_artifacts(self) -> bool:\n        \"\"\"Check if code audit artifacts exist.\"\"\"\n        code_audit_dir = self.project_root / 'code_audit'\n        if not code_audit_dir.exists():\n            return False\n        \n        # Check for any audit cases\n        return any(code_audit_dir.iterdir())\n    \n    def _has_remediation_artifacts(self) -> bool:\n        \"\"\"Check if remediation artifacts exist.\"\"\"\n        remediation_dir = self.project_root / 'remediation'\n        if not remediation_dir.exists():\n            return False\n        \n        return any(remediation_dir.iterdir())\n    \n    def _has_finalized_artifacts(self) -> bool:\n        \"\"\"Check if finalized artifacts exist.\"\"\"\n        # Check for final approval or completion marker\n        final_files = [\n            self.project_root / 'architecture' / 'Final_Approval.md',\n            self.project_root / 'project_complete.md',\n            self.project_root / 'FINALIZED'\n        ]\n        \n        return any(f.exists() for f in final_files)\n    \n    def validate_transition(self, target_state: State, context: Dict = None) -> Tuple[bool, List[str]]:\n        \"\"\"\n        Validate transition from current state to target state.\n        Returns (is_valid, reasons).\n        \"\"\"\n        if context is None:\n            context = {}\n        \n        reasons = []\n        \n        # Check if target state is valid\n        if target_state not in State:\n            reasons.append(f'Invalid target state: {target_state}')\n            return False, reasons\n        \n        # Get state definitions\n        current_def = self.state_definitions['states'].get(self.current_state.value, {})\n        target_def = self.state_definitions['states'].get(target_state.value, {})\n        \n        if not current_def or not target_def:\n            reasons.append(f'State definition missing for {self.current_state.value} or {target_state.value}')\n            return False, reasons\n        \n        # Check if transition is explicitly allowed\n        allowed_next = current_def.get('allowed_next_states', [])\n        if target_state.value in allowed_next:\n            logger.info('Transition %s → %s explicitly allowed', self.current_state.value, target_state.value)\n            return True, ['Explicitly allowed transition']\n        \n        # Check for regression (moving to earlier state)\n        state_order = self.state_definitions['state_order']\n        current_idx = state_order.index(self.current_state.value) if self.current_state.value in state_order else -1\n        target_idx = state_order.index(target_state.value) if target_state.value in state_order else -1\n        \n        if target_idx < current_idx:\n            # Regression - check if allowed\n            if target_state.value in self.state_definitions['transition_rules']['allow_regression_to']:\n                # Check regression conditions\n                regression_conditions = self.state_definitions['transition_rules']['regression_conditions']\n                if context.get('regression_reason') in regression_conditions:\n                    logger.info('Regression %s → %s allowed with reason: %s', \n                               self.current_state.value, target_state.value, context.get('regression_reason'))\n                    return True, [f'Regression allowed: {context.get(\"regression_reason\")}']\n                else:\n                    reasons.append(f'Regression to {target_state.value} requires valid reason: {regression_conditions}')\n                    return False, reasons\n            else:\n                reasons.append(f'Regression to {target_state.value} not allowed')\n                return False, reasons\n        \n        # Check hard rules\n        hard_rules = self.state_definitions['hard_rules']\n        for rule in hard_rules:\n            if self._violates_hard_rule(rule, target_state, context):\n                reasons.append(f'Hard rule violation: {rule}')\n        \n        # Check blocking conditions for target state\n        blocking_conditions = target_def.get('blocking_conditions', [])\n        for condition in blocking_conditions:\n            if self._is_blocking_condition_met(condition, context):\n                reasons.append(f'Blocking condition: {condition}')\n        \n        # Check prohibited transitions\n        prohibited = current_def.get('prohibited_transitions', [])\n        if target_state.value in prohibited:\n            reasons.append(f'Transition prohibited: {self.current_state.value} → {target_state.value}')\n        \n        # Check if architect approval required\n        require_approval = self.state_definitions['transition_rules']['require_architect_approval']\n        transition_str = f'{self.current_state.value} → {target_state.value}'\n        if transition_str in require_approval and not context.get('architect_approved', False):\n            reasons.append(f'Architect approval required for {transition_str}')\n        \n        is_valid = len(reasons) == 0\n        if is_valid:\n            logger.info('Transition %s → %s validated', self.current_state.value, target_state.value)\n        \n        return is_valid, reasons\n    \n    def _violates_hard_rule(self, rule: str, target_state: State, context: Dict) -> bool:\n        \"\"\"Check if a hard rule is violated.\"\"\"\n        rule_lower = rule.lower()\n        \n        if 'no fit_gap without scope/sow' in rule_lower and target_state == State.FIT_GAP:\n            return not context.get('has_scope_sow', False)\n        \n        elif 'no design without consolidated discovery' in rule_lower and target_state == State.DESIGN:\n            return not context.get('has_consolidated_discovery', False)\n        \n        elif 'no finalized with critical audit findings' in rule_lower and target_state == State.FINALIZED:\n            return context.get('has_critical_findings', False)\n        \n        elif 'no code_audit without clear objectives' in rule_lower and target_state == State.CODE_AUDIT:\n            return not context.get('has_clear_audit_objectives', False)\n        \n        return False\n    \n    def _is_blocking_condition_met(self, condition: str, context: Dict) -> bool:\n        \"\"\"Check if a blocking condition is met.\"\"\"\n        condition_lower = condition.lower()\n        \n        # Check context for condition status\n        for key, value in context.items():\n            if key in condition_lower:\n                return not bool(value)  # If condition mentions something and it's False, it's blocking\n        \n        # Default: assume condition is not met (not blocking)\n        return False\n    \n    def transition(self, target_state: State, context: Dict = None) -> Tuple[bool, List[str]]:\n        \"\"\"\n        Execute state transition if valid.\n        Returns (success, reasons).\n        \"\"\"\n        if context is None:\n            context = {}\n        \n        # Validate transition\n        is_valid, reasons = self.validate_transition(target_state, context)\n        \n        if not is_valid:\n            logger.warning('Transition %s → %s invalid: %s', \n                          self.current_state.value, target_state.value, reasons)\n            return False, reasons\n        \n        # Execute transition\n        old_state = self.current_state\n        self.current_state = target_state\n        self.state_history.append({\n            'from_state': old_state.value,\n            'to_state': target_state.value,\n            'timestamp': datetime.now().isoformat(),\n            'context': context\n        })\n        \n        # Update project README\n        self._update_project_state()\n        \n        logger.info('Transition executed: %s → %s', old_state.value, target_state.value)\n        return True, ['Transition successful']\n    \n    def _update_project_state(self):\n        \"\"\"Update project README with current state.\"\"\"\n        readme_path = self.project_root / 'README.md'\n        \n        if not readme_path.exists():\n            # Create new README\n            content = f\"\"\"# Project: {self.project_root.name}\n\n## Current State: {self.current_state.value}\n- Entered: {datetime.now().isoformat()}\n- Validated: {datetime.now().isoformat()}\n\n## State History\n- {self.current_state.value}: {datetime.now().isoformat()} - \n\n## Artifact Versions\n- Discovery: v0\n- Requirements: v0\n- Fit/Gap: v0\n- Design: v0\n- Data Model: v0\n- Architecture Review: v0\n- Code Audit: v0 (none)\n- Remediation: v0 (none)\n\n## Next Actions\n- [ ] Complete {self.current_state.value} phase\n\"\"\"\n        else:\n            # Update existing README\n            content = readme_path.read_text(encoding='utf-8')\n            lines = content.split('\\n')\n            updated_lines = []\n            \n            for line in lines:\n                if line.startswith('## Current State:'):\n                    updated_lines.append(f'## Current State: {self.current_state.value}')\n                elif line.startswith('- Entered:'):\n                    # Keep original entered date\n                    updated_lines.append(line)\n                elif line.startswith('- Validated:'):\n                    updated_lines.append(f'- Validated: {datetime.now().isoformat()}')\n                elif line.startswith('- ') and f'{self.current_state.value}:' in line:\n                    # Update this state's history\n                    updated_lines.append(f'- {self.current_state.value}: {datetime.now().isoformat()} - ')\n                elif line.startswith('## State History'):\n                    updated_lines.append(line)\n                    # Add new state entry if not already there\n                    if not any(f'{self.current_state.value}:' in l for l in lines):\n                        updated_lines.append(f'- {self.current_state.value}: {datetime.now().isoformat()} - ')\n                else:\n                    updated_lines.append(line)\n            \n            content = '\\n'.join(updated_lines)\n        \n        readme_path.write_text(content, encoding='utf-8')\n        logger.info('Project state updated to: %s', self.current_state.value)\n    \n    def get_state_info(self, state: State = None) -> Dict:\n        \"\"\"Get information about a state (or current state if None).\"\"\"\n        if state is None:\n            state = self.current_state\n        \n        return self.state_definitions['states'].get(state.value, {})\n    \n    def get_allowed_transitions(self) -> List[State]:\n        \"\"\"Get list of allowed transitions from current state.\"\"\"\n        current_def = self.state_definitions['states'].get(self.current_state.value, {})\n        allowed_next = current_def.get('allowed_next_states', [])\n        \n        return [State(state_str) for state_str in allowed_next if State(state_str) in State]\n    \n    def is_terminal_state(self) -> bool:\n        \"\"\"Check if current state is terminal (FINALIZED).\"\"\"\n        return self.current_state == State.FINALIZED\n\n# Utility functions for easy integration\ndef create_state_machine(project_root: Path) -> StateMachineEngine:\n    \"\"\"Create and initialize a state machine for a project.\"\"\"\n    return StateMachineEngine(project_root)\n\ndef validate_project_state(project_root: Path, target_state: str, context: Dict = None) -> Tuple[bool, List[str]]:\n    \"\"\"Convenience function to validate state transition.\"\"\"\n    engine = StateMachineEngine(project_root)\n    try:\n        target_state_enum = State(target_state)\n    except ValueError:\n        return False, [f'Invalid state: {target_state}']\n    \n    return engine.validate_transition(target_state_enum, context)\n\nif __name__ == '__main__':\n    # Test the state machine engine\n    test_project = Path.home() / '.openclaw' / 'workspace' / 'projects' / 'test_state_machine'\n    test_project.mkdir(parents=True, exist_ok=True)\n    \n    try:\n        engine = StateMachineEngine(test_project)\n        print(f'Current state: {engine.current_state.value}')\n        \n        # Test valid"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":8002,"output":4096,"cacheRead":89728,"cacheWrite":0,"totalTokens":101826,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"length","timestamp":1773081714487}}
