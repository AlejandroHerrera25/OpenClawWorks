{"type":"message","id":"94c25a43","parentId":"a0e63324","timestamp":"2026-03-10T00:19:43.266Z","message":{"role":"assistant","content":[{"type":"text","text":"Good, it's no longer referenced. Now let me create a test to verify the real integration works. First, let me create a simple test script:"},{"type":"toolCall","id":"call_00_aY5EE2p6D6aXJZT3U1dTeDhz","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/test_real_integration.py","content":"#!/usr/bin/env python3\n\"\"\"\nTest REAL Salesforce Architect ↔ Code Auditor Integration\n\"\"\"\n\nimport os\nimport sys\nimport tempfile\nimport shutil\nimport json\nimport subprocess\nfrom pathlib import Path\n\n# Add script directory to path\nsys.path.insert(0, str(Path(__file__).parent / 'skills' / 'salesforce-architect' / 'scripts'))\n\nfrom auditor_integration import AuditorIntegration\n\ndef test_real_integration():\n    \"\"\"Test REAL integration (not simulated).\"\"\"\n    \n    print(\"🧪 Testing REAL Architect ↔ Auditor Integration\")\n    print(\"=\" * 60)\n    \n    # Create test project\n    test_project = Path(tempfile.mkdtemp(prefix='test_real_integration_'))\n    print(f\"Test project: {test_project}\")\n    \n    all_tests_passed = True\n    test_results = []\n    \n    try:\n        # Test 1: Verify code auditor skill exists\n        print(\"\\n1️⃣ Verifying code auditor skill...\")\n        code_auditor_dir = Path('/home/openclaw/.openclaw/workspace/skills/salesforce-code-auditor')\n        if not code_auditor_dir.exists():\n            print(f\"  ❌ Code auditor skill not found at {code_auditor_dir}\")\n            all_tests_passed = False\n        else:\n            print(f\"  ✅ Code auditor skill found\")\n            # Check for required scripts\n            required_scripts = ['build_dependency_graph.py', 'index_inputs.py']\n            for script in required_scripts:\n                script_path = code_auditor_dir / 'scripts' / script\n                if script_path.exists():\n                    print(f\"    ✅ {script} found\")\n                else:\n                    print(f\"    ❌ {script} not found\")\n                    all_tests_passed = False\n        \n        # Test 2: Verify Salesforce fixtures exist\n        print(\"\\n2️⃣ Verifying Salesforce fixtures...\")\n        fixtures_dir = Path('/home/openclaw/.openclaw/workspace/fixtures/real_salesforce_samples')\n        if not fixtures_dir.exists():\n            print(f\"  ⚠️ Fixtures directory not found: {fixtures_dir}\")\n            print(f\"    Creating minimal test fixture...\")\n            # Create a minimal fixture\n            fixtures_dir.mkdir(parents=True, exist_ok=True)\n            test_file = fixtures_dir / 'TestController.cls'\n            test_file.write_text(\"\"\"\npublic with sharing class TestController {\n    public static void testMethod() {\n        // Test method with SOQL\n        List<Account> accounts = [SELECT Id, Name FROM Account LIMIT 10];\n    }\n}\n\"\"\")\n            print(f\"    ✅ Created test fixture\")\n        else:\n            fixture_count = len(list(fixtures_dir.glob('*')))\n            print(f\"  ✅ Found {fixture_count} Salesforce fixtures\")\n        \n        # Test 3: Initialize AuditorIntegration\n        print(\"\\n3️⃣ Initializing AuditorIntegration...\")\n        try:\n            integration = AuditorIntegration(test_project)\n            print(f\"  ✅ AuditorIntegration initialized\")\n            test_results.append((\"AuditorIntegration init\", \"PASS\"))\n        except Exception as e:\n            print(f\"  ❌ AuditorIntegration init failed: {e}\")\n            test_results.append((\"AuditorIntegration init\", \"FAIL\"))\n            all_tests_passed = False\n        \n        if not all_tests_passed:\n            print(\"\\n⚠️ Prerequisites failed, skipping further tests\")\n            return False\n        \n        # Test 4: REAL Mode A Audit Invocation\n        print(\"\\n4️⃣ Testing REAL Mode A audit invocation...\")\n        try:\n            result_a = integration.invoke_auditor(\n                mode='A',\n                audit_objectives=[\n                    'Assess current code health',\n                    'Identify technical constraints'\n                ],\n                scope={\n                    'included': ['apex_classes', 'triggers'],\n                    'excluded': ['test_classes'],\n                    'depth': 'detailed_analysis'\n                },\n                context={\n                    'business_process': 'Order management',\n                    'current_pain_points': ['Performance issues']\n                }\n            )\n            \n            print(f\"  ✅ REAL Mode A audit invoked\")\n            print(f\"    Case ID: {result_a['case_id']}\")\n            print(f\"    Validation: {result_a['validation_result']['validation_status']}\")\n            print(f\"    Compliance: {result_a['validation_result']['compliance_percentage']}%\")\n            \n            # Check for real audit results (not simulated)\n            audit_result = result_a['audit_result']\n            if 'status' in audit_result and audit_result['status'] == 'error':\n                print(f\"    ⚠️ Audit returned error: {audit_result.get('error', 'Unknown error')}\")\n            else:\n                print(f\"    ✅ Real audit results generated\")\n                print(f\"      Executive summary: {audit_result.get('executive_summary', 'N/A')[:80]}...\")\n                print(f\"      Technical assessment: {audit_result.get('technical_assessment', 'N/A')[:80]}...\")\n            \n            # Check project files were created\n            case_dir = test_project / 'code_audit' / result_a['case_id']\n            if case_dir.exists():\n                files_created = list(case_dir.rglob('*'))\n                print(f\"    ✅ Case directory created with {len(files_created)} files\")\n                \n                # Check for specific audit files\n                expected_files = ['audit_request.json', 'audit_result.json']\n                for file in expected_files:\n                    if (case_dir / file).exists():\n                        print(f\"      ✅ {file} created\")\n                    else:\n                        print(f\"      ⚠️ {file} not found\")\n            else:\n                print(f\"    ❌ Case directory not created\")\n            \n            test_results.append((\"REAL Mode A invocation\", \"PASS\"))\n            \n        except Exception as e:\n            print(f\"  ❌ REAL Mode A invocation failed: {e}\")\n            import traceback\n            traceback.print_exc()\n            test_results.append((\"REAL Mode A invocation\", \"FAIL\"))\n            all_tests_passed = False\n        \n        # Test 5: Check for anti-simulation evidence\n        print(\"\\n5️⃣ Checking anti-simulation evidence...\")\n        try:\n            # Load the audit result file\n            case_id = result_a['case_id']\n            result_file = test_project / 'code_audit' / case_id / 'audit_result.json'\n            \n            if result_file.exists():\n                with open(result_file, 'r') as f:\n                    audit_data = json.load(f)\n                \n                # Check for simulation markers\n                has_simulation_markers = False\n                simulation_indicators = ['simulated', 'placeholder', 'fake', 'test data']\n                \n                import json\n                audit_str = json.dumps(audit_data).lower()\n                for indicator in simulation_indicators:\n                    if indicator in audit_str:\n                        has_simulation_markers = True\n                        print(f\"    ⚠️ Found simulation indicator: '{indicator}'\")\n                \n                if not has_simulation_markers:\n                    print(f\"    ✅ No simulation markers found in audit results\")\n                else:\n                    print(f\"    ❌ Simulation markers detected\")\n                    all_tests_passed = False\n                \n                # Check for real data\n                has_real_data = any(key in audit_data for key in \n                                  ['executive_summary', 'technical_assessment', 'constraints_limitations'])\n                if has_real_data:\n                    print(f\"    ✅ Real audit data structure present\")\n                else:\n                    print(f\"    ⚠️ Missing real audit data structure\")\n                    \n            else:\n                print(f\"    ❌ Audit result file not found\")\n                all_tests_passed = False\n                \n            test_results.append((\"Anti-simulation check\", \"PASS\" if not has_simulation_markers else \"FAIL\"))\n            \n        except Exception as e:\n            print(f\"  ❌ Anti-simulation check failed: {e}\")\n            test_results.append((\"Anti-simulation check\", \"FAIL\"))\n            all_tests_passed = False\n        \n        # Test 6: Verify subprocess was actually called\n        print(\"\\n6️⃣ Verifying subprocess execution...\")\n        try:\n            # Check case directory for evidence of script execution\n            case_dir = test_project / 'code_audit' / case_id\n            \n            # Look for files created by code auditor scripts\n            auditor_files = [\n                'dependency_graph.json',\n                'entrypoints.json', \n                'snippets.json',\n                'inputs/'\n            ]\n            \n            found_files = []\n            for file in auditor_files:\n                if (case_dir / file).exists():\n                    found_files.append(file)\n            \n            if found_files:\n                print(f\"    ✅ Found {len(found_files)} auditor-generated files: {', '.join(found_files)}\")\n                \n                # Check file contents\n                for file in found_files:\n                    file_path = case_dir / file\n                    if file_path.is_file():\n                        try:\n                            with open(file_path, 'r') as f:\n                                content = f.read()\n                            if len(content) > 10:  # Non-empty\n                                print(f\"      ✅ {file} has content ({len(content)} chars)\")\n                            else:\n                                print(f\"      ⚠️ {file} is empty or very small\")\n                        except:\n                            print(f\"      ⚠️ Could not read {file}\")\n            else:\n                print(f\"    ⚠️ No auditor-generated files found\")\n                print(f\"      Checked: {', '.join(auditor_files)}\")\n            \n            test_results.append((\"Subprocess verification\", \"PASS\" if found_files else \"PARTIAL\"))\n            \n        except Exception as e:\n            print(f\"  ❌ Subprocess verification failed: {e}\")\n            test_results.append((\"Subprocess verification\", \"FAIL\"))\n            all_tests_passed = False\n        \n        # Summary\n        print(\"\\n\" + \"=\" * 60)\n        print(\"📊 REAL INTEGRATION TEST SUMMARY\")\n        print(\"=\" * 60)\n        \n        for test_name, result in test_results:\n            if result == \"PASS\":\n                status = \"✅ PASS\"\n            elif result == \"PARTIAL\":\n                status = \"⚠️ PARTIAL\"\n            else:\n                status = \"❌ FAIL\"\n            print(f\"{status} {test_name}\")\n        \n        if all_tests_passed:\n            print(\"\\n🎉 REAL integration tests passed!\")\n            print(\"\\n📁 Test artifacts available at:\")\n            print(f\"   Project: {test_project}\")\n            \n            # Show directory structure\n            print(\"\\n📂 Directory structure:\")\n            for root, dirs, files in os.walk(test_project):\n                level = root.replace(str(test_project), '').count(os.sep)\n                indent = ' ' * 2 * level\n                print(f'{indent}{os.path.basename(root)}/')\n                subindent = ' ' * 2 * (level + 1)\n                for file in files[:5]:  # Show first 5 files\n                    print(f'{subindent}{file}')\n                if len(files) > 5:\n                    print(f'{subindent}... and {len(files) - 5} more')\n            \n        else:\n            print(\"\\n⚠️ Some tests failed or had issues.\")\n            print(\"   Integration classification: PARTIAL\")\n        \n    except Exception as e:\n        print(f\"\\n❌ Test suite failed: {e}\")\n        import traceback\n        traceback.print_exc()\n        all_tests_passed = False\n    \n    finally:\n        # Ask if we should keep the test project\n        keep = input(\"\\nKeep test project for inspection? (y/N): \").lower().strip()\n        if keep != 'y':\n            if test_project.exists():\n                shutil.rmtree(test_project)\n                print(f\"🧹 Cleaned up test project\")\n        else:\n            print(f\"📁 Test project kept: {test_project}\")\n    \n    return all_tests_passed\n\nif __name__ == '__main__':\n    success = test_real_integration()\n    sys.exit(0 if success else 1)"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":66,"output":2695,"cacheRead":29952,"cacheWrite":0,"totalTokens":32713,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101910545}}
