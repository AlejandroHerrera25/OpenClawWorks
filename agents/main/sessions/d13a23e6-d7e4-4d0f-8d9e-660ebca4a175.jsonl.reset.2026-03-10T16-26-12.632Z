{"type":"message","id":"3f02ed37","parentId":"33e2ead1","timestamp":"2026-03-09T18:32:15.725Z","message":{"role":"assistant","content":[{"type":"text","text":"Ahora voy a ejecutar las validaciones. Primero, voy a crear un script de validación:"},{"type":"toolCall","id":"call_00_w2eAbPHnzhVFonhI5NoasaF9","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/validate_hardening.py","content":"#!/usr/bin/env python3\n\"\"\"\nValidation script for Salesforce skill hardening upgrade.\nTests all 9 validation requirements from PART 13.\n\"\"\"\n\nimport os\nimport sys\nimport json\nimport tempfile\nimport shutil\nfrom pathlib import Path\nimport subprocess\n\n# Add script directory to path\nsys.path.insert(0, str(Path(__file__).parent))\n\nfrom utils_io import (\n    check_references,\n    create_project_structure,\n    load_governance_reference,\n    detect_project_state,\n    validate_against_dod,\n    get_role_from_model,\n    emit_incident\n)\n\nWORKSPACE_ROOT = Path(os.environ.get('WORKSPACE', '/home/openclaw/.openclaw/workspace'))\nPROJECTS_ROOT = WORKSPACE_ROOT / 'projects'\n\nclass HardeningValidator:\n    \"\"\"Validate all hardening requirements.\"\"\"\n    \n    def __init__(self):\n        self.results = {}\n        self.test_project_key = 'test_hardening_validation'\n        self.test_project_root = PROJECTS_ROOT / self.test_project_key\n        \n    def cleanup(self):\n        \"\"\"Clean up test artifacts.\"\"\"\n        if self.test_project_root.exists():\n            shutil.rmtree(self.test_project_root)\n    \n    def run_all_validations(self):\n        \"\"\"Run all 9 validation tests.\"\"\"\n        print(\"=\" * 70)\n        print(\"SALESFORCE HARDENING VALIDATION SUITE\")\n        print(\"=\" * 70)\n        \n        tests = [\n            self.test_1_project_folder_creation,\n            self.test_2_artifact_containment,\n            self.test_3_role_assignment,\n            self.test_4_code_auditor_invocation,\n            self.test_5_output_rejection,\n            self.test_6_readme_updates,\n            self.test_7_state_machine_respect,\n            self.test_8_dod_enforcement,\n            self.test_9_no_scattered_artifacts\n        ]\n        \n        for i, test_func in enumerate(tests, 1):\n            print(f\"\\n{'='*60}\")\n            print(f\"TEST {i}: {test_func.__name__.replace('test_', '').replace('_', ' ').title()}\")\n            print(f\"{'='*60}\")\n            \n            try:\n                success, message = test_func()\n                self.results[f\"test_{i}\"] = {\n                    \"success\": success,\n                    \"message\": message\n                }\n                status = \"✅ PASS\" if success else \"❌ FAIL\"\n                print(f\"Result: {status}\")\n                print(f\"Details: {message}\")\n            except Exception as e:\n                self.results[f\"test_{i}\"] = {\n                    \"success\": False,\n                    \"message\": f\"Test crashed: {str(e)}\"\n                }\n                print(f\"Result: ❌ CRASH\")\n                print(f\"Error: {e}\")\n        \n        return self.summarize_results()\n    \n    def test_1_project_folder_creation(self):\n        \"\"\"Test 1: Salesforce request creates or reuses correct project folder.\"\"\"\n        print(\"Testing project folder creation/reuse...\")\n        \n        # Clean up any existing test project\n        self.cleanup()\n        \n        # Test creation\n        project_root = create_project_structure(self.test_project_key)\n        created = project_root.exists()\n        \n        if not created:\n            return False, \"Project folder not created\"\n        \n        # Test expected structure\n        expected_dirs = ['discovery', 'fit_gap', 'design', 'data_model', 'architecture', 'evidence']\n        missing_dirs = []\n        for dir_name in expected_dirs:\n            if not (project_root / dir_name).exists():\n                missing_dirs.append(dir_name)\n        \n        if missing_dirs:\n            return False, f\"Missing directories: {missing_dirs}\"\n        \n        # Test README creation\n        readme_path = project_root / 'README.md'\n        if not readme_path.exists():\n            return False, \"README.md not created\"\n        \n        # Test reuse (simulate)\n        print(\"Testing project reuse...\")\n        project_root_reuse = create_project_structure(self.test_project_key)\n        if project_root_reuse != project_root:\n            return False, \"Project reuse failed - different path returned\"\n        \n        return True, \"Project folder creation and reuse successful\"\n    \n    def test_2_artifact_containment(self):\n        \"\"\"Test 2: Artifacts written only inside project folder.\"\"\"\n        print(\"Testing artifact containment...\")\n        \n        # Create test artifacts in project folder\n        test_artifact = self.test_project_root / 'discovery' / 'Test_Artifact.md'\n        test_artifact.parent.mkdir(parents=True, exist_ok=True)\n        test_artifact.write_text(\"# Test Artifact\\n\\nThis should be inside project folder.\")\n        \n        # Check it's inside project folder\n        if not test_artifact.exists():\n            return False, \"Test artifact not created\"\n        \n        # Verify it's under projects directory\n        try:\n            test_artifact.relative_to(PROJECTS_ROOT)\n        except ValueError:\n            return False, \"Artifact created outside projects directory\"\n        \n        # Verify it's under specific project\n        try:\n            test_artifact.relative_to(self.test_project_root)\n        except ValueError:\n            return False, \"Artifact created outside project folder\"\n        \n        return True, \"All artifacts properly contained within project folder\"\n    \n    def test_3_role_assignment(self):\n        \"\"\"Test 3: Architect can assign at least 2 specialist roles correctly.\"\"\"\n        print(\"Testing role assignment...\")\n        \n        # Load role model\n        try:\n            role_model = load_governance_reference('SALESFORCE_ROLE_MODEL.md')\n        except Exception as e:\n            return False, f\"Failed to load role model: {e}\"\n        \n        # Test getting specific roles\n        test_roles = ['Salesforce Administrator', 'Salesforce Integration Developer']\n        assigned_roles = []\n        \n        for role_name in test_roles:\n            role_def = get_role_from_model(role_name, role_model)\n            if role_def:\n                assigned_roles.append({\n                    'name': role_name,\n                    'purpose': role_def.get('purpose', ''),\n                    'domain_ownership': role_def.get('domain_ownership', [])\n                })\n        \n        if len(assigned_roles) < 2:\n            return False, f\"Could only assign {len(assigned_roles)} roles, expected 2\"\n        \n        # Verify role details\n        for role in assigned_roles:\n            if not role['purpose']:\n                return False, f\"Role {role['name']} missing purpose\"\n            if not role['domain_ownership']:\n                return False, f\"Role {role['name']} missing domain ownership\"\n        \n        print(f\"Successfully assigned roles: {[r['name'] for r in assigned_roles]}\")\n        return True, f\"Assigned {len(assigned_roles)} specialist roles with complete definitions\"\n    \n    def test_4_code_auditor_invocation(self):\n        \"\"\"Test 4: Architect can invoke salesforce-code-auditor as subordinate validator.\"\"\"\n        print(\"Testing code auditor invocation...\")\n        \n        # Check if code auditor skill exists\n        code_auditor_dir = WORKSPACE_ROOT / 'skills' / 'salesforce-code-auditor'\n        if not code_auditor_dir.exists():\n            return False, \"salesforce-code-auditor skill not found\"\n        \n        # Check if scripts exist\n        required_scripts = ['init_case.py', 'generate_reports.py']\n        missing_scripts = []\n        for script in required_scripts:\n            script_path = code_auditor_dir / 'scripts' / script\n            if not script_path.exists():\n                missing_scripts.append(script)\n        \n        if missing_scripts:\n            return False, f\"Missing code auditor scripts: {missing_scripts}\"\n        \n        # Test handoff mode understanding\n        try:\n            handoff_modes = load_governance_reference('CODE_AUDIT_HANDOFF_MODES.md')\n            if not handoff_modes:\n                return False, \"Could not load handoff modes reference\"\n            \n            # Check for mode definitions\n            mode_sections = [k for k in handoff_modes.keys() if 'Mode' in k]\n            if len(mode_sections) < 3:\n                return False, f\"Expected 3 handoff modes, found {len(mode_sections)}\"\n            \n            print(f\"Found handoff modes: {mode_sections}\")\n            \n        except Exception as e:\n            return False, f\"Failed to test handoff modes: {e}\"\n        \n        return True, \"Code auditor can be invoked with proper handoff modes\"\n    \n    def test_5_output_rejection(self):\n        \"\"\"Test 5: Architect can reject weak specialist output and request correction.\"\"\"\n        print(\"Testing output rejection protocol...\")\n        \n        # Load DoD reference\n        try:\n            dod_by_role = load_governance_reference('DEFINITION_OF_DONE_BY_ROLE.md')\n        except Exception as e:\n            return False, f\"Failed to load DoD reference: {e}\"\n        \n        # Test validation against DoD\n        test_role = 'Salesforce Functional Consultant'\n        weak_artifacts = \"Some incomplete analysis without evidence or assumptions documented.\"\n        \n        is_valid, issues = validate_against_dod(test_role, weak_artifacts, dod_by_role)\n        \n        if is_valid:\n            return False, \"Weak artifacts incorrectly validated as compliant with DoD\"\n        \n        if not issues:\n            return False, \"No issues found in weak artifacts (should have found issues)\"\n        \n        print(f\"Found {len(issues)} issues in weak artifacts:\")\n        for issue in issues[:3]:  # Show first 3 issues\n            print(f\"  - {issue}\")\n        \n        return True, f\"Successfully rejected weak output with {len(issues)} DoD violations\"\n    \n    def test_6_readme_updates(self):\n        \"\"\"Test 6: Project README updates correctly.\"\"\"\n        print(\"Testing README updates...\")\n        \n        from utils_io import update_project_readme\n        \n        # Create test updates\n        updates = {\n            'current_state': 'DESIGN',\n            'state_history': 'DESIGN: 2026-03-09T13:30:00 - ',\n            'artifact_versions': {\n                'Discovery': '1',\n                'Requirements': '1',\n                'Fit/Gap': '1'\n            }\n        }\n        \n        # Apply updates\n        update_project_readme(self.test_project_root, updates)\n        \n        # Verify updates\n        readme_path = self.test_project_root / 'README.md'\n        if not readme_path.exists():\n            return False, \"README not found after update\"\n        \n        readme_content = readme_path.read_text(encoding='utf-8')\n        \n        # Check for updated state\n        if '## Current State: DESIGN' not in readme_content:\n            return False, \"Current state not updated in README\"\n        \n        # Check for state history\n        if 'DESIGN: 2026-03-09T13:30:00' not in readme_content:\n            return False, \"State history not updated in README\"\n        \n        return True, \"Project README updates correctly with state and version information\"\n    \n    def test_7_state_machine_respect(self):\n        \"\"\"Test 7: State machine is respected.\"\"\"\n        print(\"Testing state machine respect...\")\n        \n        from utils_io import validate_state_transition\n        \n        # Load state machine\n        try:\n            state_machine = load_governance_reference('SALESFORCE_PROJECT_STATE_MACHINE.md')\n        except Exception as e:\n            return False, f\"Failed to load state machine: {e}\"\n        \n        # Test valid transition\n        valid = validate_state_transition('DISCOVERY', 'REQUIREMENTS', state_machine)\n        if not valid:\n            return False, \"Valid transition DISCOVERY→REQUIREMENTS rejected\"\n        \n        # Test invalid transition (should be rejected)\n        invalid = validate_state_transition('DISCOVERY', 'FINALIZED', state_machine)\n        if invalid:\n            return False, \"Invalid transition DISCOVERY→FINALIZED incorrectly allowed\"\n        \n        # Test state detection\n        current_state = detect_project_state(self.test_project_root)\n        print(f\"Detected project state: {current_state}\")\n        \n        if not current_state:\n            return False, \"Could not detect project state\"\n        \n        return True, \"State machine respected with proper transition validation\"\n    \n    def test_8_dod_enforcement(self):\n        \"\"\"Test 8: Definition of Done is actually enforced in at least one specialist handoff.\"\"\"\n        print(\"Testing DoD enforcement...\")\n        \n        # This test builds on test_5 but with more comprehensive validation\n        from utils_io import get_role_from_model, validate_against_dod\n        \n        # Load references\n        try:\n            role_model = load_governance_reference('SALESFORCE_ROLE_MODEL.md')\n            dod_by_role = load_governance_reference('DEFINITION_OF_DONE_BY_ROLE.md')\n        except Exception as e:\n            return False, f\"Failed to load references: {e}\"\n        \n        # Test with Integration Developer role\n        test_role = 'Salesforce Integration Developer'\n        role_def = get_role_from_model(test_role, role_model)\n        \n        if not role_def:\n            return False, f\"Could not get role definition for {test_role}\"\n        \n        # Create sample artifacts that SHOULD pass DoD\n        good_artifacts = \"\"\"\n        Integration Design Document:\n        - Integration pattern: REST API with OAuth 2.0\n        - Authentication strategy: Client credentials flow\n        - Error handling: Retry logic with exponential backoff\n        - Performance: Target response time < 2 seconds\n        - Security: Data encryption in transit and at rest\n        \n        API Specifications:\n        - Endpoint: /api/v1/orders\n        - Methods: GET, POST\n        - Request/response formats: JSON\n        - Rate limiting: 100 requests/minute\n        \n        Evidence provided for all decisions.\n        \"\"\"\n        \n        # Create sample artifacts that SHOULD fail DoD\n        bad_artifacts = \"Built integration. Works fine.\"\n        \n        # Validate both\n        good_valid, good_issues = validate_against_dod(test_role, good_artifacts, dod_by_role)\n        bad_valid, bad_issues = validate_against_dod(test_role, bad_artifacts, dod_by_role)\n        \n        print(f\"Good artifacts validation: {'PASS' if good_valid else 'FAIL'} ({len(good_issues)} issues)\")\n        print(f\"Bad artifacts validation: {'PASS' if bad_valid else 'FAIL'} ({len(bad_issues)} issues)\")\n        \n        # Good artifacts should pass, bad should fail\n        if not good_valid:\n            return False, f\"Good artifacts failed DoD: {good_issues}\"\n        \n        if bad_valid:\n            return False, \"Bad artifacts incorrectly passed DoD validation\"\n        \n        return True, f\"DoD enforcement working: good artifacts pass ({len(good_issues)} issues), bad artifacts fail ({len(bad_issues)} issues)\"\n    \n    def test_9_no_scattered_artifacts(self):\n        \"\"\"Test 9: No scattered Salesforce artifacts created outside