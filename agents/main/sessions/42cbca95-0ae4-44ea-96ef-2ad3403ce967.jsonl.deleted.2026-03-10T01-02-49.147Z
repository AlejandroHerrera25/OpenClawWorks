{"type":"message","id":"56a08851","parentId":"8c1d1c2d","timestamp":"2026-03-10T00:03:14.119Z","message":{"role":"toolResult","toolCallId":"call_00_Up2AaBVmcUQFnUHe0a3Zq9vd","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nMain orchestrator for long prompt decomposition and execution.\nRefactored to ONLY generate plans, NOT spawn sub-agents.\nMain agent handles spawning and execution.\n\"\"\"\n\nimport sys\nimport os\nimport json\nimport argparse\nimport tempfile\nimport shutil\nimport time\nimport uuid\nfrom typing import Dict, List, Any, Optional\n\n# Add skill scripts directory to path\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\n\nfrom decompose import detect_and_decompose\nfrom todo import Checklist, ItemState\nfrom token_budget import TokenBudget\nfrom validate import validate_final_output\nfrom recovery import recover_from_interruption\nfrom learning_emit import emit_incident\nfrom plan_generator import PlanGenerator, generate_plan_from_decomposed_tasks\n\n# New modules for upgrade\nfrom context_monitor import ContextMonitor\nfrom context_archive import ContextArchiver\nfrom semantic_index_builder import update_semantic_index, SemanticIndexBuilder\nfrom semantic_context_search import SemanticContextSearch\nfrom task_state_manager import TaskStateManager\nfrom session_manager import SessionManager, create_new_session\nfrom memory_router import MemoryRouter, route_memory_for_step\nfrom context_cleanup import ContextCleanup\n\n# Configuration defaults\nMAX_PROMPT_TOKENS = 4000\nMAX_MINI_TASKS = 20\nGLOBAL_TOKEN_BUDGET = 16000\nINPUT_TOKEN_LIMIT = 4000\nOUTPUT_TOKEN_LIMIT = 2000\n\nWORKSPACE = os.path.expanduser(\"~/.openclaw/workspace\")\nTASKBOARDS_DIR = os.path.join(WORKSPACE, \".taskboards\")\n\ndef ensure_taskboards_dir():\n    \"\"\"Ensure .taskboards directory exists.\"\"\"\n    os.makedirs(TASKBOARDS_DIR, exist_ok=True)\n    os.makedirs(os.path.join(TASKBOARDS_DIR, \"checkpoints\"), exist_ok=True)\n\ndef simulate_model_call(context: str, max_output_tokens: int) -> str:\n    \"\"\"\n    Simulate a model call for demo purposes.\n    In production, replace with actual OpenClaw tooling.\n    \"\"\"\n    # For demo, just echo the objective and produce a placeholder output.\n    lines = context.split('\\n')\n    objective = next((line for line in lines if 'Objective:' in line), '')\n    return f\"Simulated output for {objective[:50]}...\\nThis output satisfies the acceptance criteria.\"\n\ndef run_demo_basic():\n    \"\"\"Run basic demo from example_basic.md.\"\"\"\n    print(\"=== Running Basic Demo ===\")\n    ensure_taskboards_dir()\n    \n    # Hardcoded long prompt from example_basic.md\n    prompt = \"\"\"Create a comprehensive report about climate change impacts on agriculture.\nThe report should include:\n1. Introduction: overview of climate change and its relevance to agriculture.\n2. Temperature effects: how rising temperatures affect crop yields, soil moisture, and pest dynamics.\n3. Precipitation changes: impacts of altered rainfall patterns, droughts, and floods.\n4. CO2 fertilization: the positive and negative effects of increased atmospheric CO2 on plant growth.\n5. Adaptation strategies: changes in farming practices, crop selection, irrigation, and technology.\n6. Policy recommendations: suggestions for governments, NGOs, and farmers.\n7. Conclusion: summary and future outlook.\n\nPlease write each section in detail, with sub‑headings, and include at least three references per section.\nThe report should be well‑structured, around 3000 words total.\"\"\"\n    \n    print(f\"Original prompt length: {len(prompt)} chars\")\n    \n    # Detect and decompose with low threshold to ensure decomposition\n    result = detect_and_decompose(prompt, max_prompt_tokens=100, max_mini_tasks=MAX_MINI_TASKS)\n    if isinstance(result, tuple) and len(result) == 2:\n        tasks, metrics = result\n    else:\n        tasks = result if result else []\n        metrics = {}\n    \n    if not tasks:\n        # Fallback: create dummy tasks\n        tasks = [\n            {'id': 'task_01', 'objective': 'Write introduction', 'inputs': [], 'outputs': [], 'dependencies': [], 'acceptance_criteria': [], 'max_token_budget': 1000},\n            {'id': 'task_02', 'objective': 'Write temperature effects', 'inputs': [], 'outputs': [], 'dependencies': ['task_01'], 'acceptance_criteria': [], 'max_token_budget': 1000},\n            {'id': 'task_03', 'objective': 'Write precipitation changes', 'inputs': [], 'outputs': [], 'dependencies': ['task_02'], 'acceptance_criteria': [], 'max_token_budget': 1000},\n            {'id': 'task_04', 'objective': 'Write CO2 fertilization', 'inputs': [], 'outputs': [], 'dependencies': ['task_03'], 'acceptance_criteria': [], 'max_token_budget': 1000},\n        ]\n        print(\"Decomposition fallback triggered.\")\n    \n    print(f\"Decomposed into {len(tasks)} mini-tasks.\")\n    for task in tasks:\n        print(f\"  {task['id']}: {task['objective'][:60]}...\")\n    \n    # Generate plan instead of executing\n    print(\"\\n=== Generating Plan (instead of executing) ===\")\n    plan = generate_plan_from_decomposed_tasks(prompt, tasks)\n    \n    print(f\"Plan generated: {plan['plan_id']}\")\n    print(f\"Total tasks in plan: {len(plan['tasks'])}\")\n    print(f\"Estimated total tokens: {plan['estimated_total_tokens']}\")\n    print(f\"Estimated total runtime: {plan['estimated_total_runtime_seconds']} seconds\")\n    \n    # Save plan to file\n    plan_file = os.path.join(TASKBOARDS_DIR, f\"{plan['plan_id']}.json\")\n    with open(plan_file, 'w') as f:\n        json.dump(plan, f, indent=2)\n    \n    print(f\"\\nPlan saved to: {plan_file}\")\n    print(\"\\n=== Demo Complete ===\")\n    print(\"NOTE: This skill now ONLY generates plans.\")\n    print(\"Main agent should use this plan to spawn and coordinate sub-agents.\")\n    \n    return plan\n\ndef run_demo_complex():\n    \"\"\"Run complex demo with multi-file outputs.\"\"\"\n    print(\"=== Running Complex Demo ===\")\n    ensure_taskboards_dir()\n    \n    prompt = \"\"\"Create a Python package for data analysis with the following components:\n1. data_loader.py: Functions to load CSV, JSON, and Excel files with error handling.\n2. data_cleaner.py: Functions for missing value imputation, outlier detection, and normalization.\n3. data_analyzer.py: Statistical analysis functions (mean, median, std, correlation).\n4. data_visualizer.py: Plotting functions using matplotlib and seaborn.\n5. tests/ directory: Unit tests for all modules using pytest.\n6. requirements.txt: List of dependencies.\n7. README.md: Documentation with usage examples.\n8. setup.py: Package installation configuration.\n\nEach module should have docstrings, type hints, and follow PEP 8 style guide.\nThe package should be production-ready with proper error handling and logging.\"\"\"\n    \n    print(f\"Original prompt length: {len(prompt)} chars\")\n    \n    result = detect_and_decompose(prompt, max_prompt_tokens=100, max_mini_tasks=MAX_MINI_TASKS)\n    if isinstance(result, tuple) and len(result) == 2:\n        tasks, metrics = result\n    else:\n        tasks = result if result else []\n        metrics = {}\n    \n    if not tasks:\n        tasks = [\n            {'id': 'task_01', 'objective': 'Create data_loader.py', 'inputs': [], 'outputs': ['data_loader.py'], 'dependencies': [], 'acceptance_criteria': ['File exists', 'Has docstrings', 'Follows PEP 8'], 'max_token_budget': 1500},\n            {'id': 'task_02', 'objective': 'Create data_cleaner.py', 'inputs': [], 'outputs': ['data_cleaner.py'], 'dependencies': [], 'acceptance_criteria': ['File exists', 'Has docstrings', 'Follows PEP 8'], 'max_token_budget': 1500},\n            {'id': 'task_03', 'objective': 'Create data_analyzer.py', 'inputs': [], 'outputs': ['data_analyzer.py'], 'dependencies': [], 'acceptance_criteria': ['File exists', 'Has docstrings', 'Follows PEP 8'], 'max_token_budget': 1500},\n            {'id': 'task_04', 'objective': 'Create data_visualizer.py', 'inputs': [], 'outputs': ['data_visualizer.py'], 'dependencies': [], 'acceptance_criteria': ['File exists', 'Has docstrings', 'Follows PEP 8'], 'max_token_budget': 1500},\n            {'id': 'task_05', 'objective': 'Create tests/', 'inputs': ['data_loader.py', 'data_cleaner.py', 'data_analyzer.py', 'data_visualizer.py'], 'outputs': ['tests/test_loader.py', 'tests/test_cleaner.py', 'tests/test_analyzer.py', 'tests/test_visualizer.py'], 'dependencies': ['task_01', 'task_02', 'task_03', 'task_04'], 'acceptance_criteria': ['Test files exist', 'Tests pass'], 'max_token_budget': 2000},\n        ]\n    \n    print(f\"Decomposed into {len(tasks)} mini-tasks.\")\n    \n    # Generate plan\n    print(\"\\n=== Generating Plan ===\")\n    plan = generate_plan_from_decomposed_tasks(prompt, tasks)\n    \n    print(f\"Plan generated: {plan['plan_id']}\")\n    \n    # Show tasks requiring sub-agents\n    subagent_tasks = [t for t in plan['tasks'] if t['requires_subagent']]\n    print(f\"Tasks requiring sub-agents: {len(subagent_tasks)}\")\n    for task in subagent_tasks[:3]:  # Show first 3\n        print(f\"  - {task['task_id']}: {task['objective'][:50]}...\")\n        if task.get('recommended_skill'):\n            print(f\"    Recommended skill: {task['recommended_skill']}\")\n    \n    # Save plan\n    plan_file = os.path.join(TASKBOARDS_DIR, f\"{plan['plan_id']}.json\")\n    with open(plan_file, 'w') as f:\n        json.dump(plan, f, indent=2)\n    \n    print(f\"\\nPlan saved to: {plan_file}\")\n    print(\"\\n=== Demo Complete ===\")\n    \n    return plan\n\ndef run_demo_upgrade():\n    \"\"\"Run demo of upgraded architecture (context lifecycle, semantic indexing, etc.).\"\"\"\n    print(\"=== Running Upgrade Demo ===\")\n    ensure_taskboards_dir()\n    \n    prompt = \"\"\"Analyze the current workspace and create a comprehensive improvement plan.\nThe analysis should include:\n1. File structure analysis: Identify organizational issues and suggest improvements.\n2. Code quality assessment: Review Python scripts for best practices, documentation, and error handling.\n3. Skill integration review: Check how skills are integrated and suggest better patterns.\n4. Performance evaluation: Identify bottlenecks in current workflows.\n5. Security audit: Check for potential security issues in file permissions and data handling.\n6. Documentation assessment: Evaluate completeness and quality of documentation.\n7. Improvement roadmap: Create a prioritized list of improvements with estimated effort.\n\nProvide detailed findings for each area and concrete recommendations.\nThe output should be a comprehensive report with actionable items.\"\"\"\n    \n    print(f\"Original prompt length: {len(prompt)} chars\")\n    \n    result = detect_and_decompose(prompt, max_prompt_tokens=100, max_mini_tasks=MAX_MINI_TASKS)\n    if isinstance(result, tuple) and len(result) == 2:\n        tasks, metrics = result\n    else:\n        tasks = result if result else []\n        metrics = {}\n    \n    if not tasks:\n        tasks = [\n            {'id': 'task_01', 'objective': 'Analyze file structure', 'inputs': [], 'outputs': ['file_structure_analysis.md'], 'dependencies': [], 'acceptance_criteria': ['Analysis file exists', 'Contains specific findings'], 'max_token_budget': 1200, 'complexity_score': 4},\n            {'id': 'task_02', 'objective': 'Assess code quality', 'inputs': [], 'outputs': ['code_quality_report.md'], 'dependencies': [], 'acceptance_criteria': ['Report file exists', 'Includes specific metrics'], 'max_token_budget': 1500, 'complexity_score': 5},\n            {'id': 'task_03', 'objective': 'Review skill integration', 'inputs': [], 'outputs': ['skill_integration_review.md'], 'dependencies': [], 'acceptance_criteria': ['Review file exists', 'Identifies integration patterns'], 'max_token_budget': 1300, 'complexity_score': 6},\n            {'id': 'task_04', 'objective': 'Evaluate performance', 'inputs': ['file_structure_analysis.md', 'code_quality_report.md'], 'outputs': ['performance_evaluation.md'], 'dependencies': ['task_01', 'task_02'], 'acceptance_criteria': ['Evaluation file exists', 'Identifies bottlenecks'], 'max_token_budget': 1400, 'complexity_score': 5},\n            {'id': 'task_05', 'objective': 'Conduct security audit', 'inputs': [], 'outputs': ['security_audit_report.md'], 'dependencies': [], 'acceptance_criteria': ['Audit file exists', 'Lists security issues'], 'max_token_budget': 1600, 'complexity_score': 7},\n            {'id': 'task_06', 'objective': 'Assess documentation', 'inputs': [], 'outputs': ['documentation_assessment.md'], 'dependencies': [], 'acceptance_criteria': ['Assessment file exists', 'Evaluates documentation quality'], 'max_token_budget': 1100, 'complexity_score': 3},\n            {'id': 'task_07', 'objective': 'Create improvement roadmap', 'inputs': ['file_structure_analysis.md', 'code_quality_report.md', 'skill_integration_review.md', 'performance_evaluation.md', 'security_audit_report.md', 'documentation_assessment.md'], 'outputs': ['improvement_roadmap.md'], 'dependencies': ['task_01', 'task_02', 'task_03', 'task_04', 'task_05', 'task_06'], 'acceptance_criteria': ['Roadmap file exists', 'Includes prioritized items'], 'max_token_budget': 1800, 'complexity_score': 8},\n        ]\n    \n    print(f\"Decomposed into {len(tasks)} mini-tasks.\")\n    \n    # Generate plan with upgraded features\n    print(\"\\n=== Generating Plan with Upgraded Features ===\")\n    plan = generate_plan_from_decomposed_tasks(prompt, tasks)\n    \n    print(f\"Plan generated: {plan['plan_id']}\")\n    \n    # Show complexity analysis\n    complexity_scores = [t['complexity_score'] for t in plan['tasks']]\n    avg_complexity = sum(complexity_scores) / len(complexity_scores) if complexity_scores else 0\n    \n    print(f\"Average task complexity: {avg_complexity:.1f}/10\")\n    print(f\"High complexity tasks (≥7): {sum(1 for t in plan['tasks'] if t['complexity_score'] >= 7)}\")\n    \n    # Show dependency analysis\n    deps = plan['dependency_graph']\n    print(f\"Dependency graph: {len(deps['nodes'])} nodes, {len(deps['edges'])} edges\")\n    print(f\"Topological order: {deps['topological_order']}\")\n    \n    # Show resource allocation\n    resources = plan['resource_allocation']\n    print(f\"Resource allocation: {resources['max_concurrent_tasks']} max concurrent tasks\")\n    \n    # Save plan\n    plan_file = os.path.join(TASKBOARDS_DIR, f\"{plan['plan_id']}.json\")\n    with open(plan_file, 'w') as f:\n        json.dump(plan, f, indent=2)\n    \n    print(f\"\\nPlan saved to: {plan_file}\")\n    print(\"\\n=== Upgrade Demo Complete ===\")\n    \n    return plan\n\ndef generate_plan_for_prompt(prompt: str, output_format: str = 'json') -> Dict[str, Any]:\n    \"\"\"\n    Main function: Generate plan for a long prompt.\n    \n    Args:\n        prompt: The original prompt to decompose\n        output_format: 'json' or 'text' (default: 'json')\n    \n    Returns:\n        Plan in requested format\n    \"\"\"\n    ensure_taskboards_dir()\n    \n    print(f\"Processing prompt ({len(prompt)} chars)...\")\n    \n    # Detect and decompose\n    result = detect_and_decompose(prompt, max_prompt_tokens=MAX_PROMPT_TOKENS, max_mini_tasks=MAX_MINI_TASKS)\n    if isinstance(result, tuple) and len(result) == 2:\n        tasks, metrics = result\n    else:\n        tasks = result if result else []\n        metrics = {}\n    \n    if not tasks:\n        # Prompt doesn't need decomposition\n        print(\"Prompt doesn't require decomposition.\")\n        \n        # Create a simple plan with one task\n        simple_task = {\n            'id': 'task_01',\n            'objective': 'Execute prompt directly',\n            'description': prompt[:500] + '...' if len(prompt) > 500 else prompt,\n            'inputs': [],\n            'outputs': ['direct_output.md'],\n            'dependencies': [],\n            'acceptance_criteria': ['Output generated successfully'],\n            'estimated_tokens': len(prompt) // 4,\n            'estimated_runtime': 60,\n            'complexity_score': 1\n        }\n        tasks = [simple_task]\n    \n    print(f\"Decomposed into {len(tasks)} tasks.\")\n    \n    # Generate plan\n    plan = generate_plan_from_decomposed_tasks(prompt, tasks)\n    \n    # Save plan to file\n    plan_file = os.path.join(TASKBOARDS_DIR, f\"{plan['plan_id']}.json\")\n    with open(plan_file, 'w') as f:\n        json.dump(plan, f, indent=2)\n    \n    print(f\"Plan generated: {plan['plan_id']}\")\n    print(f\"Plan saved to: {plan_file}\")\n    \n    # Return in requested format\n    if output_format == 'text':\n        return format_plan_as_text(plan)\n    else:\n        return plan\n\ndef format_plan_as_text(plan: Dict[str, Any]) -> str:\n    \"\"\"Format plan as human-readable text.\"\"\"\n    text = f\"\"\"# Plan: {plan['plan_id']}\nGenerated: {plan['created_at']}\n\n## Original Prompt\n{plan['original_prompt'][:500]}...\n\n## Summary\n- Total tasks: {len(plan['tasks'])}\n- Estimated tokens: {plan['estimated_total_tokens']}\n- Estimated runtime: {plan['estimated_total_runtime_seconds']} seconds\n- Tasks requiring sub-agents: {sum(1 for t in plan['tasks'] if t['requires_subagent'])}\n\n## Tasks\n\"\"\"\n    \n    for i, task in enumerate(plan['tasks'], 1):\n        text += f\"\"\"\n### Task {i}: {task['task_id']}\n**Objective**: {task['objective']}\n\n**Description**: {task['description'][:200]}...\n\n**Dependencies**: {', '.join(task['dependencies']) if task['dependencies'] else 'None'}\n**Outputs**: {', '.join(task['outputs']) if task['outputs'] else 'Task completion'}\n**Requires Sub-agent**: {'Yes' if task['requires_subagent'] else 'No'}\n\"\"\"\n        \n        if task.get('recommended_skill'):\n            text += f\"**Recommended Skill**: {task['recommended_skill']}\\n\"\n        \n        if task.get('recommended_model'):\n            text += f\"**Recommended Model**: {task['recommended_model']}\\n\"\n        \n        text += f\"**Priority**: {task['priority']}\\n\"\n        text += f\"**Complexity**: {task['complexity_score']}/10\\n\"\n    \n    # Add dependency graph\n    deps = plan['dependency_graph']\n    text += f\"\"\"\n## Dependency Graph\n- Nodes: {len(deps['nodes'])}\n- Edges: {len(deps['edges'])}\n- Execution order: {', '.join(deps['topological_order'][:5])}{'...' if len(deps['topological_order']) > 5 else ''}\n\n## Resource Allocation\n- Max concurrent tasks: {plan['resource_allocation']['max_concurrent_tasks']}\n- Token budget per phase: {plan['resource_allocation']['token_budget_per_phase']}\n- Recommended batch size: {plan['resource_allocation']['recommended_batch_size']}\n\n## Validation Protocol\n### Pre-execution checks:\n\"\"\"\n    \n    for check in plan['validation_protocol']['pre_execution_checks']:\n        text += f\"- {check}\\n\"\n    \n    text += \"\"\"\n### Post-execution validation:\n\"\"\"\n    \n    for validation in plan['validation_protocol']['post_execution_validation']:\n        text += f\"- {validation}\\n\"\n    \n    text += \"\"\"\n### Final synthesis requirements:\n\"\"\"\n    \n    for requirement in plan['validation_protocol']['final_synthesis_requirements']:\n        text += f\"- {requirement}\\n\"\n    \n    text += f\"\"\"\n## Next Steps\n1. Main agent should parse and validate this plan\n2. Spawn sub-agents for tasks requiring them\n3. Execute tasks according to dependency graph\n4. Validate outputs using acceptance criteria\n5. Synthesize final result\n\nPlan JSON saved to: {os.path.join(WORKSPACE, '.taskboards', f\"{plan['plan_id']}.json\")}\n\"\"\"\n    \n    return text\n\ndef main():\n    \"\"\"Main entry point.\"\"\"\n    parser = argparse.ArgumentParser(description='Long Prompt Orchestrator - Plan Generator')\n    parser.add_argument('--prompt', type=str, help='Prompt to decompose and plan')\n    parser.add_argument('--demo', choices=['basic', 'complex', 'upgrade'], help='Run demo mode')\n    parser.add_argument('--output-format', choices=['json', 'text'], default='json', help='Output format')\n    parser.add_argument('--output-file', type=str, help='Output file path')\n    \n    args = parser.parse_args()\n    \n    if args.demo:\n        if args.demo == 'basic':\n            result = run_demo_basic()\n        elif args.demo == 'complex':\n            result = run_demo_complex()\n        elif args.demo == 'upgrade':\n            result = run_demo_upgrade()\n        \n        # Output result\n        if args.output_format == 'text' and isinstance(result, dict):\n            output = format_plan_as_text(result)\n        else:\n            output = json.dumps(result, indent=2)\n        \n        if args.output_file:\n            with open(args.output_file, 'w') as f:\n                f.write(output if isinstance(output, str) else json.dumps(output, indent=2))\n            print(f\"Output written to {args.output_file}\")\n        else:\n            print(output)\n        \n        return\n    \n    if args.prompt:\n        result = generate_plan_for_prompt(args.prompt, args.output_format)\n        \n        if args.output_format == 'text' and isinstance(result, dict):\n            output = format_plan_as_text(result)\n        elif isinstance(result, dict):\n            output = json.dumps(result, indent=2)\n        else:\n            output = result\n        \n        if args.output_file:\n            with open(args.output_file, 'w') as f:\n                f.write(output if isinstance(output, str) else json.dumps(output, indent=2))\n            print(f\"Output written to {args.output_file}\")\n        else:\n            print(output)\n    else:\n        parser.print_help()\n        print(\"\\nExamples:\")\n        print(\"  python orchestrate.py --prompt \\\"Your long prompt here\\\"\")\n        print(\"  python orchestrate.py --demo basic\")\n        print(\"  python orchestrate.py --demo complex --output-format text\")\n\nif __name__ == \"__main__\":\n    main()"}],"isError":false,"timestamp":1773100994114}}
