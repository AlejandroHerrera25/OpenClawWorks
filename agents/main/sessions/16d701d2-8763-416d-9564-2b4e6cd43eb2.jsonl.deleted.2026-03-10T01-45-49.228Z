   else:\n        print(f\"   ⚠ Recommendation: {recommended_skill2} (not salesforce-code-auditor, so bug is fixed)\")\n    \n    print()\n    return True\n\ndef test_common_non_salesforce_tasks():\n    \"\"\"Test common non-Salesforce tasks that were incorrectly matched\"\"\"\n    print(\"=== Testing Common Non-Salesforce Tasks ===\")\n    \n    test_cases = [\n        (\"Inventory workspace skills\", \"workspace-janitor\"),\n        (\"Check system health\", \"agent-watchdog\"),\n        (\"Audit workspace files\", \"workspace-janitor\"),\n        (\"Review code quality\", None),  # Generic, no specific skill\n        (\"Validate system configuration\", None),  # Generic, no specific skill\n        (\"Research AI agents\", \"tavily-web-search\"),\n        (\"Search for documentation\", \"tavily-web-search\"),\n        (\"Clean workspace\", \"workspace-janitor\"),\n        (\"Monitor agents\", \"agent-watchdog\"),\n        (\"Analyze memory\", \"vector-memory\"),\n        (\"Handle errors\", \"error-learning-loop\"),\n        (\"Plan complex task\", \"long-prompt-orchestrator\"),\n    ]\n    \n    generator = PlanGenerator(\"Test prompt\")\n    all_passed = True\n    \n    for objective, expected_skill in test_cases:\n        task_data = {\n            'id': 'test_task',\n            'objective': objective,\n            'description': objective,\n            'complexity_score': 3\n        }\n        \n        recommended_skill = generator._recommend_skill_or_role(task_data)\n        \n        # The key test: NEVER recommend salesforce-code-auditor for non-Salesforce tasks\n        if recommended_skill == 'salesforce-code-auditor':\n            print(f\"❌ FAIL: '{objective}' incorrectly recommended salesforce-code-auditor\")\n            all_passed = False\n        elif recommended_skill == expected_skill:\n            print(f\"✓ PASS: '{objective}' -> {recommended_skill}\")\n        else:\n            # Acceptable if not salesforce-code-auditor, even if not exactly