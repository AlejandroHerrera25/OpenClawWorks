{"type":"message","id":"2ce52f30","parentId":"96336430","timestamp":"2026-03-09T18:49:40.762Z","message":{"role":"assistant","content":[{"type":"text","text":"Ahora voy a crear el archivo de definiciones de DoD en YAML:"},{"type":"toolCall","id":"call_00_jl3NMvSUal2zoUxQQB9dJ6Lh","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/salesforce-architect/references/dod_definitions.yaml","content":"# Definition of Done Definitions - Structured YAML Reference\n# Purpose: Deterministic validation rules for specialist outputs\n# Status: Reference asset - DO NOT regenerate on every run\n# Last Updated: 2026-03-09\n\nversion: \"1.0\"\nformat: \"yaml\"\ndescription: \"Definition of Done validation rules\"\n\nvalidation_rules:\n  required_fields:\n    all_roles:\n      - purpose_stated\n      - assumptions_documented\n      - evidence_provided\n      - decisions_documented\n      - next_actions_defined\n    \n    functional_consultant:\n      - process_interpretation\n      - scope_dependencies\n      - official_evidence\n      - open_decisions\n    \n    integration_developer:\n      - integration_pattern\n      - authentication_assumptions\n      - retry_error_strategy\n      - limits_failure_modes\n      - impacted_objects_events\n    \n    custom_ui_developer:\n      - ui_interaction_model\n      - component_structure\n      - event_flow\n      - navigation_implications\n      - accessibility_considerations\n    \n    code_auditor:\n      - findings_listed\n      - code_evidence_snippets\n      - severity_levels\n      - architectural_impact\n      - remediation_suggestions\n      - confidence_level\n    \n    architect:\n      - final_decision\n      - rationale\n      - alternatives_considered\n      - unresolved_risks\n      - next_steps\n\n  required_sections:\n    all_roles:\n      - executive_summary\n      - detailed_analysis\n      - assumptions\n      - evidence\n      - recommendations\n    \n    design_documents:\n      - introduction\n      - scope\n      - business_process_algorithms\n      - system_interactions\n      - object_model\n      - automations\n      - security\n    \n    audit_reports:\n      - executive_summary\n      - technical_assessment\n      - findings\n      - risk_assessment\n      - recommendations\n      - evidence\n    \n    requirements_documents:\n      - introduction\n      - business_context\n      - functional_requirements\n      - non_functional_requirements\n      - acceptance_criteria\n      - assumptions_constraints\n    \n    data_models:\n      - introduction\n      - entity_definitions\n      - relationships\n      - field_definitions\n      - validation_rules\n      - indexing_considerations\n\n  evidence_requirements:\n    minimum_evidence_count: 3\n    evidence_types:\n      - official_documentation\n      - code_snippets\n      - diagrams\n      - test_results\n      - performance_metrics\n      - security_assessments\n    evidence_quality:\n      - source_cited\n      - relevance_explained\n      - timestamp_provided\n      - authority_established\n\n  handoff_completeness:\n    required_elements:\n      - clear_next_owner\n      - outstanding_issues_listed\n      - dependencies_identified\n      - acceptance_criteria_met\n      - quality_gates_passed\n    quality_checks:\n      - no_ambiguous_terms\n      - all_acronyms_defined\n      - consistent_terminology\n      - actionable_recommendations\n\nvalidation_thresholds:\n  blocking_threshold: 0.8  # Must have 80% of required fields\n  warning_threshold: 0.9   # Should have 90% of required fields\n  minimum_evidence_score: 0.7\n  minimum_handoff_score: 0.8\n\n# Field definitions for better understanding\nfield_definitions:\n  purpose_stated:\n    description: \"Clear statement of what the artifact aims to achieve\"\n    examples:\n      - \"The purpose of this document is to...\"\n      - \"This design aims to solve...\"\n      - \"Objective: To integrate...\"\n  \n  assumptions_documented:\n    description: \"Explicit listing of assumptions made during analysis/design\"\n    examples:\n      - \"Assumption: The ERP system supports REST API\"\n      - \"Assuming user count remains under 1000\"\n      - \"Presumption: Salesforce licenses include...\"\n  \n  evidence_provided:\n    description: \"Supporting evidence for decisions and recommendations\"\n    examples:\n      - \"According to Salesforce documentation...\"\n      - \"Reference: Trailhead module on...\"\n      - \"Based on security assessment report...\"\n  \n  decisions_documented:\n    description: \"Clear documentation of decisions made and alternatives considered\"\n    examples:\n      - \"Decision: Use REST API instead of SOAP because...\"\n      - \"Chose OAuth 2.0 over basic auth due to...\"\n      - \"Selected Lightning Web Components over Visualforce for...\"\n  \n  next_actions_defined:\n    description: \"Specific, actionable next steps with owners\"\n    examples:\n      - \"Next: Create technical design (assigned to Integration Developer)\"\n      - \"Action: Update data model with new fields (due: 2026-03-15)\"\n      - \"Todo: Test integration with sample data\"\n\n# Section definitions\nsection_definitions:\n  executive_summary:\n    description: \"High-level overview of the artifact\"\n    required_elements:\n      - \"Problem statement\"\n      - \"Solution overview\"\n      - \"Key recommendations\"\n      - \"Expected outcomes\"\n  \n  detailed_analysis:\n    description: \"In-depth analysis of the subject matter\"\n    required_elements:\n      - \"Current state analysis\"\n      - \"Requirements analysis\"\n      - \"Solution analysis\"\n      - \"Impact assessment\"\n  \n  assumptions:\n    description: \"Explicit listing of assumptions\"\n    required_elements:\n      - \"Business assumptions\"\n      - \"Technical assumptions\"\n      - \"Resource assumptions\"\n      - \"Timeline assumptions\"\n  \n  evidence:\n    description: \"Supporting evidence for analysis and decisions\"\n    required_elements:\n      - \"Documentation references\"\n      - \"Test results\"\n      - \"Performance data\"\n      - \"Security assessments\"\n  \n  recommendations:\n    description: \"Actionable recommendations based on analysis\"\n    required_elements:\n      - \"Recommended approach\"\n      - \"Implementation steps\"\n      - \"Risk mitigation\"\n      - \"Success criteria\"\n\n# Role-specific validation profiles\nrole_profiles:\n  functional_consultant:\n    focus_areas:\n      - \"Business process analysis\"\n      - \"Requirement documentation\"\n      - \"Solution design\"\n      - \"User experience\"\n    critical_fields:\n      - process_interpretation\n      - scope_dependencies\n      - official_evidence\n    quality_indicators:\n      - \"Clear process flows\"\n      - \"Complete requirement traceability\"\n      - \"Evidence-based recommendations\"\n  \n  integration_developer:\n    focus_areas:\n      - \"Integration architecture\"\n      - \"API design\"\n      - \"Error handling\"\n      - \"Performance optimization\"\n    critical_fields:\n      - integration_pattern\n      - authentication_assumptions\n      - retry_error_strategy\n    quality_indicators:\n      - \"Clear integration patterns\"\n      - \"Robust error handling\"\n      - \"Performance considerations\"\n  \n  custom_ui_developer:\n    focus_areas:\n      - \"User interface design\"\n      - \"Component architecture\"\n      - \"User interaction\"\n      - \"Accessibility\"\n    critical_fields:\n      - ui_interaction_model\n      - component_structure\n      - accessibility_considerations\n    quality_indicators:\n      - \"Clear UI interaction models\"\n      - \"Modular component design\"\n      - \"Accessibility compliance\"\n  \n  code_auditor:\n    focus_areas:\n      - \"Code quality assessment\"\n      - \"Security review\"\n      - \"Performance analysis\"\n      - \"Architectural alignment\"\n    critical_fields:\n      - findings_listed\n      - code_evidence_snippets\n      - severity_levels\n    quality_indicators:\n      - \"Specific, actionable findings\"\n      - \"Code evidence for all findings\"\n      - \"Clear severity classification\"\n  \n  architect:\n    focus_areas:\n      - \"Architectural decisions\"\n      - \"Risk assessment\"\n      - \"Solution integration\"\n      - \"Governance enforcement\"\n    critical_fields:\n      - final_decision\n      - rationale\n      - alternatives_considered\n    quality_indicators:\n      - \"Clear architectural decisions\"\n      - \"Well-reasoned rationale\"\n      - \"Consideration of alternatives\"\n\n# Validation scoring weights\nscoring_weights:\n  required_fields: 0.4\n  required_s"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"aborted","timestamp":1773082110774,"errorMessage":"Request was aborted"}}
