{"type":"message","id":"4ba049bb","parentId":"9bd6aaa5","timestamp":"2026-03-09T18:55:20.666Z","message":{"role":"assistant","content":[{"type":"text","text":"Perfecto, voy a continuar implementando el sistema robusto de README/project control file. Este será la fuente única de verdad del estado del proyecto."},{"type":"toolCall","id":"call_00_9dAWgc4f95XVynC7uXR2rLub","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/salesforce-architect/scripts/project_control.py","content":"#!/usr/bin/env python3\n\"\"\"\nRobust Project Control File System.\nMaintains README.md as single source of truth for project state.\n\"\"\"\n\nimport os\nimport sys\nimport yaml\nimport json\nimport logging\nfrom pathlib import Path\nfrom datetime import datetime\nfrom typing import Dict, List, Optional, Any, Tuple\nfrom enum import Enum\n\n# Configure logging\nlogging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')\nlogger = logging.getLogger(__name__)\n\nclass ProjectControl:\n    \"\"\"Robust project control file management.\"\"\"\n    \n    def __init__(self, project_root: Path):\n        self.project_root = Path(project_root)\n        self.readme_path = self.project_root / 'README.md'\n        self.control_file_path = self.project_root / '.project_control.yaml'\n        \n        # Ensure project directory exists\n        self.project_root.mkdir(parents=True, exist_ok=True)\n        \n        # Initialize or load control file\n        self.control_data = self._load_or_initialize_control()\n        \n        # Ensure README is in sync\n        self._sync_readme_with_control()\n    \n    def _load_or_initialize_control(self) -> Dict:\n        \"\"\"Load existing control file or initialize new one.\"\"\"\n        if self.control_file_path.exists():\n            try:\n                with open(self.control_file_path, 'r', encoding='utf-8') as f:\n                    control_data = yaml.safe_load(f)\n                \n                # Validate structure\n                if self._validate_control_structure(control_data):\n                    logger.info('Loaded existing project control file')\n                    return control_data\n                else:\n                    logger.warning('Control file structure invalid, reinitializing')\n            except Exception as e:\n                logger.error('Error loading control file: %s, reinitializing', e)\n        \n        # Initialize new control file\n        return self._initialize_control_file()\n    \n    def _validate_control_structure(self, control_data: Dict) -> bool:\n        \"\"\"Validate control file structure.\"\"\"\n        required_sections = [\n            'project', 'current_state', 'state_history', \n            'artifact_versions', 'code_audits', 'next_actions'\n        ]\n        \n        if not isinstance(control_data, dict):\n            return False\n        \n        for section in required_sections:\n            if section not in control_data:\n                return False\n        \n        return True\n    \n    def _initialize_control_file(self) -> Dict:\n        \"\"\"Initialize new project control file.\"\"\"\n        project_name = self.project_root.name\n        \n        control_data = {\n            'project': {\n                'name': project_name,\n                'created': datetime.now().isoformat(),\n                'last_updated': datetime.now().isoformat(),\n                'architect': 'salesforce-architect',\n                'clouds': [],\n                'description': ''\n            },\n            'current_state': {\n                'state': 'DISCOVERY',\n                'entered': datetime.now().isoformat(),\n                'validated': None,\n                'blocking_conditions': []\n            },\n            'state_history': [\n                {\n                    'state': 'DISCOVERY',\n                    'entered': datetime.now().isoformat(),\n                    'exited': None,\n                    'duration_seconds': None,\n                    'trigger': 'project_creation'\n                }\n            ],\n            'artifact_versions': {\n                'discovery': {'version': 0, 'last_updated': None, 'files': []},\n                'requirements': {'version': 0, 'last_updated': None, 'files': []},\n                'fit_gap': {'version': 0, 'last_updated': None, 'files': []},\n                'design': {'version': 0, 'last_updated': None, 'files': []},\n                'data_model': {'version': 0, 'last_updated': None, 'files': []},\n                'architecture_review': {'version': 0, 'last_updated': None, 'files': []},\n                'code_audit': {'version': 0, 'last_updated': None, 'files': []},\n                'remediation': {'version': 0, 'last_updated': None, 'files': []}\n            },\n            'code_audits': [],\n            'next_actions': [],\n            'specialist_assignments': [],\n            'incidents': [],\n            'metadata': {\n                'schema_version': '1.0',\n                'last_sync': datetime.now().isoformat(),\n                'auto_update': True\n            }\n        }\n        \n        self._save_control_file(control_data)\n        logger.info('Initialized new project control file')\n        \n        return control_data\n    \n    def _save_control_file(self, control_data: Dict = None):\n        \"\"\"Save control file to disk.\"\"\"\n        if control_data is None:\n            control_data = self.control_data\n        \n        # Update metadata\n        control_data['metadata']['last_sync'] = datetime.now().isoformat()\n        control_data['project']['last_updated'] = datetime.now().isoformat()\n        \n        # Save to YAML\n        with open(self.control_file_path, 'w', encoding='utf-8') as f:\n            yaml.dump(control_data, f, default_flow_style=False, allow_unicode=True)\n        \n        logger.debug('Saved project control file')\n    \n    def _sync_readme_with_control(self):\n        \"\"\"Ensure README.md is in sync with control file.\"\"\"\n        readme_content = self._generate_readme_content()\n        self.readme_path.write_text(readme_content, encoding='utf-8')\n        logger.info('README.md synchronized with control file')\n    \n    def _generate_readme_content(self) -> str:\n        \"\"\"Generate README.md content from control data.\"\"\"\n        project = self.control_data['project']\n        current_state = self.control_data['current_state']\n        artifact_versions = self.control_data['artifact_versions']\n        code_audits = self.control_data['code_audits']\n        next_actions = self.control_data['next_actions']\n        \n        # Build README content\n        lines = []\n        \n        # Project header\n        lines.append(f'# Project: {project[\"name\"]}')\n        lines.append('')\n        \n        if project.get('description'):\n            lines.append(f'**Description**: {project[\"description\"]}')\n            lines.append('')\n        \n        # Current state\n        lines.append('## Current State')\n        lines.append(f'- **State**: {current_state[\"state\"]}')\n        lines.append(f'- **Entered**: {current_state[\"entered\"]}')\n        \n        if current_state.get('validated'):\n            lines.append(f'- **Validated**: {current_state[\"validated\"]}')\n        \n        if current_state.get('blocking_conditions'):\n            lines.append('- **Blocking Conditions**:')\n            for condition in current_state['blocking_conditions']:\n                lines.append(f'  - {condition}')\n        \n        lines.append('')\n        \n        # State history\n        lines.append('## State History')\n        for history in self.control_data['state_history']:\n            state_line = f'- **{history[\"state\"]}**: {history[\"entered\"]}'\n            if history.get('exited'):\n                state_line += f' - {history[\"exited\"]}'\n                if history.get('duration_seconds'):\n                    hours = history['duration_seconds'] / 3600\n                    state_line += f' ({hours:.1f}h)'\n            \n            if history.get('trigger'):\n                state_line += f' *({history[\"trigger\"]})*'\n            \n            lines.append(state_line)\n        \n        lines.append('')\n        \n        # Artifact versions\n        lines.append('## Artifact Versions')\n        for artifact_type, version_info in artifact_versions.items():\n            version = version_info.get('version', 0)\n            last_updated = version_info.get('last_updated', 'Never')\n            files = version_info.get('files', [])\n            \n            artifact_line = f'- **{artifact_type.replace(\"_\", \" \").title()}**: v{version}'\n            if last_updated:\n                artifact_line += f' (updated: {last_updated})'\n            \n            lines.append(artifact_line)\n            \n            # List files if available\n            if files:\n                for file in files[:3]:  # Show first 3 files\n                    lines.append(f'  - `{file}`')\n                if len(files) > 3:\n                    lines.append(f'  - ... and {len(files) - 3} more')\n        \n        lines.append('')\n        \n        # Code audits\n        if code_audits:\n            lines.append('## Code Audits')\n            for audit in code_audits:\n                audit_line = f'- **{audit.get(\"case_id\", \"Unknown\")}**: {audit.get(\"mode\", \"Unknown\")}'\n                if audit.get('date'):\n                    audit_line += f' ({audit[\"date\"]})'\n                if audit.get('status'):\n                    audit_line += f' - {audit[\"status\"]}'\n                \n                lines.append(audit_line)\n                \n                if audit.get('findings_summary'):\n                    lines.append(f'  - Findings: {audit[\"findings_summary\"]}')\n            \n            lines.append('')\n        \n        # Next actions\n        if next_actions:\n            lines.append('## Next Actions')\n            for action in next_actions:\n                status = '✅' if action.get('completed') else '⬜'\n                priority = action.get('priority', 'medium')\n                priority_symbol = '🔴' if priority == 'high' else '🟡' if priority == 'medium' else '🟢'\n                \n                action_line = f'{status} {priority_symbol} **{action.get(\"title\", \"Untitled\")}**'\n                if action.get('assigned_to'):\n                    action_line += f' → {action[\"assigned_to\"]}'\n                if action.get('due_date'):\n                    action_line += f' (due: {action[\"due_date\"]})'\n                \n                lines.append(action_line)\n                \n                if action.get('description'):\n                    lines.append(f'  - {action[\"description\"]}')\n            \n            lines.append('')\n        \n        # Project metadata\n        lines.append('## Project Metadata')\n        lines.append(f'- **Created**: {project.get(\"created\", \"Unknown\")}')\n        lines.append(f'- **Last Updated**: {project.get(\"last_updated\", \"Unknown\")}')\n        lines.append(f'- **Architect**: {project.get(\"architect\", \"Unknown\")}')\n        \n        if project.get('clouds'):\n            lines.append(f'- **Clouds**: {\", \".join(project[\"clouds\"])}')\n        \n        lines.append('')\n        lines.append('---')\n        lines.append('*This file is auto-generated from `.project_control.yaml`. Do not edit manually.*')\n        \n        return '\\n'.join(lines)\n    \n    # Public API methods\n    \n    def update_state(self, new_state: str, trigger: str = None, \n                    blocking_conditions: List[str] = None) -> bool:\n        \"\"\"\n        Update project state with proper history tracking.\n        \n        Args:\n            new_state: New state name\n            trigger: What triggered the state change\n            blocking_conditions: Any blocking conditions for new state\n            \n        Returns:\n            True if successful, False otherwise\n        \"\"\"\n        old_state = self.control_data['current_state']['state']\n        \n        if old_state == new_state:\n            logger.info('State unchanged: %s', new_state)\n            return True\n        \n        # Update current state history\n        now = datetime.now().isoformat()\n        \n        # Find and update the previous state history entry\n        for history in self.control_data['state_history']:\n            if history['state'] == old_state and history['exited'] is None:\n                history['exited'] = now\n                if history['entered']:\n                    try:\n                        entered_dt = datetime.fromisoformat(history['entered'].replace('Z', '+00:00'))\n                        exited_dt = datetime.fromisoformat(now.replace('Z', '+00:00'))\n                        duration = (exited_dt - entered_dt).total_seconds()\n                        history['duration_seconds'] = duration\n                    except Exception as e:\n                        logger.warning('Could not calculate duration: %s', e)\n                break\n        \n        # Add new state history entry\n        self.control_data['state_history'].append({\n            'state': new_state,\n            'entered': now,\n            'exited': None,\n            'duration_seconds': None,\n            'trigger': trigger or 'state_transition'\n        })\n        \n        # Update current state\n        self.control_data['current_state'] = {\n            'state': new_state,\n            'entered': now,\n            'validated': None,\n            'blocking_conditions': blocking_conditions or []\n        }\n        \n        # Save and sync\n        self._save_control_file()\n        self._sync_readme_with_control()\n        \n        logger.info('State updated: %s → %s', old_state, new_state)\n        return True\n    \n    def register_artifact(self, artifact_type: str, file_path: str, \n                         version_increment: bool = False) -> bool:\n        \"\"\"\n        Register an artifact in the project control.\n        \n        Args:\n            artifact_type: Type of artifact (discovery, design, etc.)\n            file_path: Path to artifact file (relative to project root)\n            version_increment: Whether to increment version\n            \n        Returns:\n            True if successful, False otherwise\n        \"\"\"\n        artifact_type = artifact_type.lower()\n        \n        if artifact_type not in self.control_data['artifact_versions']:\n            logger.error('Unknown artifact type: %s', artifact_type)\n            return False\n        \n        artifact_info = self.control_data['artifact_versions'][artifact_type]\n        \n        # Increment version if requested\n        if version_increment:\n            artifact_info['version'] += 1\n        \n        # Update last updated timestamp\n        artifact_info['last_updated'] = datetime.now().isoformat()\n        \n        # Add file to list if not already there\n        if file_path not in artifact_info['files']:\n            artifact_info['files'].append(file_path)\n        \n        # Save and sync\n        self._save_control_file()\n        self._sync_readme_with_control()\n        \n        logger.info('Registered artifact: %s/%s v%d', artifact_type, file_path, artifact_info['version'])\n        return True\n    \n    def add_code_audit(self, case_id: str, mode: str, findings_summary: str = None,\n                      status: str = 'open') -> bool:\n        \"\"\"\n        Add a code audit record.\n        \n        Args:\n            case_id: Unique audit case identifier\n            mode: Audit mode (A, B, C)\n            findings_summary: Summary of findings\n            status: Audit status (open, in_remediation, closed)\n            \n        Returns:\n            True if successful, False otherwise\n        \"\"\"\n        # Check if audit already exists\n        for audit in self.control_data['code_audits']:\n            if audit.get('case_id') == case_id:\n                logger.warning('Code audit %s already exists, updating', case_id)\n                audit.update({\n                    'mode': mode,\n                    'findings_summary': findings_summary,\n                    'status': status,\n                    'last_updated': datetime.now().isoformat()\n                })\n                self._save_control_file()\n                self._sync_readme_with_control()\n                return True\n        \n        # Add new audit\n        self.control_data['code_audits'].append({\n            'case_id': case_id,\n            'mode': mode,\n            'date': datetime.now().isoformat(),\n            'findings_summary': findings_summary,\n            'status': status,\n            'last_updated': datetime.now().isoformat()\n        })\n        \n        # Save and sync\n        self._save_control_file()\n        self._sync_readme_with_control()\n        \n        logger.info('Added code audit: %s (mode: %s)', case_id, mode)\n        return True\n    \n    def add_next_action(self, title: str, description: str = None,\n                       priority: str = 'medium', assigned_to: str = None,\n                       due_date: str = None) -> str:\n        \"\"\"\n        Add a next action item.\n        \n        Args:\n            title: Action title\n            description: Action description\n            priority: Priority (high, medium, low)\n            assigned_to: Who is assigned\n            due_date: Due date (ISO format)\n            \n        Returns:\n            Action ID\n        \"\"\"\n        action_id = f'action_{len(self.control_data[\"next_actions\"]) + 1:03d}'\n        \n        action = {\n            'id': action_id,\n            'title': title,\n            'description': description,\n            'priority': priority,\n            'assigned_to': assigned_to,\n            'due_date': due_date,\n            'created': datetime.now().isoformat(),\n            'completed': False,\n            'completed_date': None\n        }\n        \n        self.control_data['next_actions'].append(action)\n        \n        # Save and sync\n        self._save_control_file()\n        self._sync_readme_with_control()\n        \n        logger.info('Added next action: %s', title)\n        return action_id\n    \n    def complete_action(self, action_id: str) -> bool:\n        \"\"\"\n        Mark an action as completed.\n        \n        Args:\n            action_id: Action ID to complete\n            \n        Returns:\n            True if successful, False otherwise\n        \"\"\"\n        for action in self.control_data['next_actions']:\n            if action['id'] == action_id:\n                action['completed'] = True\n                action['completed_date'] = datetime.now().isoformat()\n                \n                # Save and sync\n                self._save_control_file()\n                self._sync_readme_with_control()\n                \n                logger.info('Completed action: %s', action['title'])\n                return True\n        \n        logger.warning('Action not found: %s', action_id)\n        return False\n    \n    def update_project_info(self, **kwargs) -> bool:\n        \"\"\"\n        Update project information.\n        \n        Args:\n            **kwargs: Project fields to update (name, description, clouds, etc.)\n            \n        Returns:\n            True if successful, False otherwise\n        \"\"\"\n        valid_fields = ['name', 'description', 'clouds', 'architect']\n        \n        for field, value in kwargs.items():\n            if field in valid_fields:\n                self.control_data['project'][field] = value\n        \n        # Save and sync\n        self._save_control_file()\n        self._sync_readme_with_control()\n        \n        logger.info('Updated"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":2466,"output":4096,"cacheRead":98176,"cacheWrite":0,"totalTokens":104738,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"length","timestamp":1773082391514}}
