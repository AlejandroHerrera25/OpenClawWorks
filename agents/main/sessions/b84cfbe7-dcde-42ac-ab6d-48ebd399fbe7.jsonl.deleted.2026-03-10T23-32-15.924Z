{"type":"message","id":"1c678496","parentId":"293f64c5","timestamp":"2026-03-09T23:33:30.234Z","message":{"role":"toolResult","toolCallId":"call_00_10yYYqVtSQZOVwP87MAH9EKW","toolName":"read","content":[{"type":"text","text":"    # Add other sections in order\n    for section_title in section_order[1:]:  # Skip title, already added\n        if section_title in sections:\n            content_lines.append(sections[section_title])\n            content_lines.append(\"\")  # Add blank line between sections\n    \n    # Join and ensure max 400 lines\n    full_content = \"\\n\".join(content_lines).strip()\n    lines = full_content.split('\\n')\n    \n    if len(lines) > 400:\n        # Trim from less important sections (start trimming from the end)\n        print(f\"Warning: MEMORY.md would be {len(lines)} lines, trimming to 400\")\n        # Keep title and essential sections, trim from milestones if needed\n        lines = lines[:400]\n    \n    return \"\\n\".join(lines)\n\ndef update_projects_md(project_updates):\n    \"\"\"Update projects.md with status changes.\"\"\"\n    if not os.path.exists(PROJECTS_PATH):\n        print(f\"Warning: {PROJECTS_PATH} not found\")\n        return\n    \n    content = read_file(PROJECTS_PATH)\n    \n    # Simple update: if we found completion events, update OpenClaw Memory System status\n    for project, updates in project_updates.items():\n        if project == \"OpenClaw Memory System\":\n            for update in updates:\n                if any(word in update.lower() for word in ['completed', 'finished', 'done']):\n                    # Update status in projects.md\n                    content = re.sub(\n                        r'## OpenClaw Memory System\\n- \\*\\*Status\\*\\*:.*?\\n',\n                        '## OpenClaw Memory System\\n- **Status**: Completed\\n',\n                        content\n                    )\n                    print(\"Updated OpenClaw Memory System status to 'Completed' in projects.md\")\n    \n    write_file(PROJECTS_PATH, content)\n\ndef run_flush_script():\n    \"\"\"Run the memory flush script.\"\"\"\n    if not os.path.exists(FLUSH_SCRIPT):\n        print(f\"Error: Flush script not found at {FLUSH_SCRIPT}\")\n        return False\n    \n    try:\n        result = subprocess.run(\n            [\"python3\", FLUSH_SCRIPT],\n            capture_output=True,\n            text=True,\n            cwd=os.path.dirname(FLUSH_SCRIPT)\n        )\n        \n        if result.returncode == 0:\n            print(\"Memory flush completed successfully\")\n            return True\n        else:\n            print(f\"Memory flush failed: {result.stderr}\")\n            return False\n    except Exception as e:\n        print(f\"Error running flush script: {e}\")\n        return False\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Auto-curate MEMORY.md\")\n    parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"Show what would be done without making changes\")\n    parser.add_argument(\"--verbose\", action=\"store_true\", help=\"Show detailed output\")\n    args = parser.parse_args()\n    \n    print(\"=== MEMORY.md Auto-Curation ===\")\n    \n    # Step 1: Find recent daily notes\n    print(\"\\n1. Finding recent daily notes...\")\n    daily_files = get_recent_daily_notes(7)\n    if args.verbose:\n        print(f\"   Found {len(daily_files)} daily notes:\")\n        for f in daily_files:\n            print(f\"   - {os.path.basename(f)}\")\n    \n    # Step 2: Read current MEMORY.md\n    print(\"\\n2. Reading current MEMORY.md...\")\n    memory_content = read_file(MEMORY_PATH)\n    if not memory_content:\n        print(\"   Error: MEMORY.md is empty or not found\")\n        return 1\n    \n    # Step 3: Analyze daily notes and identify updates\n    print(\"\\n3. Analyzing daily notes for updates...\")\n    events, project_updates = analyze_daily_notes(daily_files)\n    \n    if args.verbose:\n        print(f\"   Found {len(events)} significant events\")\n        print(f\"   Found updates for {len(project_updates)} projects\")\n    \n    # Step 4: Update MEMORY.md\n    print(\"\\n4. Updating MEMORY.md...\")\n    \n    # Extract sections\n\n[51 more lines in file. Use offset=300 to continue.]"}],"isError":false,"timestamp":1773099210231}}
