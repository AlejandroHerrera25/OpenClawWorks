{"type":"message","id":"17e7425b","parentId":"ca4b8614","timestamp":"2026-03-05T21:29:39.628Z","message":{"role":"toolResult","toolCallId":"call_00_FOaBXMIccisrcyMm1VT8ySl6","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nMain orchestrator for long prompt decomposition and execution.\nSupports demo modes (basic, complex) and real orchestration.\n\"\"\"\n\nimport sys\nimport os\nimport json\nimport argparse\nimport tempfile\nimport shutil\nfrom typing import Dict, List, Any, Optional\n\n# Add skill scripts directory to path\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\n\nfrom decompose import detect_and_decompose\nfrom todo import Checklist\nfrom token_budget import TokenBudget\nfrom validate import validate_final_output\nfrom recovery import recover_from_interruption\nfrom learning_emit import emit_incident\n\n# Configuration defaults\nMAX_PROMPT_TOKENS = 4000\nMAX_MINI_TASKS = 20\nGLOBAL_TOKEN_BUDGET = 16000\nINPUT_TOKEN_LIMIT = 4000\nOUTPUT_TOKEN_LIMIT = 2000\n\nWORKSPACE = os.path.expanduser(\"~/.openclaw/workspace\")\nTASKBOARDS_DIR = os.path.join(WORKSPACE, \".taskboards\")\n\ndef ensure_taskboards_dir():\n    \"\"\"Ensure .taskboards directory exists.\"\"\"\n    os.makedirs(TASKBOARDS_DIR, exist_ok=True)\n    os.makedirs(os.path.join(TASKBOARDS_DIR, \"checkpoints\"), exist_ok=True)\n\ndef simulate_model_call(context: str, max_output_tokens: int) -> str:\n    \"\"\"\n    Simulate a model call for demo purposes.\n    In production, replace with actual OpenClaw tooling.\n    \"\"\"\n    # For demo, just echo the objective and produce a placeholder output.\n    lines = context.split('\\n')\n    objective = next((line for line in lines if 'Objective:' in line), '')\n    return f\"Simulated output for {objective[:50]}...\\nThis output satisfies the acceptance criteria.\"\n\ndef run_demo_basic():\n\n[269 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1772746179583}}
