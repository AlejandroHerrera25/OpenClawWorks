r, Any]) -> Optional[str]:\n        \"\"\"Recommend skill for task based on content analysis.\"\"\"\n        objective = task_data.get('objective', '').lower()\n        description = task_data.get('description', '').lower()\n        \n        # Check for Salesforce-related content\n        salesforce_keywords = ['salesforce', 'apex', 'lwc', 'visualforce', 'soql', 'flow']\n        if any(keyword in objective or keyword in description for keyword in salesforce_keywords):\n            return \"salesforce-architect\"\n        \n        # Check for web search/research\n        search_keywords = ['search', 'research', 'find', 'look up', 'web', 'internet']\n        if any(keyword in objective or keyword in description for keyword in search_keywords):\n            return \"tavily-web-search\"\n        \n        # Check for code auditing\n        audit_keywords = ['audit', 'review', 'check', 'validate', 'security', 'code quality']\n        if any(keyword in objective or keyword in description for keyword in audit_keywords):\n            return \"salesforce-code-auditor\"\n        \n        # Check for workspace maintenance\n        maintenance_keywords = ['clean', 'organize', 'tidy', 'maintain', 'janitor']\n        if any(keyword in objective or keyword in description for keyword in maintenance_keywords):\n            return \"workspace-janitor\"\n        \n        return None\n    \n    def _recommend_model(self, task_data: Dict[str, Any]) -> Optional[str]:\n        \"\"\"Recommend model for task based on complexity.\"\"\"\n        complexity_score = task_data.get('complexity_score', 0)\n        \n        if complexity_score >= 8:\n            return \"gpt-4\"  # High complexity tasks\n        elif complexity_score >= 5:\n            return \"deepseek-chat\"  # Medium complexity tasks\n        else:\n            return None  # Use default model\n    \n    def _determine_priority(self, task_data: Dict[str, Any]) -> TaskPriority:\n        \"\"\"Determine task priority.\"\"\"\n        complexity_score = task_data.get('complexity_score', 0)\n        \n        if complexity_score >= 8:\n            return TaskPriority.CRITICAL\n        elif complexity_score >= 5:\n            return TaskPriority.HIGH\n        elif complexity_score >= 3:\n            return TaskPriority.MEDIUM\n        else:\n            return TaskPriority.LOW\n    \n    def build_dependency_graph(self) -> Dict[str, Any]:\n        \"\"\"Build dependency graph from tasks.\"\"\"\n        nodes = [task.task_id for task in self.tasks]\n        edges = []\n        \n        for task in self.tasks:\n            for dep in task.dependencies:\n                edges.append([dep, task.task_id])\n        \n        # Calculate topological order (simplified Kahn's algorithm)\n\n[227 more lines in file. Use offset=180 to continue.]"}],"isError":false,"timestamp":1773101067995}}
