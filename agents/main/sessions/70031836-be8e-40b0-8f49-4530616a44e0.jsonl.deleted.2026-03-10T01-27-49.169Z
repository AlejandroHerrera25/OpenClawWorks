{"type":"message","id":"b7806670","parentId":"c5cf3357","timestamp":"2026-03-10T00:36:04.733Z","message":{"role":"assistant","content":[{"type":"text","text":"The file got cut off. Let me complete it:"},{"type":"toolCall","id":"call_00_p0TLvQhlfWrzI5rFzdjpXwWV","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/salesforce-code-auditor/scripts/report_generator.py","content":"    def _get_risk_analysis(self):\n        \"\"\"Get risk analysis.\"\"\"\n        analysis = []\n        \n        overall = self.risk_assessment['risk_assessment']['overall_risk']\n        \n        analysis.append(\"#### Risk of Current Architecture:\")\n        analysis.append(f\"- **Current Risk Level**: {overall['level']} ({overall['score']}/100)\")\n        \n        if overall['level'] in ['CRITICAL', 'HIGH']:\n            analysis.append(\"- **Risk Assessment**: Architecture carries significant risk\")\n            analysis.append(\"- **Primary Concerns**: \" + self._get_primary_concerns())\n        else:\n            analysis.append(\"- **Risk Assessment**: Architecture is relatively low risk\")\n            analysis.append(\"- **Minor Concerns**: Review medium findings for optimization\")\n        \n        analysis.append(\"\\n#### Risk of Proposed Changes:\")\n        analysis.append(\"- **Implementation Risk**: Low to Medium (standard refactoring)\")\n        analysis.append(\"- **Regression Risk**: Medium (requires thorough testing)\")\n        analysis.append(\"- **Timeline Risk**: Depends on remediation scope\")\n        \n        analysis.append(\"\\n#### Risk of No Changes:\")\n        if overall['level'] in ['CRITICAL', 'HIGH']:\n            analysis.append(\"- **High Risk**: System failures, security vulnerabilities likely\")\n            analysis.append(\"- **Business Impact**: Potential data loss, performance issues\")\n        else:\n            analysis.append(\"- **Low Risk**: System functional but suboptimal\")\n            analysis.append(\"- **Business Impact**: Technical debt accumulation\")\n        \n        return \"\\n\".join(analysis)\n    \n    def _get_primary_concerns(self):\n        \"\"\"Get primary concerns from findings.\"\"\"\n        concerns = []\n        critical_findings = [f for f in self.findings['findings'] if f['severity'] == 'CRITICAL']\n        \n        for finding in critical_findings[:3]:  # Top 3 concerns\n            if 'SOQL' in finding['pattern']:\n                concerns.append(\"performance/scalability\")\n            elif 'FLS' in finding['pattern']:\n                concerns.append(\"security\")\n            elif 'RECURSION' in finding['pattern']:\n                concerns.append(\"reliability\")\n        \n        return \", \".join(set(concerns)) if concerns else \"code quality\"\n    \n    def _get_evidence_based_recommendations(self):\n        \"\"\"Get evidence-based recommendations.\"\"\"\n        recommendations = []\n        \n        # Group findings by pattern\n        pattern_groups = {}\n        for finding in self.findings['findings']:\n            pattern = finding['pattern']\n            if pattern not in pattern_groups:\n                pattern_groups[pattern] = []\n            pattern_groups[pattern].append(finding)\n        \n        # Generate recommendations for each pattern\n        for pattern, findings in pattern_groups.items():\n            if len(findings) > 0:\n                first_finding = findings[0]\n                count = len(findings)\n                \n                recommendations.append(f\"#### {pattern} ({count} occurrences)\")\n                recommendations.append(f\"- **Evidence**: Found in {count} locations\")\n                recommendations.append(f\"- **Example**: `{first_finding['file']}:{first_finding['line']}`\")\n                recommendations.append(f\"- **Recommendation**: {first_finding['recommendation']}\")\n                recommendations.append(f\"- **Impact**: {first_finding['impact']}\")\n                recommendations.append(\"\")\n        \n        return \"\\n\".join(recommendations)\n    \n    def _get_detailed_evidence(self):\n        \"\"\"Get detailed evidence.\"\"\"\n        evidence = []\n        \n        evidence.append(\"#### Code Evidence for Critical Findings:\")\n        \n        critical_findings = [f for f in self.findings['findings'] if f['severity'] == 'CRITICAL']\n        for finding in critical_findings:\n            evidence.append(f\"##### {finding['pattern']} in `{finding['file']}:{finding['line']}`\")\n            evidence.append(f\"**Description**: {finding['description']}\")\n            evidence.append(f\"**Code**:\")\n            evidence.append(f\"```\\n{finding['code_snippet']}\\n```\")\n            evidence.append(f\"**Recommendation**: {finding['recommendation']}\")\n            evidence.append(\"\")\n        \n        if not critical_findings:\n            evidence.append(\"No critical findings requiring detailed evidence.\")\n        \n        return \"\\n\".join(evidence)\n    \n    def _assess_design_feasibility(self):\n        \"\"\"Assess design feasibility.\"\"\"\n        blockers = self.risk_assessment['risk_assessment']['blocking_conditions']\n        critical_blockers = len(blockers['critical_blockers'])\n        \n        if critical_blockers > 0:\n            return {\n                'overall': 'NOT FEASIBLE without changes',\n                'concerns': f'{critical_blockers} critical issues block implementation',\n                'evidence': 'See critical findings section'\n            }\n        else:\n            return {\n                'overall': 'FEASIBLE with noted considerations',\n                'concerns': 'Review high/medium findings for optimization',\n                'evidence': 'No critical blockers identified'\n            }\n    \n    def _get_gap_analysis(self):\n        \"\"\"Get gap analysis.\"\"\"\n        gaps = []\n        \n        # Check for common gaps\n        has_test_coverage = any('TEST' in f['pattern'] for f in self.findings['findings'])\n        has_documentation = any('COMMENT' in f['pattern'] or 'DOCUMENTATION' in f['pattern'] \n                               for f in self.findings['findings'])\n        \n        if not has_test_coverage:\n            gaps.append(\"- **Testing Gap**: Limited test coverage detected\")\n        if not has_documentation:\n            gaps.append(\"- **Documentation Gap**: Insufficient code documentation\")\n        \n        # Check for design pattern gaps\n        apex_files = [node for node in self.dependency_graph.get('nodes', [])\n                     if node.get('type') == 'apex']\n        if len(apex_files) > 5 and len(self.dependency_graph.get('edges', [])) < 10:\n            gaps.append(\"- **Architecture Gap**: Limited separation of concerns in Apex classes\")\n        \n        if not gaps:\n            gaps.append(\"- **Minimal Gaps**: Current implementation aligns well with typical design patterns\")\n            gaps.append(\"- **Optimization Opportunities**: See medium/low findings for improvements\")\n        \n        return \"\\n\".join(gaps)\n    \n    def _get_implementation_complexity(self):\n        \"\"\"Get implementation complexity assessment.\"\"\"\n        complexity = []\n        \n        total_findings = self.findings['metadata']['total_findings']\n        critical_count = self.findings['metadata']['severity_counts']['CRITICAL']\n        high_count = self.findings['metadata']['severity_counts']['HIGH']\n        \n        complexity.append(f\"- **Effort Estimation**:\")\n        \n        if critical_count > 0:\n            complexity.append(f\"  - Critical fixes: {critical_count} × 2-4 hours each\")\n        if high_count > 0:\n            complexity.append(f\"  - High priority fixes: {high_count} × 1-2 hours each\")\n        \n        total_effort = (critical_count * 3) + (high_count * 1.5)\n        if total_effort > 0:\n            complexity.append(f\"  - **Total Estimated Effort**: {total_effort:.1f} hours\")\n        \n        complexity.append(f\"- **Complexity Factors**:\")\n        \n        if critical_count > 2:\n            complexity.append(\"  - Multiple critical issues increase coordination complexity\")\n        if 'SOQL_IN_LOOP' in [f['pattern'] for f in self.findings['findings']]:\n            complexity.append(\"  - Query optimization requires data model understanding\")\n        if 'FLS_MISSING' in [f['pattern'] for f in self.findings['findings']]:\n            complexity.append(\"  - Security implementation requires careful testing\")\n        \n        complexity.append(f\"- **Risk Factors**:\")\n        complexity.append(\"  - Regression risk with critical fixes\")\n        complexity.append(\"  - Testing coverage may be insufficient\")\n        \n        complexity.append(f\"- **Dependencies**:\")\n        complexity.append(\"  - Interdependent fixes may require coordinated deployment\")\n        \n        return \"\\n\".join(complexity)\n    \n    def _get_design_recommendations(self):\n        \"\"\"Get design recommendations.\"\"\"\n        recommendations = []\n        \n        # Design adjustments based on findings\n        critical_patterns = set(f['pattern'] for f in self.findings['findings'] \n                               if f['severity'] == 'CRITICAL')\n        \n        if 'SOQL_IN_LOOP' in critical_patterns:\n            recommendations.append(\"1. **Design Adjustment**: Implement service layer with bulkified data access\")\n            recommendations.append(\"   - Move queries out of loops\")\n            recommendations.append(\"   - Use maps for data relationship management\")\n        \n        if 'FLS_MISSING' in critical_patterns:\n            recommendations.append(\"2. **Security Layer**: Add security service with FLS/CRUD enforcement\")\n            recommendations.append(\"   - Centralize security checks\")\n            recommendations.append(\"   - Implement security by design pattern\")\n        \n        if 'RECURSION_RISK' in critical_patterns:\n            recommendations.append(\"3. **Trigger Framework**: Implement trigger handler pattern\")\n            recommendations.append(\"   - Add recursion guards\")\n            recommendations.append(\"   - Centralize trigger logic\")\n        \n        if not recommendations:\n            recommendations.append(\"1. **No Major Design Changes Required**\")\n            recommendations.append(\"   - Current design is feasible\")\n            recommendations.append(\"   - Proceed with implementation plan\")\n        \n        recommendations.append(\"\\n#### Implementation Approach:\")\n        recommendations.append(\"- **Incremental Refactoring**: Address findings in priority order\")\n        recommendations.append(\"- **Test-Driven**: Add tests before making changes\")\n        recommendations.append(\"- **Peer Review**: All critical fixes require code review\")\n        \n        recommendations.append(\"\\n#### Risk Mitigation:\")\n        recommendations.append(\"- **Staging Environment**: Test all changes before production\")\n        recommendations.append(\"- **Rollback Plan**: Prepare for quick rollback if needed\")\n        recommendations.append(\"- **Monitoring**: Add logging for changed components\")\n        \n        return \"\\n\".join(recommendations)\n    \n    def _get_design_evidence(self):\n        \"\"\"Get design evidence.\"\"\"\n        evidence = []\n        \n        evidence.append(\"#### Code Analysis Supporting Findings:\")\n        \n        # Show sample of findings\n        sample_findings = self.findings['findings'][:3]  # First 3 findings\n        for finding in sample_findings:\n            evidence.append(f\"##### {finding['severity']}: {finding['pattern']}\")\n            evidence.append(f\"- **File**: `{finding['file']}:{finding['line']}`\")\n            evidence.append(f\"- **Issue**: {finding['description']}\")\n            evidence.append(f\"- **Code**: `{finding['code_snippet'][:80]}...`\")\n            evidence.append(\"\")\n        \n        evidence.append(\"#### Complexity Metrics:\")\n        evidence.append(f\"- **Files Analyzed**: {len(self.dependency_graph.get('nodes', []))}\")\n        evidence.append(f\"- **Findings by Severity**:\")\n        for severity, count in self.findings['metadata']['severity_counts'].items():\n            evidence.append(f\"  - {severity}: {count}\")\n        \n        evidence.append(\"\\n#### Gap Analysis Details:\")\n        evidence.append(\"- See gap analysis section for identified gaps\")\n        evidence.append(\"- Each gap corresponds to specific findings in the audit\")\n        \n        return \"\\n\".join(evidence)\n    \n    # Generic report helpers\n    def _get_executive_summary(self):\n        \"\"\"Get executive summary.\"\"\"\n        overall = self.risk_assessment['risk_assessment']['overall_risk']\n        blockers = self.risk_assessment['risk_assessment']['blocking_conditions']\n        \n        summary = []\n        summary.append(f\"- **Audit Scope**: {len(self.dependency_graph.get('nodes', []))} files analyzed\")\n        summary.append(f\"- **Overall Risk**: {overall['level']} ({overall['score']}/100)\")\n        summary.append(f\"- **Findings**: {self.findings['metadata']['total_findings']} total\")\n        summary.append(f\"- **Critical Blockers**: {len(blockers['critical_blockers'])}\")\n        summary.append(f\"- **Recommendation**: {'Address critical issues first' if blockers['critical_blockers'] else 'Proceed with implementation'}\")\n        \n        return \"\\n\".join(summary)\n    \n    def _get_findings_by_severity(self):\n        \"\"\"Get findings by severity.\"\"\"\n        findings_text = []\n        \n        for severity in ['CRITICAL', 'HIGH', 'MEDIUM', 'LOW']:\n            severity_findings = [f for f in self.findings['findings'] if f['severity'] == severity]\n            if severity_findings:\n                findings_text.append(f\"### {severity} Findings\")\n                for finding in severity_findings:\n                    findings_text.append(f\"- **{finding['pattern']}** in `{finding['file']}:{finding['line']}`\")\n                    findings_text.append(f\"  - {finding['description']}\")\n                    findings_text.append(f\"  - Recommendation: {finding['recommendation']}\")\n                findings_text.append(\"\")\n        \n        return \"\\n\".join(findings_text)\n    \n    def _get_all_recommendations(self):\n        \"\"\"Get all recommendations.\"\"\"\n        recommendations = []\n        \n        # Group by priority\n        priorities = {\n            'CRITICAL': 'Immediate Action Required',\n            'HIGH': 'Should Address Soon',\n            'MEDIUM': 'Consider for Next Release',\n            'LOW': 'Nice to Have'\n        }\n        \n        for severity, priority_desc in priorities.items():\n            severity_findings = [f for f in self.findings['findings'] if f['severity'] == severity]\n            if severity_findings:\n                recommendations.append(f\"### {priority_desc}\")\n                for finding in severity_findings:\n                    recommendations.append(f\"1. **{finding['pattern']}** in `{finding['file']}`\")\n                    recommendations.append(f\"   - {finding['recommendation']}\")\n                recommendations.append(\"\")\n        \n        return \"\\n\".join(recommendations)\n    \n    def _get_complete_evidence(self):\n        \"\"\"Get complete evidence.\"\"\"\n        evidence = []\n        \n        evidence.append(\"### Dependency Graph\")\n        evidence.append(f\"- **Nodes**: {len(self.dependency_graph.get('nodes', []))} files\")\n        evidence.append(f\"- **Edges**: {len(self.dependency_graph.get('edges', []))} relationships\")\n        evidence.append(\"\")\n        \n        evidence.append(\"### Entry Points Identified\")\n        for ep in self.entrypoints.get('entrypoints', [])[:5]:  # First 5\n            evidence.append(f\"- **{ep['type']}**: {ep.get('file', ep.get('component', 'Unknown'))}\")\n        if len(self.entrypoints.get('entrypoints', [])) > 5:\n            evidence.append(f\"- ... and {len(self.entrypoints.get('entrypoints', [])) - 5} more\")\n        evidence.append(\"\")\n        \n        evidence.append(\"### Sample Code Snippets\")\n        sample_findings = self.findings['findings'][:2]  # First 2\n        for finding in sample_findings:\n            evidence.append(f\"#### {finding['pattern']} in {finding['file']}\")\n            evidence.append(f\"```\\n{finding['code_snippet']}\\n```\")\n            evidence.append(\"\")\n        \n        return \"\\n\".join(evidence)\n    \n    def save_report(self, report, filename='ARCHITECT_AUDIT_REPORT.md'):\n        \"\"\"Save report to file.\"\"\"\n        report_path = self.case_root / filename\n        write_file(report_path, report)\n        print(f\"Report saved to: {report_path}\")\n        return report_path\n\ndef main():\n    parser = argparse.ArgumentParser(description='Generate complete audit reports.')\n    parser.add_argument('--project-key', required=True, help='Project identifier')\n    parser.add_argument('--case-id', required=True, help='Case identifier')\n    parser.add_argument('--mode', choices=['A', 'B', 'C'], default='A', \n                       help='Handoff mode: A=Arch→Audit, B=Audit→Arch, C=Design Validation')\n    parser.add_argument('--output', help='Output filename (default: ARCHITECT_AUDIT_REPORT.md)')\n    args = parser.parse_args()\n    \n    generator = ReportGenerator(args.project_key, args.case_id, args.mode)\n    \n    try:\n        generator.load_all_data()\n        print(f\"Loaded audit data for {args.project_key}/{args.case_id}\")\n    except Exception as e:\n        print(f\"Error loading audit data: {e}\")\n        print(\"Make sure findings_synthesizer.py and risk_assessor.py have been run.\")\n        return\n    \n    report = generator.generate_architect_report()\n    \n    output_file = args.output or 'ARCHITECT_AUDIT_REPORT.md'\n    report_path = generator.save_report(report, output_file)\n    \n    print(f\"\\nGenerated {args.mode} mode report:\")\n    print(f\"  Project: {args.project_key}\")\n    print(f\"  Case: {args.case_id}\")\n    print(f\"  Mode: {args.mode}\")\n    print(f\"  File: {report_path}\")\n    print(f\"\\nReport includes:\")\n    print(f\"  - Executive summary\")\n    print(f\"  - Technical assessment\")\n    print(f\"  - Risk analysis\")\n    print(f\"  - Specific findings\")\n    print(f\"  - Actionable recommendations\")\n    print(f\"  - Evidence and code snippets\")\n\nif __name__ == '__main__':\n    main()"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":119,"output":3824,"cacheRead":39040,"cacheWrite":0,"totalTokens":42983,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773102851596}}
