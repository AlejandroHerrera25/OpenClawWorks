{"type":"message","id":"f3ac6806","parentId":"1a54059e","timestamp":"2026-03-10T00:15:00.971Z","message":{"role":"assistant","content":[{"type":"text","text":"Good, the logs show the test session being loaded. Now let me create a comprehensive test that demonstrates the full workflow:"},{"type":"toolCall","id":"call_00_u4tvyhtOuOfpTcHzc61sAqhQ","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/agent-watchdog/scripts/test_full_workflow.py","content":"#!/usr/bin/env python3\n\"\"\"\nTest the full real monitoring workflow.\nDemonstrates all 4 test scenarios from requirements.\n\"\"\"\n\nimport json\nimport time\nimport subprocess\nfrom datetime import datetime, timedelta\nfrom pathlib import Path\n\n# Workspace paths\nWORKSPACE = Path.home() / '.openclaw' / 'workspace'\nWATCHDOG_DIR = WORKSPACE / '.watchdog'\n\ndef test_scenario_1_monitoring_reality():\n    \"\"\"Test 1: Monitoring Reality Test - Show real session being monitored.\"\"\"\n    print(\"=\" * 60)\n    print(\"TEST SCENARIO 1: Monitoring Reality Test\")\n    print(\"=\" * 60)\n    \n    # Run monitor discovery\n    print(\"Running real session discovery...\")\n    result = subprocess.run(\n        ['python3', 'scripts/watchdog_monitor_real.py', '--discover'],\n        cwd=str(Path(__file__).parent.parent),\n        capture_output=True,\n        text=True\n    )\n    \n    if result.returncode == 0:\n        print(\"✓ Session discovery successful\")\n        \n        # Check monitoring directory\n        artifacts = list(WATCHDOG_DIR.glob('*'))\n        print(f\"✓ Monitoring artifacts created: {len(artifacts)} files\")\n        \n        # Check specific artifacts\n        required_artifacts = ['monitoring.log', 'session_registry.json']\n        for artifact in required_artifacts:\n            if (WATCHDOG_DIR / artifact).exists():\n                print(f\"✓ Required artifact exists: {artifact}\")\n            else:\n                print(f\"✗ Missing artifact: {artifact}\")\n        \n        # Show sample data\n        if (WATCHDOG_DIR / 'session_registry.json').exists():\n            with open(WATCHDOG_DIR / 'session_registry.json', 'r') as f:\n                registry = json.load(f)\n            \n            print(f\"✓ Real sessions being monitored: {len(registry)}\")\n            if registry:\n                sample_session = list(registry.values())[0]\n                print(f\"  Sample session: {sample_session['session_id']}\")\n                print(f\"  Source: {sample_session['source']}\")\n                print(f\"  State: {sample_session['state']}\")\n        \n        return True\n    else:\n        print(f\"✗ Session discovery failed: {result.stderr}\")\n        return False\n\ndef test_scenario_2_stall_detection():\n    \"\"\"Test 2: Stall Detection Test - Create real stall scenario.\"\"\"\n    print(\"\\n\" + \"=\" * 60)\n    print(\"TEST SCENARIO 2: Stall Detection Test\")\n    print(\"=\" * 60)\n    \n    # Create a test stalled session\n    test_session_id = \"test_stall_scenario_67890\"\n    registry_file = WATCHDOG_DIR / 'session_registry.json'\n    \n    if registry_file.exists():\n        with open(registry_file, 'r') as f:\n            registry = json.load(f)\n    else:\n        registry = {}\n    \n    # Create session that appears stalled\n    stalled_time = (datetime.utcnow() - timedelta(minutes=10)).isoformat()\n    \n    test_session = {\n        \"session_id\": test_session_id,\n        \"source\": \"stall_test\",\n        \"registered_at\": stalled_time,\n        \"last_activity\": stalled_time,\n        \"state\": \"active\",\n        \"stall_count\": 0,\n        \"recovery_attempts\": 0,\n        \"metrics\": {\n            \"total_uptime\": 600,\n            \"stall_detections\": 0,\n            \"recovery_attempts\": 0,\n            \"last_stall_time\": None\n        },\n        \"session_data_summary\": {\n            \"label\": \"Stall Test Session\",\n            \"updated_at\": int(time.time() * 1000) - 600000,\n            \"model\": \"test-model\"\n        }\n    }\n    \n    registry[test_session_id] = test_session\n    \n    with open(registry_file, 'w') as f:\n        json.dump(registry, f, indent=2)\n    \n    print(f\"Created test stalled session: {test_session_id}\")\n    \n    # Run stall detection\n    print(\"Running stall detection...\")\n    result = subprocess.run(\n        ['python3', 'scripts/watchdog_monitor_real.py', '--check-stalls'],\n        cwd=str(Path(__file__).parent.parent),\n        capture_output=True,\n        text=True\n    )\n    \n    if result.returncode == 0:\n        print(\"✓ Stall detection check completed\")\n        \n        # Check if stall was detected\n        if \"Found\" in result.stdout and \"stalled\" in result.stdout:\n            print(\"✓ Stall detection working (found stalled sessions)\")\n        else:\n            print(\"Note: No stalls found (might need different timing)\")\n        \n        # Clean up test session\n        if registry_file.exists():\n            with open(registry_file, 'r') as f:\n                registry = json.load(f)\n            \n            if test_session_id in registry:\n                del registry[test_session_id]\n                \n                with open(registry_file, 'w') as f:\n                    json.dump(registry, f, indent=2)\n                \n                print(f\"Cleaned up test session: {test_session_id}\")\n        \n        return True\n    else:\n        print(f\"✗ Stall detection failed: {result.stderr}\")\n        return False\n\ndef test_scenario_3_recovery_trigger():\n    \"\"\"Test 3: Recovery Trigger Test - Show recovery triggered by real data.\"\"\"\n    print(\"\\n\" + \"=\" * 60)\n    print(\"TEST SCENARIO 3: Recovery Trigger Test\")\n    print(\"=\" * 60)\n    \n    # First, ensure metrics file exists\n    metrics_file = WATCHDOG_DIR / 'metrics.json'\n    \n    if not metrics_file.exists():\n        print(\"Creating test metrics...\")\n        \n        # Creat