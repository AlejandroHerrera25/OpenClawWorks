pts/watchdog_orchestrator.py","oldText":"    def _rate_limit_check(self, pattern_key):\n        \"\"\"Check if pattern_key has exceeded rate limit.\"\"\"\n        with self.rate_limit_lock:\n            # Load cache\n            cache = {}\n            if RATE_LIMIT_CACHE_PATH.exists():\n                try:\n                    with open(RATE_LIMIT_CACHE_PATH, 'r', encoding='utf-8') as f:\n                        cache = json.load(f)\n                except (json.JSONDecodeError, IOError):\n                    cache = {}\n            \n            # Get timestamps for this pattern_key\n            now = datetime.utcnow()\n            timestamps = cache.get(pattern_key, [])\n            # Purge old timestamps\n            fresh_timestamps = [\n                ts for ts in timestamps\n                if (now - datetime.fromisoformat(ts)).total_seconds() < RATE_LIMIT_WINDOW_SECONDS\n            ]\n            \n            # Check limit\n            if len(fresh_timestamps) >= MAX_INCIDENTS_PER_PATTERN_PER_HOUR:\n                return False  # Rate limit exceeded\n            \n            # Add current timestamp\n            fresh_timestamps.append(now.isoformat())\n            cache[pattern_key] = fresh_timestamps\n            \n            # Save cache\n            try:\n                RATE_LIMIT_CACHE_PATH.parent.mkdir(parents=True, exist_ok=True)\n                with open(RATE_LIMIT_CACHE_PATH, 'w', encoding='utf-8') as f:\n                    json.dump(cache, f, indent=2)\n            except (IOError, OSError) as e:\n                print(f\"[Watchdog] Failed to save rate limit cache: {e}\")\n            \n            return True  # Allowed","newText":"    def _rate_limit_check(self, pattern_key):\n        \"\"\"Check if pattern_key has exceeded rate limit.\"\"\"\n        # Ensure datetime is available (imported at module level)\n        with self.rate_limit_lock:\n            # Load cache\n            cache = {}\n            if RATE_LIMIT_CACHE_PATH.exists():\n                try:\n                    with open(RATE_LIMIT_CACHE_PATH, 'r', encoding='utf-8') as f:\n                        cache = json.load(f)\n                except (json.JSONDecodeError, IOError):\n                    cache = {}\n            \n            # Get timestamps for this pattern_key\n            now = datetime.utcnow()\n            timestamps = cache.get(pattern_key, [])\n            # Purge old timestamps\n            fresh_timestamps = [\n                ts for ts in timestamps\n                if (now - datetime.fromisoformat(ts)).total_seconds() < RATE_LIMIT_WINDOW_SECONDS\n            ]\n            \n            # Check limit\n            if len(fresh_timestamps) >= MAX_INCIDENTS_PER_PATTERN_PER_HOUR:\n                return False  # Rate limit exceeded\n            \n            # Add current timestamp\n            fresh_timestamps.append(now.isoformat())\n            cache[pattern_key] = fresh_timestamps\n            \n            # Save cache\n            try:\n                RATE_LIMIT_CACHE_PATH.parent.mkdir(parents=True, exist_ok=True)\n                with open(RATE_LIMIT_CACHE_PATH, 'w', encoding='utf-8') as f:\n                    json.dump(cache, f, indent=2)\n            except (IOError, OSError) as e:\n                print(f\"[Watchdog] Failed to save rate limit cache: {e}\")\n            \n            return True  # Allowed"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-reasoner","usage":{"input":219,"output":1578,"cacheRead":104512,"cacheWrite":0,"totalTokens":106309,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772744237087}}
