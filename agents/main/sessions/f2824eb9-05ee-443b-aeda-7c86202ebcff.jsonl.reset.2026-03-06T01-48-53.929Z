= re.findall(r'Pattern[\\-‑]Key:\\s*([^\\s]+)', content)\n        return set(pk_matches)\n    promoted.update(search_in_file(agents_path))\n    promoted.update(search_in_file(tools_path))\n    return promoted","newText":"def extract_guardrails(agents_path, tools_path):\n    \"\"\"Detect which Pattern‑Keys have guardrails in AGENTS.md / TOOLS.md.\"\"\"\n    promoted = set()\n    def search_in_file(path, section_marker):\n        try:\n            with open(path, 'r', encoding='utf-8') as f:\n                content = f.read()\n        except FileNotFoundError:\n            return set()\n        # Find the guardrail section\n        # Match from section_marker to next ## or end of file\n        pattern = rf'{re.escape(section_marker)}(.*?)(?=\\n## |\\Z)'\n        match = re.search(pattern, content, re.DOTALL)\n        if not match:\n            return set()\n        section_text = match.group(1)\n        # Look for Pattern‑Key lines (allow hyphen or dash)\n        pk_matches = re.findall(r'Pattern[\\-‑]Key:\\s*([^\\s]+)', section_text)\n        return set(pk_matches)\n    \n    # AGENTS.md guardrail section\n    promoted.update(search_in_file(agents_path, \"## Guardrails (Auto-learnings)\"))\n    # TOOLS.md guardrail section\n    promoted.update(search_in_file(tools_path, \"## Tool Guardrails\"))\n    return promoted"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-reasoner","usage":{"input":324,"output":1108,"cacheRead":48768,"cacheWrite":0,"totalTokens":50200,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772731922850}}
