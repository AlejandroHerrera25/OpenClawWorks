{"type":"message","id":"c5d4d98d","parentId":"9934c88a","timestamp":"2026-03-10T02:01:47.635Z","message":{"role":"toolResult","toolCallId":"call_00_6Rt45PRQnoJKopZVLIQ2gdDn","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nWatchdog integration for memory system.\nProvides functions to register long-running memory tasks with agent-watchdog.\n\"\"\"\n\nimport os\nimport sys\nimport subprocess\nimport uuid\nfrom datetime import datetime\nfrom pathlib import Path\n\nWORKSPACE = Path.home() / '.openclaw' / 'workspace'\nWATCHDOG_SCRIPT = WORKSPACE / 'skills' / 'agent-watchdog' / 'scripts' / 'watchdog_orchestrator.py'\n\ndef register_with_watchdog(task_description, expected_runtime_minutes, model=\"custom-api-deepseek-com/deepseek-chat\", runtime_type=\"subagent\"):\n    \"\"\"\n    Register a memory task with the agent-watchdog.\n    \n    Args:\n        task_description: Description of the task\n        expected_runtime_minutes: Expected runtime in minutes\n        model: Model being used\n        runtime_type: 'subagent' or 'acp'\n    \n    Returns:\n        tuple: (session_id, run_id) or (None, None) if registration fails\n    \"\"\"\n    if not WATCHDOG_SCRIPT.exists():\n        print(f\"[WATCHDOG] Warning: Watchdog script not found at {WATCHDOG_SCRIPT}\")\n        return None, None\n    \n    # Generate unique IDs\n    session_id = f\"memory_{datetime.now().strftime('%Y%m%d_%H%M%S')}_{uuid.uuid4().hex[:8]}\"\n    run_id = f\"run_{uuid.uuid4().hex[:8]}\"\n    \n    # Build command\n    cmd = [\n        sys.executable, str(WATCHDOG_SCRIPT),\n        \"--register\",\n        \"--session-id\", session_id,\n        \"--run-id\", run_id,\n        \"--task\", task_description,\n        \"--expected-runtime\", str(expected_runtime_minutes),\n        \"--model\", model,\n        \"--runtime-type\", runtime_type\n    ]\n    \n    try:\n\n[118 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1773108107628}}
