{"type":"message","id":"7bcee7f5","parentId":"3d969139","timestamp":"2026-03-10T00:08:21.607Z","message":{"role":"assistant","content":[{"type":"text","text":"So there's no actual invocation of the code auditor scripts. The integration is simulated. Let me create a test that actually tries to invoke the real code auditor:"},{"type":"toolCall","id":"call_00_3eClwsbmgLKoqbszFs7HgErM","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/test_real_auditor_invocation.py","content":"#!/usr/bin/env python3\n\"\"\"\nTest REAL invocation of Salesforce Code Auditor from Architect.\nThis test attempts to actually call the code auditor scripts.\n\"\"\"\n\nimport os\nimport sys\nimport subprocess\nimport tempfile\nimport json\nfrom pathlib import Path\n\n# Workspace root\nWORKSPACE_ROOT = Path('/home/openclaw/.openclaw/workspace')\nCODE_AUDITOR_SCRIPTS = WORKSPACE_ROOT / 'skills' / 'salesforce-code-auditor' / 'scripts'\n\ndef test_real_auditor_invocation():\n    \"\"\"Test if we can actually invoke the code auditor.\"\"\"\n    \n    print(\"🧪 Testing REAL Code Auditor Invocation\")\n    print(\"=\" * 60)\n    \n    # Check if code auditor scripts exist\n    if not CODE_AUDITOR_SCRIPTS.exists():\n        print(f\"❌ Code auditor scripts not found at: {CODE_AUDITOR_SCRIPTS}\")\n        return False\n    \n    print(f\"✅ Code auditor scripts found at: {CODE_AUDITOR_SCRIPTS}\")\n    \n    # Test 1: Check if init_case.py can be executed\n    print(\"\\n1️⃣ Testing init_case.py execution...\")\n    init_case_script = CODE_AUDITOR_SCRIPTS / 'init_case.py'\n    \n    if not init_case_script.exists():\n        print(f\"❌ init_case.py not found at: {init_case_script}\")\n        return False\n    \n    print(f\"✅ init_case.py found\")\n    \n    # Create a test project directory\n    test_project = WORKSPACE_ROOT / 'projects' / 'test_real_auditor'\n    test_project.mkdir(parents=True, exist_ok=True)\n    \n    # Create a test case ID\n    case_id = 'test_real_invocation_case'\n    \n    try:\n        # Try to execute init_case.py\n        cmd = [\n            'python3', str(init_case_script),\n            '--project-key', 'test_real_auditor',\n            '--case-id', case_id,\n            '--demo'\n        ]\n        \n        print(f\"  Executing: {' '.join(cmd)}\")\n        \n        result = subprocess.run(\n            cmd,\n            capture_output=True,\n            text=True,\n            cwd=WORKSPACE_ROOT\n        )\n        \n        if result.returncode == 0:\n            print(f\"  ✅ init_case.py executed successfully\")\n            print(f\"  Output: {result.stdout[:100]}...\")\n        else:\n            print(f\"  ❌ init_case.py failed with return code {result.returncode}\")\n            print(f\"  Error: {result.stderr[:200]}\")\n            return False\n        \n        # Check if case directory was created\n        case_dir = test_project / 'code_audit' / case_id\n        if case_dir.exists():\n            print(f\"  ✅ Case directory created: {case_dir}\")\n        else:\n            print(f\"  ❌ Case directory not created: {case_dir}\")\n            return False\n        \n    except Exception as e:\n        print(f\"  ❌ Execution failed: {e}\")\n        return False\n    \n    # Test 2: Check if we can create a simple integration that actually calls auditor\n    print(\"\\n2️⃣ Creating real integration test...\")\n    \n    # Create a simple test script that mimics what architect should do\n    integration_test = test_project / 'test_real_integration.py'\n    integration_test.write_text('''\nimport subprocess\nimport sys\nimport json\nfrom pathlib import Path\n\ndef invoke_real_auditor(project_key, case_id, audit_request):\n    \"\"\"Actually invoke the code auditor with real scripts.\"\"\"\n    \n    workspace = Path('/home/openclaw/.openclaw/workspace')\n    scripts_dir = workspace / 'skills' / 'salesforce-code-auditor' / 'scripts'\n    \n    # Step 1: Initialize case\n    init_cmd = [\n        'python3', str(scripts_dir / 'init_case.py'),\n        '--project-key', project_key,\n        '--case-id', case_id\n    ]\n    \n    print(f\"Initializing case: {' '.join(init_cmd)}\")\n    result = subprocess.run(init_cmd, capture_output=True, text=True, cwd=workspace)\n    \n    if result.returncode != 0:\n        return {'error': f'init_case failed: {result.stderr}'}\n    \n    # Step 2: Save audit request\n    case_dir = workspace / 'projects' / project_key / 'code_audit' / case_id\n    request_file = case_dir / 'audit_request.json'\n    \n    with open(request_file, 'w') as f:\n        json.dump(audit_request, f, indent=2)\n    \n    # Step 3: Create some test code to audit\n    inputs_dir = case_dir / 'inputs'\n    test_code = inputs_dir / 'TestClass.cls'\n    test_code.write_text('''\npublic class TestClass {\n    public static void testMethod() {\n        System.debug('Test method');\n    }\n}\n''')\n    \n    # Step 4: Run indexing\n    index_cmd = [\n        'python3', str(scripts_dir / 'index_inputs.py'),\n        '--project-key', project_key,\n        '--case-id', case_id\n    ]\n    \n    print(f\"Indexing files: {' '.join(index_cmd)}\")\n    result = subprocess.run(index_cmd, capture_output=True, text=True, cwd=workspace)\n    \n    if result.returncode != 0:\n        return {'error': f'index_inputs failed: {result.stderr}'}\n    \n    # Step 5: Generate reports\n    reports_cmd = [\n        'python3', str(scripts_dir / 'generate_reports.py'),\n        '--project-key', project_key,\n        '--case-id', case_id\n    ]\n    \n    print(f\"Generating reports: {' '.join(reports_cmd)}\")\n    result = subprocess.run(reports_cmd, capture_output=True, text=True, cwd=workspace)\n    \n    if result.returncode != 0:\n        return {'error': f'generate_reports failed: {result.stderr}'}\n    \n    # Step 6: Read audit report\n    report_file = case_dir / 'AUDIT_REPORT.md'\n    if report_file.exists():\n        with open(report_file, 'r') as f:\n            report_content = f.read()\n        \n        return {\n            'success': True,\n            'case_id': case_id,\n            'report_generated': True,\n            'report_length': len(report_content)\n        }\n    else:\n        return {'error': 'AUDIT_REPORT.md not generated'}\n\n# Test the function\nif __name__ == '__main__':\n    request = {\n        'project': 'test_real_auditor',\n        'case_id': 'integration_test_case',\n        'mode': 'A',\n        'audit_objectives': ['Test real integration']\n    }\n    \n    result = invoke_real_auditor('test_real_auditor', 'integration_test_case', request)\n    print(json.dumps(result, indent=2))\n''')\n    \n    print(f\"✅ Integration test script created: {integration_test}\")\n    \n    # Test 3: Actually run the integration test\n    print(\"\\n3️⃣ Running real integration test...\")\n    try:\n        cmd = ['python3', str(integration_test)]\n        result = subprocess.run(\n            cmd,\n            capture_output=True,\n            text=True,\n            cwd=test_project\n        )\n        \n        print(f\"  Return code: {result.returncode}\")\n        \n        if result.returncode == 0:\n            print(f\"  ✅ Integration test executed successfully\")\n            print(f\"  Output:\\n{result.stdout}\")\n            \n            # Parse the JSON output\n            try:\n                output_data = json.loads(result.stdout)\n                print(f\"\\n  Integration result: {json.dumps(output_data, indent=2)}\")\n                \n                if output_data.get('success'):\n                    print(f\"\\n🎉 REAL INTEGRATION VERIFIED!\")\n                    print(f\"   - Code auditor actually invoked\")\n                    print(f\"   - Real scripts executed\")\n                    print(f\"   - Real audit report generated\")\n                else:\n                    print(f\"\\n⚠️ Integration test completed but with issues\")\n                    print(f\"   Error: {output_data.get('error', 'Unknown error')}\")\n                    \n            except json.JSONDecodeError:\n                print(f\"  Output (not JSON): {result.stdout[:200]}...\")\n                \n        else:\n            print(f\"  ❌ Integration test failed\")\n            print(f\"  Error: {result.stderr[:200]}\")\n            \n    except Exception as e:\n        print(f\"  ❌ Integration test execution failed: {e}\")\n        import traceback\n        traceback.print_exc()\n    \n    print(\"\\n\" + \"=\" * 60)\n    print(\"📊 REAL INVOCATION TEST SUMMARY\")\n    print(\"=\" * 60)\n    \n    # Check what we actually tested\n    print(f\"Test project: {test_project}\")\n    print(f\"Code auditor scripts: {'✅ Found' if CODE_AUDITOR_SCRIPTS.exists() else '❌ Not found'}\")\n    \n    # List created artifacts\n    print(f\"\\nCreated artifacts in test project:\")\n    for item in test_project.rglob('*'):\n        if item.is_file():\n            rel_path = item.relative_to(test_project)\n            print(f\"  - {rel_path}\")\n    \n    return True\n\nif __name__ == '__main__':\n    success = test_real_auditor_invocation()\n    \n    print(f\"\\n📁 Test project kept for inspection at: /home/openclaw/.openclaw/workspace/projects/test_real_auditor\")\n    \n    sys.exit(0 if success else 1)"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":56,"output":2196,"cacheRead":39680,"cacheWrite":0,"totalTokens":41932,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101237098}}
