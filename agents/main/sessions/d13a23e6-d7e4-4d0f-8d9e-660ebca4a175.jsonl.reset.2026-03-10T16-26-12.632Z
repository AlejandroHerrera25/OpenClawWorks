{"type":"message","id":"35306ff7","parentId":"b8c2e71a","timestamp":"2026-03-09T18:41:54.460Z","message":{"role":"assistant","content":[{"type":"text","text":"Ahora voy a crear el motor real de state machine en YAML:"},{"type":"toolCall","id":"call_00_Ek6TlEDIwElHqjhArdJPJnx7","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/salesforce-architect/references/state_machine.yaml","content":"# Salesforce Project State Machine - Structured YAML Reference\n# Purpose: Formal lifecycle states with clear entry/exit conditions\n# Status: Reference asset - DO NOT regenerate on every run\n# Last Updated: 2026-03-09\n\nversion: \"1.0\"\nformat: \"yaml\"\ndescription: \"Salesforce project lifecycle state machine\"\n\nstates:\n  DISCOVERY:\n    purpose: \"Gather initial information about business processes, actors, and systems\"\n    entry_conditions:\n      - \"project_key identified\"\n      - \"initial business context provided\"\n      - \"no existing discovery artifacts for this project\"\n    required_artifacts:\n      - \"Discovery_Report.md\"\n      - \"Discovery_Process_Analysis.md\"\n      - \"Discovery_QA.xlsx\"\n    blocking_conditions:\n      - \"missing mandatory inputs (project name, industry, country, clouds, user count, process description, scope)\"\n      - \"incomplete actor/process identification\"\n    allowed_next_states:\n      - \"REQUIREMENTS\"\n      - \"FIT_GAP\"\n    prohibited_transitions:\n      - \"DESIGN\"\n      - \"FINALIZED\"\n    architect_responsibilities:\n      - \"validate completeness of discovery\"\n      - \"identify missing information\"\n      - \"ensure EC0249 compliance\"\n      - \"emit incidents for blocking conditions\"\n\n  REQUIREMENTS:\n    purpose: \"Transform discovery into structured, actionable requirements\"\n    entry_conditions:\n      - \"DISCOVERY artifacts complete and validated\"\n      - \"all mandatory inputs available\"\n    required_artifacts:\n      - \"consolidated requirements list\"\n      - \"requirement prioritization\"\n      - \"acceptance criteria per requirement\"\n    blocking_conditions:\n      - \"incomplete discovery\"\n      - \"unclear acceptance criteria\"\n      - \"missing stakeholder validation\"\n    allowed_next_states:\n      - \"FIT_GAP\"\n      - \"DESIGN\"\n    prohibited_transitions:\n      - \"CODE_AUDIT\"\n    architect_responsibilities:\n      - \"validate requirement completeness\"\n      - \"ensure traceability to discovery\"\n      - \"prioritize requirements\"\n      - \"validate acceptance criteria\"\n\n  FIT_GAP:\n    purpose: \"Analyze requirements against available Salesforce features and identify gaps\"\n    entry_conditions:\n      - \"REQUIREMENTS complete OR DISCOVERY complete with scope/SOW\"\n      - \"scope/SOW document available\"\n    required_artifacts:\n      - \"Fit_Gap_Matrix.xlsx\"\n    blocking_conditions:\n      - \"missing scope/SOW document\"\n      - \"incomplete requirements\"\n      - \"unclear licensing constraints\"\n    allowed_next_states:\n      - \"DESIGN\"\n      - \"REQUIREMENTS\"\n    prohibited_transitions:\n      - \"DATA_MODEL\"\n      - \"FINALIZED\"\n    architect_responsibilities:\n      - \"validate scope/SOW availability\"\n      - \"ensure proper Fit/GAP classification\"\n      - \"document licensing impacts\"\n      - \"identify architectural implications of gaps\"\n\n  DESIGN:\n    purpose: \"Create functional design based on requirements and Fit/GAP analysis\"\n    entry_conditions:\n      - \"FIT_GAP complete OR REQUIREMENTS complete (if no Fit/GAP needed)\"\n      - \"clear understanding of what will be built vs. gaps\"\n    required_artifacts:\n      - \"Functional_Design.docx\"\n      - \"architecture alternatives (2-3 options)\"\n      - \"pros/cons analysis\"\n      - \"licensing impact assessment\"\n      - \"official documentation evidence\"\n    blocking_conditions:\n      - \"unresolved Fit/GAP items\"\n      - \"missing evidence for key decisions\"\n      - \"unclear licensing constraints\"\n    allowed_next_states:\n      - \"DATA_MODEL\"\n      - \"ARCH_REVIEW\"\n      - \"FIT_GAP\"\n    prohibited_transitions:\n      - \"CODE_AUDIT\"\n      - \"FINALIZED\"\n    architect_responsibilities:\n      - \"ensure design follows template\"\n      - \"validate evidence for decisions\"\n      - \"conduct debate mode for alternatives\"\n      - \"document architectural decisions\"\n\n  DATA_MODEL:\n    purpose: \"Design detailed data model supporting the functional design\"\n    entry_conditions:\n      - \"DESIGN complete and validated\"\n      - \"clear understanding of data requirements\"\n    required_artifacts:\n      - \"Data_Model.xlsx\"\n    blocking_conditions:\n      - \"incomplete functional design\"\n      - \"unclear data relationships\"\n      - \"missing validation requirements\"\n    allowed_next_states:\n      - \"ARCH_REVIEW\"\n      - \"DESIGN\"\n      - \"CODE_AUDIT\"\n    prohibited_transitions:\n      - \"REMEDIATION\"\n      - \"FINALIZED\"\n    architect_responsibilities:\n      - \"validate data model completeness\"\n      - \"ensure relationship integrity\"\n      - \"consider performance implications\"\n      - \"document data governance requirements\"\n\n  ARCH_REVIEW:\n    purpose: \"Architectural review and validation of design and data model\"\n    entry_conditions:\n      - \"DESIGN and DATA_MODEL complete\"\n      - \"OR specific architectural review requested\"\n    required_artifacts:\n      - \"architecture review report\"\n      - \"risk assessment\"\n      - \"scalability analysis\"\n      - \"security assessment\"\n      - \"integration impact analysis\"\n    blocking_conditions:\n      - \"missing design or data model artifacts\"\n      - \"unresolved architectural risks\"\n      - \"unvalidated assumptions\"\n    allowed_next_states:\n      - \"CODE_AUDIT\"\n      - \"REMEDIATION\"\n      - \"FINALIZED\"\n      - \"DESIGN\"\n      - \"DATA_MODEL\"\n    prohibited_transitions:\n      - \"DISCOVERY\"\n      - \"REQUIREMENTS\"\n    architect_responsibilities:\n      - \"conduct comprehensive architectural review\"\n      - \"identify risks and mitigation strategies\"\n      - \"validate against Salesforce limits and best practices\"\n      - \"make go/no-go decision for implementation\"\n\n  CODE_AUDIT:\n    purpose: \"Technical review of existing or proposed code\"\n    entry_conditions:\n      - \"ARCH_REVIEW complete OR specific code audit requested\"\n      - \"code available for review\"\n      - \"clear audit objectives\"\n    required_artifacts:\n      - \"code audit report\"\n      - \"findings with severity levels\"\n      - \"code snippets as evidence\"\n      - \"remediation suggestions\"\n      - \"impact assessment\"\n    blocking_conditions:\n      - \"no code available for audit\"\n      - \"unclear audit objectives\"\n      - \"missing context about code purpose\"\n    allowed_next_states:\n      - \"REMEDIATION\"\n      - \"ARCH_REVIEW\"\n      - \"FINALIZED\"\n    prohibited_transitions:\n      - \"DESIGN\"\n      - \"DATA_MODEL\"\n    architect_responsibilities:\n      - \"define audit scope and objectives\"\n      - \"review audit findings\"\n      - \"assess architectural impact\"\n      - \"decide remediation requirements\"\n\n  REMEDIATION:\n    purpose: \"Address issues found during code audit or architectural review\"\n    entry_conditions:\n      - \"CODE_AUDIT or ARCH_REVIEW identified issues requiring fixes\"\n      - \"clear remediation plan\"\n    required_artifacts:\n      - \"remediation plan\"\n      - \"updated artifacts (design, data model, code)\"\n      - \"validation of fixes\"\n      - \"updated risk assessment\"\n    blocking_conditions:\n      - \"unclear remediation requirements\"\n      - \"missing approval for changes\"\n      - \"unresolved dependencies\"\n    allowed_next_states:\n      - \"CODE_AUDIT\"\n      - \"ARCH_REVIEW\"\n      - \"FINALIZED\"\n    prohibited_transitions:\n      - \"DISCOVERY\"\n      - \"REQUIREMENTS\"\n    architect_responsibilities:\n      - \"approve remediation plan\"\n      - \"validate fixes\"\n      - \"update architectural documentation\"\n      - \"ensure no regression of existing functionality\"\n\n  FINALIZED:\n    purpose: \"Project completion with all artifacts finalized and approved\"\n    entry_conditions:\n      - \"all previous states complete and validated\"\n      - \"all artifacts approved\"\n      - \"no open critical issues\"\n      - \"stakeholder sign-off (if required)\"\n    required_artifacts:\n      - \"final project package\"\n      - \"executive summary\"\n      - \"lessons learned\"\n      - \"handoff documentation\"\n    blocking_conditions:\n      - \"open critical issues\"\n      - \"missing stakeholder approval (if required)\"\n      - \"incomplete artifacts\"\n    allowed_next_states: []\n    prohibited_transitions:\n      - \"any transition from FINALIZED except new project phase\"\n    architect_responsibilities:\n      - \"final validation of all artifacts\"\n      - \"ensure completeness of documentation\"\n      - \"document lessons learned\"\n      - \"formal project closure\"\n\n# Hard rules and constraints\nhard_rules:\n  - \"no FIT_GAP without scope/SOW\"\n  - \"no DESIGN without consolidated discovery\"\n  - \"no FINALIZED with critical audit findings\"\n  - \"no CODE_AUDIT without clear objectives\"\n\nstate_order:\n  - \"DISCOVERY\"\n  - \"REQUIREMENTS\"\n  - \"FIT_GAP\"\n  - \"DESIGN\"\n  - \"DATA_MODEL\"\n  - \"ARCH_REVIEW\"\n  - \"CODE_AUDIT\"\n  - \"REMEDIATION\"\n  - \"FINALIZED\"\n\n# State transition validation rules\ntransition_rules:\n  allow_regression_to:\n    - \"DISCOVERY\"\n    - \"REQUIREMENTS\"\n    - \"FIT_GAP\"\n    - \"DESIGN\"\n  regression_conditions:\n    - \"major gaps found\"\n    - \"new information changes fundamentals\"\n    - \"stakeholder requirements changed\"\n  require_architect_approval:\n    - \"REMEDIATION → FINALIZED\"\n    - \"CODE_AUDIT → FINALIZED\"\n    - \"ARCH_REVIEW → FINALIZED\""}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":102,"output":2199,"cacheRead":96960,"cacheWrite":0,"totalTokens":99261,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773081640911}}
