e, cwd=workspace)\n    \n    if result.returncode != 0:\n        return {'error': f'init_case failed: {result.stderr}'}\n    \n    # Step 2: Save audit request\n    case_dir = workspace / 'projects' / project_key / 'code_audit' / case_id\n    request_file = case_dir / 'audit_request.json'\n    \n    with open(request_file, 'w') as f:\n        json.dump(audit_request, f, indent=2)\n    \n    # Step 3: Create some test code to audit\n    inputs_dir = case_dir / 'inputs'\n    inputs_dir.mkdir(exist_ok=True)\n    \n    test_code = inputs_dir / 'TestClass.cls'\n    test_code.write_text(\"\"\"public class TestClass {\n    public static void testMethod() {\n        System.debug('Test method');\n    }\n}\n\"\"\")\n    \n    # Step 4: Run indexing\n    index_cmd = [\n        'python3', str(scripts_dir / 'index_inputs.py'),\n        '--project-key', project_key,\n        '--case-id', case_id\n    ]\n    \n    print(f\"Indexing files: {' '.join(index_cmd)}\")\n    result = subprocess.run(index_cmd, capture_output=True, text=True, cwd=workspace)\n    \n    if result.returncode != 0:\n        return {'error': f'index_inputs failed: {result.stderr}'}\n    \n    # Step 5: Generate reports\n    reports_cmd = [\n        'python3', str(scripts_dir / 'generate_reports.py'),\n        '--project-key', project_key,\n        '--case-id', case_id\n    ]\n    \n    print(f\"Generating reports: {' '.join(reports_cmd)}\")\n    result = subprocess.run(reports_cmd, capture_output=True, text=True, cwd=workspace)\n    \n    if result.returncode != 0:\n        return {'error': f'generate_reports failed: {result.stderr}'}\n    \n    # Step 6: Read audit report\n    report_file = case_dir / 'AUDIT_REPORT.md'\n    if report_file.exists():\n        with open(report_file, 'r') as f:\n            report_content = f.read()\n        \n        return {\n            'success': True,\n            'case_id': case_id,\n            'report_generated': True,\n            'report_length': len(report_content),\n  