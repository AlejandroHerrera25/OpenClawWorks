{"type":"message","id":"0d595dad","parentId":"7dc3cf65","timestamp":"2026-03-10T02:10:26.793Z","message":{"role":"toolResult","toolCallId":"call_00_vG1vdjiSLFvUHTfXlhfbel9Y","toolName":"read","content":[{"type":"text","text":"\ndef get_session_stats():\n    \"\"\"Get session statistics\"\"\"\n    sessions_data = load_json_file(SESSION_REGISTRY)\n    sessions = sessions_data.get(\"sessions\", [])\n    \n    stats = {\n        \"total\": len(sessions),\n        \"active\": sum(1 for s in sessions if s.get(\"status\") == \"active\"),\n        \"stalled\": sum(1 for s in sessions if s.get(\"status\") == \"stalled\"),\n        \"by_source\": {},\n        \"recent\": []\n    }\n    \n    # Group by source\n    for session in sessions:\n        source = session.get(\"source\", \"unknown\")\n        stats[\"by_source\"][source] = stats[\"by_source\"].get(source, 0) + 1\n    \n    # Get recent sessions (last 10)\n\n[400 more lines in file. Use offset=50 to continue.]"}],"isError":false,"timestamp":1773108626781}}
