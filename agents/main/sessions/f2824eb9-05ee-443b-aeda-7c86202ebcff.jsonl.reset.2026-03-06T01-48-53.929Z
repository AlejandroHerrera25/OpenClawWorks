{"type":"message","id":"fabe2071","parentId":"45324ecd","timestamp":"2026-03-05T19:53:38.956Z","message":{"role":"toolResult","toolCallId":"call_00_xEsKuBhxJ5OeWbOnwgfVB8cp","toolName":"read","content":[{"type":"text","text":"def main():\n    if len(sys.argv) > 1:\n        base_dir = Path(sys.argv[1])\n    else:\n        base_dir = Path.cwd()\n    \n    learnings_dir = base_dir / '.learnings'\n    if not learnings_dir.exists():\n        print(f\"ERROR: .learnings directory not found in {base_dir}\", file=sys.stderr)\n        sys.exit(1)\n    \n    errors_path = learnings_dir / 'ERRORS.md'\n    learnings_path = learnings_dir / 'LEARNINGS.md'\n    agents_path = base_dir / 'AGENTS.md'\n    tools_path = base_dir / 'TOOLS.md'\n    \n    if not errors_path.exists():\n        print(f\"ERROR: {errors_path} not found\", file=sys.stderr)\n        sys.exit(1)\n    if not learnings_path.exists():\n        print(f\"ERROR: {learnings_path} not found\", file=sys.stderr)\n        sys.exit(1)\n    \n    errors_keys = parse_errors_md(errors_path)\n    learnings_dict = parse_learnings_md(learnings_path)\n    promoted_set = extract_guardrails(agents_path, tools_path)\n    merged = deduplicate_entries(errors_keys, learnings_dict)\n    \n    # Generate new files\n    index_content = generate_index(merged, promoted_set, base_dir)\n    report_content = generate_report(merged, promoted_set, base_dir)\n    \n    index_path = learnings_dir / 'INDEX.md'\n    with open(index_path, 'w', encoding='utf-8') as f:\n        f.write(index_content)\n    print(f\"✅ INDEX.md updated at {index_path}\")\n    \n    report_path = learnings_dir / 'REPORT.md'\n    with open(report_path, 'w', encoding='utf-8') as f:\n        f.write(report_content)\n    print(f\"✅ REPORT.md updated at {report_path}\")\n    \n    # Verify each Pattern‑Key appears only once in INDEX.md\n    with open(index_path, 'r', encoding='utf-8') as f:\n        index_text = f.read()\n    pk_matches = re.findall(r'Pattern-Key: ([^\\n]+)', index_text)\n    if len(pk_matches) != len(set(pk_matches)):\n        print(\"⚠️  WARNING: Duplicate Pattern‑Keys found in INDEX.md\")\n    else:\n        print(f\"✓ Each Pattern‑Key appears exactly once ({len(pk_matches)} total).\")\n\nif __name__ == '__main__':\n    main()"}],"isError":false,"timestamp":1772740418932}}
