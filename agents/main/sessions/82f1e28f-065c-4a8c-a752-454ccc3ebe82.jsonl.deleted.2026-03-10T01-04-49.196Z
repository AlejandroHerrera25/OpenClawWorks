p['class']}` with @AuraEnabled methods: {', '.join(ep.get('aura_enabled_methods', []))}\\n\"\n\n    trace += \"\\n## Typical Flow\\n\"\n    # Simplified: just list UI -> Controller -> Service -> Integration -> Trigger\n    trace += \"1. UI event (button click, page load)\\n\"\n    trace += \"2. Controller method invoked\\n\"\n    trace += \"3. Service/validation logic\\n\"\n    trace += \"4. DML operation\\n\"\n\n[196 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1773101571133}}
