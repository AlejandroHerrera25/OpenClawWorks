{"type":"message","id":"f83fdefd","parentId":"a4f6b568","timestamp":"2026-03-09T15:48:15.841Z","message":{"role":"toolResult","toolCallId":"call_00_RwYjhWbLxXgIwoupzf4TG61h","toolName":"read","content":[{"type":"text","text":"        \"\"\"Load search results from cache if valid.\"\"\"\n        cache_file = self.cache_dir / f\"search_{cache_key}.json\"\n        \n        if not cache_file.exists():\n            return None\n        \n        try:\n            with open(cache_file) as f:\n                cached_data = json.load(f)\n            \n            # Check TTL\n            cache_ttl = self.defaults.get(\"cache_ttl_minutes\", 15)\n            cached_time = datetime.fromisoformat(cached_data.get(\"cached_at\", \"\"))\n            \n            if datetime.now() - cached_time > timedelta(minutes=cache_ttl):\n                print(f\"[CACHE] Cache expired for key: {cache_key}\")\n                return None\n            \n            print(f\"[CACHE] Cache hit for key: {cache_key}\")\n            return cached_data.get(\"results\")\n        \n        except Exception as e:\n            print(f\"[CACHE] Error loading cache: {e}\")\n            return None\n    \n    def _save_to_cache(self, cache_key: str, results: Dict):\n        \"\"\"Save search results to cache.\"\"\"\n        cache_file = self.cache_dir / f\"search_{cache_key}.json\"\n        \n        cache_data = {\n            \"cached_at\": datetime.now().isoformat(),\n            \"query_hash\": cache_key,\n            \"results\": results\n        }\n        \n        try:\n            with open(cache_file, \"w\") as f:\n                json.dump(cache_data, f, indent=2)\n            print(f\"[CACHE] Saved to cache: {cache_file}\")\n        except Exception as e:\n            print(f\"[CACHE] Error saving cache: {e}\")\n    \n    def _register_search_with_watchdog(self, query: str, params: Dict):\n        \"\"\"Register search operation with watchdog.\"\"\"\n        session_id = f\"tavily_search_{int(time.time())}\"\n        run_id = hashlib.md5(f\"{query}_{time.time()}\".encode()).hexdigest()[:8]\n        \n        task_desc = f\"Tavily search: {query[:50]}...\"\n        expected_time = params.get(\"timeout\", self.defaults.get(\"timeout\", 30))\n        \n\n[296 more lines in file. Use offset=150 to continue.]"}],"isError":false,"timestamp":1773071295831}}
