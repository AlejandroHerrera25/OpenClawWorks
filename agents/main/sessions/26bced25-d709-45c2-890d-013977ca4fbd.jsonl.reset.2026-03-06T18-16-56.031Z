{"type":"message","id":"dac5dc31","parentId":"74659cf2","timestamp":"2026-03-06T16:10:34.637Z","message":{"role":"toolResult","toolCallId":"call_00_prHAo3PqAQrW8GGXfiR08mG0","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nLearning System Integration\nEmit incidents and trigger learning‑loop fallback.\n\"\"\"\n\nimport logging\nfrom pathlib import Path\nfrom utils_io import emit_incident\n\nlogger = logging.getLogger(__name__)\n\ndef emit_blocking_incident(pattern_key, symptom, evidence=''):\n    \"\"\"\n    Emit a blocking incident and trigger learning‑loop fallback.\n    \"\"\"\n    logger.critical('Blocking incident: %s', pattern_key)\n    emit_incident(pattern_key, symptom, evidence, severity='S1')\n    # Trigger learning‑loop fallback (in production, call the error‑learning‑loop skill)\n    # For now, just log\n    logger.info('Learning‑loop fallback triggered (placeholder).')\n\ndef emit_nonblocking_incident(pattern_key, symptom, evidence=''):\n    \"\"\"\n    Emit a non‑blocking incident (warning).\n    \"\"\"\n    logger.warning('Non‑blocking incident: %s', pattern_key)\n    emit_incident(pattern_key, symptom, evidence, severity='S3')\n\n# Common incident helpers\ndef missing_sow():\n    emit_blocking_incident(\n        'fitgap|FAILURE|scope_missing|cannot_classify|blocked',\n        'SOW/proposal scope missing; cannot classify FIT/GAP.',\n        'User provided process description but no SOW document.'\n    )\n\ndef missing_evidence(feature):\n    emit_nonblocking_incident(\n        'evidence|MISSING|salesforce_official|feature_unverified|blocked',\n        f'Could not find official Salesforce documentation for feature: {feature}.',\n        f'Searched allowed domains for {feature}.'\n    )\n\ndef licensing_conflict(feature, required_license, available_licenses):\n    emit_blocking_incident(\n        'licensing|CONFLICT|feature_requires_license|not_available|alternate_needed',\n        f'Feature \"{feature}\" requires license \"{required_license}\" which is not available.',\n        f'Available licenses: {available_licenses}.'\n    )\n\nif __name__ == '__main__':\n    missing_sow()\n    missing_evidence('Custom Object')\n    licensing_conflict('Field Service', 'Field Service', ['Sales Cloud'])"}],"isError":false,"timestamp":1772813434623}}
