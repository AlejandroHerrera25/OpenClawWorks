ted but with issues\")\n                    print(f\"   Error: {output_data.get('error', 'Unknown error')}\")\n                    \n            except json.JSONDecodeError:\n                print(f\"  Output (not JSON): {result.stdout[:200]}...\")\n                \n        else:\n            print(f\"  ❌ Integration test failed\")\n            print(f\"  Error: {result.stderr[:200]}\")\n            \n    except Exception as e:\n        print(f\"  ❌ Integration test execution failed: {e}\")\n        import traceback\n        traceback.print_exc()\n    \n    print(\"\\n\" + \"=\" * 60)\n    print(\"📊 REAL INVOCATION TEST SUMMARY\")\n    print(\"=\" * 60)\n    \n    # Check what we actually tested\n    print(f\"Test project: {test_project}\")\n    print(f\"Code auditor scripts: {'✅ Found' if CODE_AUDITOR_SCRIPTS.exists() else '❌ Not found'}\")\n    \n    # List created artifacts\n    print(f\"\\nCreated artifacts in test project:\")\n    for item in test_project.rglob('*'):\n        if item.is_file():\n            rel_path = item.relative_to(test_project)\n            print(f\"  - {rel_path}\")\n    \n    return True\n\nif __name__ == '__main__':\n    success = test_real_auditor_invocation()\n    \n    print(f\"\\n📁 Test project kept for inspection at: /home/openclaw/.openclaw/workspace/projects/test_real_auditor\")\n    \n    sys.exit(0 if success else 1)"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":131,"output":2221,"cacheRead":41984,"cacheWrite":0,"totalTokens":44336,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101305423}}
