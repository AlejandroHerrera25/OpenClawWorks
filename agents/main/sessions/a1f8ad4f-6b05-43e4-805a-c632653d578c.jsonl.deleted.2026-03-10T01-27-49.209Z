{"type":"message","id":"331bb4d4","parentId":"d37db27a","timestamp":"2026-03-10T00:27:59.245Z","message":{"role":"toolResult","toolCallId":"call_00_J2O1F6AIsF44OBigOEDPvqbo","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nMain orchestrator for long prompt decomposition and execution.\nRefactored to ONLY generate plans, NOT spawn sub-agents.\nMain agent handles spawning and execution.\n\"\"\"\n\nimport sys\nimport os\nimport json\nimport argparse\nimport tempfile\nimport shutil\nimport time\nimport uuid\nfrom typing import Dict, List, Any, Optional\n\n# Add skill scripts directory to path\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\n\nfrom decompose import detect_and_decompose\nfrom todo import Checklist, ItemState\nfrom token_budget import TokenBudget\nfrom validate import validate_final_output\nfrom recovery import recover_from_interruption\nfrom learning_emit import emit_incident\nfrom plan_generator import PlanGenerator, generate_plan_from_decomposed_tasks\n\n# New modules for upgrade\nfrom context_monitor import ContextMonitor\nfrom context_archive import ContextArchiver\nfrom semantic_index_builder import update_semantic_index, SemanticIndexBuilder\nfrom semantic_context_search import SemanticContextSearch\nfrom task_state_manager import TaskStateManager\nfrom session_manager import SessionManager, create_new_session\nfrom memory_router import MemoryRouter, route_memory_for_step\nfrom context_cleanup import ContextCleanup\n\n# Configuration defaults\nMAX_PROMPT_TOKENS = 4000\nMAX_MINI_TASKS = 20\nGLOBAL_TOKEN_BUDGET = 16000\nINPUT_TOKEN_LIMIT = 4000\nOUTPUT_TOKEN_LIMIT = 2000\n\nWORKSPACE = os.path.expanduser(\"~/.openclaw/workspace\")\nTASKBOARDS_DIR = os.path.join(WORKSPACE, \".taskboards\")\n\ndef ensure_taskboards_dir():\n    \"\"\"Ensure .taskboards directory exists.\"\"\"\n    os.makedirs(TASKBOARDS_DIR, exist_ok=True)\n    os.makedirs(os.path.join(TASKBOARDS_DIR, \"checkpoints\"), exist_ok=True)\n\ndef simulate_model_call(context: str, max_output_tokens: int) -> str:\n    \"\"\"\n    Simulate a model call for demo purposes.\n    In production, replace with actual OpenClaw tooling.\n    \"\"\"\n    # For demo, just echo the objective and produce a placeholder output.\n    lines = context.split('\\n')\n    objective = next((line for line in lines if 'Objective:' in line), '')\n    return f\"Simulated output for {objective[:50]}...\\nThis output satisfies the acceptance criteria.\"\n\ndef run_demo_basic():\n    \"\"\"Run basic demo from example_basic.md.\"\"\"\n    print(\"=== Running Basic Demo ===\")\n    ensure_taskboards_dir()\n    \n    # Hardcoded long prompt from example_basic.md\n    prompt = \"\"\"Create a comprehensive report about climate change impacts on agriculture.\nThe report should include:\n1. Introduction: overview of climate change and its relevance to agriculture.\n2. Temperature effects: how rising temperatures affect crop yields, soil moisture, and pest dynamics.\n3. Precipitation changes: impacts of altered rainfall patterns, droughts, and floods.\n4. CO2 fertilization: the positive and negative effects of increased atmospheric CO2 on plant growth.\n5. Adaptation strategies: changes in farming practices, crop selection, irrigation, and technology.\n6. Policy recommendations: suggestions for governments, NGOs, and farmers.\n7. Conclusion: summary and future outlook.\n\nPlease write each section in detail, with sub‑headings, and include at least three references per section.\nThe report should be well‑structured, around 3000 words total.\"\"\"\n    \n    print(f\"Original prompt length: {len(prompt)} chars\")\n    \n    # Detect and decompose with low threshold to ensure decomposition\n    result = detect_and_decompose(prompt, max_prompt_tokens=100, max_mini_tasks=MAX_MINI_TASKS)\n    if isinstance(result, tuple) and len(result) == 2:\n        tasks, metrics = result\n    else:\n        tasks = result if result else []\n        metrics = {}\n    \n    if not tasks:\n        # Fallback: create dummy tasks\n        tasks = [\n            {'id': 'task_01', 'objective': 'Write introduction', 'inputs': [], 'outputs': [], 'dependencies': [], 'acceptance_criteria': [], 'max_token_budget': 1000},\n            {'id': 'task_02', 'objective': 'Write temperature effects', 'inputs': [], 'outputs': [], 'dependencies': ['task_01'], 'acceptance_criteria': [], 'max_token_budget': 1000},\n            {'id': 'task_03', 'objective': 'Write precipitation changes', 'inputs': [], 'outputs': [], 'dependencies': ['task_02'], 'acceptance_criteria': [], 'max_token_budget': 1000},\n            {'id': 'task_04', 'objective': 'Write CO2 fertilization', 'inputs': [], 'outputs': [], 'dependencies': ['task_03'], 'acceptance_criteria': [], 'max_token_budget': 1000},\n        ]\n\n[379 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1773102479240}}
