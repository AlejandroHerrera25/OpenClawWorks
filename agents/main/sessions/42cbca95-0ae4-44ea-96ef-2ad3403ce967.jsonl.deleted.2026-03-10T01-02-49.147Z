Invoke tavily-web-search skill with objective: Research temperature effects...\",\n      \"required_inputs\": [],\n      \"expected_outputs\": [\n        \"research_notes.json\",\n        \"statistics.csv\"\n      ],\n      \"dependencies\": [],\n      \"validation_method\": \"Check that output files exist: research_notes.json, statistics.csv\",\n      \"estimated_tokens\": 1500,\n      \"estimated_runtime_seconds\": 120,\n      \"complexity_score\": 6,\n      \"recommended_skill_or_role\": \"tavily-web-search\",\n      \"artifact_destination\": \"projects/{project_key}/research_notes.json\",\n      \"priority\": \"high\",\n      \"execution_hints\": {\n        \"parallelizable\": true,\n        \"requires_isolation\": false,\n        \"risk_level\": \"medium\",\n        \"retry_policy\": \"exponential_backoff_3\"\n      }\n    },\n    {\n      \"task_id\": \"task_03_synthesis\",\n      \"objective\": \"Synthesize findings into report\",\n      \"description\": \"Combine introduction and research findings into comprehensive report section.\",\n      \"execution_mode\": \"subagent\",\n      \"action_type\": \"skill_invocation\",\n      \"action_instructions\": \"Invoke tavily-web-search skill with objective: Synthesize findings into report...\",\n      \"required_inputs\": [\n        \"introduction.md\",\n        \"research_notes.json\"\n      ],\n      \"expected_outputs\": [\n        \"temperature_effects_section.md\"\n      ],\n      \"dependencies\": [\n        \"task_01_introduction\",\n        \"task_02_research\"\n      ],\n      \"validation_method\": \"Check that output files exist: temperature_effects_section.md\",\n      \"estimated_tokens\": 1200,\n      \"estimated_runtime_seconds\": 90,\n      \"complexity_score\": 4,\n      \"recommended_skill_or_role\": \"tavily-web-search\",\n      \"artifact_destination\": \"projects/{project_key}/temperature_effects_section.md\",\n      \"priority\": \"medium\",\n      \"execution_hints\": {\n        \"parallelizab