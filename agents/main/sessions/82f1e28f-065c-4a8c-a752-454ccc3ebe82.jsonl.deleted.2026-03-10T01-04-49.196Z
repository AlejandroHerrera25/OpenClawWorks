{"type":"message","id":"92606b81","parentId":"2fd57b2c","timestamp":"2026-03-10T00:11:03.444Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create a test script to run the salesforce-code-auditor with these fixtures:"},{"type":"toolCall","id":"call_00_np0UfVCbVp6xx4mq90bzXEVB","name":"write","arguments":{"path":"~/.openclaw/workspace/tests/test_with_real_fixtures.py","content":"#!/usr/bin/env python3\n\"\"\"\nTest salesforce-code-auditor with real Salesforce fixtures.\n\"\"\"\nimport os\nimport sys\nimport json\nimport shutil\nimport subprocess\nfrom pathlib import Path\n\n# Add skill scripts to path\nskill_dir = Path.home() / '.openclaw' / 'workspace' / 'skills' / 'salesforce-code-auditor' / 'scripts'\nsys.path.append(str(skill_dir))\n\n# Workspace paths\nworkspace = Path.home() / '.openclaw' / 'workspace'\nfixtures_dir = workspace / 'fixtures' / 'real_salesforce_samples'\nevidence_dir = workspace / 'evidence' / 'audit_outputs'\n\ndef setup_test_environment():\n    \"\"\"Create test project structure.\"\"\"\n    print(\"Setting up test environment...\")\n    \n    # Create evidence directory\n    evidence_dir.mkdir(parents=True, exist_ok=True)\n    \n    # Create test project\n    project_dir = workspace / 'projects' / 'test_real_fixtures'\n    project_dir.mkdir(parents=True, exist_ok=True)\n    \n    return project_dir\n\ndef run_audit_pipeline(project_key, case_id):\n    \"\"\"Run the full audit pipeline.\"\"\"\n    print(f\"\\nRunning audit pipeline for {project_key}/{case_id}...\")\n    \n    # Step 1: Initialize case\n    print(\"Step 1: Initializing case...\")\n    init_cmd = [\n        sys.executable, str(skill_dir / 'init_case.py'),\n        '--project-key', project_key,\n        '--case-id', case_id\n    ]\n    \n    try:\n        result = subprocess.run(init_cmd, capture_output=True, text=True, cwd=workspace)\n        if result.returncode != 0:\n            print(f\"Init failed: {result.stderr}\")\n            return False\n        print(\"✓ Case initialized\")\n    except Exception as e:\n        print(f\"Init error: {e}\")\n        return False\n    \n    # Step 2: Copy fixtures to inputs directory\n    print(\"Step 2: Copying fixtures...\")\n    inputs_dir = workspace / 'projects' / project_key / 'code_audit' / case_id / 'inputs'\n    inputs_dir.mkdir(parents=True, exist_ok=True)\n    \n    # Copy all fixture files\n    for fixture_file in fixtures_dir.glob('*'):\n        if fixture_file.is_file():\n            shutil.copy2(fixture_file, inputs_dir / fixture_file.name)\n            print(f\"  Copied: {fixture_file.name}\")\n    \n    # Step 3: Index inputs\n    print(\"Step 3: Indexing inputs...\")\n    index_cmd = [\n        sys.executable, str(skill_dir / 'index_inputs.py'),\n        '--project-key', project_key,\n        '--case-id', case_id\n    ]\n    \n    try:\n        result = subprocess.run(index_cmd, capture_output=True, text=True, cwd=workspace)\n        if result.returncode != 0:\n            print(f\"Indexing failed: {result.stderr}\")\n            return False\n        print(\"✓ Inputs indexed\")\n    except Exception as e:\n        print(f\"Indexing error: {e}\")\n        return False\n    \n    # Step 4: Detect entrypoints\n    print(\"Step 4: Detecting entrypoints...\")\n    entry_cmd = [\n        sys.executable, str(skill_dir / 'detect_entrypoints.py'),\n        '--project-key', project_key,\n        '--case-id', case_id\n    ]\n    \n    try:\n        result = subprocess.run(entry_cmd, capture_output=True, text=True, cwd=workspace)\n        if result.returncode != 0:\n            print(f\"Entrypoint detection failed: {result.stderr}\")\n            return False\n        print(\"✓ Entrypoints detected\")\n    except Exception as e:\n        print(f\"Entrypoint detection error: {e}\")\n        return False\n    \n    # Step 5: Build dependency graph\n    print(\"Step 5: Building dependency graph...\")\n    dep_cmd = [\n        sys.executable, str(skill_dir / 'build_dependency_graph.py'),\n        '--project-key', project_key,\n        '--case-id', case_id\n    ]\n    \n    try:\n        result = subprocess.run(dep_cmd, capture_output=True, text=True, cwd=workspace)\n        if result.returncode != 0:\n            print(f\"Dependency graph failed: {result.stderr}\")\n            return False\n        print(\"✓ Dependency graph built\")\n    except Exception as e:\n        print(f\"Dependency graph error: {e}\")\n        return False\n    \n    # Step 6: Generate reports\n    print(\"Step 6: Generating reports...\")\n    report_cmd = [\n        sys.executable, str(skill_dir / 'generate_reports.py'),\n        '--project-key', project_key,\n        '--case-id', case_id\n    ]\n    \n    try:\n        result = subprocess.run(report_cmd, capture_output=True, text=True, cwd=workspace)\n        if result.returncode != 0:\n            print(f\"Report generation failed: {result.stderr}\")\n            return False\n        print(\"✓ Reports generated\")\n    except Exception as e:\n        print(f\"Report generation error: {e}\")\n        return False\n    \n    return True\n\ndef analyze_results(project_key, case_id):\n    \"\"\"Analyze audit results for substance and completeness.\"\"\"\n    print(f\"\\nAnalyzing results for {project_key}/{case_id}...\")\n    \n    case_dir = workspace / 'projects' / project_key / 'code_audit' / case_id\n    results = {\n        'files_processed': 0,\n        'findings_count': 0,\n        'has_dependency_graph': False,\n        'has_audit_report': False,\n        'findings_substance': [],\n        'integration_readiness': False\n    }\n    \n    # Check what files were created\n    expected_files = [\n        'INDEX.md',\n        'MANIFEST.json',\n        'DEPENDENCY_GRAPH.json',\n        'ENTRYPOINTS.json',\n        'FINDINGS.md',\n        'AUDIT_REPORT.md'\n    ]\n    \n    for file in expected_files:\n        file_path = case_dir / file\n        if file_path.exists():\n            print(f\"✓ {file} exists\")\n            \n            if file == 'FINDINGS.md':\n                content = file_path.read_text()\n                findings = [line for line in content.split('\\n') if line.strip().startswith('-')]\n                results['findings_count'] = len(findings)\n                results['findings_substance'] = findings[:5]  # Sample first 5\n                \n            elif file == 'DEPENDENCY_GRAPH.json':\n                results['has_dependency_graph'] = True\n                \n            elif file == 'AUDIT_REPORT.md':\n                results['has_audit_report'] = True\n                content = file_path.read_text()\n                # Check for substantive content\n                if len(content) > 500 and '###' in content:\n                    results['integration_readiness'] = True\n    \n    # Count processed files from INDEX.md\n    index_path = case_dir / 'INDEX.md'\n    if index_path.exists():\n        content = index_path.read_text()\n        # Simple count of file entries\n        results['files_processed'] = content.count('.cls') + content.count('.trigger') + \\\n                                   content.count('.js') + content.count('.html') + \\\n                                   content.count('.page') + content.count('.flow-meta.xml')\n    \n    # Copy evidence to evidence directory\n    print(\"\\nCopying evidence to evidence directory...\")\n    for file in expected_files:\n        src = case_dir / file\n        if src.exists():\n            dst = evidence_dir / file\n            shutil.copy2(src, dst)\n            print(f\"  Copied: {file}\")\n    \n    return results\n\ndef test_apex_analysis():\n    \"\"\"Test APEX analysis specifically.\"\"\"\n    print(\"\\n=== APEX Analysis Test ===\")\n    \n    # Create a simple test case for APEX only\n    project_key = 'test_apex'\n    case_id = 'apex_analysis'\n    \n    success = run_audit_pipeline(project_key, case_id)\n    if not success:\n        return False\n    \n    results = analyze_results(project_key, case_id)\n    \n    print(f\"\\nAPEX Analysis Results:\")\n    print(f\"  Files processed: {results['files_processed']}\")\n    print(f\"  Findings count: {results['findings_count']}\")\n    print(f\"  Has dependency graph: {results['has_dependency_graph']}\")\n    print(f\"  Has audit report: {results['has_audit_report']}\")\n    \n    if results['findings_count'] > 0:\n        print(f\"\\nSample findings:\")\n        for finding in results['findings_substance'][:3]:\n            print(f\"  - {finding}\")\n    \n    return results['findings_count'] > 0 and results['has_audit_report']\n\ndef test_lwc_analysis():\n    \"\"\"Test LWC analysis specifically.\"\"\"\n    print(\"\\n=== LWC Analysis Test ===\")\n    \n    # Check if LWC files were analyzed\n    case_dir = workspace / 'projects' / 'test_real_fixtures' / 'code_audit' / 'full_audit'\n    findings_path = case_dir / 'FINDINGS.md'\n    \n    if not findings_path.exists():\n        print(\"No findings file found\")\n        return False\n    \n    content = findings_path.read_text()\n    \n    # Look for LWC-related findings\n    lwc_keywords = ['LWC', 'Lightning', 'JavaScript', 'template', 'wire', '@track']\n    lwc_findings = []\n    \n    for line in content.split('\\n'):\n        if any(keyword.lower() in line.lower() for keyword in lwc_keywords):\n            lwc_findings.append(line.strip())\n    \n    print(f\"Found {len(lwc_findings)} LWC-related findings\")\n    if lwc_findings:\n        print(\"\\nSample LWC findings:\")\n        for finding in lwc_findings[:3]:\n            print(f\"  - {finding}\")\n    \n    return len(lwc_findings) > 0\n\ndef test_dependency_graph():\n    \"\"\"Test dependency graph generation.\"\"\"\n    print(\"\\n=== Dependency Graph Test ===\")\n    \n    graph_path = workspace / 'projects' / 'test_real_fixtures' / 'code_audit' / 'full_audit' / 'DEPENDENCY_GRAPH.json'\n    \n    if not graph_path.exists():\n        print(\"No dependency graph found\")\n        return False\n    \n    try:\n        with open(graph_path, 'r') as f:\n            graph = json.load(f)\n        \n        print(f\"Dependency graph contains:\")\n        print(f\"  Nodes: {len(graph.get('nodes', []))}\")\n        print(f\"  Edges: {len(graph.get('edges', []))}\")\n        \n        # Check for specific dependencies\n        nodes = [node.get('id', '') for node in graph.get('nodes', [])]\n        if 'AccountController' in nodes and 'AccountService' in nodes:\n            print(\"✓ Found expected APEX classes\")\n        \n        return len(graph.get('nodes', [])) > 0 and len(graph.get('edges', [])) > 0\n        \n    except Exception as e:\n        print(f\"Error reading dependency graph: {e}\")\n        return False\n\ndef test_integration_readiness():\n    \"\"\"Test if outputs are consumable by salesforce-architect.\"\"\"\n    print(\"\\n=== Integration Readiness Test ===\")\n    \n    report_path = workspace / 'projects' / 'test_real_fixtures' / 'code_audit' / 'full_audit' / 'AUDIT_REPORT.md'\n    \n    if not report_path.exists():\n        print(\"No audit report found\")\n        return False\n    \n    content = report_path.read_text()\n    \n    # Check for architect-consumable format\n    required_sections = [\n        '## Code Audit Report',\n        '### Executive Summary',\n        '### Technical Assessment',\n        '### Risk Assessment',\n        '### Recommendations'\n    ]\n    \n    missing_sections = []\n    for section in required_sections:\n        if section not in content:\n            missing_sections.append(section)\n    \n    if missing_sections:\n        print(f\"Missing sections: {missing_sections}\")\n        return False\n    \n    print(\"✓ Audit report has required sections for architect consumption\")\n    \n    # Check for specific, technical findings (not placeholder)\n    placeholder_phrases = [\n        'placeholder',\n        'sample text',\n        'TODO',\n        'FIXME',\n        'example only'\n    ]\n    \n    has_placeholder = any(phrase in content.lower() for phrase in placeholder_phrases)\n    if has_placeholder:\n        print(\"✗ Report contains placeholder text\")\n        return False\n    \n    print(\"✓ Report contains substantive technical findings\")\n    return True\n\ndef main():\n    \"\"\"Main test execution.\"\"\"\n    print(\"=\" * 60)\n    print(\"Salesforce Code Auditor - Real Fixtures Test\")\n    print(\"=\" * 60)\n    \n    # Setup\n    setup_test_environment()\n    \n    # Run full audit pipeline\n    print(\"\\n=== Full Audit Pipeline Test ===\")\n    full_success = run_audit_pipeline('test_real_fixtures', 'full_audit')\n    \n    if not full_success:\n        print(\"\\n✗ Full audit pipeline failed\")\n        return False\n    \n    print(\"\\n✓ Full audit pipeline completed successfully\")\n    \n    # Analyze results\n    results = analyze_results('test_real_fixtures', 'full_audit')\n    \n    print(f\"\\nOverall Results:\")\n    print(f\"  Files processed: {results['files_processed']}\")\n    print(f\"  Findings count: {results['findings_count']}\")\n    print(f\"  Has dependency graph: {results['has_dependency_graph']}\")\n    print(f\"  Has audit report: {results['has_audit_report']}\")\n    print(f\"  Integration ready: {results['integration_readiness']}\")\n    \n    # Run specific tests\n    tests = {\n        'APEX Analysis': test_apex_analysis,\n        'LWC Analysis': test_lwc_analysis,\n        'Dependency Graph': test_dependency_graph,\n        'Integration Readiness': test_integration_readiness\n    }\n    \n    test_results = {}\n    for test_name, test_func in tests.items():\n        print(f\"\\nRunning {test_name}...\")\n        try:\n            test_results[test_name] = test_func()\n            print(f\"  Result: {'✓ PASS' if test_results[test_name] else '✗ FAIL'}\")\n        except Exception as e:\n            print(f\"  Error: {e}\")\n            test_results[test_name] = False\n    \n    # Determine classification\n    print(\"\\n\" + \"=\" * 60)\n    print(\"CLASSIFICATION ASSESSMENT\")\n    print(\"=\" * 60)\n    \n    passed_tests = sum(1 for result in test_results.values() if result)\n    total_tests = len(test_results)\n    \n    print(f\"\\nTests passed: {passed_tests}/{total_tests}\")\n    \n    # Check for substantive findings\n    has_substantive_findings = results['findings_count'] > 10  # Arbitrary threshold\n    \n    if passed_tests == total_tests and has_substantive_findings:\n        classification = \"FUNCTIONAL\"\n        print(\"✓ All tests passed with substantive findings\")\n        print(\"✓ Real code analysis performed\")\n        print(\"✓ Integration-ready outputs generated\")\n    elif passed_tests >= 2 and results['findings_count'] > 0:\n        classification = \"PARTIAL\"\n        print(\"~ Some functions work but limitations exist\")\n        print(f\"~ Found {results['findings_count']} findings\")\n    else:\n        classification = \"SIMULATED\"\n        print(\"✗ Only placeholder outputs or no real analysis\")\n    \n    print(f\"\\nFinal Classification: {classification}\")\n    \n    # Generate integration test report\n    generate_integration_report(test_results, results, classification)\n    \n    return classification == \"FUNCTIONAL\"\n\ndef generate_integration_report(test_results, overall_results, classification):\n    \"\"\"Generate integration test report.\"\"\"\n    print(\"\\nGenerating integration test report...\")\n    \n    report_path = workspace / 'integration_test_report.md'\n    \n    report = f\"\"\"# Integration Test Report - Salesforce Code Auditor\n\n## Test Summary\n- **Date**: {subprocess.check_output(['date']).decode().strip()}\n- **Classification**: {classification}\n- **Files Processed**: {overall_results['files_processed']}\n- **Findings Generated**: {overall_results['findings_count']}\n\n## Test Results\n\n### Individual Tests\n\"\"\"\n    \n    for test_name, result in test_results.items():\n        report += f\"- **{test_name}**: {'✓ PASS' if result else '✗ FAIL'}\\n\"\n    \n    report += f\"\"\"\n### Overall Assessment\n- **Dependency Graph Generated**: {'✓ Yes' if overall_results['has_dependency_graph'] else '✗ No'}\n- **Audit Report Generated**: {'✓ Yes' if overall_results['has_audit_report'] else '✗ No'}\n- **Integration Ready**: {'✓ Yes' if overall_results['integration_readiness'] else '✗ No'}\n\n## Evidence Location\nAll audit outputs have been copied to: `{evidence_dir}`\n\n## Files Created\n1. **Real Salesforce fixtures**: `{fixtures_dir}`\n2. **Test script**: `{workspace / 'tests' / 'test_with_real_fixtures.py'}`\n3. **Audit evidence**: `{evidence_dir}`\n4. **This report**: `{report_path}`\n\n## Sample Findings\n\"\"\"\n    \n    if overall_results['findings_substance']:\n        for finding in overall_results['findings_substance'][:5]:\n            report += f\"- {finding}\\n\"\n    else:\n        report += \"No substantive findings generated.\\n\"\n    \n    report += f\"\"\"\n## Classification Rationale\n**{classification}** - Because:\n\"\"\"\n    \n    if classification == \"FUNCTIONAL\":\n        report += \"\"\"1. All test scenarios passed\n2. Substantive technical findings were generated\n3. Complete audit reports were created\n4. Outputs are consumable by salesforce-architect\n5. Real dependency graphs were generated from real code\n\"\"\"\n    elif classification == \"PARTIAL\":\n        report += \"\"\"1. Some functions work but limitations exist\n2. May have generated findings but with gaps\n3. Integration with architect may be limited\n\"\"\"\n    else:\n        report += \"\"\"1. Only placeholder or descriptive outputs\n2. No real code analysis performed\n3. Findings are generic or missing\n\"\"\"\n\n    report += \"\"\"\n## Next Steps\n1"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":105,"output":4096,"cacheRead":27712,"cacheWrite":0,"totalTokens":31913,"cost":{"input":0,"output":0,"cach