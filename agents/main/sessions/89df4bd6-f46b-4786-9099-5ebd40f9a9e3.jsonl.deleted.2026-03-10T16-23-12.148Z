e='*.py' | head -10\"\n 209                 else:\n 210                     return \"grep -r 'TODO\\\\|FIXME' /home/openclaw/.openclaw/workspace --include='*.py' --include='*.md' | head -10\"\n 211             elif \"count\" in obj_lower or \"measure\" in obj_lower:\n 212                 if \"line\" in obj_lower:\n 213                     return \"find /home/openclaw/.openclaw/workspace -type f -name '*.py' -exec wc -l {} \\\\; | tail -1\"\n 214                 elif \"file\" in obj_lower:\n 215                     return \"find /home/openclaw/.openclaw/workspace -type f | wc -l\"\n 216                 else:\n 217                     return \"find /home/openclaw/.openclaw/workspace -type f -name '*.py' | wc -l\"\n 218             elif \"check\" in obj_lower or \"verify\" in obj_lower:\n 219                 return \"python3 -m py_compile /home/openclaw/.openclaw/workspace/skills/*/scripts/*.py 2>&1 | head -10\"\n 220             else:\n-221                 # Generic command based on objective\n-222                 return f\"# Execute: {objective[:80]}\\necho 'Starting task: {objective[:80]}...'\\ndate\"\n+228                 # For truly generic tasks, provide specific guidance instead of echo\n+229                 return self._generate_specific_guidance(objective, description, outputs)\n 223         \n 224         elif action_type == \"python\":\n 225             # Generate Python script instructions\n 226             if \"analyze\" in objective.lower() or \"process\" in objective.lower():\n     ...","firstChangedLine":194},"isError":false,"timestamp":1773105862117}}
{"type":"message","id":"6713cc42","parentId":"f034d8da","timestamp":"2026-03-10T01:26:40.125Z","message":{"role":"assistant","content":[{"type":"text","text":"Now I need to add the helper methods for handling complex task patterns and generating specific guidance. Let me add these methods to the PlanGenerator class:"},{"type":"toolCall","id":"call_00_d99RIWumKmqreqWa4SD6oUuL","name":"edit","arguments":{"path":"~/.openclaw/workspace/skills/long-prompt-orchestrator/scripts/plan_generator.py","oldText":"        return f\"# Execute: {objective[:80]}\\n# Determine appropriate action based on task requirements\"\n    \n    def _generate_validation_method(self, task_data: Dict[str, Any]) -> str:","newText":"        return f\"# Execute: {objective[:80]}\\n# Determine appropriate action based on task requirements\"\n    \n    def _handle_complex_task_patterns(self, objective: str, obj_lower: str, outputs: List[str]) -> Optional[str]:\n        \"\"\"Handle complex task patterns with specific executable instructions.\"\"\"\n        # Validation tasks\n        if \"validates\" in obj_lower or \"validate\" in obj_lower:\n            return self._generate_validation_instructions(objective, obj_lower, outputs)\n        \n        # Testing tasks\n        elif \"tests\" in obj_lower or \"test\" in obj_lower:\n            return self._generate_testing_instructions(objective, obj_lower, outputs)\n        \n        # Creation tasks\n        elif \"creates\" in obj_lower or \"create\" in obj_lower or \"generates\" in obj_lower or \"generate\" in obj_lower:\n            return self._generate_creation_instructions(objective, obj_lower, outputs)\n        \n        # Analysis tasks\n        elif \"analyzes\" in obj_lower or \"analyze\" in obj_lower or \"analysis\" in obj_lower:\n            return self._generate_analysis_instructions(objective, obj_lower, outputs)\n        \n        # Monitoring tasks\n        elif \"monitors\" in obj_lower or \"monitor\" in obj_lower or \"dashboard\" in obj_lower:\n            return self._generate_monitoring_instructions(objective, obj_lower, outputs)\n        \n        # Audit tasks\n        elif \"audits\" in obj_lower or \"audit\" in obj_lower or \"reviews\" in obj_lower or \"review\" in obj_lower:\n            return self._generate_audit_instructions(objective, obj_lower, outputs)\n        \n        # Implementation tasks\n        elif \"implements\" in obj_lower or \"implement\" in obj_lower or \"builds\" in obj_lower or \"build\" in obj_lower:\n            return self._generate_implementation_instructions(objective, obj_lower, outputs)\n        \n        # Documentation tasks\n        elif \"documents\" in obj_lower or \"document\" in obj_lower or \"writes\" in obj_lower or \"write\" in obj_lower:\n            return self._generate_documentation_instructions(objective, obj_lower, outputs)\n        \n        return None\n    \n    def _generate_validation_instructions(self, objective: str, obj_lower: str, outputs: List[str]) -> str:\n        \"\"\"Generate specific validation instructions.\"\"\"\n        # Extract what needs to be validated\n        import re\n        \n        # Check for component validation\n        component_match = re.search(r'(\\d+)\\s+(component|module|function|skill)', obj_lower)\n        if component_match:\n            count = component_match.group(1)\n            item_type = component_match.group(2)\n            \n            if item_type == \"skill\":\n                # Validate skills\n                instructions = []\n                instructions.append(\"# Validate all skills in workspace\")\n                instructions.append(\"\")\n                \n                # List all skills\n                instructions.append(\"# 1. List all skills\")\n                instructions.append(\"find /home/openclaw/.openclaw/workspace/skills -type f -name 'SKILL.md' -exec dirname {} \\\\; | xargs -I {} basename {} | sort\")\n                instructions.append(\"\")\n                \n                # Check each skill\n                instructions.append(\"# 2. Check each skill's structure\")\n                instructions.append(\"for skill in $(find /home/openclaw/.openclaw/workspace/skills -type f -name 'SKILL.md' -exec dirname {} \\\\; | xargs -I {} basename {}); do\")\n                instructions.append(\"  echo \\\"Checking skill: $skill\\\"\")\n                instructions.append(\"  # Check SKILL.md exists\")\n                instructions.append(\"  if [ -f \\\"/home/openclaw/.openclaw/workspace/skills/$skill/SKILL.md\\\" ]; then\")\n                instructions.append(\"    echo \\\"  ✓ SKILL.md exists\\\"\")\n                instructions.append(\"  else\")\n                instructions.append(\"    echo \\\"  ✗ SKILL.md missing\\\"\")\n                instructions.append(\"  fi\")\n                instructions.append(\"  \")\n                instructions.append(\"  # Check scripts directory\")\n                instructions.append(\"  if [ -d \\\"/home/openclaw/.openclaw/workspace/skills/$skill/scripts\\\" ]; then\")\n                instructions.append(\"    echo \\\"  ✓ scripts directory exists\\\"\")\n                instructions.append(\"    # Count Python files\")\n                instructions.append(\"    count=$(find \\\"/home/openclaw/.openclaw/workspace/skills/$skill/scripts\\\" -name \\\"*.py\\\" | wc -l)\")\n                instructions.append(\"    echo \\\"  ✓ Found $count Python files\\\"\")\n                instructions.append(\"  else\")\n                instructions.append(\"    echo \\\"  ✗ scripts directory missing\\\"\")\n                instructions.append(\"  fi\")\n                instructions.append(\"done\")\n                instructions.append(\"\")\n                \n                # Generate validation report\n                if outputs:\n                    output_file = outputs[0]\n                    instructions.append(f\"# 3. Generate validation report\")\n                    instructions.append(f\"echo \\\"# Skill Validation Report\\\" > {output_file}\")\n                    instructions.append(f\"echo \\\"Generated: $(date)\\\" >> {output_file}\")\n                    instructions.append(f\"echo \\\"\\\" >> {output_file}\")\n                    instructions.append(f\"echo \\\"## Summary\\\" >> {output_file}\")\n                    instructions.append(f\"echo \\\"Validated all skills in workspace.\\\" >> {output_file}\")\n                \n                return \"\\n\".join(instructions)\n        \n        # Generic validation\n        instructions = []\n        instructions.append(f\"# Validation: {objective}\")\n        instructions.append(\"\")\n        instructions.append(\"# 1. Define validation criteria\")\n        instructions.append(f\"VALIDATION_CRITERIA=\\\"Validate: {objective}\\\"\")\n        instructions.append(\"echo \\\"Validation criteria: $VALIDATION_CRITERIA\\\"\")\n        instructions.append(\"\")\n        instructions.append(\"# 2. Perform validation checks\")\n        instructions.append(\"# TODO: Implement specific validation logic based on objective\")\n        instructions.append(\"# Example: Check system components, verify configurations, test functionality\")\n        instructions.append(\"\")\n        instructions.append(\"# 3. Record validation results\")\n        instructions.append(\"VALIDATION_RESULT=\\\"pending\\\"\")\n        instructions.append(\"# Determine validation result based on checks\")\n        instructions.append(\"\")\n        \n        if outputs:\n            output_file = outputs[0]\n            instructions.append(f\"# 4. Generate validation report\")\n            instructions.append(f\"echo \\\"# Validation Report\\\" > {output_file}\")\n            instructions.append(f\"echo \\\"Objective: {objective}\\\" >> {output_file}\")\n            instructions.append(f\"echo \\\"Date: $(date)\\\" >> {output_file}\")\n            instructions.append(f\"echo \\\"Result: $VALIDATION_RESULT\\\" >> {output_file}\")\n            instructions.append(f\"echo \\\"Details: Validation completed\\\" >> {output_file}\")\n        \n        return \"\\n\".join(instructions)\n    \n    def _generate_testing_instructions(self, objective: str, obj_lower: str, outputs: List[str]) -> str:\n        \"\"\"Generate specific testing instructions.\"\"\"\n        instructions = []\n        instructions.append(f\"# Testing: {objective}\")\n        instructions.append(\"\")\n        instructions.append(\"# 1. Define test cases\")\n        instructions.append(f\"TEST_CASES=\\\"Test: {objective}\\\"\")\n        instructions.append(\"echo \\\"Test cases: $TEST_CASES\\\"\")\n        instructions.append(\"\")\n        instructions.append(\"# 2. Execute tests\")\n        instructions.append(\"# TODO: Implement specific test execution\")\n        instructions.append(\"# Example: Run unit tests, integration tests, system tests\")\n        instructions.append(\"\")\n        instructions.append(\"# 3. Record test results\")\n        instructions.append(\"TEST_RESULT=\\\"pending\\\"\")\n        instructions.append(\"# Determine test result based on execution\")\n        instructions.append(\"\")\n        \n        if outputs:\n            output_file = outputs[0]\n            instructions.append(f\"# 4. Generate test report\")\n            instructions.append(f\"echo \\\"# Test Report\\\" > {output_file}\")\n            instructions.append(f\"echo \\\"Objective: {objective}\\\" >> {output_file}\")\n            instructions.append(f\"echo \\\"Date: $(date)\\\" >> {output_file}\")\n            instructions.append(f\"echo \\\"Result: $TEST_RESULT\\\" >> {output_file}\")\n            instructions.append(f\"echo \\\"Details: Testing completed\\\" >> {output_file}\")\n        \n        return \"\\n\".join(instructions)\n    \n    def _generate_creation_instructions(self, objective: str, obj_lower: str, outputs: List[str]) -> str:\n        \"\"\"Generate specific creation instructions.\"\"\"\n        # Check for dashboard creati