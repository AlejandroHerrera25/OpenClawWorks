+= \"3. **Medium**: \\n\"\n-178     report += \"4. **Low**: \\n\\n\"\n-179 \n-180     report += \"## Appendix\\n\"\n-181     report += \"- Files examined: \\n\"\n-182     report += \"- Snippets extracted: \\n\"\n-183     report += \"- Dependency graph: see DEPENDENCY_GRAPH.json\\n\"\n-184     report += \"- Execution trace: see EXECUTION_TRACE.md\\n\"\n-185 \n-186     write_file(case_root / 'AUDIT_REPORT.md', report)\n-187     print(f\"Written {case_root / 'AUDIT_REPORT.md'}\")\n-188 \n 189 def emit_incidents(project_key, case_id):\n 190     \"\"\"If critical issues found, emit incident via unified emitter.\"\"\"\n 191     # Path to the unified incident emitter script\n 192     script_path = WORKSPACE_ROOT / 'skills' / 'error-learning-loop' / 'scripts' / 'emit_incident.py'\n     ...","firstChangedLine":3},"isError":false,"timestamp":1773103119400}}
