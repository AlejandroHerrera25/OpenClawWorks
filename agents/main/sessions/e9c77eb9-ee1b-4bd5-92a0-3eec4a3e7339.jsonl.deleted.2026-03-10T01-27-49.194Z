{"type":"message","id":"cfeaa32d","parentId":"e42286f2","timestamp":"2026-03-10T00:29:02.128Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create the main agent monitoring integration:"},{"type":"toolCall","id":"call_00_ulCaCAdT2ZuwGqM4CRwzcjQn","name":"write","arguments":{"path":"~/.openclaw/workspace/integration/main_agent_monitoring.py","content":"#!/usr/bin/env python3\n\"\"\"\nMain Agent Monitoring Integration\nRegisters main agent sessions with watchdog and enables monitoring.\n\"\"\"\n\nimport os\nimport json\nimport time\nimport sys\nimport uuid\nfrom datetime import datetime\nfrom pathlib import Path\n\n# Workspace paths\nWORKSPACE = Path.home() / '.openclaw' / 'workspace'\nWATCHDOG_DIR = WORKSPACE / '.watchdog'\nSESSION_REGISTRY = WATCHDOG_DIR / 'session_registry.json'\nMONITORING_LOG = WATCHDOG_DIR / 'monitoring.log'\n\nclass MainAgentMonitor:\n    \"\"\"Main agent monitoring integration.\"\"\"\n    \n    def __init__(self):\n        self.session_id = None\n        self.task_description = None\n        self.expected_runtime = None\n        self.start_time = None\n        \n    def log_monitoring(self, message, level=\"INFO\"):\n        \"\"\"Log monitoring activity.\"\"\"\n        timestamp = datetime.utcnow().isoformat()\n        log_entry = f\"[{timestamp}] [MAIN_AGENT] [{level}] {message}\\n\"\n        \n        # Write to monitoring log\n        try:\n            with open(MONITORING_LOG, 'a') as f:\n                f.write(log_entry)\n        except Exception as e:\n            print(f\"Failed to write to monitoring log: {e}\")\n        \n        # Also print to console\n        print(log_entry.strip())\n    \n    def register_main_agent_session(self, task_description, expected_runtime_minutes=5):\n        \"\"\"Register main agent session with watchdog.\"\"\"\n        # Generate session ID if not already set\n        if not self.session_id:\n            self.session_id = f\"main_{uuid.uuid4().hex[:8]}\"\n        \n        self.task_description = task_description\n        self.expected_runtime = expected_runtime_minutes\n        self.start_time = datetime.utcnow().isoformat()\n        \n        # Create session entry\n        session_entry = {\n            \"session_id\": self.session_id,\n            \"source\": \"main_agent_integration\",\n            \"registered_at\": self.start_time,\n            \"last_activity\": self.start_time,\n            \"state\": \"active\",\n            \"task_description\": task_description,\n            \"expected_runtime_minutes\": expected_runtime_minutes,\n            \"stall_count\": 0,\n            \"recovery_attempts\": 0,\n            \"metrics\": {\n                \"total_uptime\": 0,\n                \"stall_detections\": 0,\n                \"recovery_attempts\": 0,\n                \"last_activity\": self.start_time\n            },\n            \"session_data_summary\": {\n                \"agent_type\": \"main\",\n                \"task_type\": \"orchestration\",\n                \"integration_level\": \"monitored\"\n            }\n        }\n        \n        # Load existing registry\n        registry = {}\n        if SESSION_REGISTRY.exists():\n            try:\n                with open(SESSION_REGISTRY, 'r') as f:\n                    registry = json.load(f)\n            except Exception as e:\n                self.log_monitoring(f\"Error loading registry: {e}\", level=\"ERROR\")\n        \n        # Add or update session\n        registry[self.session_id] = session_entry\n        \n        # Save registry\n        try:\n            with open(SESSION_REGISTRY, 'w') as f:\n                json.dump(registry, f, indent=2)\n        except Exception as e:\n            self.log_monitoring(f\"Error saving registry: {e}\", level=\"ERROR\")\n            return False\n        \n        self.log_monitoring(f\"Registered main agent session: {self.session_id} - {task_description}\")\n        return True\n    \n    def update_activity(self, activity_description=None):\n        \"\"\"Update activity timestamp for main agent session.\"\"\"\n        if not self.session_id:\n            self.log_monitoring(\"No active session to update\", level=\"WARNING\")\n            return False\n        \n        current_time = datetime.utcnow().isoformat()\n        \n        # Load registry\n        if not SESSION_REGISTRY.exists():\n            self.log_monitoring(\"Registry file not found\", level=\"ERROR\")\n            return False\n        \n        try:\n            with open(SESSION_REGISTRY, 'r') as f:\n                registry = json.load(f)\n        except Exception as e:\n            self.log_monitoring(f\"Error loading registry: {e}\", level=\"ERROR\")\n            return False\n        \n        # Update session\n        if self.session_id in registry:\n            registry[self.session_id][\"last_activity\"] = current_time\n            registry[self.session_id][\"state\"] = \"active\"\n            \n            # Add activity description if provided\n            if activity_description:\n                if \"recent_activities\" not in registry[self.session_id]:\n                    registry[self.session_id][\"recent_activities\"] = []\n                registry[self.session_id][\"recent_activities\"].append({\n                    \"timestamp\": current_time,\n                    \"description\": activity_description\n                })\n                # Keep only last 10 activities\n                if len(registry[self.session_id][\"recent_activities\"]) > 10:\n                    registry[self.session_id][\"recent_activities\"] = registry[self.session_id][\"recent_activities\"][-10:]\n            \n            # Save registry\n            try:\n                with open(SESSION_REGISTRY, 'w') as f:\n                    json.dump(registry, f, indent=2)\n            except Exception as e:\n                self.log_monitoring(f\"Error saving registry: {e}\", level=\"ERROR\")\n                return False\n            \n            self.log_monitoring(f\"Updated activity for session {self.session_id}: {activity_description or 'heartbeat'}\")\n            return True\n        else:\n            self.log_monitoring(f\"Session {self.session_id} not found in registry\", level=\"WARNING\")\n            return False\n    \n    def register_subagent_spawn(self, subagent_id, task_description, expected_runtime_minutes=3):\n        \"\"\"Register a sub-agent spawn event.\"\"\"\n        if not self.session_id:\n            self.log_monitoring(\"No active main agent session\", level=\"WARNING\")\n            return False\n        \n        current_time = datetime.utcnow().isoformat()\n        \n        # Load registry\n        if not SESSION_REGISTRY.exists():\n            self.log_monitoring(\"Registry file not found\", level=\"ERROR\")\n            return False\n        \n        try:\n            with open(SESSION_REGISTRY, 'r') as f:\n                registry = json.load(f)\n        except Exception as e:\n            self.log_monitoring(f\"Error loading registry: {e}\", level=\"ERROR\")\n            return False\n        \n        # Update main agent session with sub-agent info\n        if self.session_id in registry:\n            if \"subagents\" not in registry[self.session_id]:\n                registry[self.session_id][\"subagents\"] = []\n            \n            subagent_entry = {\n                \"subagent_id\": subagent_id,\n                \"spawned_at\": current_time,\n                \"task_description\": task_description,\n                \"expected_runtime_minutes\": expected_runtime_minutes,\n                \"status\": \"spawned\",\n                \"parent_session\": self.session_id\n            }\n            \n            registry[self.session_id][\"subagents\"].append(subagent_entry)\n            \n            # Also create separate entry for sub-agent\n            subagent_session_id = f\"sub_{subagent_id}\"\n            registry[subagent_session_id] = {\n                \"session_id\": subagent_session_id,\n                \"source\": \"subagent_integration\",\n                \"registered_at\": current_time,\n                \"last_activity\": current_time,\n                \"state\": \"active\",\n                \"task_description\": task_description,\n                \"expected_runtime_minutes\": expected_runtime_minutes,\n                \"parent_session\": self.session_id,\n                \"stall_count\": 0,\n                \"recovery_attempts\": 0,\n                \"metrics\": {\n                    \"total_uptime\": 0,\n                    \"stall_detections\": 0,\n                    \"recovery_attempts\": 0,\n                    \"last_activity\": current_time\n                },\n                \"session_data_summary\": {\n                    \"agent_type\": \"subagent\",\n                    \"task_type\": \"execution\",\n                    \"integration_level\": \"monitored\"\n                }\n            }\n            \n            # Save registry\n            try:\n                with open(SESSION_REGISTRY, 'w') as f:\n                    json.dump(registry, f, indent=2)\n            except Exception as e:\n                self.log_monitoring(f\"Error saving registry: {e}\", level=\"ERROR\")\n                return False\n            \n            self.log_monitoring(f\"Registered sub-agent spawn: {subagent_id} - {task_description}\")\n            return True\n        else:\n            self.log_monitoring(f\"Main session {self.session_id} not found\", level=\"WARNING\")\n            return False\n    \n    def complete_session(self, outcome=\"success\", completion_notes=None):\n        \"\"\"Mark main agent session as completed.\"\"\"\n        if not self.session_id:\n            self.log_monitoring(\"No active session to complete\", level=\"WARNING\")\n            return False\n        \n        current_time = datetime.utcnow().isoformat()\n        \n        # Load registry\n        if not SESSION_REGISTRY.exists():\n            self.log_monitoring(\"Registry file not found\", level=\"ERROR\")\n            return False\n        \n        try:\n            with open(SESSION_REGISTRY, 'r') as f:\n                registry = json.load(f)\n        except Exception as e:\n            self.log_monitoring(f\"Error loading registry: {e}\", level=\"ERROR\")\n            return False\n        \n        # Update session\n        if self.session_id in registry:\n            registry[self.session_id][\"state\"] = \"completed\"\n            registry[self.session_id][\"completed_at\"] = current_time\n            registry[self.session_id][\"outcome\"] = outcome\n            \n            if completion_notes:\n                registry[self.session_id][\"completion_notes\"] = completion_notes\n            \n            # Calculate runtime\n            start_time = datetime.fromisoformat(registry[self.session_id][\"registered_at\"])\n            end_time = datetime.fromisoformat(current_time)\n            runtime_seconds = (end_time - start_time).total_seconds()\n            registry[self.session_id][\"metrics\"][\"total_uptime\"] = runtime_seconds\n            \n            # Save registry\n            try:\n                with open(SESSION_REGISTRY, 'w') as f:\n                    json.dump(registry, f, indent=2)\n            except Exception as e:\n                self.log_monitoring(f\"Error saving registry: {e}\", level=\"ERROR\")\n                return False\n            \n            self.log_monitoring(f\"Completed main agent session: {self.session_id} - Outcome: {outcome}\")\n            \n            # Reset session ID\n            self.session_id = None\n            return True\n        else:\n            self.log_monitoring(f\"Session {self.session_id} not found\", level=\"WARNING\")\n            return False\n\n# Global instance for easy import\nmain_monitor = MainAgentMonitor()\n\nif __name__ == \"__main__\":\n    # Test the monitoring integration\n    monitor = MainAgentMonitor()\n    \n    # Test 1: Register main agent session\n    print(\"Test 1: Registering main agent session...\")\n    if monitor.register_main_agent_session(\"Test monitoring integration\", expected_runtime_minutes=10):\n        print(\"✓ Main agent session registered\")\n    else:\n        print(\"✗ Failed to register main agent session\")\n    \n    # Test 2: Update activity\n    print(\"\\nTest 2: Updating activity...\")\n    if monitor.update_activity(\"Testing monitoring system\"):\n        print(\"✓ Activity updated\")\n    else:\n        print(\"✗ Failed to update activity\")\n    \n    # Test 3: Register sub-agent spawn\n    print(\"\\nTest 3: Registering sub-agent spawn...\")\n    subagent_id = \"test_subagent_123\"\n    if monitor.register_subagent_spawn(subagent_id, \"Test sub-agent task\", expected_runtime_minutes=5):\n        print(\"✓ Sub-agent spawn registered\")\n    else:\n        print(\"✗ Failed to register sub-agent spawn\")\n    \n    # Test 4: Complete session\n    print(\"\\nTest 4: Completing session...\")\n    if monitor.complete_session(\"success\", \"Integration test completed\"):\n        print(\"✓ Session completed\")\n    else:\n        print(\"✗ Failed to complete session\")"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":78,"output":2640,"cacheRead":21504,"cacheWrite":0,"totalTokens":24222,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773102466340}}
