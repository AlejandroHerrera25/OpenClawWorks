{"type":"message","id":"719f6f72","parentId":"be3415b9","timestamp":"2026-03-09T22:03:40.217Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_00_BlEF3cvoAUi9JwmJxJjBcbSs","name":"read","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/long-prompt-orchestrator/scripts/orchestrate.py","limit":100}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":2421,"output":86,"cacheRead":60416,"cacheWrite":0,"totalTokens":62923,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773093814772}}
{"type":"message","id":"36b52764","parentId":"719f6f72","timestamp":"2026-03-09T22:03:40.238Z","message":{"role":"toolResult","toolCallId":"call_00_BlEF3cvoAUi9JwmJxJjBcbSs","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nMain orchestrator for long prompt decomposition and execution.\nRefactored to ONLY generate plans, NOT spawn sub-agents.\nMain agent handles spawning and execution.\n\"\"\"\n\nimport sys\nimport os\nimport json\nimport argparse\nimport tempfile\nimport shutil\nimport time\nimport uuid\nfrom typing import Dict, List, Any, Optional\n\n# Add skill scripts directory to path\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\n\nfrom decompose import detect_and_decompose\nfrom todo import Checklist, ItemState\nfrom token_budget import TokenBudget\nfrom validate import validate_final_output\nfrom recovery import recover_from_interruption\nfrom learning_emit import emit_incident\nfrom plan_generator import PlanGenerator, generate_plan_from_decomposed_tasks\n\n# New modules for upgrade\nfrom context_monitor import ContextMonitor\nfrom context_archive import ContextArchiver\nfrom semantic_index_builder import update_semantic_index, SemanticIndexBuilder\nfrom semantic_context_search import SemanticContextSearch\nfrom task_state_manager import TaskStateManager\nfrom session_manager import SessionManager, create_new_session\nfrom memory_router import MemoryRouter, route_memory_for_step\nfrom context_cleanup import ContextCleanup\n\n# Configuration defaults\nMAX_PROMPT_TOKENS = 4000\nMAX_MINI_TASKS = 20\nGLOBAL_TOKEN_BUDGET = 16000\nINPUT_TOKEN_LIMIT = 4000\nOUTPUT_TOKEN_LIMIT = 2000\n\nWORKSPACE = os.path.expanduser(\"~/.openclaw/workspace\")\nTASKBOARDS_DIR = os.path.join(WORKSPACE, \".taskboards\")\n\ndef ensure_taskboards_dir():\n    \"\"\"Ensure .taskboards directory exists.\"\"\"\n    os.makedirs(TASKBOARDS_DIR, exist_ok=True)\n    os.makedirs(os.path.join(TASKBOARDS_DIR, \"checkpoints\"), exist_ok=True)\n\ndef simulate_model_call(context: str, max_output_tokens: int) -> str:\n    \"\"\"\n    Simulate a model call for demo purposes.\n    In production, replace with actual OpenClaw tooling.\n    \"\"\"\n    # For demo, just echo the objective and produce a placeholder output.\n    lines = context.split('\\n')\n    objective = next((line for line in lines if 'Objective:' in line), '')\n    return f\"Simulated output for {objective[:50]}...\\nThis output satisfies the acceptance criteria.\"\n\ndef run_demo_basic():\n    \"\"\"Run basic demo from example_basic.md.\"\"\"\n    print(\"=== Running Basic Demo ===\")\n    ensure_taskboards_dir()\n    \n    # Hardcoded long prompt from example_basic.md\n    prompt = \"\"\"Create a comprehensive report about climate change impacts on agriculture.\nThe report should include:\n1. Introduction: overview of climate change and its relevance to agriculture.\n2. Temperature effects: how rising temperatures affect crop yields, soil moisture, and pest dynamics.\n3. Precipitation changes: impacts of altered rainfall patterns, droughts, and floods.\n4. CO2 fertilization: the positive and negative effects of increased atmospheric CO2 on plant growth.\n5. Adaptation strategies: changes in farming practices, crop selection, irrigation, and technology.\n6. Policy recommendations: suggestions for governments, NGOs, and farmers.\n7. Conclusion: summary and future outlook.\n\nPlease write each section in detail, with sub‑headings, and include at least three references per section.\nThe report should be well‑structured, around 3000 words total.\"\"\"\n    \n    print(f\"Original prompt length: {len(prompt)} chars\")\n    \n    # Detect and decompose with low threshold to ensure decomposition\n    result = detect_and_decompose(prompt, max_prompt_tokens=100, max_mini_tasks=MAX_MINI_TASKS)\n    if isinstance(result, tuple) and len(result) == 2:\n        tasks, metrics = result\n    else:\n        tasks = result if result else []\n        metrics = {}\n    \n    if not tasks:\n        # Fallback: create dummy tasks\n        tasks = [\n            {'id': 'task_01', 'objective': 'Write introduction', 'inputs': [], 'outputs': [], 'dependencies': [], 'acceptance_criteria': [], 'max_token_budget': 1000},\n            {'id': 'task_02', 'objective': 'Write temperature effects', 'inputs': [], 'outputs': [], 'dependencies': ['task_01'], 'acceptance_criteria': [], 'max_token_budget': 1000},\n            {'id': 'task_03', 'objective': 'Write precipitation changes', 'inputs': [], 'outputs': [], 'dependencies': ['task_02'], 'acceptance_criteria': [], 'max_token_budget': 1000},\n            {'id': 'task_04', 'objective': 'Write CO2 fertilization', 'inputs': [], 'outputs': [], 'dependencies': ['task_03'], 'acceptance_criteria': [], 'max_token_budget': 1000},\n        ]\n\n[365 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1773093820228}}
{"type":"message","id":"47b4c63d","parentId":"36b52764","timestamp":"2026-03-09T22:03:44.289Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_00_5lasVyuq0N3tlYxwkvfAnXff","name":"read","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/long-prompt-orchestrator/scripts/plan_generator.py"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":1104,"output":71,"cacheRead":62912,"cacheWrite":0,"totalTokens":64087,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773093820236}}
{"type":"message","id":"ff68aa35","parentId":"47b4c63d","timestamp":"2026-03-09T22:03:44.308Z","message":{"role":"toolResult","toolCallId":"call_00_5lasVyuq0N3tlYxwkvfAnXff","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nPlan Generator for long-prompt-orchestrator skill.\nGenerates structured plans for main agent execution.\nReplaces incorrect spawning code with proper planning interface.\n\"\"\"\n\nimport json\nimport os\nimport uuid\nimport time\nfrom typing import Dict, List, Any, Optional, Tuple\nfrom dataclasses import dataclass, asdict\nfrom enum import Enum\n\nWORKSPACE = os.path.expanduser(\"~/.openclaw/workspace\")\n\nclass TaskPriority(Enum):\n    LOW = \"low\"\n    MEDIUM = \"medium\"\n    HIGH = \"high\"\n    CRITICAL = \"critical\"\n\n@dataclass\nclass PlanTask:\n    \"\"\"Task representation in a plan.\"\"\"\n    task_id: str\n    objective: str\n    description: str\n    inputs: List[str]\n    outputs: List[str]\n    dependencies: List[str]\n    acceptance_criteria: List[str]\n    estimated_tokens: int\n    estimated_runtime_seconds: int\n    complexity_score: int\n    requires_subagent: bool\n    recommended_skill: Optional[str]\n    recommended_model: Optional[str]\n    priority: TaskPriority = TaskPriority.MEDIUM\n    execution_hints: Optional[Dict[str, Any]] = None\n    \n    def to_dict(self) -> Dict[str, Any]:\n        \"\"\"Convert to dictionary for JSON serialization.\"\"\"\n        data = asdict(self)\n        data['priority'] = self.priority.value\n        if self.execution_hints is None:\n            data['execution_hints'] = self._default_execution_hints()\n        return data\n    \n    def _default_execution_hints(self) -> Dict[str, Any]:\n        \"\"\"Generate default execution hints based on task properties.\"\"\"\n        return {\n            \"parallelizable\": len(self.dependencies) == 0,\n            \"requires_isolation\": self.complexity_score >= 7,\n            \"risk_level\": \"high\" if self.complexity_score >= 7 else \"medium\" if self.complexity_score >= 4 else \"low\",\n            \"retry_policy\": \"exponential_backoff_3\" if self.complexity_score >= 5 else \"immediate_2\"\n        }\n\nclass PlanGenerator:\n    \"\"\"Generates structured plans for main agent execution.\"\"\"\n    \n    def __init__(self, original_prompt: str):\n        self.original_prompt = original_prompt\n        self.plan_id = f\"plan_{int(time.time())}_{uuid.uuid4().hex[:8]}\"\n        self.tasks: List[PlanTask] = []\n        self.created_at = time.strftime(\"%Y-%m-%dT%H:%M:%SZ\", time.gmtime())\n    \n    def add_task(self, task_data: Dict[str, Any]) -> str:\n        \"\"\"Add a task to the plan.\"\"\"\n        # Generate task_id if not provided\n        task_id = task_data.get('id', f\"task_{len(self.tasks)+1:02d}\")\n        \n        # Create PlanTask object\n        task = PlanTask(\n            task_id=task_id,\n            objective=task_data.get('objective', ''),\n            description=task_data.get('description', task_data.get('objective', '')),\n            inputs=task_data.get('inputs', []),\n            outputs=task_data.get('outputs', []),\n            dependencies=task_data.get('dependencies', []),\n            acceptance_criteria=task_data.get('acceptance_criteria', []),\n            estimated_tokens=task_data.get('estimated_tokens', 1000),\n            estimated_runtime_seconds=task_data.get('estimated_runtime', 60),\n            complexity_score=task_data.get('complexity_score', 0),\n            requires_subagent=self._should_require_subagent(task_data),\n            recommended_skill=self._recommend_skill(task_data),\n            recommended_model=self._recommend_model(task_data),\n            priority=self._determine_priority(task_data)\n        )\n        \n        self.tasks.append(task)\n        return task_id\n    \n    def _should_require_subagent(self, task_data: Dict[str, Any]) -> bool:\n        \"\"\"Determine if task requires sub-agent.\"\"\"\n        # Always require subagent if explicitly specified\n        if task_data.get('subagent_required', False):\n            return True\n        \n        # Require subagent for complex tasks\n        complexity_score = task_data.get('complexity_score', 0)\n        if complexity_score >= 5:\n            return True\n        \n        # Require subagent for specialized tasks\n        if self._recommend_skill(task_data) is not None:\n            return True\n        \n        # Require subagent for long-running tasks\n        estimated_runtime = task_data.get('estimated_runtime', 0)\n        if estimated_runtime > 300:  # 5 minutes\n            return True\n        \n        return False\n    \n    def _recommend_skill(self, task_data: Dict[str, Any]) -> Optional[str]:\n        \"\"\"Recommend skill for task based on content analysis.\"\"\"\n        objective = task_data.get('objective', '').lower()\n        description = task_data.get('description', '').lower()\n        \n        # Check for Salesforce-related content\n        salesforce_keywords = ['salesforce', 'apex', 'lwc', 'visualforce', 'soql', 'flow']\n        if any(keyword in objective or keyword in description for keyword in salesforce_keywords):\n            return \"salesforce-architect\"\n        \n        # Check for web search/research\n        search_keywords = ['search', 'research', 'find', 'look up', 'web', 'internet']\n        if any(keyword in objective or keyword in description for keyword in search_keywords):\n            return \"tavily-web-search\"\n        \n        # Check for code auditing\n        audit_keywords = ['audit', 'review', 'check', 'validate', 'security', 'code quality']\n        if any(keyword in objective or keyword in description for keyword in audit_keywords):\n            return \"salesforce-code-auditor\"\n        \n        # Check for workspace maintenance\n        maintenance_keywords = ['clean', 'organize', 'tidy', 'maintain', 'janitor']\n        if any(keyword in objective or keyword in description for keyword in maintenance_keywords):\n            return \"workspace-janitor\"\n        \n        return None\n    \n    def _recommend_model(self, task_data: Dict[str, Any]) -> Optional[str]:\n        \"\"\"Recommend model for task based on complexity.\"\"\"\n        complexity_score = task_data.get('complexity_score', 0)\n        \n        if complexity_score >= 8:\n            return \"gpt-4\"  # High complexity tasks\n        elif complexity_score >= 5:\n            return \"deepseek-chat\"  # Medium complexity tasks\n        else:\n            return None  # Use default model\n    \n    def _determine_priority(self, task_data: Dict[str, Any]) -> TaskPriority:\n        \"\"\"Determine task priority.\"\"\"\n        complexity_score = task_data.get('complexity_score', 0)\n        \n        if complexity_score >= 8:\n            return TaskPriority.CRITICAL\n        elif complexity_score >= 5:\n            return TaskPriority.HIGH\n        elif complexity_score >= 3:\n            return TaskPriority.MEDIUM\n        else:\n            return TaskPriority.LOW\n    \n    def build_dependency_graph(self) -> Dict[str, Any]:\n        \"\"\"Build dependency graph from tasks.\"\"\"\n        nodes = [task.task_id for task in self.tasks]\n        edges = []\n        \n        for task in self.tasks:\n            for dep in task.dependencies:\n                edges.append([dep, task.task_id])\n        \n        # Calculate topological order (simplified Kahn's algorithm)\n        topological_order = self._calculate_topological_order(nodes, edges)\n        \n        return {\n            \"nodes\": nodes,\n            \"edges\": edges,\n            \"topological_order\": topological_order\n        }\n    \n    def _calculate_topological_order(self, nodes: List[str], edges: List[List[str]]) -> List[str]:\n        \"\"\"Calculate topological order using Kahn's algorithm.\"\"\"\n        from collections import defaultdict, deque\n        \n        # Build adjacency list and in-degree count\n        graph = defaultdict(list)\n        in_degree = defaultdict(int)\n        \n        for node in nodes:\n            in_degree[node] = 0\n        \n        for from_node, to_node in edges:\n            graph[from_node].append(to_node)\n            in_degree[to_node] += 1\n        \n        # Initialize queue with nodes having no incoming edges\n        queue = deque([node for node in nodes if in_degree[node] == 0])\n        topological_order = []\n        \n        # Process queue\n        while queue:\n            node = queue.popleft()\n            topological_order.append(node)\n            \n            for neighbor in graph[node]:\n                in_degree[neighbor] -= 1\n                if in_degree[neighbor] == 0:\n                    queue.append(neighbor)\n        \n        # Check for cycles\n        if len(topological_order) != len(nodes):\n            # Graph has a cycle, return nodes in original order\n            return nodes\n        \n        return topological_order\n    \n    def calculate_resource_allocation(self) -> Dict[str, Any]:\n        \"\"\"Calculate resource allocation recommendations.\"\"\"\n        total_tokens = sum(task.estimated_tokens for task in self.tasks)\n        total_runtime = sum(task.estimated_runtime_seconds for task in self.tasks)\n        \n        # Count tasks that can run in parallel (no dependencies)\n        parallelizable_tasks = sum(1 for task in self.tasks if len(task.dependencies) == 0)\n        \n        # Calculate max concurrent tasks (simplified)\n        max_concurrent = min(parallelizable_tasks, 5)  # Cap at 5 concurrent\n        \n        # Calculate token budget per phase\n        token_budget_per_phase = min(4000, total_tokens // 3)\n        \n        return {\n            \"max_concurrent_tasks\": max_concurrent,\n            \"token_budget_per_phase\": token_budget_per_phase,\n            \"recommended_batch_size\": min(3, max_concurrent)\n        }\n    \n    def generate_validation_protocol(self) -> Dict[str, Any]:\n        \"\"\"Generate validation protocol for the plan.\"\"\"\n        return {\n            \"pre_execution_checks\": [\n                \"Verify workspace has write permissions\",\n                \"Check available token budget\",\n                \"Validate task dependencies are acyclic\"\n            ],\n            \"post_execution_validation\": [\n                \"Validate each task's acceptance criteria\",\n                \"Check output files exist and are readable\",\n                \"Verify task outputs match expected formats\"\n            ],\n            \"final_synthesis_requirements\": [\n                \"Combine all task outputs into final result\",\n                \"Validate final result against original prompt requirements\",\n                \"Ensure proper formatting and structure\"\n            ]\n        }\n    \n    def generate_plan(self) -> Dict[str, Any]:\n        \"\"\"Generate complete plan in standard format.\"\"\"\n        # Calculate total resources\n        total_tokens = sum(task.estimated_tokens for task in self.tasks)\n        total_runtime = sum(task.estimated_runtime_seconds for task in self.tasks)\n        \n        # Build plan structure\n        plan = {\n            \"plan_id\": self.plan_id,\n            \"original_prompt\": self.original_prompt[:1000] + \"...\" if len(self.original_prompt) > 1000 else self.original_prompt,\n            \"created_at\": self.created_at,\n            \"estimated_total_tokens\": total_tokens,\n            \"estimated_total_runtime_seconds\": total_runtime,\n            \"global_token_budget\": 16000,  # Default budget\n            \"tasks\": [task.to_dict() for task in self.tasks],\n            \"dependency_graph\": self.build_dependency_graph(),\n            \"resource_allocation\": self.calculate_resource_allocation(),\n            \"validation_protocol\": self.generate_validation_protocol()\n        }\n        \n        return plan\n    \n    def save_plan(self, output_path: Optional[str] = None) -> str:\n        \"\"\"Save plan to file.\"\"\"\n        if output_path is None:\n            output_path = os.path.join(WORKSPACE, f\"{self.plan_id}.json\")\n        \n        plan = self.generate_plan()\n        \n        with open(output_path, 'w') as f:\n            json.dump(plan, f, indent=2)\n        \n        return output_path\n\ndef generate_plan_from_decomposed_tasks(original_prompt: str, decomposed_tasks: List[Dict[str, Any]]) -> Dict[str, Any]:\n    \"\"\"\n    Generate a plan from decomposed tasks.\n    \n    Args:\n        original_prompt: The original prompt\n        decomposed_tasks: List of decomposed tasks from decompose.py\n        \n    Returns:\n        Structured plan in standard format\n    \"\"\"\n    generator = PlanGenerator(original_prompt)\n    \n    for task_data in decomposed_tasks:\n        generator.add_task(task_data)\n    \n    return generator.generate_plan()\n\ndef demo_plan_generation():\n    \"\"\"Demo plan generation with example tasks.\"\"\"\n    print(\"=== Demo: Plan Generation ===\")\n    \n    # Example decomposed tasks\n    example_tasks = [\n        {\n            'id': 'task_01_introduction',\n            'objective': 'Write introduction section',\n            'description': 'Create a 300-word introduction that provides an overview of climate change and its relevance to agriculture.',\n            'inputs': [],\n            'outputs': ['introduction.md'],\n            'dependencies': [],\n            'acceptance_criteria': [\n                'File exists: introduction.md',\n                'Word count >= 250',\n                'Contains keywords: climate, agriculture, overview'\n            ],\n            'estimated_tokens': 800,\n            'estimated_runtime': 60,\n            'complexity_score': 3\n        },\n        {\n            'id': 'task_02_research',\n            'objective': 'Research temperature effects',\n            'description': 'Research how rising temperatures affect crop yields, soil moisture, and pest dynamics.',\n            'inputs': [],\n            'outputs': ['research_notes.json', 'statistics.csv'],\n            'dependencies': [],\n            'acceptance_criteria': [\n                'File exists: research_notes.json',\n                'Contains at least 5 data points',\n                'Includes citations to recent studies'\n            ],\n            'estimated_tokens': 1500,\n            'estimated_runtime': 120,\n            'complexity_score': 6,\n            'subagent_required': True\n        },\n        {\n            'id': 'task_03_synthesis',\n            'objective': 'Synthesize findings into report',\n            'description': 'Combine introduction and research findings into comprehensive report section.',\n            'inputs': ['introduction.md', 'research_notes.json'],\n            'outputs': ['temperature_effects_section.md'],\n            'dependencies': ['task_01_introduction', 'task_02_research'],\n            'acceptance_criteria': [\n                'File exists: temperature_effects_section.md',\n                'Word count >= 500',\n                'Integrates data from research notes'\n            ],\n            'estimated_tokens': 1200,\n            'estimated_runtime': 90,\n            'complexity_score': 4\n        }\n    ]\n    \n    original_prompt = \"Create a comprehensive report about climate change impacts on agriculture.\"\n    \n    generator = PlanGenerator(original_prompt)\n    \n    for task in example_tasks:\n        generator.add_task(task)\n    \n    plan = generator.generate_plan()\n    \n    print(f\"Generated plan: {plan['plan_id']}\")\n    print(f\"Total tasks: {len(plan['tasks'])}\")\n    print(f\"Estimated tokens: {plan['estimated_total_tokens']}\")\n    print(f\"Estimated runtime: {plan['estimated_total_runtime_seconds']} seconds\")\n    \n    print(\"\\nTasks requiring sub-agents:\")\n    for task in plan['tasks']:\n        if task['requires_subagent']:\n            print(f\"  - {task['task_id']}: {task['objective'][:50]}...\")\n            if task['recommended_skill']:\n                print(f\"    Recommended skill: {task['recommended_skill']}\")\n    \n    print(\"\\nDependency graph:\")\n    print(f\"  Nodes: {len(plan['dependency_graph']['nodes'])}\")\n    print(f\"  Edges: {len(plan['dependency_graph']['edges'])}\")\n    print(f\"  Topological order: {plan['dependency_graph']['topological_order']}\")\n    \n    # Save plan to file\n    output_path = generator.save_plan()\n    print(f\"\\nPlan saved to: {output_path}\")\n    \n    return plan\n\nif __name__ == \"__main__\":\n    demo_plan_generation()"}],"isError":false,"timestamp":1773093824299}}
