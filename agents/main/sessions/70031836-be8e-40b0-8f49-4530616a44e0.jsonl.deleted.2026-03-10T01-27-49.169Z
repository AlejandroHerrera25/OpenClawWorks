    \n    # Group by pattern\n    patterns = {}\n    for f in findings['findings']:\n        p = f['pattern']\n        if p not in patterns:\n            patterns[p] = []\n        patterns[p].append(f)\n    \n    for p, fs in patterns.items():\n        if fs:\n            count = len(fs)\n            f = fs[0]\n            recs.append(f\"#### {p} ({count} occurrences)\")\n            recs.append(f\"- **Example**: `{f['file']}:{f['line']}`\")\n            recs.append(f\"- **Fix**: {f['recommendation']}\")\n    \n    return \"\\n\".join(recs)\n\ndef _get_detailed_evidence(findings):\n    evidence = []\n    critical = [f for f in findings['findings'] if f['severity'] == 'CRITICAL']\n    \n    if critical:\n        evidence.append(\"#### Critical Findings:\")\n        for f in critical:\n            evidence.append(f\"##### {f['pattern']} in `{f['file']}:{f['line']}`\")\n            evidence.append(f\"```\\n{f['code_snippet']}\\n```\")\n            evidence.append(f\"**Fix**: {f['recommendation']}\")\n            evidence.append(\"\")\n    \n    return \"\\n\".join(evidence)\n\ndef _get_feasibility(blockers):\n    critical = len(blockers['critical_blockers'])\n    \n    if critical > 0:\n        return f\"\"\"- **Feasibility**: NOT FEASIBLE without changes\n- **Blockers**: {critical} critical issues\n- **Action**: Address critical findings first\"\"\"\n    else:\n        return f\"\"\"- **Feasibility**: FEASIBLE\n- **Concerns**: Review high/medium findings\n- **Action**: Proceed with design\"\"\"\n\ndef _get_gap_analysis(findings):\n    gaps = []\n    \n    has_test = any('TEST' in f['pattern'] for f in findings['findings'])\n    if not has_test:\n        gaps.append(\"- **Testing**: Limited test coverage\")\n    \n    if not gaps:\n        gaps.append(\"- **Minimal Gaps**: Implementation aligns with design\")\n    \n    return \"\\n\".join(gaps)\n\ndef _get_complexity(findings):\n    critical = findings['metadata']['severity_counts']['CRITICAL']\n    high = findings['metadata']['severity_counts']['HIGH']\n    \n    complexity = []\n    complexity.append(\"- **Effort Estimation**:\")\n    \n    if critical > 0:\n        complexity.append(f\"  - Critical: {critical} × 2-4 hours\")\n    if high > 0:\n        complexity.append(f\"  - High: {high} × 1-2 hours\")\n    \n    total = (critical * 3) + (high * 1.5)\n    if total > 0:\n        complexity.append(f\"  - **Total**: ~{total:.1f} hours\")\n    \n    return \"\\n\".join(complexity)\n\ndef _get_design_recommendations(findings):\n    recs = []\n    \n    critical_patterns = set(f['pattern'] for f in findings['findings'] if f['severity'] == 'CRITICAL')\n    \n    if 'SOQL_IN_LOOP' in critical_patterns:\n        recs.append(\"1. **Design Adjustment**: Implement bulkified data access\")\n    if 'FLS_MISSING' in critical_patterns:\n        recs.append(\"2. **Security Layer**: Add security service\")\n    if 'RECURSION_RISK' in critical_patterns:\n        recs.append(\"3. **Trigger Framework**: Implement handler pattern\")\n    \n    if not recs:\n        recs.append(\"1. **No Major Changes**: Current design is feasible\")\n    \n    return \"\\n\".join(recs)\n\ndef _get_design_evidence(findings):\n    evidence = []\n    sample = findings['findings'][:2] if len(findings['findings']) > 0 else []\n    \n    if sample:\n        evidence.append(\"#### Sample Findings:\")\n        for f in sample:\n            evidence.append(f\"- **{f['severity']}**: {f['pattern']}\")\n            evidence.append(f\"  - `{f['file']}:{f['line']}`\")\n            evidence.append(f\"  - {f['description'][:100]}...\")\n    \n    return \"\\n\".join(evidence)\n\ndef _get_exec_summary(findings, risk):\n    overall = risk['risk_assessment']['overall_risk']\n    \n    summary = []\n    summary.append(f\"- **Findings**: {findings['metadata']['total_findings']}\")\n    summary.append(f\"- **Risk**: {overall['level']} ({overall['score']}/100)\")\n    summary.append(f\"- **Critical**: {findings['metadata']['severity_counts']['CRITICAL']}\")\n    \n    return \"\\n\".join(summary)\n\ndef _get_findings_by_severity(findings):\n    text = []\n    \n    for severity in ['CRITICAL', 'HIGH', 'MEDIUM', 'LOW']:\n        fs = [f for f in findings['findings'] if f['severity'] == severity]\n        if fs:\n            text.append(f\"### {severity} Findings\")\n            for f in fs:\n                text.append(f\"- **{f['pattern']}** in `{f['file']}:{f['line']}`\")\n                text.append(f\"  - {f['description']}\")\n            text.append(\"\")\n    \n    return \"\\n\".join(text)\n\ndef _get_all_recommendations(findings):\n    recs = []\n    \n    priorities = {\n        'CRITICAL': 'Immediate Action',\n        'HIGH': 'Should Address Soon',\n        'MEDIUM': 'Consider for Next Release',\n        'LOW': 'Nice to Have'\n    }\n    \n    for severity, desc in priorities.items():\n        fs = [f for f in findings['findings'] if f['severity'] == severity]\n        if fs:\n            recs.append(f\"### {desc}\")\n            for f in fs:\n                recs.append(f\"1. **{f['pattern']}** in `{f['file']}`\")\n                recs.append(f\"   - {f['recommendation']}\")\n            recs.append(\"\")\n    \n    return \"\\n\".join(recs)\n\ndef _get_complete_evidence(findings):\n    evidence = []\n    \n    evidence.append(\"### Findings Summary\")\n    evidence.append(f\"- **Total**: {findings['metadata']['total_findings']}\")\n    \n    for severity, count in findings['metadata']['severity_counts'].items():\n        evidence.append(f\"- **{severity}**: {count}\")\n    \n    if findings['findings']:\n        evidence.append(\"\\n### Sample Code Issues\")\n        for f in findings['findings'][:2]:\n            evidence.append(f\"#### {f['pattern']} in {f['file']}\")\n            evidence.append(f\"```\\n{f['code_snippet']}\\n```\")\n    \n    return \"\\n\".join(evidence)\n\ndef main():\n    parser = argparse.ArgumentParser(description='Generate complete audit reports.')\n    parser.add_argument('--project-key', required=True, help='Project identifier')\n    parser.add_argument('--case-id', required=True, help='Case identifier')\n    parser.add_argument('--mode', choices=['A', 'B', 'C'], default='A', \n                       help='Handoff mode: A=Arch→Audit, B=Audit→Arch, C=Design Validation')\n    parser.add_argument('--output', help='Output filename (default: ARCHITECT_AUDIT"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":94,"output":4096,"cacheRead":61440,"cacheWrite":0,"totalTokens":65630,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"length","timestamp":1773103433398}}
