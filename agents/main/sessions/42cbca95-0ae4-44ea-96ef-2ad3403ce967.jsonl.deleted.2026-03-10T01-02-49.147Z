{"type":"message","id":"f3255622","parentId":"bdc0d04b","timestamp":"2026-03-10T00:11:37.522Z","message":{"role":"assistant","content":[{"type":"text","text":"Good! The plan is being generated with the new executable format. However, I notice the action instructions could be more specific. Let me improve the `_generate_action_instructions` method to create more executable instructions:"},{"type":"toolCall","id":"call_00_kzxOaQnujp2wdf7MnADubLrO","name":"edit","arguments":{"path":"/home/openclaw/.openclaw/workspace/skills/long-prompt-orchestrator/scripts/plan_generator.py","oldText":"    def _generate_action_instructions(self, task_data: Dict[str, Any], action_type: str) -> str:\n        \"\"\"Generate executable instructions based on action type.\"\"\"\n        objective = task_data.get('objective', '')\n        \n        if action_type == \"exec\":\n            # Convert objective to shell command\n            if \"list\" in objective.lower() or \"inventory\" in objective.lower():\n                return \"find /home/openclaw/.openclaw/workspace/skills -type f -name 'SKILL.md' | sort\"\n            elif \"search\" in objective.lower() or \"find\" in objective.lower():\n                return \"grep -r 'pattern' /home/openclaw/.openclaw/workspace --include='*.md' --include='*.py' | head -20\"\n            elif \"count\" in objective.lower() or \"measure\" in objective.lower():\n                return \"find /home/openclaw/.openclaw/workspace -type f -name '*.py' | wc -l\"\n            else:\n                return f\"echo 'Executing: {objective[:100]}...'\"\n        \n        elif action_type == \"python\":\n            # Generate Python script instructions\n            return f\"\"\"# Python script to: {objective[:100]}\nimport os\nimport sys\n\n# TODO: Implement based on objective\nprint(\"Task: {objective[:100]}...\")\"\"\"\n        \n        elif action_type == \"skill_invocation\":\n            skill = self._recommend_skill_or_role(task_data)\n            if skill:\n                return f\"Invoke {skill} skill with objective: {objective[:100]}...\"\n            else:\n                return f\"Invoke appropriate skill for: {objective[:100]}...\"\n        \n        elif action_type == \"file_operation\":\n            # Generate file operation instructions\n            if \"create\" in objective.lower() or \"write\" in objective.lower():\n                return f\"Create file with content based on: {objective[:100]}...\"\n            elif \"read\" in objective.lower() or \"analyze\" in objective.lower():\n                return f\"Read and analyze relevant files for: {objective[:100]}...\"\n            else:\n                return f\"Perform file operation: {objective[:100]}...\"\n        \n        return f\"Execute: {objective[:100]}...\"","newText":"    def _generate_action_instructions(self, task_data: Dict[str, Any], action_type: str) -> str:\n        \"\"\"Generate executable instructions based on action type.\"\"\"\n        objective = task_data.get('objective', '')\n        description = task_data.get('description', '')\n        outputs = task_data.get('outputs', [])\n        \n        if action_type == \"exec\":\n            # Convert objective to shell command\n            obj_lower = objective.lower()\n            if \"list\" in obj_lower or \"inventory\" in obj_lower:\n                if \"skill\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace/skills -type f -name 'SKILL.md' -exec basename {} \\\\; | sort\"\n                elif \"file\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace -type f -name '*.md' -o -name '*.py' | head -20\"\n                else:\n                    return \"ls -la /home/openclaw/.openclaw/workspace | head -20\"\n            elif \"search\" in obj_lower or \"find\" in obj_lower:\n                # Extract search terms from objective\n                import re\n                terms = re.findall(r'\\\"([^\\\"]+)\\\"|\\'([^\\']+)\\'|for\\s+([a-zA-Z0-9_]+)', objective)\n                search_terms = [term for group in terms for term in group if term]\n                if search_terms:\n                    term = search_terms[0]\n                    return f\"grep -r '{term}' /home/openclaw/.openclaw/workspace --include='*.md' --include='*.py' | head -10\"\n                else:\n                    return \"grep -r 'TODO\\|FIXME' /home/openclaw/.openclaw/workspace --include='*.py' --include='*.md' | head -10\"\n            elif \"count\" in obj_lower or \"measure\" in obj_lower:\n                if \"line\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace -type f -name '*.py' -exec wc -l {} \\\\; | tail -1\"\n                elif \"file\" in obj_lower:\n                    return \"find /home/openclaw/.openclaw/workspace -type f | wc -l\"\n                else:\n                    return \"find /home/openclaw/.openclaw/workspace -type f -name '*.py' | wc -l\"\n            elif \"check\" in obj_lower or \"verify\" in obj_lower:\n                return \"python3 -m py_compile /home/openclaw/.openclaw/workspace/skills/*/scripts/*.py 2>&1 | head -10\"\n            else:\n                # Generic command based on objective\n                return f\"# Execute: {objective[:80]}\\necho 'Starting task: {objective[:80]}...'\\ndate\"\n        \n        elif action_type == \"python\":\n            # Generate Python script instructions\n            if \"analyze\" in objective.lower() or \"process\" in objective.lower():\n                return f\"\"\"# Python script to: {objective[:80]}\nimport json\nimport os\nimport sys\n\ndef main():\n    print(\"Analyzing: {objective[:80]}...\")\n    # TODO: Implement analysis logic\n    result = {{\"status\": \"completed\", \"task\": \"{objective[:80]}\"}}\n    \n    # Save output if specified\n    outputs = {outputs}\n    if outputs:\n        with open(outputs[0], 'w') as f:\n            json.dump(result, f, indent=2)\n    \n    return result\n\nif __name__ == \"__main__\":\n    main()\"\"\"\n            else:\n                return f\"\"\"# Python script to: {objective[:80]}\nimport os\nimport sys\n\ndef main():\n    print(\"Executing: {objective[:80]}...\")\n    # TODO: Implement based on objective\n    return {{\"status\": \"completed\"}}\n\nif __name__ == \"__main__\":\n    main()\"\"\"\n        \n        elif action_type == \"skill_invocation\":\n            skill = self._recommend_skill_or_role(task_data)\n            if skill == \"tavily-web-search\":\n                # Extract search query from objective\n                import re\n                query_terms = re.findall(r'\\\"([^\\\"]+)\\\"|\\'([^\\']+)\\'|about\\s+([a-zA-Z0-9_\\s]+)', objective)\n                query = next((term for group in query_terms for term in group if term), objective[:50])\n                return f\"Invoke tavily-web-search skill with query: '{query}' --max-results 3 --output /tmp/search_results.json\"\n            elif skill == \"salesforce-architect\":\n                return f\"Invoke salesforce-architect skill with requirement: {objective[:80]}...\"\n            elif skill == \"salesforce-code-auditor\":\n                return f\"Invoke salesforce-code-auditor skill to audit: {objective[:80]}...\"\n            elif skill == \"workspace-janitor\":\n                return \"Invoke workspace-janitor skill to clean up temporary files and organize workspace\"\n            elif skill == \"long-prompt-orchestrator\":\n                return f\"Invoke long-prompt-orchestrator skill to plan: {objective[:80]}...\"\n            elif skill:\n                return f\"Invoke {skill} skill with objective: {objective[:80]}...\"\n            else:\n                return f\"# Determine appropriate skill for: {objective[:80]}\\n# Check available skills in /home/openclaw/.openclaw/workspace/skills/\"\n        \n        elif action_type == \"file_operation\":\n            # Generate file operation instructions\n            if outputs:\n                output_file = outputs[0]\n                if output_file.endswith('.md'):\n                    return f\"\"\"# Create markdown file: {output_file}\ncat > {output_file} << 'EOF'\n# {objective}\n\n{description[:200]}\n\n## Details\n- Created: $(date)\n- Task: {objective[:80]}\n- Status: In progress\n\n## Content\nTODO: Add content based on objective.\nEOF\necho \"Created {output_file}\" \"\"\"\n                elif output_file.endswith('.json'):\n                    return f\"\"\"# Create JSON file: {output_file}\ncat > {output_file} << 'EOF'\n{{\n  \"task\": \"{objective[:80]}\",\n  \"status\": \"pending\",\n  \"created_at\": \"$(date -Iseconds)\",\n  \"description\": \"{description[:100]}\"\n}}\nEOF\necho \"Created {output_file}\" \"\"\"\n                else:\n                    return f\"# Create file: {output_file}\\necho 'File: {output_file}' > {output_file}\\necho 'Content for: {objective[:80]}' >> {output_file}\"\n            else:\n                return f\"# File operation for: {objective[:80]}\\n# Determine appropriate file operation based on objective\"\n        \n        return f\"# Execute: {objective[:80]}\\n# Determine appropriate action based on task requirements\""}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":1017,"output":2156,"cacheRead":55168,"cacheWrite":0,"totalTokens":58341,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773101432986}}
