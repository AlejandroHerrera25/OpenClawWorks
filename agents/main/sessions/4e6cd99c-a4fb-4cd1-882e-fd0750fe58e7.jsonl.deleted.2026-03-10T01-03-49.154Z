{"type":"message","id":"bf04f4a4","parentId":"b60f6cc4","timestamp":"2026-03-10T00:03:59.258Z","message":{"role":"toolResult","toolCallId":"call_00_z6p9QgM7eG2frCSVXjqesGWt","toolName":"read","content":[{"type":"text","text":"\nfrom datetime import datetime\n\ndef generate_incident(model, stall_duration, recovery_level, success,\n                      runtime_type='subagent', task_type='unknown', items_count=0):\n    \"\"\"Generate stall incident telemetry.\"\"\"\n    if runtime_type == 'acp':\n        pattern_key = f\"runtime|STALL|acp_agent|no_response|acp_session_stuck\"\n    else:\n        pattern_key = f\"model|STALL|{model}|no_response|runtime_stuck\"\n    \n    return {\n        \"pattern_key\": pattern_key,\n        \"timestamp\": datetime.utcnow().isoformat(),\n        \"model\": model,\n        \"stall_duration\": stall_duration,\n        \"recovery_level\": recovery_level,\n        \"success\": success,\n        \"runtime_type\": runtime_type,\n        \"task_type\": task_type,\n        \"items_count\": items_count\n    }\n\ndef generate_deadlock_incident(cycle, recovery_strategy, success):\n    \"\"\"Generate deadlock incident telemetry.\"\"\"\n    return {\n        \"pattern_key\": \"multi_agent|DEADLOCK|dependency_cycle|agents_waiting\",\n        \"timestamp\": datetime.utcnow().isoformat(),\n        \"cycle_size\": len(cycle),\n        \"agents_involved\": cycle,\n        \"recovery_strategy\": recovery_strategy,\n        \"success\": success\n    }\n"}],"isError":false,"timestamp":1773101039255}}
