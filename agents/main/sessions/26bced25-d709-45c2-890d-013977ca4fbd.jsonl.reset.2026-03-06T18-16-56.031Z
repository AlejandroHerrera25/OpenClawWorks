{"type":"message","id":"ba39d69c","parentId":"04245676","timestamp":"2026-03-06T16:31:31.997Z","message":{"role":"toolResult","toolCallId":"call_00_bKJC9SFv0mlqc65aCaK1BRi9","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nArchive reasoning artifacts to disk (context_archive).\n\"\"\"\n\nimport os\nimport json\nimport time\nfrom typing import Dict, List, Any, Optional\nfrom dataclasses import dataclass, asdict\n\nWORKSPACE_MEMORY = os.path.expanduser(\"~/.openclaw/workspace/memory\")\nCONTEXT_ARCHIVE_DIR = os.path.join(WORKSPACE_MEMORY, \"context_archive\")\n\n@dataclass\nclass ReasoningArtifact:\n    \"\"\"Represents a single reasoning artifact to archive.\"\"\"\n    artifact_id: str\n    content: str\n    artifact_type: str  # 'reasoning_summary', 'decision', 'fact', 'task_history'\n    tags: List[str]\n    related_tasks: List[str]\n    created_at: float = None\n    \n    def __post_init__(self):\n        if self.created_at is None:\n            self.created_at = time.time()\n\nclass ContextArchiver:\n    \"\"\"\n    Manages archiving of reasoning artifacts to context_archive/run_<session_id>/.\n    \"\"\"\n    \n    def __init__(self, session_id: str, run_id: Optional[str] = None):\n        self.session_id = session_id\n        self.run_id = run_id or f\"run_{int(time.time())}\"\n        self.archive_dir = os.path.join(CONTEXT_ARCHIVE_DIR, f\"{self.run_id}\")\n        os.makedirs(self.archive_dir, exist_ok=True)\n        self.artifacts: List[ReasoningArtifact] = []\n    \n    def add_artifact(self, artifact: ReasoningArtifact):\n        self.artifacts.append(artifact)\n    \n    def add_reasoning_summary(self, summary: str, tags: List[str], related_tasks: List[str]):\n        \"\"\"Add a reasoning summary artifact.\"\"\"\n        artifact = ReasoningArtifact(\n            artifact_id=f\"reasoning_{len(self.artifacts)}\",\n            content=summary,\n            artifact_type=\"reasoning_summary\",\n            tags=tags,\n\n[150 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1772814691984}}
