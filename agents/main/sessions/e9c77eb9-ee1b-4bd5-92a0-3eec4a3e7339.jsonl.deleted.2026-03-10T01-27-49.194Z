{"type":"message","id":"e3cf1a2a","parentId":"04ae7027","timestamp":"2026-03-10T00:32:18.912Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create the cron monitoring integration:"},{"type":"toolCall","id":"call_00_v79nU6ZAlw7Gw1n9Rnwwn25I","name":"write","arguments":{"path":"~/.openclaw/workspace/integration/cron_monitoring.py","content":"#!/usr/bin/env python3\n\"\"\"\nCron Job Monitoring Integration\nMonitors cron job executions with watchdog.\n\"\"\"\n\nimport os\nimport json\nimport time\nimport sys\nimport uuid\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\n# Workspace paths\nWORKSPACE = Path.home() / '.openclaw' / 'workspace'\nWATCHDOG_DIR = WORKSPACE / '.watchdog'\nSESSION_REGISTRY = WATCHDOG_DIR / 'session_registry.json'\nMONITORING_LOG = WATCHDOG_DIR / 'monitoring.log'\nCRON_JOBS_FILE = WATCHDOG_DIR / 'cron_jobs.json'\n\nclass CronMonitor:\n    \"\"\"Cron job monitoring integration.\"\"\"\n    \n    def __init__(self):\n        self.cron_jobs = {}\n        \n    def log_monitoring(self, message, level=\"INFO\"):\n        \"\"\"Log monitoring activity.\"\"\"\n        timestamp = datetime.utcnow().isoformat()\n        log_entry = f\"[{timestamp}] [CRON] [{level}] {message}\\n\"\n        \n        # Write to monitoring log\n        try:\n            with open(MONITORING_LOG, 'a') as f:\n                f.write(log_entry)\n        except Exception as e:\n            print(f\"Failed to write to monitoring log: {e}\")\n        \n        # Also print to console\n        print(log_entry.strip())\n    \n    def load_cron_jobs(self):\n        \"\"\"Load cron jobs from file.\"\"\"\n        if CRON_JOBS_FILE.exists():\n            try:\n                with open(CRON_JOBS_FILE, 'r') as f:\n                    self.cron_jobs = json.load(f)\n                return True\n            except Exception as e:\n                self.log_monitoring(f\"Error loading cron jobs: {e}\", level=\"ERROR\")\n                self.cron_jobs = {}\n        return False\n    \n    def save_cron_jobs(self):\n        \"\"\"Save cron jobs to file.\"\"\"\n        try:\n            with open(CRON_JOBS_FILE, 'w') as f:\n                json.dump(self.cron_jobs, f, indent=2)\n            return True\n        except Exception as e:\n            self.log_monitoring(f\"Error saving cron jobs: {e}\", level=\"ERROR\")\n            return False\n    \n    def register_cron_job(self, job_name, schedule, command, description=None, expected_runtime_minutes=2):\n        \"\"\"Register a cron job for monitoring.\"\"\"\n        self.load_cron_jobs()\n        \n        job_id = f\"cron_{uuid.uuid4().hex[:8]}\"\n        current_time = datetime.utcnow().isoformat()\n        \n        cron_job = {\n            \"job_id\": job_id,\n            \"job_name\": job_name,\n            \"schedule\": schedule,\n            \"command\": command,\n            \"description\": description or job_name,\n            \"expected_runtime_minutes\": expected_runtime_minutes,\n            \"registered_at\": current_time,\n            \"enabled\": True,\n            \"execution_history\": [],\n            \"metrics\": {\n                \"total_executions\": 0,\n                \"successful_executions\": 0,\n                \"failed_executions\": 0,\n                \"average_runtime_seconds\": 0,\n                \"last_execution_time\": None\n            }\n        }\n        \n        self.cron_jobs[job_id] = cron_job\n        \n        if self.save_cron_jobs():\n            self.log_monitoring(f\"Registered cron job: {job_name} ({schedule})\")\n            \n            # Also register as a session for real-time monitoring\n            self._register_cron_execution_session(job_id, \"scheduled\", \"Registered for monitoring\")\n            return job_id\n        else:\n            return None\n    \n    def _register_cron_execution_session(self, job_id, status, description):\n        \"\"\"Register cron execution as a session for monitoring.\"\"\"\n        if job_id not in self.cron_jobs:\n            return False\n        \n        cron_job = self.cron_jobs[job_id]\n        session_id = f\"cron_exec_{job_id}_{uuid.uuid4().hex[:4]}\"\n        current_time = datetime.utcnow().isoformat()\n        \n        # Create session entry\n        session_entry = {\n            \"session_id\": session_id,\n            \"source\": \"cron_integration\",\n            \"registered_at\": current_time,\n            \"last_activity\": current_time,\n            \"state\": \"active\",\n            \"task_description\": f\"Cron job: {cron_job['job_name']} - {description}\",\n            \"expected_runtime_minutes\": cron_job[\"expected_runtime_minutes\"],\n            \"cron_job_id\": job_id,\n            \"cron_job_name\": cron_job[\"job_name\"],\n            \"status\": status,\n            \"stall_count\": 0,\n            \"recovery_attempts\": 0,\n            \"metrics\": {\n                \"total_uptime\": 0,\n                \"stall_detections\": 0,\n                \"recovery_attempts\": 0,\n                \"last_activity\": current_time\n            },\n            \"session_data_summary\": {\n                \"agent_type\": \"cron_job\",\n                \"task_type\": \"scheduled\",\n                \"integration_level\": \"monitored\"\n            }\n        }\n        \n        # Load existing registry\n        registry = {}\n        if SESSION_REGISTRY.exists():\n            try:\n                with open(SESSION_REGISTRY, 'r') as f:\n                    registry = json.load(f)\n            except Exception as e:\n                self.log_monitoring(f\"Error loading registry: {e}\", level=\"ERROR\")\n        \n        # Add session\n        registry[session_id] = session_entry\n        \n        # Save registry\n        try:\n            with open(SESSION_REGISTRY, 'w') as f:\n                json.dump(registry, f, indent=2)\n        except Exception as e:\n            self.log_monitoring(f\"Error saving registry: {e}\", level=\"ERROR\")\n            return False\n        \n        return session_id\n    \n    def start_cron_execution(self, job_id):\n        \"\"\"Record the start of a cron job execution.\"\"\"\n        if job_id not in self.cron_jobs:\n            self.log_monitoring(f\"Cron job {job_id} not found\", level=\"WARNING\")\n            return None\n        \n        current_time = datetime.utcnow().isoformat()\n        \n        # Update cron job metrics\n        self.cron_jobs[job_id][\"last_started\"] = current_time\n        self.cron_jobs[job_id][\"current_execution\"] = {\n            \"started_at\": current_time,\n            \"status\": \"running\",\n            \"session_id\": None\n        }\n        \n        # Register execution session\n        session_id = self._register_cron_execution_session(job_id, \"running\", \"Execution started\")\n        if session_id:\n            self.cron_jobs[job_id][\"current_execution\"][\"session_id\"] = session_id\n        \n        self.save_cron_jobs()\n        self.log_monitoring(f\"Started cron job execution: {self.cron_jobs[job_id]['job_name']}\")\n        return session_id\n    \n    def complete_cron_execution(self, job_id, success=True, output=None, error=None, runtime_seconds=None):\n        \"\"\"Record the completion of a cron job execution.\"\"\"\n        if job_id not in self.cron_jobs:\n            self.log_monitoring(f\"Cron job {job_id} not found\", level=\"WARNING\")\n            return False\n        \n        current_time = datetime.utcnow().isoformat()\n        cron_job = self.cron_jobs[job_id]\n        \n        # Calculate runtime if not provided\n        if runtime_seconds is None and \"current_execution\" in cron_job:\n            started_at = cron_job[\"current_execution\"].get(\"started_at\")\n            if started_at:\n                try:\n                    start_time = datetime.fromisoformat(started_at)\n                    end_time = datetime.fromisoformat(current_time)\n                    runtime_seconds = (end_time - start_time).total_seconds()\n                except Exception as e:\n                    self.log_monitoring(f\"Error calculating runtime: {e}\", level=\"ERROR\")\n                    runtime_seconds = 0\n        \n        # Create execution record\n        execution_record = {\n            \"execution_id\": f\"exec_{uuid.uuid4().hex[:8]}\",\n            \"started_at\": cron_job.get(\"current_execution\", {}).get(\"started_at\", current_time),\n            \"completed_at\": current_time,\n            \"success\": success,\n            \"runtime_seconds\": runtime_seconds or 0,\n            \"output\": output[:1000] if output else None,  # Truncate long output\n            \"error\": error[:1000] if error else None      # Truncate long errors\n        }\n        \n        # Add to execution history\n        if \"execution_history\" not in cron_job:\n            cron_job[\"execution_history\"] = []\n        cron_job[\"execution_history\"].append(execution_record)\n        \n        # Keep only last 50 executions\n        if len(cron_job[\"execution_history\"]) > 50:\n            cron_job[\"execution_history\"] = cron_job[\"execution_history\"][-50:]\n        \n        # Update metrics\n        cron_job[\"metrics\"][\"total_executions\"] = cron_job[\"metrics\"].get(\"total_executions\", 0) + 1\n        if success:\n            cron_job[\"metrics\"][\"successful_executions\"] = cron_job[\"metrics\"].get(\"successful_executions\", 0) + 1\n        else:\n            cron_job[\"metrics\"][\"failed_executions\"] = cron_job[\"metrics\"].get(\"failed_executions\", 0) + 1\n        \n        # Update average runtime\n        total_runtime = cron_job[\"metrics\"].get(\"average_runtime_seconds\", 0) * (cron_job[\"metrics\"][\"total_executions\"] - 1)\n        total_runtime += runtime_seconds or 0\n        cron_job[\"metrics\"][\"average_runtime_seconds\"] = total_runtime / cron_job[\"metrics\"][\"total_executions\"]\n        \n        cron_job[\"metrics\"][\"last_execution_time\"] = current_time\n        \n        # Clear current execution\n        if \"current_execution\" in cron_job:\n            # Update session if it exists\n            session_id = cron_job[\"current_execution\"].get(\"session_id\")\n            if session_id:\n                self._complete_cron_session(session_id, \"success\" if success else \"failure\", execution_record)\n            del cron_job[\"current_execruction\"]\n        \n        self.save_cron_jobs()\n        \n        status = \"success\" if success else \"failure\"\n        self.log_monitoring(f\"Completed cron job execution: {cron_job['job_name']} - {status} ({runtime_seconds or 0:.1f}s)\")\n        return True\n    \n    def _complete_cron_session(self, session_id, outcome, execution_record):\n        \"\"\"Complete a cron execution session.\"\"\"\n        if not SESSION_REGISTRY.exists():\n            return False\n        \n        try:\n            with open(SESSION_REGISTRY, 'r') as f:\n                registry = json.load(f)\n        except Exception as e:\n            self.log_monitoring(f\"Error loading registry: {e}\", level=\"ERROR\")\n            return False\n        \n        if session_id in registry:\n            registry[session_id][\"state\"] = \"completed\"\n            registry[session_id][\"completed_at\"] = datetime.utcnow().isoformat()\n            registry[session_id][\"outcome\"] = outcome\n            registry[session_id][\"execution_record\"] = execution_record\n            \n            # Calculate runtime\n            start_time = datetime.fromisoformat(registry[session_id][\"registered_at\"])\n            end_time = datetime.utcnow()\n            runtime_seconds = (end_time - start_time).total_seconds()\n            registry[session_id][\"metrics\"][\"total_uptime\"] = runtime_seconds\n            \n            # Save registry\n            try:\n                with open(SESSION_REGISTRY, 'w') as f:\n                    json.dump(registry, f, indent=2)\n            except Exception as e:\n                self.log_monitoring(f\"Error saving registry: {e}\", level=\"ERROR\")\n                return False\n            \n            return True\n        \n        return False\n    \n    def check_cron_stalls(self, timeout_minutes=10):\n        \"\"\"Check for stalled cron job executions.\"\"\"\n        self.load_cron_jobs()\n        \n        stalled_jobs = []\n        current_time = datetime.utcnow()\n        \n        for job_id, cron_job in self.cron_jobs.items():\n            if not cron_job.get(\"enabled\", True):\n                continue\n            \n            current_execution = cron_job.get(\"current_execution\")\n            if current_execution and current_execution.get(\"status\") == \"running\":\n                started_at = current_execution.get(\"started_at\")\n                if started_at:\n                    try:\n                        start_time = datetime.fromisoformat(started_at)\n                        runtime_seconds = (current_time - start_time).total_seconds()\n                        \n                        expected_runtime = cron_job.get(\"expected_runtime_minutes\", 2) * 60\n                        if runtime_seconds > (expected_runtime * 2):  # 2x expected runtime\n                            stalled_jobs.append({\n                                \"job_id\": job_id,\n                                \"job_name\": cron_job[\"job_name\"],\n                                \"runtime_seconds\": runtime_seconds,\n                                \"expected_runtime_seconds\": expected_runtime,\n                                \"session_id\": current_execution.get(\"session_id\")\n                            })\n                    except Exception as e:\n                        self.log_monitoring(f\"Error checking stall for {job_id}: {e}\", level=\"ERROR\")\n        \n        # Handle stalled jobs\n        for stalled_job in stalled_jobs:\n            self.log_monitoring(f\"Detected stalled cron job: {stalled_job['job_name']} - running for {stalled_job['runtime_seconds']:.0f}s (expected {stalled_job['expected_runtime_seconds']:.0f}s)\", level=\"WARNING\")\n            \n            # Mark as failed\n            self.complete_cron_execution(\n                stalled_job[\"job_id\"],\n                success=False,\n                error=f\"Stalled: running for {stalled_job['runtime_seconds']:.0f}s (expected {stalled_job['expected_runtime_seconds']:.0f}s)\",\n                runtime_seconds=stalled_job[\"runtime_seconds\"]\n            )\n        \n        return stalled_jobs\n    \n    def get_cron_status(self):\n        \"\"\"Get status of all cron jobs.\"\"\"\n        self.load_cron_jobs()\n        \n        status = {\n            \"total_jobs\": len(self.cron_jobs),\n            \"enabled_jobs\": sum(1 for job in self.cron_jobs.values() if job.get(\"enabled\", True)),\n            \"currently_running\": 0,\n            \"recent_executions\": 0,\n            \"success_rate\": 0\n        }\n        \n        total_executions = 0\n        successful_executions = 0\n        \n        for cron_job in self.cron_jobs.values():\n            if cron_job.get(\"current_execution\", {}).get(\"status\") == \"running\":\n                status[\"currently_running\"] += 1\n            \n            metrics = cron_job.get(\"metrics\", {})\n            total_executions += metrics.get(\"total_executions\", 0)\n            successful_executions += metrics.get(\"successful_executions\", 0)\n            \n            # Count recent executions (last 24 hours)\n            if \"execution_history\" in cron_job:\n                for execution in cron_job[\"execution_history\"][-10:]:  # Check last 10\n                    if \"completed_at\" in execution:\n                        try:\n                            completed_at = datetime.fromisoformat(execution[\"completed_at\"])\n                            hours_ago = (datetime.utcnow() - completed_at).total_seconds() / 3600\n                            if hours_ago < 24:\n                                status[\"recent_executions\"] += 1\n                        except Exception:\n                            pass\n        \n        if total_executions > 0:\n            status[\"success_rate\"] = (successful_executions / total_executions) * 100\n        \n        return status\n\n# Global instance for easy import\ncron_monitor = CronMonitor()\n\nif __name__ == \"__main__\":\n    # Test the cron monitoring integration\n    monitor = CronMonitor()\n    \n    # Test 1: Register a cron job\n    print(\"Test 1: Registering cron job...\")\n    job_id = monitor.register_cron_job(\n        job_name=\"Test Cron Job\",\n        schedule=\"*/5 * * * *\",\n        command=\"echo 'Hello from cron'\",\n        description=\"Test cron job for monitoring\",\n        expected_runtime_minutes=1\n    )\n    \n    if job_id:\n        print(f\"✓ Cron job registered with ID: {job_id}\")\n    else:\n        print(\"✗ Failed to register cron job\")\n    \n    # Test 2: Start cron execution\n    print(\"\\nTest 2: Starting cron execution...\")\n    session_id = monitor.start_cron_execution(job_id)\n    if session_id:\n        print(f\"✓ Cron execution started with session: {session_id}\")\n    else:\n        print(\"✗ Failed to start cron execution\")\n    \n    # Test 3: Complete cron execution\n    print(\"\\nTest 3: Completing cron execution...\")\n    if monitor.complete_cron_execution(\n        job_id,\n        success=True,\n        output=\"Hello from cron\\nExecution completed successfully\",\n        runtime_seconds=2.5\n    ):\n        print(\"✓ Cron execution completed\")\n    else:\n        print(\"✗ Failed to complete cron execution\")\n    \n    # Test 4: Get cron status\n    print(\"\\nTest 4: Getting cron status...\")\n    status = monitor.get_cron_status()\n    print(f\"✓ Cron status: {status}\")"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":43,"output":3885,"cacheRead":26944,"cacheWrite":0,"totalTokens":30872,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773102618800}}
