n        name: \"Workspace Scan Test\"\n        description: \"Scan workspace and generate inventory\"\n        execution: \"python3 scripts/scan_workspace.py --dry-run\"\n        expected_output: \"Inventory file created with file count\"\n        validation: \"workspace_inventory.json created\"\n        status: PASSED\n        evidence: \"676 files scanned, 27.0 MB, inventory created\"\n\n  error-learning-loop:\n    classification: FUNCTIONAL\n    last_tested: 2026-03-09\n    test_cases:\n      - id: ELL-001\n        name: \"Incident Emission Test\"\n        description: \"Emit test incident to learning loop\"\n        execution: \"python3 scripts/emit_incident.py test|TEST|audit|test_incident S3 audit-skill 'Test incident' 'Testing'\"\n        expected_output: \"Incident logged successfully\"\n        validation: \"Success message\"\n        status: PASSED\n        evidence: \"Incident logged: test|TEST|audit|test_incident\"\n\n  vector-memory:\n    classification: FUNCTIONAL\n    last_tested: 2026-03-09\n    test_cases:\n      - id: VM-001\n        name: \"Memory Curation Test\"\n        description: \"Execute memory curation wrapper\"\n        execution: \"python3 scripts/memory_curation_wrapper.py --dry-run\"\n        expected_output: \"Backup created, curation process executed\"\n        validation: \"Backup file created\"\n        status: PASSED\n        evidence: \"MEMORY_2026-03-09_181922.md.bak created\"\n\n  tavily-web-search:\n    classification: FUNCTIONAL\n    last_tested: 2026-03-09\n    test_cases:\n      - id: TWS-001\n        name: \"Integration Test\"\n        description: \"Test ecosystem integrations\"\n        execution: \"python3 scripts/tavily_integrations.py --test\"\n        expected_output: \"Watchdog registration, incident emission, janitor cleanup verified\"\n        validation: \"Success messages for all integrations\"\n        status: PASSED\n        evidence: \"Watchdog registration SUCCESS, incident emission SUCCESS, janitor setup SUCCESS\"\n\n  OC-Intent-Governor:\n    classification: FUNCTIONAL\n    last_tested: 2026-03-09\n    test_cases:\n      - id: OIG-001\n        name: \"Intent Parsing Test\"\n        description: \"Parse test instructions\"\n        execution: \"python3 scripts/oc_intent_governor.py --instruction 'test audit' --test\"\n        expected_output: \"Intent analysis with entities and constraints\"\n        validation: \"Output shows parsed components\"\n        status: PASSED\n        evidence: \"Entities extracted, risks detected\"\n\n  OC-Respawner:\n    classification: PARTIAL\n    last_tested: 2026-03-09\n    test_cases:\n      - id: OCR-001\n        name: \"Script Existence Test\"\n        description: \"Verify scripts exist and can be invoked\"\n        execution: \"python3 scripts/validate_environment.py --test\"\n        expected_output: \"Script executes or shows usage\"\n        validation: \"Exit code 0 or usage displayed\"\n        status: PARTIAL\n        evidence: \"No output, script exists but test parameter not recognized\"\n\n  OC-System-Evolver:\n    classification: PARTIAL\n    last_tested: 2026-03-09\n    test_cases:\n      - id: OSE-001\n        name: \"Improvement Engine Test\"\n        description: \"Execute improvement engine\"\n        execution: \"python3 scripts/improvement_engine.py --test\"\n        expected_output: \"Improvement proposals or usage info\"\n        validation: \"Output generated\"\n        status: PARTIAL\n        evidence: \"Script exists but test parameter not recognized\"\n\n# Classification Rules\nclassification_rules:\n  FUNCTIONAL:\n    - All critical test cases PASSED\n    - Real operational evidence exists\n    - Integration paths verified\n    - Production-usable outputs\n    \n  PARTIAL:\n    - Some test cases PASSED\n    - Some functionality exists but incomplete\n    - Missing critical operational evidence\n    - Not production-ready\n    \n  SIMULATED:\n    - Outputs are descriptive only\n    - No real execution path\n    - Fake IDs or placeholder artifacts\n    - Integration exists only in documentation\n    \n  BROKEN:\n    - Invocation fails\n    - Critical dependencies missing\n    - Expected outputs not produced\n    - Error handling absent\n    \n  NOT_YET_VERIFIED:\n    - No operational tests performed\n    - Insufficient evidence for classification"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":72,"output":2255,"cacheRead":98176,"cacheWrite":0,"totalTokens":100503,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773100534077}}
