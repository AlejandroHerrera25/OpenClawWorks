{"type":"message","id":"c6cc3410","parentId":"9baa29ee","timestamp":"2026-03-06T15:43:29.167Z","message":{"role":"toolResult","toolCallId":"call_00_sOStLK6zPN6lmJI34NkERsOv","toolName":"read","content":[{"type":"text","text":"\nimport time\nfrom datetime import datetime\n\nSTALL_TIMEOUT = 120\nMONITOR_INTERVAL = 30\nACP_STALL_TIMEOUT = 180  # Longer timeout for ACP sessions\n\nclass Session:\n    def __init__(self, session_id, run_id=None, task_description=\"\", expected_runtime=0,\n                 model=\"unknown\", runtime_type=\"subagent\"):\n        self.session_id = session_id\n        self.run_id = run_id\n        self.task_description = task_description\n        self.expected_runtime = expected_runtime\n        self.model = model\n        self.runtime_type = runtime_type\n        self.last_activity = datetime.utcnow()\n        self.start_time = datetime.utcnow()\n        self.state = \"running\"\n        self.items_count = 0\n\ndef detect_stall(session):\n    inactivity = (datetime.utcnow() - session.last_activity).total_seconds()\n    timeout = ACP_STALL_TIMEOUT if session.runtime_type == 'acp' else STALL_TIMEOUT\n    if session.state == \"running\" and inactivity > timeout:\n        return True\n    return False\n\ndef monitor(session):\n    while True:\n        if detect_stall(session):\n            return \"stall_detected\"\n        time.sleep(MONITOR_INTERVAL)\n"}],"isError":false,"timestamp":1772811809163}}
