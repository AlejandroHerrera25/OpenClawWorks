{"type":"message","id":"ebc425d8","parentId":"ad1f4f73","timestamp":"2026-03-10T00:45:52.273Z","message":{"role":"assistant","content":[{"type":"text","text":"The file got cut off again. Let me create a minimal working version:"},{"type":"toolCall","id":"call_00_hF8PJuGqEvdUL9nmhRVT4Ypd","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/salesforce-code-auditor/scripts/report_generator.py","content":"#!/usr/bin/env python3\n\"\"\"\nComplete Audit Report Generator - Minimal working version.\n\"\"\"\n\nimport argparse\nimport os\nfrom datetime import datetime\nfrom pathlib import Path\nfrom utils_fs import read_file, write_file, read_json\n\nWORKSPACE_ROOT = Path(os.getenv('WORKSPACE', '/home/openclaw/.openclaw/workspace'))\n\ndef generate_report(project_key, case_id, mode='A'):\n    \"\"\"Generate complete audit report.\"\"\"\n    case_root = WORKSPACE_ROOT / 'projects' / project_key / 'code_audit' / case_id\n    \n    # Load data\n    try:\n        manifest = read_json(case_root / 'MANIFEST.json')\n        findings = read_json(case_root / 'FINDINGS_DETAILED.json')\n        risk = read_json(case_root / 'RISK_ASSESSMENT.json')\n    except Exception as e:\n        return f\"Error loading data: {e}\"\n    \n    # Generate report based on mode\n    if mode == 'A':\n        return _generate_mode_a(project_key, case_id, manifest, findings, risk)\n    elif mode == 'B':\n        return _generate_mode_b(project_key, case_id, manifest, findings, risk)\n    elif mode == 'C':\n        return _generate_mode_c(project_key, case_id, manifest, findings, risk)\n    else:\n        return _generate_generic(project_key, case_id, manifest, findings, risk)\n\ndef _generate_mode_a(project_key, case_id, manifest, findings, risk):\n    \"\"\"Mode A: Architecture → Code Audit.\"\"\"\n    overall = risk['risk_assessment']['overall_risk']\n    blockers = risk['risk_assessment']['blocking_conditions']\n    \n    report = f\"\"\"## Code Audit Report - Mode A\n\n**Project**: {project_key}\n**Audit Case ID**: {case_id}\n**Mode**: Architecture → Code Audit\n**Report Date**: {datetime.utcnow().isoformat()}Z\n\n### Executive Summary\n- **Code Health**: {_get_health(findings)}\n- **Overall Risk**: {overall['level']} ({overall['score']}/100)\n- **Total Findings**: {findings['metadata']['total_findings']}\n- **Critical Findings**: {findings['metadata']['severity_counts']['CRITICAL']}\n- **High Findings**: {findings['metadata']['severity_counts']['HIGH']}\n- **Architectural Implications**: {_get_implications(blockers)}\n\n### Technical Assessment\n{_get_tech_assessment(findings)}\n\n### Risk Assessment\n{_get_risk_summary(risk)}\n\n### Recommendations\n{_get_recommendations(findings)}\n\n### Evidence\n{_get_evidence(findings)}\n\"\"\"\n    return report\n\ndef _generate_mode_b(project_key, case_id, manifest, findings, risk):\n    \"\"\"Mode B: Code Audit → Architecture.\"\"\"\n    overall = risk['risk_assessment']['overall_risk']\n    \n    report = f\"\"\"## Code Audit Report - Mode B\n\n**Project**: {project_key}\n**Audit Case ID**: {case_id}\n**Mode**: Code Audit → Architecture\n**Report Date**: {datetime.utcnow().isoformat()}Z\n\n### Critical Findings Summary\n{_get_critical_summary(findings)}\n\n### Architectural Impact\n{_get_arch_impact(findings)}\n\n### Remediation Options\n{_get_remediation(findings)}\n\n### Risk Analysis\n{_get_risk_analysis(risk)}\n\n### Recommendations\n{_get_evidence_recommendations(findings)}\n\n### Evidence\n{_get_detailed_evidence(findings)}\n\"\"\"\n    return report\n\ndef _generate_mode_c(project_key, case_id, manifest, findings, risk):\n    \"\"\"Mode C: Design Validation.\"\"\"\n    blockers = risk['risk_assessment']['blocking_conditions']\n    \n    report = f\"\"\"## Code Audit Report - Mode C\n\n**Project**: {project_key}\n**Audit Case ID**: {case_id}\n**Mode**: Design Validation\n**Report Date**: {datetime.utcnow().isoformat()}Z\n\n### Design Feasibility\n{_get_feasibility(blockers)}\n\n### Gap Analysis\n{_get_gap_analysis(findings)}\n\n### Implementation Complexity\n{_get_complexity(findings)}\n\n### Recommendations\n{_get_design_recommendations(findings)}\n\n### Evidence\n{_get_design_evidence(findings)}\n\"\"\"\n    return report\n\ndef _generate_generic(project_key, case_id, manifest, findings, risk):\n    \"\"\"Generic audit report.\"\"\"\n    overall = risk['risk_assessment']['overall_risk']\n    \n    report = f\"\"\"# Complete Audit Report\n\n**Project**: {project_key}\n**Audit Case ID**: {case_id}\n**Report Date**: {datetime.utcnow().isoformat()}Z\n\n## Executive Summary\n{_get_exec_summary(findings, risk)}\n\n## Findings by Severity\n{_get_findings_by_severity(findings)}\n\n## Risk Assessment\n{_get_risk_summary(risk)}\n\n## Recommendations\n{_get_all_recommendations(findings)}\n\n## Evidence\n{_get_complete_evidence(findings)}\n\"\"\"\n    return report\n\n# Helper functions\ndef _get_health(findings):\n    total = findings['metadata']['total_findings']\n    critical = findings['metadata']['severity_counts']['CRITICAL']\n    if critical > 0:\n        return \"POOR - Critical issues need immediate attention\"\n    elif total > 10:\n        return \"FAIR - Multiple issues to address\"\n    elif total > 5:\n        return \"GOOD - Some improvements needed\"\n    else:\n        return \"EXCELLENT - Minimal issues\"\n\ndef _get_implications(blockers):\n    critical = len(blockers['critical_blockers'])\n    if critical > 0:\n        return f\"{critical} critical findings block architectural decisions\"\n    return \"No critical blockers found\"\n\ndef _get_tech_assessment(findings):\n    patterns = len(set(f['pattern'] for f in findings['findings']))\n    return f\"\"\"- **Findings**: {findings['metadata']['total_findings']} total\n- **Patterns**: {patterns} distinct issue patterns\n- **Critical**: {findings['metadata']['severity_counts']['CRITICAL']}\n- **High**: {findings['metadata']['severity_counts']['HIGH']}\"\"\"\n\ndef _get_risk_summary(risk):\n    overall = risk['risk_assessment']['overall_risk']\n    blockers = risk['risk_assessment']['blocking_conditions']\n    \n    summary = [f\"- **Overall Risk**: {overall['level']} ({overall['score']}/100)\"]\n    \n    for cat, stats in overall['by_category'].items():\n        summary.append(f\"- **{cat}**: {stats['average_score']:.1f}/100 ({stats['finding_count']} findings)\")\n    \n    if blockers['critical_blockers']:\n        summary.append(f\"- **Critical Blockers**: {len(blockers['critical_blockers'])}\")\n    \n    return \"\\n\".join(summary)\n\ndef _get_recommendations(findings):\n    recs = []\n    priority = 1\n    \n    for f in findings['findings']:\n        if f['severity'] == 'CRITICAL':\n            recs.append(f\"{priority}. **{f['pattern']}** in `{f['file']}`: {f['recommendation']}\")\n            priority += 1\n    \n    for f in findings['findings']:\n        if f['severity'] == 'HIGH':\n            recs.append(f\"{priority}. **{f['pattern']}** in `{f['file']}`: {f['recommendation']}\")\n            priority += 1\n    \n    if not recs:\n        recs.append(\"1. No critical/high findings - proceed with architecture\")\n    \n    return \"\\n\".join(recs)\n\ndef _get_evidence(findings):\n    evidence = []\n    critical = [f for f in findings['findings'] if f['severity'] in ['CRITICAL', 'HIGH']]\n    \n    if critical:\n        evidence.append(\"#### Code Snippets:\")\n        for f in critical[:3]:\n            evidence.append(f\"- `{f['file']}:{f['line']}` - {f['pattern']}\")\n            evidence.append(f\"  ```\\n  {f['code_snippet'][:100]}...\\n  ```\")\n    \n    return \"\\n\".join(evidence)\n\ndef _get_critical_summary(findings):\n    critical = [f for f in findings['findings'] if f['severity'] == 'CRITICAL']\n    high = [f for f in findings['findings'] if f['severity'] == 'HIGH']\n    \n    summary = [f\"- **Critical Findings**: {len(critical)}\"]\n    summary.append(f\"- **High Findings**: {len(high)}\")\n    \n    if critical:\n        summary.append