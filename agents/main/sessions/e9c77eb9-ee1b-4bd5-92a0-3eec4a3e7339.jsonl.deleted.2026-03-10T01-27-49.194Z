{"type":"message","id":"8a9f01d7","parentId":"ad8001bc","timestamp":"2026-03-10T00:37:21.324Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create a simple wrapper script to test the integration:"},{"type":"toolCall","id":"call_00_rtcakhpakQnOclc97sXPRoqs","name":"write","arguments":{"path":"~/.openclaw/workspace/integration/test_integration.py","content":"#!/usr/bin/env python3\n\"\"\"\nTest script for monitoring integration.\n\"\"\"\n\nimport sys\nimport time\nfrom pathlib import Path\n\n# Add integration directory to path\nsys.path.insert(0, str(Path(__file__).parent))\n\nfrom main_agent_monitoring import main_monitor\nfrom subagent_monitoring import subagent_monitor\nfrom cron_monitoring import cron_monitor\nfrom alerts.real_time_alerts import alerts_system\n\ndef test_main_agent_integration():\n    \"\"\"Test main agent monitoring integration.\"\"\"\n    print(\"=\" * 60)\n    print(\"Testing Main Agent Monitoring Integration\")\n    print(\"=\" * 60)\n    \n    # Register main agent session\n    print(\"\\n1. Registering main agent session...\")\n    if main_monitor.register_main_agent_session(\n        task_description=\"Test monitoring integration workflow\",\n        expected_runtime_minutes=15\n    ):\n        print(\"✓ Main agent session registered\")\n    else:\n        print(\"✗ Failed to register main agent session\")\n        return False\n    \n    # Update activity\n    print(\"\\n2. Updating activity...\")\n    if main_monitor.update_activity(\"Starting integration tests\"):\n        print(\"✓ Activity updated\")\n    else:\n        print(\"✗ Failed to update activity\")\n    \n    # Register sub-agent spawn\n    print(\"\\n3. Registering sub-agent spawn...\")\n    subagent_id = \"test_subagent_integration\"\n    if main_monitor.register_subagent_spawn(\n        subagent_id=subagent_id,\n        task_description=\"Test sub-agent monitoring\",\n        expected_runtime_minutes=5\n    ):\n        print(\"✓ Sub-agent spawn registered\")\n    else:\n        print(\"✗ Failed to register sub-agent spawn\")\n    \n    # Complete session\n    print(\"\\n4. Completing main agent session...\")\n    if main_monitor.complete_session(\n        outcome=\"success\",\n        completion_notes=\"Integration test completed successfully\"\n    ):\n        print(\"✓ Main agent session completed\")\n    else:\n        print(\"✗ Failed to complete main agent session\")\n    \n    return True\n\ndef test_subagent_integration():\n    \"\"\"Test sub-agent monitoring integration.\"\"\"\n    print(\"\\n\" + \"=\" * 60)\n    print(\"Testing Sub-agent Monitoring Integration\")\n    print(\"=\" * 60)\n    \n    # Create sub-agent monitor\n    monitor = subagent_monitor\n    monitor.subagent_id = \"integration_test_subagent\"\n    monitor.parent_session_id = \"main_test_session\"\n    \n    # Register sub-agent session\n    print(\"\\n1. Registering sub-agent session...\")\n    if monitor.register_subagent_session(\n        task_description=\"Test sub-agent monitoring integration\",\n        expected_runtime_minutes=3,\n        parent_session_id=\"main_test_session\"\n    ):\n        print(\"✓ Sub-agent session registered\")\n    else:\n        print(\"✗ Failed to register sub-agent session\")\n        return False\n    \n    # Update activity with progress\n    print(\"\\n2. Updating activity with progress...\")\n    for progress in [25, 50, 75]:\n        if monitor.update_activity(\n            activity_description=f\"Processing data - {progress}% complete\",\n            progress_percentage=progress\n        ):\n            print(f\"✓ Progress updated to {progress}%\")\n        time.sleep(0.5)\n    \n    # Complete session with handoff report\n    print(\"\\n3. Completing sub-agent session...\")\n    handoff_report = {\n        \"outcome\": \"success\",\n        \"files_created\": [\"integration_test_results.json\"],\n        \"incidents\": [],\n        \"next_actions\": [\"Verify integration\", \"Update documentation\"]\n    }\n    if monitor.complete_session(\n        outcome=\"success\",\n        completion_notes=\"Sub-agent integration test completed\",\n        handoff_report=handoff_report\n    ):\n        print(\"✓ Sub-agent session completed with handoff report\")\n    else:\n        print(\"✗ Failed to complete sub-agent session\")\n    \n    return True\n\ndef test_cron_integration():\n    \"\"\"Test cron monitoring integration.\"\"\"\n    print(\"\\n\" + \"=\" * 60)\n    print(\"Testing Cron Monitoring Integration\")\n    print(\"=\" * 60)\n    \n    # Register cron job\n    print(\"\\n1. Registering cron job...\")\n    job_id = cron_monitor.register_cron_job(\n        job_name=\"Integration Test Cron Job\",\n        schedule=\"*/15 * * * *\",\n        command=\"python -c \\\"print('Cron test')\\\"\",\n        description=\"Test cron job for monitoring integration\",\n        expected_runtime_minutes=1\n    )\n    \n    if job_id:\n        print(f\"✓ Cron job registered with ID: {job_id}\")\n    else:\n        print(\"✗ Failed to register cron job\")\n        return False\n    \n    # Start cron execution\n    print(\"\\n2. Starting cron execution...\")\n    session_id = cron_monitor.start_cron_execution(job_id)\n    if session_id:\n        print(f\"✓ Cron execution started with session: {session_id}\")\n    else:\n        print(\"✗ Failed to start cron execution\")\n    \n    # Complete cron execution\n    print(\"\\n3. Completing cron execution...\")\n    if cron_monitor.complete_cron_execution(\n        job_id,\n        success=True,\n        output=\"Cron test\\nExecution successful\",\n        runtime_seconds=1.2\n    ):\n        print(\"✓ Cron execution completed\")\n    else:\n        print(\"✗ Failed to complete cron execution\")\n    \n    # Get cron status\n    print(\"\\n4. Getting cron status...\")\n    status = cron_monitor.get_cron_status()\n    print(f\"✓ Cron status: {status}\")\n    \n    return True\n\ndef test_alerts_integration():\n    \"\"\"Test alerts integration.\"\"\"\n    print(\"\\n\" + \"=\" * 60)\n    print(\"Testing Alerts Integration\")\n    print(\"=\" * 60)\n    \n    # Run alert cycle\n    print(\"\\n1. Running alert cycle...\")\n    triggered_alerts = alerts_system.run_alert_cycle()\n    print(f\"✓ Alert cycle complete: {len(triggered_alerts)} alerts triggered\")\n    \n    # Get recent alerts\n    print(\"\\n2. Getting recent alerts...\")\n    recent_alerts = alerts_system.get_recent_alerts(hours=1)\n    print(f\"✓ Found {len(recent_alerts)} recent alerts\")\n    \n    # Display alerts\n    if recent_alerts:\n        print(\"\\nRecent Alerts:\")\n        for alert in recent_alerts[:3]:\n            print(f\"  [{alert['severity'].upper()}] {alert['message'][:50]}...\")\n    \n    return True\n\ndef test_watchdog_integration():\n    \"\"\"Test integration with existing watchdog.\"\"\"\n    print(\"\\n\" + \"=\" * 60)\n    print(\"Testing Watchdog Integration\")\n    print(\"=\" * 60)\n    \n    from pathlib import Path\n    import json\n    \n    watchdog_dir = Path.home() / '.openclaw' / 'workspace' / '.watchdog'\n    \n    # Check watchdog files\n    print(\"\\n1. Checking watchdog files...\")\n    files_to_check = [\n        \"session_registry.json\",\n        \"monitoring.log\",\n        \"metrics.json\",\n        \"incidents.json\"\n    ]\n    \n    for filename in files_to_check:\n        filepath = watchdog_dir / filename\n        if filepath.exists():\n            size = filepath.stat().st_size\n            print(f\"✓ {filename}: {size} bytes\")\n        else:\n            print(f\"✗ {filename}: Not found\")\n    \n    # Check session registry\n    print(\"\\n2. Checking session registry...\")\n    registry_file = watchdog_dir / \"session_registry.json\"\n    if registry_file.exists():\n        try:\n            with open(registry_file, 'r') as f:\n                registry = json.load(f)\n            print(f\"✓ Session registry: {len(registry)} sessions\")\n            \n            # Count by source\n            sources = {}\n            for session in registry.values():\n                source = session.get(\"source\", \"unknown\")\n                sources[source] = sources.get(source, 0) + 1\n            \n            print(\"  Session sources:\")\n            for source, count in sources.items():\n                print(f\"    {source}: {count}\")\n                \n        except Exception as e:\n            print(f\"✗ Error reading registry: {e}\")\n    else:\n        print(\"✗ Session registry not found\")\n    \n    return True\n\ndef main():\n    \"\"\"Run all integration tests.\"\"\"\n    print(\"OpenClaw Monitoring Integration Test Suite\")\n    print(\"=\" * 60)\n    \n    tests = [\n        (\"Main Agent Integration\", test_main_agent_integration),\n        (\"Sub-agent Integration\", test_subagent_integration),\n        (\"Cron Integration\", test_cron_integration),\n        (\"Alerts Integration\", test_alerts_integration),\n        (\"Watchdog Integration\", test_watchdog_integration)\n    ]\n    \n    results = []\n    \n    for test_name, test_func in tests:\n        try:\n            success = test_func()\n            results.append((test_name, success))\n        except Exception as e:\n            print(f\"\\n⚠ Error in {test_name}: {e}\")\n            results.append((test_name, False))\n    \n    # Print summary\n    print(\"\\n\" + \"=\" * 60)\n    print(\"Integration Test Summary\")\n    print(\"=\" * 60)\n    \n    passed = 0\n    for test_name, success in results:\n        status = \"✓ PASS\" if success else \"✗ FAIL\"\n        print(f\"{status} - {test_name}\")\n        if success:\n            passed += 1\n    \n    print(f\"\\n{passed}/{len(results)} tests passed\")\n    \n    if passed == len(results):\n        print(\"\\n✅ All integration tests passed!\")\n        return 0\n    else:\n        print(\"\\n⚠ Some integration tests failed\")\n        return 1\n\nif __name__ == \"__main__\":\n    sys.exit(main())"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-chat","usage":{"input":82,"output":2180,"cacheRead":38976,"cacheWrite":0,"totalTokens":41238,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773102973972}}
