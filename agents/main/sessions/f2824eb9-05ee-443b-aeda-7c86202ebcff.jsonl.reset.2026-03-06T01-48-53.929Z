{"type":"message","id":"d6f9eebd","parentId":"a6673ad9","timestamp":"2026-03-05T21:00:20.647Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Ahora creemos un test para self-protection. Necesitamos simular una excepción en el ciclo de monitoreo. Podemos hacerlo monkey-patch. También necesitamos verificar que se agregue un incidente con el pattern_key correcto.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_KimrbL5KvUi2hSBkE0GALbWu","name":"write","arguments":{"path":"~/.openclaw/workspace/skills/agent-watchdog/scripts/test_self_protection_simple.py","content":"#!/usr/bin/env python3\nimport sys\nimport os\nimport io\nimport contextlib\nsys.path.insert(0, os.path.dirname(__file__))\n\nfrom watchdog_orchestrator import AgentWatchdog\nfrom pathlib import Path\n\ndef test_self_protection():\n    print(\"Testing watchdog self-protection...\")\n    \n    # Count initial watchdog failure incidents\n    workspace = Path.home() / '.openclaw' / 'workspace'\n    errors_path = workspace / '.learnings' / 'ERRORS.md'\n    initial_count = 0\n    if errors_path.exists():\n        with open(errors_path, 'r', encoding='utf-8') as f:\n            content = f.read()\n            initial_count = content.count('watchdog|FAILURE|orchestrator|runtime_error')\n    \n    print(f\"Initial watchdog failure incidents: {initial_count}\")\n    \n    # Create watchdog instance\n    watchdog = AgentWatchdog()\n    \n    # Force an exception in monitoring cycle by monkey-patching detect_stalls\n    original_detect_stalls = watchdog.detect_stalls\n    def failing_detect_stalls():\n        raise RuntimeError(\"Simulated watchdog failure for testing\")\n    \n    watchdog.detect_stalls = failing_detect_stalls\n    \n    # Capture output\n    f = io.StringIO()\n    with contextlib.redirect_stdout(f):\n        watchdog.run_monitoring_cycle()\n    output = f.getvalue()\n    \n    # Check for expected messages\n    success = True\n    if \"CRITICAL: Monitoring cycle failed\" in output:\n        print(\"✅ Exception caught and logged\")\n    else:\n        print(\"❌ Exception not caught\")\n        success = False\n    \n    if \"Self-protection: emitted watchdog failure incident\" in output:\n        print(\"✅ Watchdog failure incident emitted\")\n    else:\n        print(\"❌ Watchdog failure incident not emitted\")\n        success = False\n    \n    if \"Self-restart attempt\" in output:\n        print(\"✅ Self-restart attempted\")\n    else:\n        print(\"⚠️  Self-restart not attempted (may be due to restart count)\")\n    \n    # Count final watchdog failure incidents\n    final_count = 0\n    if errors_path.exists():\n        with open(errors_path, 'r', encoding='utf-8') as f:\n            content = f.read()\n            final_count = content.count('watchdog|FAILURE|orchestrator|runtime_error')\n    \n    print(f\"Final watchdog failure incidents: {final_count}\")\n    \n    if final_count > initial_count:\n        print(\"✅ Watchdog failure incident appended to ERRORS.md\")\n    else:\n        print(\"❌ No new watchdog failure incident appended\")\n        success = False\n    \n    # Check restart count\n    print(f\"Watchdog restart count: {watchdog.watchdog_restart_count}\")\n    if watchdog.watchdog_restart_count == 1:\n        print(\"✅ Restart count correctly incremented\")\n    else:\n        print(f\"⚠️  Restart count is {watchdog.watchdog_restart_count}, expected 1\")\n        success = False\n    \n    # Check if incident has correct fields (optional)\n    if final_count > initial_count:\n        # Find the new incident\n        with open(errors_path, 'r', encoding='utf-8') as f:\n            lines = f.readlines()\n            for i, line in enumerate(lines):\n                if 'watchdog|FAILURE|orchestrator|runtime_error' in line:\n                    print(\"✅ Found watchdog failure incident with correct pattern key\")\n                    # Print a few lines after for context\n                    for j in range(i, min(i+5, len(lines))):\n                        print(f\"   {lines[j].rstrip()}\")\n                    break\n    \n    return success\n\nif __name__ == '__main__':\n    test_self_protection()"}}],"api":"openai-completions","provider":"custom-api-deepseek-com","model":"deepseek-reasoner","usage":{"input":269,"output":1003,"cacheRead":107264,"cacheWrite":0,"totalTokens":108536,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772744390396}}
